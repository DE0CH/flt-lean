{
  "permissions": {
    "allow": [
      "Edit(**)",
      "Bash(grep *)",
      "Bash(head *)",
      "WebSearch",
      "mcp__annas-mcp__search_annas",
      "mcp__annas-mcp__download_annas",
      "Read(//tmp/**)",
      "Bash(lake exe cache get)",
      "Bash(lake exe cache get:*)",
      "Bash(cd * && lake exe cache get)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git push*--force*)",
      "Bash(git push*-f)",
      "Bash(git push*-f *)",
      "Bash(lake:*)",
      "Bash(lake *)",
      "Bash(*lake build*)",
      "Bash(* lake *)",
      "Bash(*&& lake*)",
      "Bash(*; lake*)",
      "Bash(*| lake*)",
      "Bash(lean:*)",
      "Bash(lean *)",
      "Bash(elan:*)",
      "Bash(elan *)"
    ],
    "denyExplanations": {
      "lake": "BANNED (Deyao, 2026-07-22): all lake/lean/elan CLI invocations are denied except `lake exe cache get` (mathlib artifact fetch for a fresh worktree). Please use the MCP (lean-lsp) — its diagnostics are the trusted verification gate for everything; per-worktree servers exist and compile imports on demand. Headless scripts use the detached report server."
    },
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "defaultMode": "acceptEdits",
  "env": {
    "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "1000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/worktree-pool-hook.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/post-merge-reminder.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__report-flt-lean.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/unused-binding-check.py\"",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/check-sorries.py\"",
            "timeout": 3600,
            "statusMessage": "Checking the FLT loop exit condition (sorries + sorry gate)"
          }
        ]
      }
    ]
  }
}
