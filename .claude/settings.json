{
  "permissions": {
    "allow": [
      "Edit(**)",
      "Bash(grep *)",
      "Bash(head *)",
      "WebSearch",
      "mcp__annas-mcp__search_annas",
      "mcp__annas-mcp__download_annas",
      "Read(//tmp/**)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git push*--force*)",
      "Bash(git push*-f)",
      "Bash(git push*-f *)",
      "Bash(lake build:*)",
      "Bash(*lake build*)",
      "Bash(lake env lean:*)",
      "Bash(*lake env lean*)",
      "Bash(lake lean:*)",
      "Bash(*lake lean *)"
    ],
    "denyExplanations": {
      "lake": "BANNED (Deyao, 2026-07-22): please use the MCP (lean-lsp) — its diagnostics are the trusted verification gate for EVERYTHING; it accepts absolute paths into agent worktrees and compiles imports on demand. Nothing verifies outside an MCP door; headless scripts use the detached report server."
    },
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "defaultMode": "acceptEdits",
  "env": {
    "CLAUDE_CODE_STOP_HOOK_BLOCK_CAP": "1000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__lean-lsp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/lean-pretool-reminder.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/check-sorries.py\"",
            "timeout": 3600,
            "statusMessage": "Checking the FLT loop exit condition (sorries + sorry gate)"
          }
        ]
      }
    ]
  }
}
