theorem poitouPoleTerm_integrable {a : ‚ĄĚ} (ha : 0 < a) :
    Integrable fun t : ‚ĄĚ => poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I) := by
  obtain ‚ü®M, hM0, hM‚ü© := poitouPhi_line_decay
  set C : ‚ĄĚ := ‚ąę x : ‚ĄĚ, ‚ÄĖpoitouG x‚ÄĖ with hC
  have hC0 : 0 ‚Č§ C := by
    rw [hC]
    exact integral_nonneg fun x => norm_nonneg _
  set K : ‚ĄĚ := max (2 * C / a) (2 * M) with hK
  have hcont : Continuous fun t : ‚ĄĚ =>
      poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I) := by
    refine poitouPhi_line_continuous.div (by fun_prop) fun t => ?_
    intro hzero
    have hre := congrArg Complex.re hzero
    simp at hre
    exact ha.ne' hre
  refine (integrable_inv_one_add_sq.const_mul K).mono' hcont.aestronglyMeasurable ?_
  refine Filter.Eventually.of_forall fun t => ?_
  have hden‚āĀ : a ‚Č§ ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ := by
    have h := Complex.abs_re_le_norm ((a : ‚Ąā) + t * Complex.I)
    have hre : ((a : ‚Ąā) + t * Complex.I).re = a := by simp
    rw [hre] at h
    exact (le_abs_self a).trans h
  have hden‚āā : |t| ‚Č§ ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ := by
    have h := Complex.abs_im_le_norm ((a : ‚Ąā) + t * Complex.I)
    have him : ((a : ‚Ąā) + t * Complex.I).im = t := by simp
    rwa [him] at h
  rw [norm_div]
  have hmain : ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ / ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ *
      (1 + t ^ 2) ‚Č§ K := by
    rcases le_total |t| 1 with hcase | hcase
    ¬∑ have h1 : ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ / ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ ‚Č§ C / a := by
        refine div_le_div‚āÄ hC0 ?_ ha hden‚āĀ
        rw [hC]
        exact poitouPhi_line_norm_le_const t
      have h2 : (1 : ‚ĄĚ) + t ^ 2 ‚Č§ 2 := by
        nlinarith [abs_nonneg t, abs_mul_abs_self t, sq_abs t]
      calc ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ / ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ * (1 + t ^ 2)
          ‚Č§ C / a * 2 := by
            refine mul_le_mul h1 h2 (by positivity) (by positivity)
        _ = 2 * C / a := by ring
        _ ‚Č§ K := le_max_left _ _
    ¬∑ have htpos : (0:‚ĄĚ) < |t| := lt_of_lt_of_le zero_lt_one hcase
      have ht0 : t ‚Č† 0 := abs_pos.mp htpos
      have h1 : ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ / ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ ‚Č§
          M / t ^ 2 := by
        have hstep : ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ / ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ ‚Č§
            (M / |t|) / |t| := by
          refine div_le_div‚āÄ (by positivity) (hM t ht0) htpos hden‚āā
        refine hstep.trans (le_of_eq ?_)
        rw [div_div, abs_mul_abs_self, ‚Üź sq]
      have h2 : (1:‚ĄĚ) + t ^ 2 ‚Č§ 2 * t ^ 2 := by
        nlinarith [abs_nonneg t, abs_mul_abs_self t, sq_abs t]
      calc ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ / ‚ÄĖ(a : ‚Ąā) + t * Complex.I‚ÄĖ * (1 + t ^ 2)
          ‚Č§ M / t ^ 2 * (2 * t ^ 2) := by
            refine mul_le_mul h1 h2 (by positivity) (by positivity)
        _ = 2 * M := by
            have ht2 : t ^ 2 ‚Č† 0 := pow_ne_zero _ ht0
            field_simp [ht2]
        _ ‚Č§ K := le_max_right _ _
  rw [‚Üź div_eq_mul_inv, le_div_iff‚āÄ (by positivity : (0:‚ĄĚ) < 1 + t ^ 2)]
  exact hmain

/-- **Integrability of `F¬∑e^{cx}` complexified** (PROVEN 2026-07-24):
continuous with compact support in `[-6, 6]`. -/
theorem integrable_ofReal_poitouF_mul_exp (c : ‚ĄĚ) :
    Integrable fun x : ‚ĄĚ => ((poitouF x * Real.exp (c * x) : ‚ĄĚ) : ‚Ąā) := by
  refine Continuous.integrable_of_hasCompactSupport ?_ ?_
  ¬∑ exact Complex.continuous_ofReal.comp (continuous_poitouF.mul (by fun_prop))
  ¬∑ apply HasCompactSupport.intro (isCompact_Icc (a := (-6:‚ĄĚ)) (b := 6))
    intro x hx
    have h6 : (6:‚ĄĚ) ‚Č§ |x| := by
      simp only [Set.mem_Icc, not_and_or, not_le] at hx
      rcases hx with h | h
      ¬∑ exact le_abs.2 (Or.inr (by linarith))
      ¬∑ exact le_abs.2 (Or.inl h.le)
    have h0 : odlyzkoTestFn x = 0 := by
      rw [odlyzkoTestFn, max_eq_right]
      nlinarith [h6]
    rw [poitouF, h0, zero_div, zero_mul, Complex.ofReal_zero]

/-- **`ő¶` at a real point as a real-profile integral**
(PROVEN 2026-07-24): `ő¶(r) = ‚ąę F(x)¬∑e^{(r-1/2)x} dx` coerced. -/
theorem poitouPhi_ofReal (r : ‚ĄĚ) :
    poitouPhi (r : ‚Ąā) = ‚ąę x : ‚ĄĚ, ((poitouF x * Real.exp ((r - 1 / 2) * x) : ‚ĄĚ) : ‚Ąā) := by
  rw [poitouPhi]
  have h : ‚ąÄ x : ‚ĄĚ, ((odlyzkoTestFn x / Real.cosh (x / 2) : ‚ĄĚ) : ‚Ąā) *
      Complex.exp (((r : ‚Ąā) - 1 / 2) * (x : ‚Ąā)) =
      ((poitouF x * Real.exp ((r - 1 / 2) * x) : ‚ĄĚ) : ‚Ąā) := by
    intro x
    rw [show ((r : ‚Ąā) - 1 / 2) * (x : ‚Ąā) = (((r - 1 / 2) * x : ‚ĄĚ) : ‚Ąā) by push_cast; ring,
      ‚Üź Complex.ofReal_exp, poitouF]
    push_cast
    ring
  simp_rw [h]

/-- **`ő¶(0) + ő¶(1)` as a one-sided Fej√©r integral**
(PROVEN 2026-07-24, complex-level twin of the later
`poitouPhi_zero_add_one_re`, needed at this earlier point of the
file): `e^{-x/2} + e^{x/2} = 2¬∑cosh(x/2)` cancels the `cosh` in
`poitouF`, and evenness folds `‚ąę_‚ĄĚ = 2‚ąę_0^‚ąě`. -/
theorem poitouPhi_zero_add_one :
    poitouPhi 0 + poitouPhi 1 =
      ((4 * ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x : ‚ĄĚ) : ‚Ąā) := by
  have h0 : poitouPhi 0 = ‚ąę x : ‚ĄĚ, ((poitouF x * Real.exp ((0 - 1 / 2) * x) : ‚ĄĚ) : ‚Ąā) := by
    rw [show (0:‚Ąā) = ((0:‚ĄĚ) : ‚Ąā) by norm_num, poitouPhi_ofReal]
  have h1 : poitouPhi 1 = ‚ąę x : ‚ĄĚ, ((poitouF x * Real.exp ((1 - 1 / 2) * x) : ‚ĄĚ) : ‚Ąā) := by
    rw [show (1:‚Ąā) = ((1:‚ĄĚ) : ‚Ąā) by norm_num, poitouPhi_ofReal]
  rw [h0, h1, ‚Üź integral_add (integrable_ofReal_poitouF_mul_exp _)
    (integrable_ofReal_poitouF_mul_exp _)]
  have hsum : ‚ąÄ x : ‚ĄĚ, ((poitouF x * Real.exp ((0 - 1 / 2) * x) : ‚ĄĚ) : ‚Ąā) +
      ((poitouF x * Real.exp ((1 - 1 / 2) * x) : ‚ĄĚ) : ‚Ąā) =
      ((2 * odlyzkoTestFn x : ‚ĄĚ) : ‚Ąā) := by
    intro x
    rw [‚Üź Complex.ofReal_add]
    congr 1
    have e0 : (0 - 1 / 2 : ‚ĄĚ) * x = -(x / 2) := by ring
    have e1 : (1 - 1 / 2 : ‚ĄĚ) * x = x / 2 := by ring
    rw [e0, e1]
    have hcosh : Real.cosh (x / 2) ‚Č† 0 := (Real.cosh_pos _).ne'
    rw [Real.cosh_eq] at hcosh
    rw [poitouF, Real.cosh_eq]
    field_simp [hcosh]
    ring
  simp_rw [hsum]
  rw [integral_complex_ofReal]
  congr 1
  rw [integral_const_mul]
  have heven : (‚ąę x : ‚ĄĚ, odlyzkoTestFn x) =
      2 * ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x := by
    have habs := integral_comp_abs (f := fun y : ‚ĄĚ => max (1 - y / 6) 0)
    have hL : (‚ąę x : ‚ĄĚ, odlyzkoTestFn x) = ‚ąę x : ‚ĄĚ, max (1 - |x| / 6) 0 := by
      simp only [odlyzkoTestFn]
    have hR : (‚ąę x in Set.Ioi (0:‚ĄĚ), max (1 - x / 6) 0) =
        ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x := by
      refine setIntegral_congr_fun measurableSet_Ioi fun x hx => ?_
      rw [odlyzkoTestFn, abs_of_pos hx]
    rw [hL, habs, hR]
  rw [heven]
  ring

/-- **The pole part of the vertical edge gives `ő¶(0) + ő¶(1)`**
(PROVEN 2026-07-24 ‚ÄĒ leaf (b‚āāŠĶĘ) of the decomposition of
`DedekindContinuation.poitouEdge_tendsto`; the mirrored residue
computation, no `pkg` involved).  Instead of the rectangle contour,
the proof evaluates the whole line integral by FOURIER INVERSION:
the integrand splits as `ő¶/(5/4+ti) + ő¶/(1/4+ti)`
(since `s‚ąí1 = 1/4+ti` on the line), each pole term is integrable on
`‚ĄĚ` (`poitouPoleTerm_integrable`, from the trivial bound and the
integration-by-parts decay `‚ÄĖő¶(5/4+ti)‚ÄĖ ‚Č§ M/|t|`), and
`integral_poitouPhi_line_div` ‚ÄĒ Fourier inversion applied at `0` to
the convolution of `poitouG` with a one-sided exponential kernel ‚ÄĒ
evaluates `‚ąę_‚ĄĚ ő¶(5/4+ti)/(a+ti) dt = 2ŌÄ ‚ąę_0^‚ąě e^{-au} G(u) du` for
`a ‚ąą {5/4, 1/4}`.  The two one-sided integrals recombine by
`e^{-u/2} + e^{u/2} = 2 cosh(u/2)` into `4ŌÄ ‚ąę_0^‚ąě F`, which equals
`ŌÄ¬∑(ő¶(0)+ő¶(1)).re` by `poitouPhi_zero_add_one`; the truncation limit
`‚ąę_{-T}^T ‚Üí ‚ąę_‚ĄĚ` is `MeasureTheory.intervalIntegral_tendsto_integral`
on the real parts, and the `ŌÄ‚ĀĽ¬Ļ` prefactor cancels. -/
theorem poitouPoleEdge_tendsto :
    Filter.Tendsto poitouPoleEdge Filter.atTop
      (nhds ((poitouPhi 0).re + (poitouPhi 1).re)) := by
  have h54 := poitouPoleTerm_integrable (a := 5/4) (by norm_num)
  have h14 := poitouPoleTerm_integrable (a := 1/4) (by norm_num)
  have hv54 := integral_poitouPhi_line_div (a := 5/4) (by norm_num) h54
  have hv14 := integral_poitouPhi_line_div (a := 1/4) (by norm_num) h14
  set Fc : ‚ĄĚ ‚Üí ‚Ąā := fun t => poitouPhi (5 / 4 + t * Complex.I) *
    (1 / (5 / 4 + t * Complex.I) + 1 / (5 / 4 + t * Complex.I - 1)) with hFc
  have hsplit : ‚ąÄ t : ‚ĄĚ, Fc t =
      poitouPhi (5 / 4 + t * Complex.I) / (((5/4 : ‚ĄĚ) : ‚Ąā) + t * Complex.I) +
      poitouPhi (5 / 4 + t * Complex.I) / (((1/4 : ‚ĄĚ) : ‚Ąā) + t * Complex.I) := by
    intro t
    rw [hFc]
    push_cast
    ring
  have hIntF : Integrable Fc := by
    refine (h54.add h14).congr (Filter.Eventually.of_forall fun t => ?_)
    exact (hsplit t).symm
  have hint : ‚ąÄ c : ‚ĄĚ, 0 ‚Č§ c ‚Üí IntegrableOn
      (fun u : ‚ĄĚ => Complex.exp (((-(c * u) : ‚ĄĚ) : ‚Ąā)) * poitouG u) (Set.Ioi (0:‚ĄĚ)) := by
    intro c hc
    refine Integrable.mono' poitouG_integrable.norm.integrableOn
      ((Complex.continuous_exp.comp (by fun_prop)).mul continuous_poitouG).aestronglyMeasurable ?_
    refine (ae_restrict_iff' measurableSet_Ioi).2 (Filter.Eventually.of_forall fun u hu => ?_)
    rw [norm_mul, ‚Üź Complex.ofReal_exp, Complex.norm_real, Real.norm_eq_abs,
      abs_of_pos (Real.exp_pos _)]
    have hle : Real.exp (-(c * u)) ‚Č§ 1 :=
      Real.exp_le_one_iff.2 (neg_nonpos.2 (mul_nonneg hc hu.le))
    calc Real.exp (-(c * u)) * ‚ÄĖpoitouG u‚ÄĖ ‚Č§ 1 * ‚ÄĖpoitouG u‚ÄĖ :=
          mul_le_mul_of_nonneg_right hle (norm_nonneg _)
      _ = ‚ÄĖpoitouG u‚ÄĖ := one_mul _
  have hpt : ‚ąÄ u : ‚ĄĚ, Complex.exp (((-(5/4 * u : ‚ĄĚ) : ‚ĄĚ) : ‚Ąā)) * poitouG u +
      Complex.exp (((-(1/4 * u : ‚ĄĚ) : ‚ĄĚ) : ‚Ąā)) * poitouG u =
      ((2 * odlyzkoTestFn u : ‚ĄĚ) : ‚Ąā) := by
    intro u
    rw [poitouG, ‚Üź Complex.ofReal_exp, ‚Üź Complex.ofReal_exp, ‚Üź Complex.ofReal_mul,
      ‚Üź Complex.ofReal_mul, ‚Üź Complex.ofReal_add]
    congr 1
    have e1 : Real.exp (-(5/4 * u)) * Real.exp (3 / 4 * u) = Real.exp (-(u / 2)) := by
      rw [‚Üź Real.exp_add]
      congr 1
      ring
    have e2 : Real.exp (-(1/4 * u)) * Real.exp (3 / 4 * u) = Real.exp (u / 2) := by
      rw [‚Üź Real.exp_add]
      congr 1
      ring
    have hcosh : Real.cosh (u / 2) ‚Č† 0 := (Real.cosh_pos _).ne'
    calc Real.exp (-(5/4 * u)) * (poitouF u * Real.exp (3 / 4 * u)) +
        Real.exp (-(1/4 * u)) * (poitouF u * Real.exp (3 / 4 * u))
        = poitouF u * (Real.exp (-(5/4 * u)) * Real.exp (3 / 4 * u) +
            Real.exp (-(1/4 * u)) * Real.exp (3 / 4 * u)) := by ring
      _ = poitouF u * (Real.exp (-(u / 2)) + Real.exp (u / 2)) := by rw [e1, e2]
      _ = poitouF u * (2 * Real.cosh (u / 2)) := by
          rw [Real.cosh_eq]
          ring
      _ = 2 * odlyzkoTestFn u := by
          rw [poitouF]
          field_simp [hcosh]
  have hkey : (‚ąę t : ‚ĄĚ, Fc t) =
      ((4 * Real.pi * ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x : ‚ĄĚ) : ‚Ąā) := by
    rw [integral_congr_ae (Filter.Eventually.of_forall hsplit), integral_add h54 h14,
      hv54, hv14, ‚Üź smul_add, ‚Üź integral_add (hint (5/4) (by norm_num)) (hint (1/4) (by norm_num))]
    rw [setIntegral_congr_fun measurableSet_Ioi (fun u _ => hpt u)]
    rw [integral_complex_ofReal, Complex.real_smul, ‚Üź Complex.ofReal_mul]
    congr 1
    rw [integral_const_mul]
    ring
  have hIntRe : Integrable fun t : ‚ĄĚ => (Fc t).re := by
    have h := Complex.reCLM.integrable_comp hIntF
    simpa using h
  have hre_val : (‚ąę t : ‚ĄĚ, (Fc t).re) =
      4 * Real.pi * ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x := by
    have h := Complex.reCLM.integral_comp_comm hIntF
    rw [hkey] at h
    simpa using h
  have hlim : Filter.Tendsto (fun T : ‚ĄĚ => ‚ąę t in (-T)..T, (Fc t).re) Filter.atTop
      (nhds (‚ąę t : ‚ĄĚ, (Fc t).re)) :=
    intervalIntegral_tendsto_integral hIntRe tendsto_neg_atTop_atBot tendsto_id
  have hfin := hlim.const_mul Real.pi‚ĀĽ¬Ļ
  rw [hre_val] at hfin
  have hzo : (poitouPhi 0).re + (poitouPhi 1).re =
      4 * ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x := by
    have h := congrArg Complex.re poitouPhi_zero_add_one
    simpa using h
  have hval : Real.pi‚ĀĽ¬Ļ * (4 * Real.pi * ‚ąę x in Set.Ioi (0:‚ĄĚ), odlyzkoTestFn x) =
      (poitouPhi 0).re + (poitouPhi 1).re := by
    rw [hzo]
    have hpi : Real.pi ‚Č† 0 := Real.pi_ne_zero
    field_simp [hpi]
  rw [hval] at hfin
  have hEq : poitouPoleEdge = fun T : ‚ĄĚ => Real.pi‚ĀĽ¬Ļ * ‚ąę t in (-T)..T, (Fc t).re := by
    funext T
    rw [poitouPoleEdge]
  rw [hEq]
  exact hfin

end PoitouPoleEdgeFourier

/-- **The discriminant part of the folded vertical edge** (definition,
2026-07-24 ‚ÄĒ introduced in the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`): the analogue
of `DedekindContinuation.poitouEdge` with the CONSTANT `(log|d_K|)/2`
‚ÄĒ the log-derivative of the discriminant factor `|d_K|^{s/2}` of the
completed zeta `Z_K` ‚ÄĒ in place of `őĺ'/őĺ`. -/
noncomputable def poitouConstEdge (K : Type*) [Field K] [NumberField K]
    (T : ‚ĄĚ) : ‚ĄĚ :=
  Real.pi‚ĀĽ¬Ļ * ‚ąę t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      Complex.ofReal (Real.log |(NumberField.discr K : ‚ĄĚ)| / 2)).re

/-- **The archimedean part of the folded vertical edge** (definition,
2026-07-24 ‚ÄĒ introduced in the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`): the analogue
of `DedekindContinuation.poitouEdge` with
`r‚āā¬∑(Ōą(s) ‚ąí log 2ŌÄ)` ‚ÄĒ the log-derivative of the archimedean factor
`őď_‚Ąā(s)^{r‚āā} = (2¬∑(2ŌÄ)^{‚ąís}¬∑őď(s))^{r‚āā}` of the completed zeta, where
`Ōą = Complex.digamma` is the pin's logarithmic derivative of `őď` ‚ÄĒ
in place of `őĺ'/őĺ`.  (For the totally complex fields of the consuming
decomposition the real factor `őď_‚ĄĚ^{r‚āĀ}` is absent, `r‚āĀ = 0`, so this
is the WHOLE archimedean log-derivative.) -/
noncomputable def poitouGammaEdge (K : Type*) [Field K] [NumberField K]
    (T : ‚ĄĚ) : ‚ĄĚ :=
  Real.pi‚ĀĽ¬Ļ * ‚ąę t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      ((NumberField.InfinitePlace.nrComplexPlaces K : ‚Ąā) *
        (Complex.digamma (5 / 4 + t * Complex.I) -
          Complex.ofReal (Real.log (2 * Real.pi))))).re

/-- **The prime part of the folded vertical edge** (definition,
2026-07-24 ‚ÄĒ introduced in the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`): the analogue
of `DedekindContinuation.poitouEdge` with the log-derivative
`ő∂_K'/ő∂_K` of the pin's raw Dedekind zeta Dirichlet series in place
of `őĺ'/őĺ`.  On the edge line `re s = 5/4 > 1` the series converges
absolutely and `ő∂_K(s) ‚Č† 0` (`dedekindZeta_ne_zero_of_one_lt_re`), so
the integrand is the honest logarithmic derivative there. -/
noncomputable def poitouPrimeEdge (K : Type*) [Field K] [NumberField K]
    (T : ‚ĄĚ) : ‚ĄĚ :=
  Real.pi‚ĀĽ¬Ļ * ‚ąę t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      (deriv (NumberField.dedekindZeta K) (5 / 4 + t * Complex.I) /
        NumberField.dedekindZeta K (5 / 4 + t * Complex.I))).re

/-- **The integrand split: edge minus pole edge = discriminant +
archimedean + prime edges** (sorry node, stated 2026-07-24 ‚ÄĒ leaf
(b‚āāŠĶĘŠĶĘ¬∑0), the log-derivative bookkeeping stage of the decomposition
of `DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`; an exact
identity for EVERY `T`, no limits).  Intended proof, pointwise on the
edge `s = 5/4 + it` where `re s = 5/4 > 1`:

1. `eq_of_one_lt_re` writes `őĺ` on the OPEN half-plane `re > 1` as
   the product `s(s‚ąí1)¬∑|d|^{s/2}¬∑őď_‚ĄĚ-factor^{r‚āĀ}¬∑őď_‚Ąā-factor^{r‚āā}¬∑ő∂_K`,
   and `htc` kills the real factor
   (`NumberField.IsTotallyComplex.nrRealPlaces_eq_zero`, `pow_zero`).
2. Openness (`isOpen_lt continuous_const Complex.continuous_re`) lets
   `Filter.EventuallyEq.deriv_eq` transport `deriv pkg.xi` to the
   derivative of the product; each factor is differentiable at `s` ‚ÄĒ
   polynomials, the `cpow`s with nonzero constant base
   (`|d| ‚Č† 0` by `NumberField.discr_ne_zero`, `2ŌÄ ‚Č† 0`), `őď(s)` for
   `re s > 0`, and `ő∂_K` by the pin's `LSeries_hasDerivAt` above the
   abscissa of absolute convergence (`‚Č§ 1` for the ideal-counting
   coefficients via `summable_natCard_absNorm_mul_rpow_neg` from
   `Chebotarev.lean`) ‚ÄĒ and nonvanishing at `s`: `s, s‚ąí1 ‚Č† 0`
   (`re = 5/4`), `Complex.Gamma_ne_zero`, nonzero-base `cpow`s, and
   `dedekindZeta_ne_zero_of_one_lt_re` (PROVEN above).  Iterated
   `logDeriv_mul`/`logDeriv_pow` then split the logarithmic
   derivative: `(őĺ'/őĺ)(s) = 1/s + 1/(s‚ąí1) + (log|d|)/2 +
   r‚āā¬∑(Ōą(s) ‚ąí log 2ŌÄ) + (ő∂_K'/ő∂_K)(s)`, with `Ōą = Complex.digamma`
   (`Complex.digamma_def`, `logDeriv_apply`) and the elementary
   log-derivatives `(c^s)'/c^s = log c` of constant-base `cpow`.
3. Multiply by `ő¶(s)`, take `Re`: pointwise in `t`, the
   `DedekindContinuation.poitouEdge` integrand minus the
   `poitouPoleEdge` integrand equals the sum of the three edge
   integrands (`mul_add`, `Complex.add_re`).
4. Integrate over `[‚ąíT, T]`: `intervalIntegral.integral_sub` and
   `integral_add` need integrability of each piece, which follows
   from continuity in `t` (`Continuous.intervalIntegrable`): `ő¶`
   along the edge by dominated parameter-continuity of `poitouPhi`
   (compactly supported integrand ‚ÄĒ the same continuity brick the
   sibling leaf `poitouPoleEdge_tendsto` needs; manufacture a shared
   forward helper), `Ōą` at zero-free points of the differentiable
   `őď`, `ő∂_K'/ő∂_K` since `deriv ő∂_K` is again an `LSeries`
   (`LSeries_deriv`) differentiable above the abscissa and the
   denominator is nonvanishing and continuous; finally distribute
   `ŌÄ‚ĀĽ¬Ļ` over the sum (`mul_add`). -/
theorem DedekindContinuation.poitouEdge_sub_poleEdge_eq {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K)
    (htc : NumberField.IsTotallyComplex K) (T : ‚ĄĚ) :
    pkg.poitouEdge T - poitouPoleEdge T =
      poitouConstEdge K T + poitouGammaEdge K T + poitouPrimeEdge K T := by
  sorry

/-- **Fourier inversion at the origin: the discriminant edge converges
to `log |d_K|`** (sorry node, stated 2026-07-24 ‚ÄĒ leaf (b‚āāŠĶĘŠĶĘ¬∑1), the
Fourier/test-function bookkeeping stage of the decomposition of
