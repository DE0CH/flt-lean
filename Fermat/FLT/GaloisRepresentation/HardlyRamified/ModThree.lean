      (fun g hg => MonoidHom.mem_ker.mpr (hО·KПҒ g hg)) hKПҒ_open
  -- `ПҲ` and `ПҮ` are unramified at `2`, so `О·` is unramified outside `3`
  have hПҮ2 := quotCharacter_unramified_at_two V hV hПҒ WвӮҖ ПҮ hWвӮҖfr hstable hПҮ
  have hПҲ2 := subCharacter_unramified_at_two V hV hПҒ WвӮҖ hWвӮҖfr hstable ПҲ hПҲ ПҮ hПҮ
  have hО·unr : вҲҖ (q : в„•) (hq : q.Prime), q вү  3 вҶ’
      вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        О· (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 := by
    intro q hq hq3 Пғ hПғ
    by_cases hq2 : q = 2
    В· subst hq2
      have hПҮ1 := hПҮ2 hПғ
      have hПҲ1 := hПҲ2 hПғ
      rw [MonoidHom.mem_ker] at hПҮ1 hПҲ1
      have hПҲu : ПҲ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 := hПҲ1
      have hПҮu : ПҮ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 := hПҮ1
      exact (hagree _).mpr (by rw [hПҲu, hПҮu])
    В· obtain вҹЁhПҲ1, hПҮ1, -вҹ© := hunr q hq hq2 hq3 Пғ hПғ
      exact (hagree _).mpr (by rw [hПҲ1, hПҮ1])
  -- the procyclic inertia image at `3`: a generator `Оө` with `ОөВІ = 1`
  obtain вҹЁt, htmem, hsq, hgenвҹ© := exists_localInertia_three_generator
    (fun a ha => units_eq_one_of_pow_three_eq_one h3k a ha) О· hО·open
  set Оө : kЛЈ := О· (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) t)
  -- Minkowski on the quotient by `вҹЁОөвҹ©` confines the image of `О·`
  have hS : вҲҖ g : О“ в„ҡ, О· g вҲҲ Subgroup.zpowers Оө := by
    set ПҖ : kЛЈ вҶ’* kЛЈ в§ё Subgroup.zpowers Оө :=
      QuotientGroup.mk' (Subgroup.zpowers Оө)
    have hПҖОө : ПҖ Оө = 1 := (QuotientGroup.eq_one_iff Оө).mpr
      (Subgroup.mem_zpowers Оө)
    have hle : KПҒ вүӨ (ПҖ.comp О·).ker := by
      intro g' hg'
      rw [MonoidHom.mem_ker, MonoidHom.comp_apply, hО·KПҒ g' hg', map_one]
    have hopen' : IsOpen (((ПҖ.comp О·).ker : Subgroup (О“ в„ҡ)) : Set (О“ в„ҡ)) :=
      Subgroup.isOpen_mono hle hKПҒ_open
    have hunram : вҲҖ (q : в„•) (hq : q.Prime),
        localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat вүӨ
          ((ПҖ.comp О·).comp (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom).ker := by
      intro q hq Пғ hПғ
      rw [MonoidHom.mem_ker]
      show ПҖ (О· ((Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          hq.toHeightOneSpectrumRingOfIntegersRat))) Пғ)) = 1
      by_cases hq3 : q = 3
      В· subst hq3
        obtain вҹЁm, hmвҹ© := hgen Пғ hПғ
        have hm' : О· ((Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat))) Пғ) = Оө ^ m := hm
        rw [hm', map_pow, hПҖОө, one_pow]
      В· rw [hО·unr q hq hq3 Пғ hПғ, map_one]
    have htriv := minkowski_character_trivial (ПҖ.comp О·) hopen' hunram
    intro g
    have hg1 : ПҖ (О· g) = 1 := by
      have h : (ПҖ.comp О·) g = 1 := by rw [htriv]; rfl
      rwa [MonoidHom.comp_apply] at h
    exact (QuotientGroup.eq_one_iff (О· g)).mp hg1
  by_cases hОө1 : Оө = 1
  В· -- `Оө = 1`: `О· = 1` globally, `b` is a global additive character
    have hО·1 : вҲҖ g : О“ в„ҡ, О· g = 1 := by
      intro g
      obtain вҹЁm, hmвҹ© := Subgroup.mem_zpowers_iff.mp (hS g)
      rw [вҶҗ hm, hОө1, one_zpow]
    set B : О“ в„ҡ вҶ’* Multiplicative k :=
      MonoidHom.mk' (fun g => Multiplicative.ofAdd (b g))
        (fun g h => by
          rw [show b (g * h) = b g + b h from
            hbadd g h ((hagree g).mp (hО·1 g)) ((hagree h).mp (hО·1 h))]
          rfl)
    have hBKПҒ : KПҒ вүӨ B.ker := by
      intro g hg
      rw [MonoidHom.mem_ker]
      show Multiplicative.ofAdd (b g) = 1
      rw [(hker g hg).2.2]
      rfl
    have hBopen : IsOpen (B.ker : Set (О“ в„ҡ)) :=
      Subgroup.isOpen_mono hBKПҒ hKПҒ_open
    have hB2tf : вҲҖ a : Multiplicative k, a ^ 2 = 1 вҶ’ a = 1 := by
      intro a ha
      rw [pow_two] at ha
      have hx : a.toAdd + a.toAdd = 0 := by
        have h := congrArg Multiplicative.toAdd ha
        rwa [toAdd_mul, toAdd_one] at h
      have hx3 : a.toAdd + a.toAdd + a.toAdd = 0 := by
        calc a.toAdd + a.toAdd + a.toAdd = (3 : k) * a.toAdd := by ring
          _ = 0 := by rw [h3k, zero_mul]
      have hx0 : a.toAdd = 0 := by linear_combination hx3 - hx
      have h1 : Multiplicative.ofAdd a.toAdd = Multiplicative.ofAdd 0 :=
        congrArg Multiplicative.ofAdd hx0
      simpa using h1
    have hB2 := localInertia_two_eq_one_of_no_two_torsion hB2tf B hBopen
    have hBunram : вҲҖ (q : в„•) (hq : q.Prime),
        localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat вүӨ
          (B.comp (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom).ker := by
      intro q hq Пғ hПғ
      rw [MonoidHom.mem_ker]
      by_cases hq2 : q = 2
      В· subst hq2
        exact hB2 Пғ hПғ
      В· by_cases hq3 : q = 3
        В· subst hq3
          have hb0 : b (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
              (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
                hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 0 :=
            h3z Пғ hПғ ((hagree _).mp (hО·1 _))
          show Multiplicative.ofAdd (b ((Field.absoluteGaloisGroup.map
            (algebraMap в„ҡ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat))) Пғ)) = 1
          rw [hb0]
          rfl
        В· have hb0 := (hunr q hq hq2 hq3 Пғ hПғ).2.2
          show Multiplicative.ofAdd (b ((Field.absoluteGaloisGroup.map
            (algebraMap в„ҡ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat))) Пғ)) = 1
          rw [hb0]
          rfl
    have hBtriv := minkowski_character_trivial B hBopen hBunram
    intro g _
    have h : B g = 1 := by rw [hBtriv]; rfl
    have h' : Multiplicative.ofAdd (b g) = Multiplicative.ofAdd 0 := h
    exact Multiplicative.ofAdd.injective h'
  В· -- `Оө = -1`: `О·` is the quadratic character of `в„ҡ(вҲҡ-3)`;
    -- the ray-class sorry node finishes
    have hО·2 : вҲҖ g : О“ в„ҡ, О· g = 1 вҲЁ (О· g : k) = -1 := by
      intro g
      obtain вҹЁm, hmвҹ© := Subgroup.mem_zpowers_iff.mp (hS g)
      have hsq2 : (О· g) ^ 2 = 1 := by
        rw [вҶҗ hm]
        calc (Оө ^ m) ^ 2 = (Оө ^ 2) ^ m := by
              rw [вҶҗ zpow_natCast (Оө ^ m) 2, вҶҗ zpow_mul, mul_comm,
                zpow_mul, zpow_natCast]
          _ = 1 := by rw [hsq, one_zpow]
      have hval : ((О· g : kЛЈ) : k) ^ 2 = 1 := by
        rw [вҶҗ Units.val_pow_eq_pow_val, hsq2, Units.val_one]
      have hfac : (((О· g : kЛЈ) : k) - 1) * (((О· g : kЛЈ) : k) + 1) = 0 := by
        linear_combination hval
      rcases mul_eq_zero.mp hfac with h | h
      В· left
        exact Units.ext (by rw [Units.val_one]; linear_combination h)
      В· right
        linear_combination h
    have hО·3 : В¬ (localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat вүӨ
        (О·.comp (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom).ker) := by
      intro hle
      apply hОө1
      have h := hle htmem
      rw [MonoidHom.mem_ker] at h
      exact h
    have hbadd' : вҲҖ g h : О“ в„ҡ, О· g = 1 вҶ’ О· h = 1 вҶ’ b (g * h) = b g + b h :=
      fun g h hg hh => hbadd g h ((hagree g).mp hg) ((hagree h).mp hh)
    have hUker : вҲҖ g вҲҲ KПҒ, О· g = 1 вҲ§ b g = 0 :=
      fun g hg => вҹЁhО·KПҒ g hg, (hker g hg).2.2вҹ©
    have hbunr' : вҲҖ (q : в„•) (hq : q.Prime), q вү  2 вҶ’
        вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
          О· (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 вҶ’
          b (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 0 := by
      intro q hq hq2 Пғ hПғ hО·Пғ
      by_cases hq3 : q = 3
      В· subst hq3
        exact h3z Пғ hПғ ((hagree _).mp hО·Пғ)
      В· exact (hunr q hq hq2 hq3 Пғ hПғ).2.2
    have hbconj' : вҲҖ g h : О“ в„ҡ, О· h = 1 вҶ’
        b (g * h * gвҒ»В№) = (О· g : k) * b h := by
      intro g h hh
      have hc := hconj g h ((hagree h).mp hh)
