    intro m h
    have hre := congrArg Complex.re h
    simp only [Complex.neg_re, Complex.natCast_re] at hre
    have hm : (0 : ‚ĄĚ) ‚Č§ (m : ‚ĄĚ) := Nat.cast_nonneg m
    linarith
