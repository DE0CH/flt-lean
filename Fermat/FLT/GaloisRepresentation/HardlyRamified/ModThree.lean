    В· funext j
      simp only [Matrix.vecMul, dotProduct, LinearMap.toMatrix_apply,
        Pi.zero_apply]
      have hterm : вҲҖ i : Fin 2,
          ПҖ' (bk i) * (bk.repr (((ПҒ g' : Module.End k V) - 1) (bk j))) i =
          ПҖ' ((bk.repr (((ПҒ g' : Module.End k V) - 1) (bk j))) i вҖў bk i) := by
        intro i
