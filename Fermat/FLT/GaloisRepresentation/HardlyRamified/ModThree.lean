      rw [sub_mul, mul_sub, smul_mul_assoc, one_mul, mul_smul_comm, mul_one, hcg]
    have hwker : Matrix.mulVec (f - t вҖў 1) (Matrix.mulVec (u g).val v) = 0 := by
      rw [Matrix.mulVec_mulVec, hswap, вҶҗ Matrix.mulVec_mulVec, hvker,
