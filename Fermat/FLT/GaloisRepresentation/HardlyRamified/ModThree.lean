    Ideal.pow_le_pow_right (Nat.add_le_add_right hgŌÉ 1)
  refine hf ŌÉ hŌÉ1 (AddSubgroup.mem_inertia.mpr fun x => ?_)
  have h2 := AddSubgroup.mem_inertia.mp hŌÉ x
  rw [Submodule.mem_toAddSubgroup] at h2 ‚äĘ
  exact hle h2

/-- **A Serre-style residue generator with a uniformizing polynomial value**
(Serre, *Corps Locaux* III ¬ß6, proof of Prop. 12, globalized): at a nonzero
