  intro ŌÉ hŌÉ
  by_contra hŌÉ1
  have hgŌÉ : f ŌÉ hŌÉ1 ‚Č§ Finset.univ.sup g := by
    have h1 : g ŌÉ = f ŌÉ hŌÉ1 := dif_neg hŌÉ1
