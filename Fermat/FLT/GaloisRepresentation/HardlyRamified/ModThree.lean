/-- **Trivial quotient from the stable line** (DERIVED 2026-07-17 from
the local leaf above and the PROVEN character bookkeeping of
`MazurTorsion.lean`): given a `őď ‚Ąö`-stable proper nonzero submodule of
a mod-3 hardly ramified representation, there is an equivariant
surjection `ŌÄ` onto the trivial 1-dimensional representation.
Assembly: the leaf provides a stable line whose quotient character
`Ōá‚āā` is unramified at `2` and `3`; outside `{2, 3}` the whole
representation is unramified (`IsHardlyRamified.isUnramified`,
transported by `character_localInertia_le_ker_of_isUnramifiedAt` and
the `Rat.subsingleton_ringHom` spelling bridge); the kernel of `Ōá‚āā` is
open (it contains the open kernel of `ŌĀ`); Minkowski
(`minkowski_character_trivial`, now target-generic) kills `Ōá‚āā`; and
`ŌÄ` is the coordinate of the rank-1 quotient. -/
theorem mod_three_of_stable_line {k : Type u} [Finite k] [Field k] [Algebra ‚Ą§_[3] k]
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V] [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (W : Submodule k V) (hW0 : W ‚Č† ‚ä•) (hWtop : W ‚Č† ‚ä§)
    (hWstable : ‚ąÄ g : őď ‚Ąö, W.map (ŌĀ g) ‚Č§ W) :
    ‚ąÉ (ŌÄ : V ‚Üí‚āó[k] k) (_ : Function.Surjective ŌÄ),
    ‚ąÄ g : őď ‚Ąö, ‚ąÄ v : V, ŌÄ (ŌĀ g v) = ŌÄ v := by
  classical
  obtain ‚ü®W', Ōá‚āā, hW'1, hstab, hŌá‚āā, hun2, hun3‚ü© :=
    exists_line_with_locally_unramified_quotCharacter V hV hŌĀ W hW0 hWtop
      hWstable
  haveI hfinV : Finite V := Module.finite_of_finite k
  have hfr : Module.finrank k V = 2 :=
    Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
  have hW'top : W' ‚Č† ‚ä§ := by
    intro htop
    rw [htop, finrank_top, hfr] at hW'1
    omega
  -- the quotient character is trivial wherever the representation is
  have htriv : ‚ąÄ g, ŌĀ g = 1 ‚Üí Ōá‚āā g = 1 := by
    intro g hg
    apply Units.ext
    rw [Units.val_one]
    refine quotCharacter_eq_one_of_sq_eq_zero (ŌĀ g) ?_ W' hW'top (hŌá‚āā g)
    rw [hg, sub_self]
    exact zero_pow two_ne_zero
  -- the kernel of the representation is open, hence so is that of `Ōá‚āā`
  let KŌĀ : Subgroup (őď ‚Ąö) :=
    { carrier := {g | ŌĀ g = 1}
      one_mem' := map_one ŌĀ
      mul_mem' := by
        intro a b ha hb
        show ŌĀ (a * b) = 1
        rw [map_mul, ha, hb, mul_one]
      inv_mem' := by
        intro a ha
        show ŌĀ a‚ĀĽ¬Ļ = 1
        have h1 : ŌĀ a‚ĀĽ¬Ļ * ŌĀ a = 1 := by
          rw [‚Üź map_mul, inv_mul_cancel, map_one]
        rwa [ha, mul_one] at h1 }
  have hKŌĀ_open : IsOpen (KŌĀ : Set (őď ‚Ąö)) :=
    isOpen_setOf_galoisRep_eq_one ŌĀ hfinV
  have hker‚āā : KŌĀ ‚Č§ Ōá‚āā.ker := fun g hg => MonoidHom.mem_ker.mpr (htriv g hg)
  have hopen‚āā : IsOpen (Ōá‚āā.ker : Set (őď ‚Ąö)) :=
    Subgroup.isOpen_mono hker‚āā hKŌĀ_open
  -- unramified at every finite place, then Minkowski
  have hunram : ‚ąÄ (q : ‚Ąē) (hq : q.Prime),
      localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat ‚Č§
        (Ōá‚āā.comp (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
            hq.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom).ker := by
    intro q hq
    by_cases hq2 : q = 2
    ¬∑ subst hq2
      exact hun2
    ¬∑ by_cases hq3 : q = 3
      ¬∑ subst hq3
        exact hun3
      ¬∑ intro ŌÉ hŌÉ
        have h4 := character_localInertia_le_ker_of_isUnramifiedAt ŌĀ
          hq.toHeightOneSpectrumRingOfIntegersRat
          (hŌĀ.isUnramified q hq ‚ü®hq2, hq3‚ü©) Ōá‚āā htriv
        have h5 := h4 hŌÉ
        convert h5 using 5
        exact Subsingleton.elim _ _
  have hŌátriv : Ōá‚āā = 1 := minkowski_character_trivial Ōá‚āā hopen‚āā hunram
  -- the projection onto the rank-1 quotient
  have hQ1 : Module.finrank k (V ‚ßł W') = 1 := by
    have hsum := Submodule.finrank_quotient_add_finrank W'
    rw [hfr, hW'1] at hsum
    omega
  let b : Module.Basis (Fin 1) k (V ‚ßł W') :=
    Module.finBasisOfFinrankEq k (V ‚ßł W') hQ1
  refine ‚ü®(b.coord 0).comp W'.mkQ, ?_, ?_‚ü©
  ¬∑ -- surjectivity: hit `c` with a preimage of `c ‚ÄĘ b 0`
    intro c
    obtain ‚ü®v, hv‚ü© := W'.mkQ_surjective (c ‚ÄĘ b 0)
    refine ‚ü®v, ?_‚ü©
    rw [LinearMap.comp_apply, hv, map_smul, smul_eq_mul,
      Module.Basis.coord_apply, Module.Basis.repr_self]
    simp
  ¬∑ -- equivariance from the trivial quotient character
    intro g v
    rw [LinearMap.comp_apply, LinearMap.comp_apply, hŌá‚āā, hŌátriv]
    simp only [MonoidHom.one_apply, Units.val_one, one_smul]

/-- **Mod-3 classification** (DERIVED 2026-07-16 from the two nodes
above): a mod-3 hardly ramified representation is an extension of the
trivial character by the (mod-3 cyclotomic) character: there is a
`őď ‚Ąö`-equivariant surjection onto the trivial 1-dimensional
representation. Input to **B6c** (`Threeadic.lean`). Reducibility
(`mod_three_reducible`, the Dickson/discriminant content) produces the
stable line; the quotient-character analysis
(`mod_three_of_stable_line`) produces the surjection. -/
theorem mod_three {k : Type u} [Finite k] [Field k] [Algebra ‚Ą§_[3] k] --
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V] [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ) :
    ‚ąÉ (ŌÄ : V ‚Üí‚āó[k] k) (_ : Function.Surjective ŌÄ),
    ‚ąÄ g : őď ‚Ąö, ‚ąÄ v : V, ŌÄ (ŌĀ g v) = ŌÄ v := by
  obtain ‚ü®W, hW0, hWtop, hWstable‚ü© := mod_three_reducible V hV hŌĀ
  exact mod_three_of_stable_line V hV hŌĀ W hW0 hWtop hWstable

end GaloisRepresentation.IsHardlyRamified
