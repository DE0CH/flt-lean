    intro g
    by_contra hg
    push Not at hg
    have h1 : ({1, ŌÉ, g} : Finset (K ‚ČÉ‚āź[‚Ąö] K)).card = 3 := by
      rw [Finset.card_insert_of_notMem (by
        simp only [Finset.mem_insert, Finset.mem_singleton]
        push Not
