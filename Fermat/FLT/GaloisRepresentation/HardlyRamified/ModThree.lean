/-- **Units of `рқ”ҪМ„вӮғ` have finite order prime to `3`** (PROVEN
2026-07-24 вҖ” the tameness input of the dihedral ray-class reduction):
every nonzero element of `Dickson.K 3 = рқ”ҪМ„вӮғ = вӢғвӮҷ рқ”Ҫ_{3вҒҝ}` satisfies
`x ^ n = 1` for some positive `n` not divisible by `3`. Content: `x`
is integral over `рқ”ҪвӮғ`, so `рқ”ҪвӮғвҹ®xвҹҜ` is a finite field of cardinality
`3 ^ m` with `m вүҘ 1`, and `x ^ (3 ^ m - 1) = 1` with
`3 вҲӨ 3 ^ m - 1`. Consequence downstream: any character with values
in `рқ”ҪМ„вӮғЛЈ` kills every pro-3 group вҖ” in particular the wild inertia
at `3` вҖ” so such characters are automatically tame at `3`. -/
theorem exists_pow_eq_one_not_three_dvd_of_ne_zero
    (x : Dickson.K 3) (hx : x вү  0) :
    вҲғ n : в„•, 0 < n вҲ§ В¬ (3 вҲЈ n) вҲ§ x ^ n = 1 := by
  classical
  have hint : IsIntegral (ZMod 3) x :=
    Algebra.IsIntegral.isIntegral (R := ZMod 3) x
  set F : IntermediateField (ZMod 3) (AlgebraicClosure (ZMod 3)) :=
    IntermediateField.adjoin (ZMod 3) {x} with hF
  haveI : FiniteDimensional (ZMod 3) F :=
    IntermediateField.adjoin.finiteDimensional hint
  haveI : Finite F := Module.finite_of_finite (ZMod 3)
  haveI : Fintype F := Fintype.ofFinite F
  set y : F := вҹЁx, IntermediateField.mem_adjoin_simple_self _ xвҹ© with hy
  have hyne : y вү  0 := by
    intro h
    exact hx (congrArg Subtype.val h)
  have hcard : Fintype.card F = 3 ^ (Module.finrank (ZMod 3) F) := by
    have := Module.card_eq_pow_finrank (K := ZMod 3) (V := F)
    simpa using this
  have hpow : y ^ (Fintype.card F - 1) = 1 :=
    FiniteField.pow_card_sub_one_eq_one y hyne
  have h2 : 1 < Fintype.card F := Fintype.one_lt_card
  have hge : 1 вүӨ 3 ^ (Module.finrank (ZMod 3) F) :=
    Nat.one_le_pow _ _ (by norm_num)
  have hmpos : 0 < Module.finrank (ZMod 3) F := Module.finrank_pos
  refine вҹЁFintype.card F - 1, by omega, ?_, ?_вҹ©
  В· intro hdvd
    rw [hcard] at hdvd
    have h3 : (3 : в„•) вҲЈ 3 ^ (Module.finrank (ZMod 3) F) :=
      dvd_pow_self 3 hmpos.ne'
    omega
  В· have := congrArg (Subtype.val) hpow
    simpa using this

