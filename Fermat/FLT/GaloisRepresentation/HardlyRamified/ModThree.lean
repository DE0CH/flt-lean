      rcases hd with h | h | h | h | h | h | h
      В· exact Or.inl h
      В· exact Or.inr (Or.inl h)
      В· exact Or.inr (Or.inr (Or.inl h))
      В· exact Or.inr (Or.inr (Or.inr (Or.inl h)))
