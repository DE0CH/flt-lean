  -- the numeric endgame: `1/6 + (14/9)В·e^{-3/2} вүӨ 5/8` via `e^{3/2} вүҘ 4`
  have hE : (4 : в„қ) вүӨ Real.exp (3 / 2) := by
    have h3 : Real.exp (3 / 2) * Real.exp (3 / 2) = Real.exp 3 := by
      rw [вҶҗ Real.exp_add]; norm_num
