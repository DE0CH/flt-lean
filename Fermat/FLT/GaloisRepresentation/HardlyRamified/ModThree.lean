      (4 ^ Module.finrank ‚Ąö K * |NumberField.discr K|) ^ 6 :=
    pow_le_pow_left‚āÄ (by positivity) h1 6
  -- strict comparison of the bases: `314928¬∑4‚Ā∂ < 33‚Ā∂`
  have hlt : ((314928 : ‚Ą§) * 4 ^ 6) ^ Module.finrank ‚Ąö K <
      ((33 : ‚Ą§) ^ 6) ^ Module.finrank ‚Ąö K :=
    pow_lt_pow_left‚āÄ (by norm_num) (by positivity) hn0
