  have hbq : ((b : ‚Ąē) : ‚Ąö) ‚Č† 0 := by exact_mod_cast hb0
  have hdenq : ((r.den : ‚Ąē) : ‚Ąö) ‚Č† 0 := by exact_mod_cast r.den_nz
  have hc‚āÄ0 : c‚āÄ ‚Č† 0 := div_ne_zero hdenq hbq
  refine ‚ü®ŌÉ, algebraMap ‚Ąö K c‚āÄ * x‚āĀ, d, hŌÉ, hŌÉ2, huniv, ?_, ?_, hdsq, ?_‚ü©
  ¬∑ rw [map_mul, AlgEquiv.commutes, hx‚āĀŌÉ]
    ring
