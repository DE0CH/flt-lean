  have h1 : Ōá.comp ((1 : WithConv (A ‚Üí‚āź[R] A)).ofConv) =
      (1 : WithConv (A ‚Üí‚āź[R] C)).ofConv := by
    rw [AlgHom.convOne_def, AlgHom.convOne_def, WithConv.ofConv_toConv,
      WithConv.ofConv_toConv, ‚Üź AlgHom.comp_assoc]
    congr 1
    refine AlgHom.ext fun r => ?_
    simp [Algebra.ofId_apply]
  rw [h1] at h
  have h2 : Ōá.comp ((toConv (AlgHom.id R A)).ofConv) = Ōá := AlgHom.comp_id Ōá
  rw [h2] at h
