      ((AlgEquiv.restrictNormalHom N Пғ) вҖў x - x) =
      Пғ вҖў (integralClosureInclusion
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat N x) -
      integralClosureInclusion
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat N x := by
    rw [map_sub]
    congr 1
    exact Subtype.ext (AlgEquiv.restrictNormal_commutes Пғ N x.1)
  -- the defining property of the full local inertia group
  have hbig := AddSubgroup.mem_inertia.mp hПғ
    (integralClosureInclusion
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat N x)
  rw [Submodule.mem_toAddSubgroup] at hbig
  -- a unit inside the big maximal ideal: absurd
  have hmap := hunit.map (integralClosureInclusion
    Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat N)
  rw [hkey] at hmap
  exact (IsLocalRing.maximalIdeal.isMaximal _).ne_top
    (Ideal.eq_top_of_isUnit_mem _ hbig hmap)

section TameGeneratorThree

open scoped Pointwise

local notation "KvвӮғ" =>
  IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
    Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat
local notation "OvвӮғ" =>
  IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
    Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat

set_option backward.isDefEq.respectTransparency false in
set_option synthInstance.maxHeartbeats 1000000 in
set_option maxHeartbeats 2000000 in
/-- **Finite-level tame ramification at `3`** (PROVEN 2026-07-24 by
specializing `exists_finite_level_tame_generator_of_frobenius` above;
Serre, *Corps Locaux* IV В§1вҖ“2): for every finite Galois subextension
`N` of the algebraic closure of `в„ҡвӮғбөҘ` there is a finite-level inertia
element `t` such that (a) every finite-level inertia element agrees
with a power of `t` up to an element of `3`-power order вҖ” the wild
inertia `P` is the (normal) `3`-Sylow of the inertia `I`, the tame
quotient `I/P` is CYCLIC (it embeds into the multiplicative group of
the residue field of `N` via `Пғ вҶҰ Пғ(ПҖ)/ПҖ` for a uniformizer `ПҖ`), `t`
is any preimage of a generator, and the error `(tбөҗ)вҒ»В№Пғ` lies in `P` вҖ”
and (b) some automorphism `ПҶ` of `N` (any Frobenius lift) conjugates
`t` into `tВі` up to an element of `3`-power order: the tame character
is Frobenius-semilinear, `ПҶtПҶвҒ»В№ вүЎ t^q (mod P)` with
`q = |рқ’ӘбөҘ/рқ”ӘбөҘ| = |рқ”ҪвӮғ| = 3`. The specialization supplies: faithfulness
of the Galois action on the integral closure (fraction-field
denominator clearing), `3 вҲҲ рқ”Ә` (lying over `рқ”ӘбөҘ = (3)`), and a
Frobenius lift acting as cubing on the residue field
(`Ideal.Quotient.stabilizerHom_surjective` against the cubing
automorphism, which is `ОәбөҘ`-linear because `|ОәбөҘ| = 3` by
`natCard_residue_quotient_toHeightOneSpectrum`). -/
theorem exists_finite_level_tame_generator_three
    (N : IntermediateField
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
        (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)))
    [FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N]
    [IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N] :
    вҲғ t вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
        (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] N),
      (вҲҖ Пғ вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
          (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
          (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] N),
        вҲғ m j : в„•, ((t ^ m)вҒ»В№ * Пғ) ^ 3 ^ j = 1) вҲ§
      (вҲғ ПҶ : N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] N,
        вҲғ j : в„•, (ПҶ * t * ПҶвҒ»В№ * (t ^ 3)вҒ»В№) ^ 3 ^ j = 1) := by
  classical
  -- `3` lies in the maximal ideal downstairs, hence upstairs
  have h3O : (3 : OvвӮғ) вҲҲ IsLocalRing.maximalIdeal OvвӮғ := by
    rw [maximalIdeal_adicCompletionIntegers_eq_span Nat.prime_three]
    exact_mod_cast Ideal.mem_span_singleton_self ((3 : в„•) : OvвӮғ)
  have h3R : (3 : IntegralClosure OvвӮғ N) вҲҲ
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N) := by
    have h2 := (Ideal.mem_of_liesOver
      (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N))
      (IsLocalRing.maximalIdeal OvвӮғ) (3 : OvвӮғ)).mp h3O
    rwa [map_ofNat] at h2
  -- faithfulness of the Galois action on the integral closure
  haveI : IsFractionRing (IntegralClosure OvвӮғ N) N :=
    IsIntegralClosure.isFractionRing_of_finite_extension OvвӮғ KvвӮғ N
      (IntegralClosure OvвӮғ N)
  have halgmapinj : Function.Injective (algebraMap OvвӮғ N) := by
    rw [IsScalarTower.algebraMap_eq OvвӮғ KvвӮғ N]
    exact (algebraMap KvвӮғ N).injective.comp (IsFractionRing.injective OvвӮғ KvвӮғ)
  haveI : Module.IsTorsionFree OvвӮғ N :=
    Module.isTorsionFree_iff_algebraMap_injective.mpr halgmapinj
  have hfaith : вҲҖ g : N вүғвӮҗ[KvвӮғ] N,
      (вҲҖ a : IntegralClosure OvвӮғ N, g вҖў a = a) вҶ’ g = 1 := by
    intro g hg
    refine AlgEquiv.ext fun x => ?_
    have halg : IsAlgebraic OvвӮғ x :=
      (IsFractionRing.isAlgebraic_iff OvвӮғ KvвӮғ N).mpr
        (Algebra.IsAlgebraic.isAlgebraic x)
    obtain вҹЁc, hc0, hcxвҹ© := halg.exists_integral_multiple
    have hfix : g вҖў (c вҖў x) = c вҖў x := by
      have h1 := congrArg Subtype.val (hg вҹЁc вҖў x, hcxвҹ©)
      rwa [IntegralClosure.coe_smul] at h1
    rw [smul_comm] at hfix
    have hgx : g вҖў x = x := smul_right_injective N hc0 hfix
    simpa [AlgEquiv.smul_def] using hgx
  -- the residue field downstairs has three elements
  haveI hOmax : (IsLocalRing.maximalIdeal OvвӮғ).IsMaximal :=
    IsLocalRing.maximalIdeal.isMaximal _
  have hcard : Nat.card (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ) = 3 := by
    have h1 := natCard_residue_quotient_toHeightOneSpectrum Nat.prime_three
    rwa [IsLocalRing.eq_maximalIdeal (Ideal.IsMaximal.under OvвӮғ
      (IsLocalRing.maximalIdeal
        (IntegralClosure OvвӮғ (AlgebraicClosure KvвӮғ))))] at h1
  haveI hfinbase : Finite (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ) :=
    Nat.finite_of_card_ne_zero (by rw [hcard]; norm_num)
  have hpow3 : вҲҖ y : OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ, y ^ 3 = y := by
    haveI : Fintype (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ) := Fintype.ofFinite _
    letI : Field (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ) :=
      Ideal.Quotient.field (IsLocalRing.maximalIdeal OvвӮғ)
    intro y
    have h := FiniteField.pow_card y
    rwa [show Fintype.card (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ) = 3 from by
      rw [вҶҗ Nat.card_eq_fintype_card, hcard]] at h
  -- the residue field upstairs: characteristic `3`, finite
  haveI hRmax : (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)).IsMaximal :=
    IsLocalRing.maximalIdeal.isMaximal _
  have h30 : ((3 : в„•) : (IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) = 0 := by
    rw [вҶҗ map_natCast (Ideal.Quotient.mk
      (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)))]
    exact Ideal.Quotient.eq_zero_iff_mem.mpr (by exact_mod_cast h3R)
  haveI : CharP ((IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) 3 := by
    have h := CharP.ringChar_of_prime_eq_zero Nat.prime_three h30
    haveI := ringChar.charP ((IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N))
    exact CharP.congr _ h
  haveI : ExpChar ((IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) 3 :=
    ExpChar.prime Nat.prime_three
  haveI : Module.Finite OvвӮғ (IntegralClosure OvвӮғ N) :=
    IsIntegralClosure.finite OvвӮғ KvвӮғ N (IntegralClosure OvвӮғ N)
  haveI : Module.Finite OvвӮғ ((IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) :=
    Module.Finite.of_surjective
      (Ideal.Quotient.mkвӮҗ OvвӮғ
        (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N))).toLinearMap
      (Ideal.Quotient.mkвӮҗ_surjective OvвӮғ _)
  haveI : Module.Finite (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ)
      ((IntegralClosure OvвӮғ N) в§ё
        IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) :=
    Module.Finite.of_restrictScalars_finite OvвӮғ _ _
  haveI hfinQ : Finite ((IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) :=
    Module.finite_of_finite (OvвӮғ в§ё IsLocalRing.maximalIdeal OvвӮғ)
  -- the cubing automorphism of the residue field upstairs
  have hbij : Function.Bijective (frobenius ((IntegralClosure OvвӮғ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N)) 3) :=
    Finite.injective_iff_bijective.mp (frobenius_inj _ 3)
  have hfrE_apply : вҲҖ z, (RingEquiv.ofBijective _ hbij) z = z ^ 3 := fun z => rfl
  obtain вҹЁПҶ', hПҶ'вҹ© := Ideal.Quotient.stabilizerHom_surjective (N вүғвӮҗ[KvвӮғ] N)
    (IsLocalRing.maximalIdeal OvвӮғ)
    (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N))
    (AlgEquiv.ofRingEquiv (f := RingEquiv.ofBijective _ hbij)
      (fun y => by rw [hfrE_apply, вҶҗ map_pow, hpow3 y]))
  have hПҶfrob : вҲҖ x : IntegralClosure OvвӮғ N,
      (ПҶ' : N вүғвӮҗ[KvвӮғ] N) вҖў x - x ^ 3 вҲҲ
        IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N) := by
    intro x
    have h1 : Ideal.Quotient.stabilizerHom
        (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N))
        (IsLocalRing.maximalIdeal OvвӮғ) (N вүғвӮҗ[KvвӮғ] N) ПҶ'
        (Ideal.Quotient.mk _ x) =
        Ideal.Quotient.mk _ ((ПҶ' : N вүғвӮҗ[KvвӮғ] N) вҖў x) := rfl
    have h2 : Ideal.Quotient.stabilizerHom
        (IsLocalRing.maximalIdeal (IntegralClosure OvвӮғ N))
        (IsLocalRing.maximalIdeal OvвӮғ) (N вүғвӮҗ[KvвӮғ] N) ПҶ'
        (Ideal.Quotient.mk _ x) = (Ideal.Quotient.mk _ x) ^ 3 := by
      rw [hПҶ']
      exact hfrE_apply _
    refine Ideal.Quotient.eq.mp ?_
    rw [вҶҗ h1, h2, map_pow]
  obtain вҹЁt, htmem, hgen, hjвҹ© :=
    exists_finite_level_tame_generator_of_frobenius hfaith Nat.prime_three
      (by exact_mod_cast h3R) (ПҶ' : N вүғвӮҗ[KvвӮғ] N) hПҶfrob
  exact вҹЁt, htmem, hgen, (ПҶ' : N вүғвӮҗ[KvвӮғ] N), hjвҹ©

end TameGeneratorThree

set_option backward.isDefEq.respectTransparency false in
set_option synthInstance.maxHeartbeats 1000000 in
set_option maxHeartbeats 4000000 in
/-- **The eighth power of a prime-to-`3`-order character of
`О“_{в„ҡ(вҲҡd)}` dies on every conjugated inertia element at `3` вҖ” the
conductor-descent leaf at the residual prime** (PROVEN 2026-07-24 вҖ”
leaf (a) of the decomposition of `odd_order_character_eq_one_ray_class`
below, over the finite-level engine above): a function `ОҪ` that is
a nonvanishing multiplicative character on `H = ker Оё' = О“_{в„ҡ(вҲҡd)}`
(`hОҪmul`, `hОҪne0`) with OPEN kernel (`hUopen`, `hUker`) and pointwise
orders coprime to `3` (only the `В¬ 3 вҲЈ n` clause of `hОҪodd` is
genuinely consumed; the full packet is passed for uniformity with the
consumer) satisfies `ОҪ(П„)вҒё = 1` for every `О“ в„ҡ`-conjugate
`П„ = cВ·ПғМғВ·cвҒ»В№ вҲҲ H` of a local inertia image `ПғМғ` at `3`.

Content (Serre, *Corps Locaux* IV В§2; Serre, Duke 1987 В§5.3): the
local inertia `I вүӨ О“ в„ҡвӮғбөҘ` is an extension of the procyclic
prime-to-`3` tame quotient by the pro-`3` wild inertia, and any
Frobenius lift conjugates the tame quotient by cubing. The proof
runs the finite-level leaf `exists_finite_level_tame_generator_three`
above (tame generator `tМ„` with `3`-power-order errors, Frobenius `ПҶ`
with `ПҶtМ„ПҶвҒ»В№В·(tМ„Ві)вҒ»В№` of `3`-power order) through
`exists_mem_localInertiaGroup_restrictNormalHom_eq` /
`restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_three`,
mirroring the PROVEN global assembly
`exists_localInertia_three_generator` below вҖ” which does not apply
literally, since `ОҪ` is a character of the index-`2` subgroup `H`
only. The three index-`2` adaptations: (1) the finite Galois level
`N` is chosen inside the `Emb`-preimage of the `c`-conjugated kernel
`{Оі | cВ·Emb ОіВ·cвҒ»В№ вҲҲ U}` вҖ” openness survives conjugation, so no
normal core is needed; (2) `ОҪ` cannot be factored through level `N`
(it is not a homomorphism on `О“ в„ҡ`), so every kill happens upstairs:
an element `Оі` whose level-`N` restriction has `3`-power order has
`(cВ·Emb ОіВ·cвҒ»В№)^{3^k} вҲҲ U`, whence `Оё'` dies on it (odd power in
`ZMod 2`) and `ОҪ` dies against the prime-to-`3` pointwise orders;
(3) the tame conjugation uses the SQUARE `ОҰВІ` of a profinite
Frobenius lift `ОҰ`: `Оё'(ОҰВІ) = Оё'(ОҰ)ВІ = 1` always (values in
`ZMod 2`), so `ОҰВІ`-conjugation is by an `H`-element, under which `ОҪ`
is invariant (abelian values, `hОҪmul`), while
`ОҰВІВ·tВ·ОҰвҒ»ВІ = PВ·tвҒ№` with `P` an explicit five-factor product of
conjugates of level-`N`-trivial or `3`-power-order elements; this
forces `ОҪ = ОҪвҒ№` on the tame part, i.e. its eighth power is `1` вҖ”
uniformly over the seven `d`, with no case split on the splitting
behaviour of `3` in `в„ҡ(вҲҡd)` (the sharp exponent is
`3^f вҲ’ 1 вҲҲ {2, 8}`, but `2 вҲЈ 8` makes `8` uniform). When the
transported tame generator falls OUTSIDE `H` (`Оё'` value `вү  1`, the
ramified fields), its exponent `m` in the decomposition of `П„` is
even and the same argument runs on the square of the generator.
NOTE: the quadratic-field data (`d`, `x`) of the consumer is NOT
needed вҖ” the statement holds for the kernel of ANY character
`Оё' : О“ в„ҡ вҶ’* Multiplicative (ZMod 2)`, since the `ОҰВІ`/even-exponent
splitting sidesteps the residue degrees entirely. -/
theorem character_pow_eight_localInertia_three_eq_one_ray_class
    (Оё' : О“ в„ҡ вҶ’* Multiplicative (ZMod 2))
    (ОҪ : О“ в„ҡ вҶ’ Dickson.K 3)
    (hОҪmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ОҪ (g * h) = ОҪ g * ОҪ h)
    (hОҪne0 : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g вү  0)
    (U : Subgroup (О“ в„ҡ)) (hUopen : IsOpen (U : Set (О“ в„ҡ)))
    (hUker : вҲҖ g вҲҲ U, Оё' g = 1 вҲ§ ОҪ g = 1)
    (hОҪodd : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’
      вҲғ n : в„•, 0 < n вҲ§ Odd n вҲ§ В¬ (3 вҲЈ n) вҲ§ ОҪ g ^ n = 1) :
    вҲҖ c : О“ в„ҡ,
      вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat,
        Оё' (c * Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ * cвҒ»В№) = 1 вҶ’
        ОҪ (c * Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ * cвҒ»В№) ^ 8
          = 1 := by
  classical
  intro c
  set v := Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat
  set Emb := Field.absoluteGaloisGroup.map (algebraMap в„ҡ
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
  intro ПғвӮғ hПғвӮғ hОёП„
  -- (0) `H = ker Оё'` bookkeeping: closure, unit value, inverses,
  -- powers, `H`-conjugation invariance
  have hHinv : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' gвҒ»В№ = 1 := by
    intro g hg
    rw [map_inv, hg, inv_one]
  have hHmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’ Оё' (g * h) = 1 := by
    intro g h hg hh
    rw [map_mul, hg, hh, mul_one]
  have hОҪone : ОҪ 1 = 1 := by
    have h := hОҪmul 1 1 (map_one Оё') (map_one Оё')
    rw [mul_one] at h
    have hne := hОҪne0 1 (map_one Оё')
    field_simp at h
    exact h.symm
  have hОҪinv : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ gвҒ»В№ = (ОҪ g)вҒ»В№ := by
    intro g hg
    have h := hОҪmul gвҒ»В№ g (hHinv g hg) hg
    rw [inv_mul_cancel, hОҪone] at h
    exact eq_inv_of_mul_eq_one_left h.symm
  have hОҪpow : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ вҲҖ n : в„•, ОҪ (g ^ n) = ОҪ g ^ n := by
    intro g hg n
    induction n with
    | zero => simpa using hОҪone
    | succ n ih =>
      have hgn : Оё' (g ^ n) = 1 := by rw [map_pow, hg, one_pow]
      rw [pow_succ, pow_succ, hОҪmul _ _ hgn hg, ih]
  have hОҪconj : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ОҪ (h * g * hвҒ»В№) = ОҪ g := by
    intro g h hg hh
    rw [hОҪmul (h * g) hвҒ»В№ (hHmul h g hh hg) (hHinv h hh),
      hОҪmul h g hh hg, hОҪinv h hh]
    field_simp [hОҪne0 h hh]
  -- (1) arithmetic of `Multiplicative (ZMod 2)`: squares vanish, odd
  -- powers are the identity
  have hОёsq : вҲҖ a : Multiplicative (ZMod 2), a ^ 2 = 1 := by decide
  have hОёpow3 : вҲҖ (a : Multiplicative (ZMod 2)) (k : в„•), a ^ 3 ^ k = a := by
    intro a k
    obtain вҹЁs, hsвҹ© : вҲғ s, 3 ^ k = 2 * s + 1 := by
      have h1 : 3 ^ k % 2 = 1 := by
        rw [Nat.pow_mod]
        simp
      exact вҹЁ3 ^ k / 2, by omegaвҹ©
    rw [hs, pow_add, pow_mul, hОёsq, one_pow, pow_one, one_mul]
  -- (2) the transport homomorphism `Оі вҶҰ cВ·(Emb Оі)В·cвҒ»В№`
  set T := ((MulAut.conj c).toMonoidHom.comp Emb.toMonoidHom) with hTdef
  have hTapp : вҲҖ Оі, T Оі = c * Emb Оі * cвҒ»В№ := by
    intro Оі
    simp [hTdef, MonoidHom.comp_apply, MulAut.conj_apply]
  rw [вҶҗ hTapp ПғвӮғ] at hОёП„ вҠў
  -- (3) a finite Galois level inside the `c`-conjugated kernel
  have hcont : Continuous fun Оі :
      О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) =>
      c * Emb Оі * cвҒ»В№ :=
