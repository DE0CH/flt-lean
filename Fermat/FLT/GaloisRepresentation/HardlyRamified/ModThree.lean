    have h2 : (c‚āĀ : ‚Ą§) ‚ÄĘ w ‚ąą Q ^ m := hJQ (zsmul_mem hwJ _)
    have h3 : őł - x = (őł‚āā - x) + (c‚āĀ : ‚Ą§) ‚ÄĘ w := by
      rw [hőłdef]; ring
