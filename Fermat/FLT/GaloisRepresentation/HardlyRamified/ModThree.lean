    intro g hg
    apply Units.ext
    rw [Units.val_one, hu g]
    have h1 : (Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g =
        ((MonoidHomClass.toMonoidHom ŌĀ :
          Representation k (őď ‚Ąö) V) g).baseChange (AlgebraicClosure k) := rfl
    have h2 : (MonoidHomClass.toMonoidHom ŌĀ :
        Representation k (őď ‚Ąö) V) g = 1 := hg
    rw [h1, h2, Module.End.one_eq_id, LinearMap.baseChange_id,
      ‚Üź Module.End.one_eq_id, LinearMap.toMatrix_one,
      Matrix.map_one _ (map_zero e) (map_one e)]
  -- `ker u` is an open (hence closed) normal subgroup
  let KŌĀ : Subgroup (őď ‚Ąö) :=
    { carrier := {g | ŌĀ g = 1}
      one_mem' := map_one ŌĀ
      mul_mem' := by
        intro a b ha hb
        show ŌĀ (a * b) = 1
        rw [map_mul, ha, hb, mul_one]
      inv_mem' := by
        intro a ha
        show ŌĀ a‚ĀĽ¬Ļ = 1
        have h1 : ŌĀ a‚ĀĽ¬Ļ * ŌĀ a = 1 := by
          rw [‚Üź map_mul, inv_mul_cancel, map_one]
        rwa [ha, mul_one] at h1 }
  have hKŌĀ_open : IsOpen (KŌĀ : Set (őď ‚Ąö)) :=
    isOpen_setOf_galoisRep_eq_one ŌĀ hfinV
  have hker : KŌĀ ‚Č§ u.ker := fun g hg => MonoidHom.mem_ker.mpr (htriv g hg)
  have hopen : IsOpen (u.ker : Set (őď ‚Ąö)) :=
    Subgroup.isOpen_mono hker hKŌĀ_open
  have hclosed : IsClosed (u.ker : Set (őď ‚Ąö)) :=
    Subgroup.isClosed_of_isOpen u.ker hopen
  -- the fixed field of `ker u`
  haveI halgQ : Algebra.IsAlgebraic ‚Ąö (AlgebraicClosure ‚Ąö) :=
    AlgebraicClosure.isAlgebraic ‚Ąö
  haveI hacQ : IsAlgClosure ‚Ąö (AlgebraicClosure ‚Ąö) :=
    ‚ü®inferInstance, halgQ‚ü©
  haveI hnormQ : Normal ‚Ąö (AlgebraicClosure ‚Ąö) :=
    IsAlgClosure.normal ‚Ąö (AlgebraicClosure ‚Ąö)
  haveI hsepQ : Algebra.IsSeparable ‚Ąö (AlgebraicClosure ‚Ąö) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  haveI hgalQ : IsGalois ‚Ąö (AlgebraicClosure ‚Ąö) := ‚ü®‚ü©
  set K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö) :=
    IntermediateField.fixedField (E := AlgebraicClosure ‚Ąö) u.ker
  have hfix : K.fixingSubgroup = u.ker :=
    InfiniteGalois.fixingSubgroup_fixedField ‚ü®u.ker, hclosed‚ü©
  haveI hfd : FiniteDimensional ‚Ąö K :=
    (InfiniteGalois.isOpen_iff_finite K).mp (by rw [hfix]; exact hopen)
  haveI hnorm : u.ker.Normal := u.normal_ker
  haveI hgalK : IsGalois ‚Ąö K := (InfiniteGalois.normal_iff_isGalois K).mp
    (by rw [hfix]; exact hnorm)
  haveI : NumberField K := ‚ü®‚ü©
  -- the degree: `[K : ‚Ąö] = #Gal(K/‚Ąö) = #(őď ‚Ąö / ker u) = #u.range`
  have e1 : (őď ‚Ąö) ‚ßł u.ker ‚ČÉ* ((IntermediateField.fixedField
      ((‚ü®u.ker, hclosed‚ü© : ClosedSubgroup (őď ‚Ąö)) : Subgroup (őď ‚Ąö))) ‚ČÉ‚āź[‚Ąö]
        (IntermediateField.fixedField
          ((‚ü®u.ker, hclosed‚ü© : ClosedSubgroup (őď ‚Ąö)) : Subgroup (őď ‚Ąö)))) :=
    InfiniteGalois.normalAutEquivQuotient ‚ü®u.ker, hclosed‚ü©
  have e2 : (őď ‚Ąö) ‚ßł u.ker ‚ČÉ* u.range :=
    QuotientGroup.quotientKerEquivRange u
  have hcard1 : Nat.card (K ‚ČÉ‚āź[‚Ąö] K) = Module.finrank ‚Ąö K :=
    IsGalois.card_aut_eq_finrank ‚Ąö K
  refine ‚ü®K, inferInstance, inferInstance, hfix, ?_‚ü©
  rw [‚Üź hcard1]
  exact ((Nat.card_congr e1.toEquiv).symm).trans (Nat.card_congr e2.toEquiv)

/-- **Complex conjugation at a real place** (PROVEN 2026-07-23 ‚ÄĒ the
embedding plumbing of the oddness argument; a `ŌĀ`-free statement about
number fields): a subfield `K ‚äÜ ‚ĄöŠĶÉň°ŠĶć` that is NOT totally complex
admits an element `c ‚ąą őď ‚Ąö` fixing `K` pointwise on which the 3-adic
cyclotomic character is `‚ąí1`. Proof: a real infinite place of `K` is
induced by a real embedding `ŌÜ : K ‚Üí ‚Ąā`; extend `ŌÜ` to `Ōą : ‚ĄöŠĶÉň°ŠĶć ‚Üí ‚Ąā`
THROUGH `K` (`IsAlgClosed.lift` over the algebraic extension
`K ‚äÜ ‚ĄöŠĶÉň°ŠĶć`); complex conjugation restricts along `Ōą` to the (normal)
image (`AlgEquiv.restrictNormal` with the `Ōą`-algebra structure on
`‚Ąā`), giving `c ‚ąą őď ‚Ąö` with `Ōą ‚ąė c = conj ‚ąė Ōą`; `c` fixes `K`
pointwise (`Ōą(K) = ŌÜ(K) ‚äÜ ‚ĄĚ`) and is an involution fixing no
primitive cube root of unity (they are not real), so `Ōá‚āÉ(c)¬≤ = 1` and
`Ōá‚āÉ(c) ‚Č† 1` in the domain `‚Ą§_[3]`, forcing `Ōá‚āÉ(c) = ‚ąí1` ‚ÄĒ the
argument of `exists_conj_cyclotomicCharacter_three` relative to the
place. -/
theorem exists_conj_fixingSubgroup_of_not_isTotallyComplex
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    (hK : ¬¨ NumberField.IsTotallyComplex K) :
    ‚ąÉ c : őď ‚Ąö, c ‚ąą K.fixingSubgroup ‚ąß
      ((cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 c.toRingEquiv :
        ‚Ą§_[3]ň£) : ‚Ą§_[3]) = -1 := by
  haveI h3 : Fact (Nat.Prime 3) := ‚ü®Nat.prime_three‚ü©
  classical
  -- a real infinite place of `K` gives a real complex embedding
  obtain ‚ü®w, hw‚ü© : ‚ąÉ w : NumberField.InfinitePlace K, w.IsReal := by
    rw [NumberField.isTotallyComplex_iff] at hK
    push Not at hK
    obtain ‚ü®w, hw‚ü© := hK
    exact ‚ü®w, (NumberField.InfinitePlace.isReal_or_isComplex w).resolve_right hw‚ü©
  set ŌÜ : K ‚Üí+* ‚Ąā := w.embedding
  have hŌÜreal : ‚ąÄ y : K, (starRingEnd ‚Ąā) (ŌÜ y) = ŌÜ y := by
    intro y
    have h1 : NumberField.ComplexEmbedding.IsReal ŌÜ :=
      NumberField.InfinitePlace.isReal_iff.mp hw
    exact RingHom.congr_fun (NumberField.ComplexEmbedding.isReal_iff.mp h1) y
  -- extend `ŌÜ` to `Ōą : ‚ĄöŠĶÉň°ŠĶć ‚Üí ‚Ąā` THROUGH `K` (`IsAlgClosed.lift`)
  haveI : IsAlgClosed ‚Ąā := Complex.isAlgClosed
  letI : Algebra K ‚Ąā := ŌÜ.toAlgebra
  haveI halgQ : Algebra.IsAlgebraic ‚Ąö (AlgebraicClosure ‚Ąö) :=
    AlgebraicClosure.isAlgebraic ‚Ąö
  haveI halgK : Algebra.IsAlgebraic K (AlgebraicClosure ‚Ąö) :=
    Algebra.IsAlgebraic.tower_top (K := ‚Ąö) K
  haveI : IsScalarTower ‚Ąö K ‚Ąā := IsScalarTower.of_algebraMap_eq fun q => by
    have h1 : algebraMap ‚Ąö ‚Ąā q = (q : ‚Ąā) := eq_ratCast _ q
    have h2 : ŌÜ (algebraMap ‚Ąö K q) = (q : ‚Ąā) :=
      eq_ratCast (ŌÜ.comp (algebraMap ‚Ąö K)) q
    rw [h1, ‚Üź h2]
    rfl
  set ŌąK : AlgebraicClosure ‚Ąö ‚Üí‚āź[K] ‚Ąā := IsAlgClosed.lift
  set Ōą : AlgebraicClosure ‚Ąö ‚Üí+* ‚Ąā := (ŌąK.restrictScalars ‚Ąö).toRingHom
  have hŌąK : ‚ąÄ y : K, Ōą (algebraMap K (AlgebraicClosure ‚Ąö) y) = ŌÜ y :=
    fun y => ŌąK.commutes y
  -- pull complex conjugation back along `Ōą` (the image is normal)
  letI : Algebra (AlgebraicClosure ‚Ąö) ‚Ąā := Ōą.toAlgebra
  haveI : IsScalarTower ‚Ąö (AlgebraicClosure ‚Ąö) ‚Ąā :=
    IsScalarTower.of_algebraMap_eq fun q => by
      have h1 : algebraMap ‚Ąö ‚Ąā q = (q : ‚Ąā) := eq_ratCast _ q
      have h2 : Ōą (algebraMap ‚Ąö (AlgebraicClosure ‚Ąö) q) = (q : ‚Ąā) :=
        eq_ratCast (Ōą.comp (algebraMap ‚Ąö (AlgebraicClosure ‚Ąö))) q
      rw [h1, ‚Üź h2]
      rfl
  haveI hacQ : IsAlgClosure ‚Ąö (AlgebraicClosure ‚Ąö) := ‚ü®inferInstance, halgQ‚ü©
  haveI hnormQ : Normal ‚Ąö (AlgebraicClosure ‚Ąö) :=
    IsAlgClosure.normal ‚Ąö (AlgebraicClosure ‚Ąö)
  set ő≥ : ‚Ąā ‚ČÉ‚āź[‚Ąö] ‚Ąā := Complex.conjAe.restrictScalars ‚Ąö
  set c : (AlgebraicClosure ‚Ąö) ‚ČÉ‚āź[‚Ąö] (AlgebraicClosure ‚Ąö) :=
    AlgEquiv.restrictNormal ő≥ (AlgebraicClosure ‚Ąö)
  have hcomm : ‚ąÄ z : AlgebraicClosure ‚Ąö, Ōą (c z) = (starRingEnd ‚Ąā) (Ōą z) :=
    fun z => AlgEquiv.restrictNormal_commutes ő≥ (AlgebraicClosure ‚Ąö) z
  have hŌąinj : Function.Injective Ōą := Ōą.injective
  refine ‚ü®c, ?_, ?_‚ü©
  ¬∑ -- `c` fixes `K` pointwise: `Ōą` maps `K` into `‚ĄĚ`
    intro y
    apply hŌąinj
    show Ōą (c (algebraMap K (AlgebraicClosure ‚Ąö) y)) =
      Ōą (algebraMap K (AlgebraicClosure ‚Ąö) y)
    rw [hcomm, hŌąK, hŌÜreal]
  ¬∑ -- `Ōá‚āÉ(c) = ‚ąí1`: `c` is an involution moving the cube roots of unity
    have hc2 : c * c = 1 := by
      refine AlgEquiv.ext fun z => ?_
      apply hŌąinj
      show Ōą (c (c z)) = Ōą ((1 : (AlgebraicClosure ‚Ąö) ‚ČÉ‚āź[‚Ąö]
        (AlgebraicClosure ‚Ąö)) z)
      rw [hcomm, hcomm, Complex.conj_conj]
      rfl
    set t : ‚Ą§_[3] :=
      ((cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 c.toRingEquiv :
        ‚Ą§_[3]ň£) : ‚Ą§_[3])
    have hsq : t * t = 1 := by
      have hmul : (c * c).toRingEquiv = c.toRingEquiv * c.toRingEquiv := rfl
      have hone : ((1 : őď ‚Ąö).toRingEquiv) = 1 := rfl
      have h := congrArg (fun g => ((cyclotomicCharacter
        (AlgebraicClosure ‚Ąö) 3 g : ‚Ą§_[3]ň£) : ‚Ą§_[3]))
        (hmul.symm.trans (((by rw [hc2]; rfl :
          (c * c).toRingEquiv = (1 : őď ‚Ąö).toRingEquiv)).trans hone))
      simpa [map_mul] using h
    rcases mul_self_eq_one_iff.mp hsq with ht1 | htm1
    swap
    ¬∑ exact htm1
    -- rule out `t = 1`: `c` would fix a primitive cube root of unity
    exfalso
    obtain ‚ü®ő∂, hő∂‚ü© := HasEnoughRootsOfUnity.exists_primitiveRoot
      (AlgebraicClosure ‚Ąö) 3
    have hfix : c.toRingEquiv ő∂ = ő∂ := by
      have hspec := cyclotomicCharacter.spec 3 (n := 1) c.toRingEquiv ő∂
        (by rw [pow_one]; exact hő∂.pow_eq_one)
      rw [hspec, show (cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3
        c.toRingEquiv).val = t from rfl, ht1, map_one]
      rw [show ((1 : ZMod (3 ^ 1)).val) = 1 from rfl, pow_one]
    -- so `Ōą ő∂` is a REAL primitive cube root of unity in `‚Ąā`
    set z : ‚Ąā := Ōą ő∂ with hzdef
    have hzconj : (starRingEnd ‚Ąā) z = z := by
      rw [hzdef, ‚Üź hcomm, show c ő∂ = c.toRingEquiv ő∂ from rfl, hfix]
    have hzprim : IsPrimitiveRoot z 3 := hő∂.map_of_injective hŌąinj
    have hzre : ((z.re : ‚ĄĚ) : ‚Ąā) = z := Complex.conj_eq_iff_re.mp hzconj
    have hz3 : z ^ 3 = 1 := hzprim.pow_eq_one
    have hre3 : (z.re : ‚ĄĚ) ^ 3 = 1 := by
      have h1 : (((z.re : ‚ĄĚ) ^ 3 : ‚ĄĚ) : ‚Ąā) = ((1 : ‚ĄĚ) : ‚Ąā) := by
        push_cast
        rw [hzre, hz3]
      exact_mod_cast h1
    have hre1 : (z.re : ‚ĄĚ) = 1 := by
      nlinarith [sq_nonneg (z.re - 1), sq_nonneg (z.re + 1)]
    exact hzprim.ne_one (by norm_num) (by rw [‚Üź hzre, hre1]; norm_num)

set_option backward.isDefEq.respectTransparency false in
/-- **The kernel field is totally complex** (PROVEN 2026-07-23 ‚ÄĒ via
the conjugation-at-a-real-place leaf
`exists_conj_fixingSubgroup_of_not_isTotallyComplex` above, now
itself proven): the number field cut out by the
kernel of the matrix form of a mod-3 hardly ramified representation
has no real place. The proven reduction: were `K` not totally
complex, the leaf would produce `c ‚ąą fixingSubgroup K = ker u` with
`Ōá‚āÉ(c) = ‚ąí1`; but the determinant of `u c` is the image in
`Dickson.K 3` of `Ōá‚āÉ(c)` (`hŌĀ.det` transported along `hu` and
`LinearMap.det_baseChange`, as in the two-element determinant image
argument of `card_matrixRange_ge_of_exceptional`), so `u c = 1`
forces `1 = ‚ąí1` in `Dickson.K 3` ‚ÄĒ impossible in characteristic
`3`. -/
theorem isTotallyComplex_of_kernel_field {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    [IsGalois ‚Ąö K] (hfix : K.fixingSubgroup = u.ker) :
    NumberField.IsTotallyComplex K := by
  classical
  by_contra hK
  obtain ‚ü®c, hcfix, hcŌá‚ü© :=
    exists_conj_fixingSubgroup_of_not_isTotallyComplex K hK
  -- `c` kills the matrix form
  have hcker : u c = 1 := by
    have h1 : c ‚ąą u.ker := by
      rw [‚Üź hfix]
      exact hcfix
    exact MonoidHom.mem_ker.mp h1
  -- `2 ‚Č† 0` in `ūĚĒĹŐĄ‚āÉ`
  have h2ne : (2 : Dickson.K 3) ‚Č† 0 := by
    intro h
    have h3ne : ((2 : ‚Ąē) : Dickson.K 3) ‚Č† 0 := by
      rw [Ne, CharP.cast_eq_zero_iff (Dickson.K 3) 3]
      omega
    exact h3ne (by push_cast; exact h)
  -- the determinant of `u c` is the image of `Ōá‚āÉ c`
  have hdet_val :
      ((Matrix.GeneralLinearGroup.det (u c) : (Dickson.K 3)ň£) : Dickson.K 3) =
        ((e : AlgebraicClosure k ‚Üí+* Dickson.K 3).comp
          ((algebraMap k (AlgebraicClosure k)).comp (algebraMap ‚Ą§_[3] k)))
          ((cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 c.toRingEquiv :
            ‚Ą§_[3]ň£) : ‚Ą§_[3]) := by
    calc ((Matrix.GeneralLinearGroup.det (u c) : (Dickson.K 3)ň£) : Dickson.K 3)
        = ((u c : GL (Fin 2) (Dickson.K 3)) :
            Matrix (Fin 2) (Fin 2) (Dickson.K 3)).det := rfl
      _ = ((LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ)) c)).map e).det := by rw [hu c]
      _ = e ((LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ)) c)).det) :=
          (RingEquiv.map_det e _).symm
      _ = e (LinearMap.det ((Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ)) c)) := by rw [LinearMap.det_toMatrix]
      _ = e (algebraMap k (AlgebraicClosure k)
            (LinearMap.det ((MonoidHomClass.toMonoidHom ŌĀ :
              Representation k (őď ‚Ąö) V) c))) := by
          rw [show (Slop.OddRep.baseChange (AlgebraicClosure k)
              (MonoidHomClass.toMonoidHom ŌĀ)) c =
            ((MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V) c).baseChange
              (AlgebraicClosure k) from rfl, LinearMap.det_baseChange]
      _ = _ := by
          have hdg := hŌĀ.det c
          rw [GaloisRep.det_apply] at hdg
          rw [show LinearMap.det ((MonoidHomClass.toMonoidHom ŌĀ :
              Representation k (őď ‚Ąö) V) c) = LinearMap.det (ŌĀ c) from rfl, hdg]
          rfl
  -- `u c = 1` forces `1 = ‚ąí1` in `ūĚĒĹŐĄ‚āÉ`
  rw [hcker, map_one, Units.val_one, hcŌá, map_neg, map_one] at hdet_val
  exact h2ne (by linear_combination hdet_val)

/-- **Unramifiedness of the kernel field outside `{2, 3}`** (PROVEN
2026-07-23): the number field cut out by the kernel of the matrix
form of a mod-3 hardly ramified representation is unramified at every
prime `p ‚ąČ {2, 3}`, stated as `p ‚ą§ d_K`. Proof: at `p ‚ąČ {2, 3}` the
representation is unramified (`hŌĀ.isUnramified`), so the local
inertia at `p` lands in `ker ŌĀ ‚Č§ ker u = K.fixingSubgroup` (the
matrix transport `htriv` of `exists_kernel_field_of_matrixRange`); by
the inertia dictionary `isUnramifiedAt_of_inertia_le_fixingSubgroup`
of `MazurTorsion` every prime of `ūĚďě K` over `p` is unramified, and an
everywhere-unramified prime does not divide the discriminant
(`NumberField.not_dvd_discr_iff_forall_mem`). -/
theorem kernel_field_not_dvd_discr {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    [IsGalois ‚Ąö K] (hfix : K.fixingSubgroup = u.ker)
    (p : ‚Ąē) (hp : p.Prime) (hp2 : p ‚Č† 2) (hp3 : p ‚Č† 3) :
    ¬¨ ((p : ‚Ą§) ‚ą£ NumberField.discr K) := by
  classical
  -- the matrix transport of the identity: `ker ŌĀ ‚Č§ ker u`
  have htriv : ‚ąÄ g : őď ‚Ąö, ŌĀ g = 1 ‚Üí u g = 1 := by
    intro g hg
    apply Units.ext
    rw [Units.val_one, hu g]
    have h1 : (Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g =
        ((MonoidHomClass.toMonoidHom ŌĀ :
          Representation k (őď ‚Ąö) V) g).baseChange (AlgebraicClosure k) := rfl
    have h2 : (MonoidHomClass.toMonoidHom ŌĀ :
        Representation k (őď ‚Ąö) V) g = 1 := hg
    rw [h1, h2, Module.End.one_eq_id, LinearMap.baseChange_id,
      ‚Üź Module.End.one_eq_id, LinearMap.toMatrix_one,
      Matrix.map_one _ (map_zero e) (map_one e)]
  -- the local inertia image at `p` kills `u` (through `hŌĀ.isUnramified`)
  have hunram : ‚ąÄ ŌÉ ‚ąą localInertiaGroup hp.toHeightOneSpectrumRingOfIntegersRat,
      u (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
          hp.toHeightOneSpectrumRingOfIntegersRat)) ŌÉ) = 1 := by
    intro ŌÉ hŌÉ
    apply htriv
    have h1 : (ŌĀ.toLocal hp.toHeightOneSpectrumRingOfIntegersRat) ŌÉ = 1 :=
      (hŌĀ.isUnramified p hp ‚ü®hp2, hp3‚ü©).localInertiaGroup_le hŌÉ
    rw [GaloisRep.toLocal_apply] at h1
    convert h1 using 4
    exact Subsingleton.elim _ _
  -- ‚Ä¶ so the mapped local inertia fixes `K`
  have hle : Subgroup.map (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
        hp.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom
      (localInertiaGroup hp.toHeightOneSpectrumRingOfIntegersRat)
      ‚Č§ K.fixingSubgroup := by
    rintro g ‚ü®ŌÉ, hŌÉ, rfl‚ü©
    rw [hfix]
    exact MonoidHom.mem_ker.mpr (hunram ŌÉ hŌÉ)
  -- every prime of `ūĚďě K` over `p` is unramified, so `p ‚ą§ d_K`
  have hpZ : Prime ((p : ‚Ą§)) := Nat.prime_iff_prime_int.mp hp
  rw [NumberField.not_dvd_discr_iff_forall_mem K
    (NumberField.RingOfIntegers K) hpZ]
  intro P hP hmem
  haveI := hP
  exact isUnramifiedAt_of_inertia_le_fixingSubgroup K hp hle P
    (by exact_mod_cast hmem)

open UniqueFactorizationMonoid in
/-- **The discriminant exponent from per-prime different-exponent
bounds** (sorry node, isolated 2026-07-23 from the two discriminant
exponent leaves below): for a number field `K`, a rational prime `p`
and weights `a, b`, if every prime `Q` of `ūĚďě K` over `p` satisfies
`a¬∑d_Q ‚Č§ b¬∑e_Q` for its different exponent `d_Q` ‚ÄĒ stated
multiplicity-free: every `d` with `Q^d ‚ą£ ūĚĒ°_{K/‚Ąö}` has
`a¬∑d ‚Č§ b¬∑e(Q‚ą£p)` ‚ÄĒ then `a¬∑v_p(d_K) ‚Č§ b¬∑[K:‚Ąö]`. Intended proof (norm
bookkeeping, no new arithmetic): `N(ūĚĒ°_{K/‚Ąö}) = |d_K|`
(`NumberField.absNorm_differentIdeal`), so
`v_p(d_K) = ő£_{Q‚ą£p} f_Q¬∑d_Q` by multiplicativity of `Ideal.absNorm`
along the factorization of the different into primes, whence
`a¬∑v_p(d_K) = ő£_{Q‚ą£p} f_Q¬∑(a¬∑d_Q) ‚Č§ b¬∑ő£_{Q‚ą£p} f_Q¬∑e_Q = b¬∑[K:‚Ąö]`
(`Ideal.sum_ramification_inertia`). PROVEN 2026-07-23 along exactly
that route: the different is factored into `normalizedFactors`, the
norm is pushed through the product (`map_prod`), `Nat.factorization`
distributes over it, primes not over `p` contribute `0`
(`Ideal.exists_isMaximal_dvd_of_dvd_absNorm'`), primes over `p`
contribute `d_Q¬∑f_Q` (`Ideal.absNorm_eq_pow_inertiaDeg'`), and the
per-prime hypothesis plus `Ideal.sum_ramification_inertia` close. -/
theorem discr_factorization_le_of_forall_differentIdeal_pow_dvd
    (K : Type*) [Field K] [NumberField K] (p : ‚Ąē) (hp : p.Prime) (a b : ‚Ąē)
    (h : ‚ąÄ Q : Ideal (NumberField.RingOfIntegers K), Q.IsPrime ‚Üí
      ((p : NumberField.RingOfIntegers K) ‚ąą Q) ‚Üí ‚ąÄ d : ‚Ąē,
      Q ^ d ‚ą£ differentIdeal ‚Ą§ (NumberField.RingOfIntegers K) ‚Üí
      a * d ‚Č§ b * Ideal.ramificationIdx' (Ideal.span {(p : ‚Ą§)}) Q) :
    a * (NumberField.discr K).natAbs.factorization p ‚Č§
      b * Module.finrank ‚Ąö K := by
  classical
  set R := NumberField.RingOfIntegers K with hRdef
  set D := differentIdeal ‚Ą§ R with hDdef
  have hD0 : D ‚Č† 0 := by
    rw [hDdef, Submodule.zero_eq_bot]
    exact differentIdeal_ne_bot
  have hnorm : Ideal.absNorm D = (NumberField.discr K).natAbs :=
    NumberField.absNorm_differentIdeal K R
  rw [‚Üź hnorm]
  -- the factorization of the different into primes
  have hDprod : D = ‚ąŹ Q ‚ąą (normalizedFactors D).toFinset,
      Q ^ (normalizedFactors D).count Q := by
    conv_lhs => rw [‚Üź associated_iff_eq.mp (prod_normalizedFactors hD0)]
    exact Finset.prod_multiset_count _
  have hQprime : ‚ąÄ Q ‚ąą (normalizedFactors D).toFinset, Prime Q := fun Q hQ =>
    prime_of_normalized_factor Q (Multiset.mem_toFinset.mp hQ)
  have habs0 : ‚ąÄ Q ‚ąą (normalizedFactors D).toFinset,
      Ideal.absNorm Q ‚Č† 0 := fun Q hQ => by
    rw [Ne, Ideal.absNorm_eq_zero_iff, ‚Üź Ideal.zero_eq_bot]
    exact (hQprime Q hQ).ne_zero
  -- multiplicativity of the norm along the factorization
  have hnormD : Ideal.absNorm D = ‚ąŹ Q ‚ąą (normalizedFactors D).toFinset,
      Ideal.absNorm Q ^ (normalizedFactors D).count Q := by
    conv_lhs => rw [hDprod]
    rw [map_prod]
    exact Finset.prod_congr rfl fun Q _ => map_pow _ _ _
  -- the `p`-adic valuation of the norm, term by term
  have hfact : (Ideal.absNorm D).factorization p
      = ‚ąĎ Q ‚ąą (normalizedFactors D).toFinset,
        (normalizedFactors D).count Q * (Ideal.absNorm Q).factorization p := by
    rw [hnormD, Nat.factorization_prod (fun Q hQ => pow_ne_zero _ (habs0 Q hQ)),
      Finset.sum_apply']
    exact Finset.sum_congr rfl fun Q hQ => by
      rw [Nat.factorization_pow, Finsupp.smul_apply, smul_eq_mul]
  -- primes not containing `p` contribute nothing
  have hmem_of_ne : ‚ąÄ Q ‚ąą (normalizedFactors D).toFinset,
      (normalizedFactors D).count Q * (Ideal.absNorm Q).factorization p ‚Č† 0 ‚Üí
      ((p : ‚Ąē) : R) ‚ąą Q := by
    intro Q hQF hne
    by_contra hpnot
    apply hne
    rw [Nat.mul_eq_zero]
    right
    by_contra hne2
    have hdvd : p ‚ą£ Ideal.absNorm Q := Nat.dvd_of_factorization_pos hne2
    obtain ‚ü®P, hPmax, hPunder, hPdvd‚ü© :=
      Ideal.exists_isMaximal_dvd_of_dvd_absNorm' hp Q hdvd
    have hQpr : Q.IsPrime := Ideal.isPrime_of_prime (hQprime Q hQF)
    have hQ0 : Q ‚Č† ‚ä• := by
      rw [‚Üź Ideal.zero_eq_bot]
      exact (hQprime Q hQF).ne_zero
    have hQP : Q = P := (hQpr.isMaximal hQ0).eq_of_le hPmax.ne_top
      (Ideal.le_of_dvd hPdvd)
    apply hpnot
    have hmemP : algebraMap ‚Ą§ R ((p : ‚Ąē) : ‚Ą§) ‚ąą P := by
      have hu : ((p : ‚Ąē) : ‚Ą§) ‚ąą P.under ‚Ą§ := by
        rw [hPunder]
        exact Ideal.mem_span_singleton_self _
      exact hu
    rw [map_natCast] at hmemP
    rw [hQP]
    exact hmemP
  have hsum : (Ideal.absNorm D).factorization p =
      ‚ąĎ Q ‚ąą (normalizedFactors D).toFinset.filter (fun Q => ((p : ‚Ąē) : R) ‚ąą Q),
        (normalizedFactors D).count Q * (Ideal.absNorm Q).factorization p := by
    rw [hfact]
    exact (Finset.sum_filter_of_ne hmem_of_ne).symm
  -- the setup at `p`
  have hpZ : Prime ((p : ‚Ąē) : ‚Ą§) := Nat.prime_iff_prime_int.mp hp
  have hspan0 : (Ideal.span {((p : ‚Ąē) : ‚Ą§)} : Ideal ‚Ą§) ‚Č† ‚ä• := by
    simp only [Ne, Ideal.span_singleton_eq_bot]
    exact_mod_cast hp.ne_zero
  haveI hspanMax : (Ideal.span {((p : ‚Ąē) : ‚Ą§)} : Ideal ‚Ą§).IsMaximal :=
    (((Ideal.span_singleton_prime (by exact_mod_cast hp.ne_zero)).mpr
      hpZ).isMaximal hspan0)
  have hmain := Ideal.sum_ramification_inertia R ‚Ąö K hspan0
  -- the per-prime bound
  have hle : ‚ąÄ Q ‚ąą (normalizedFactors D).toFinset.filter
      (fun Q => ((p : ‚Ąē) : R) ‚ąą Q),
      a * ((normalizedFactors D).count Q * (Ideal.absNorm Q).factorization p) ‚Č§
      b * (Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q *
        Ideal.inertiaDeg' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q) := by
    intro Q hQ
    obtain ‚ü®hQF, hpQ‚ü© := Finset.mem_filter.mp hQ
    have hQpr : Q.IsPrime := Ideal.isPrime_of_prime (hQprime Q hQF)
    haveI := hQpr
    haveI hlies : Q.LiesOver (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) :=
      (Ideal.liesOver_span_iff hQpr.ne_top hpZ).mpr (by exact_mod_cast hpQ)
    have hf : (Ideal.absNorm Q).factorization p =
        Ideal.inertiaDeg' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q := by
      rw [Ideal.absNorm_eq_pow_inertiaDeg' Q hp, hp.factorization_pow,
        Finsupp.single_eq_same]
    have hdvd : Q ^ (normalizedFactors D).count Q ‚ą£ D := by
      conv_rhs => rw [hDprod]
      exact Finset.dvd_prod_of_mem _ hQF
    have hcntle : a * (normalizedFactors D).count Q ‚Č§
        b * Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q :=
      h Q hQpr hpQ ((normalizedFactors D).count Q) hdvd
    calc a * ((normalizedFactors D).count Q * (Ideal.absNorm Q).factorization p)
        = (a * (normalizedFactors D).count Q) *
          (Ideal.absNorm Q).factorization p := by ring
      _ ‚Č§ (b * Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q) *
          (Ideal.absNorm Q).factorization p :=
        Nat.mul_le_mul_right _ hcntle
      _ = b * (Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q *
          Ideal.inertiaDeg' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q) := by
        rw [hf]; ring
  have hsub : (normalizedFactors D).toFinset.filter
      (fun Q => ((p : ‚Ąē) : R) ‚ąą Q) ‚äÜ
      IsDedekindDomain.primesOverFinset (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) R := by
    intro Q hQ
    obtain ‚ü®hQF, hpQ‚ü© := Finset.mem_filter.mp hQ
    have hQpr : Q.IsPrime := Ideal.isPrime_of_prime (hQprime Q hQF)
    rw [IsDedekindDomain.mem_primesOverFinset_iff hspan0]
    exact ‚ü®hQpr, (Ideal.liesOver_span_iff hQpr.ne_top hpZ).mpr
      (by exact_mod_cast hpQ)‚ü©
  rw [hsum, Finset.mul_sum]
  calc ‚ąĎ Q ‚ąą (normalizedFactors D).toFinset.filter
        (fun Q => ((p : ‚Ąē) : R) ‚ąą Q),
        a * ((normalizedFactors D).count Q * (Ideal.absNorm Q).factorization p)
      ‚Č§ ‚ąĎ Q ‚ąą (normalizedFactors D).toFinset.filter
        (fun Q => ((p : ‚Ąē) : R) ‚ąą Q),
        b * (Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q *
          Ideal.inertiaDeg' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q) :=
      Finset.sum_le_sum hle
    _ ‚Č§ ‚ąĎ Q ‚ąą IsDedekindDomain.primesOverFinset
          (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) R,
        b * (Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q *
          Ideal.inertiaDeg' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q) :=
      Finset.sum_le_sum_of_subset hsub
    _ = b * Module.finrank ‚Ąö K := by rw [‚Üź Finset.mul_sum, hmain]

open Module in
/-- **Nonvanishing of the trace form of a tame local algebra** (PROVEN
2026-07-23; the residue-theoretic core of the tame different bound
below): the trace form of a finite local algebra `C` over a field `F`
is nonzero as soon as the residue extension is separable and the
residue-field dimension of `C` is invertible in `F` (the tame case).
Proof: a Cohen-style multiplicative section `C ‚ßł m ‚Üí‚āź[F] C` (formal
smoothness of the separable residue extension against the nilpotent
maximal ideal, `Algebra.FormallySmooth.lift`) turns `C` into a
`C ‚ßł m`-vector space, and transitivity of the trace evaluates the
trace of a residue scalar `y` as `n ‚ÄĘ Tr_{(C‚ßłm)/F}(y)` with
`n = dim_{C‚ßłm} C`, nonzero for suitable `y` because the separable
residue trace is nonzero (`Algebra.trace_ne_zero`). -/
lemma exists_trace_ne_zero_of_isNilpotent
    (F C : Type*) [Field F] [CommRing C] [Algebra F C] [Module.Finite F C]
    (m : Ideal C) (hm : IsNilpotent m) [hmax : m.IsMaximal]
    [Algebra.IsSeparable F (C ‚ßł m)]
    (hd : ‚ąÄ n : ‚Ąē, finrank F C = finrank F (C ‚ßł m) * n ‚Üí (n : F) ‚Č† 0) :
    ‚ąÉ w : C, Algebra.trace F C w ‚Č† 0 := by
  classical
  letI : Field (C ‚ßł m) := Ideal.Quotient.field m
  haveI : Module.Finite F (C ‚ßł m) :=
    Module.Finite.of_surjective (Ideal.Quotient.mk‚āź F m).toLinearMap
      Ideal.Quotient.mk_surjective
  obtain ‚ü®y, hy‚ü© : ‚ąÉ y : C ‚ßł m, Algebra.trace F (C ‚ßł m) y ‚Č† 0 := by
    simpa [LinearMap.ext_iff] using Algebra.trace_ne_zero F (C ‚ßł m)
  -- the Cohen multiplicative section
  haveI : Algebra.FormallySmooth F (C ‚ßł m) := by
    haveI := Algebra.FormallyEtale.of_isSeparable F (C ‚ßł m)
    infer_instance
  let ŌÉ : (C ‚ßł m) ‚Üí‚āź[F] C :=
    Algebra.FormallySmooth.lift m hm (AlgHom.id F (C ‚ßł m))
  letI : Algebra (C ‚ßł m) C := ŌÉ.toAlgebra
  haveI : IsScalarTower F (C ‚ßł m) C :=
    IsScalarTower.of_algebraMap_eq' ŌÉ.comp_algebraMap.symm
  haveI : Module.Finite (C ‚ßł m) C :=
    Module.Finite.of_restrictScalars_finite F _ _
  refine ‚ü®algebraMap (C ‚ßł m) C y, fun h0 => ?_‚ü©
  rw [‚Üź Algebra.trace_trace (S := C ‚ßł m), Algebra.trace_algebraMap,
    map_nsmul, nsmul_eq_mul] at h0
  rcases mul_eq_zero.mp h0 with h1 | h1
  ¬∑ exact hd _ (Module.finrank_mul_finrank F (C ‚ßł m) C).symm h1
  ¬∑ exact hy h1

open UniqueFactorizationMonoid in
/-- **The tame different bound** (PROVEN 2026-07-23; Serre, *Corps
Locaux* III ¬ß6 Prop. 13 / Neukirch III.2.6): if the ramification index
`e = e(Q‚ą£p)` of a prime `Q` of `ūĚďě K` over the rational prime `p` is
not divisible by `p` (tame ramification ‚ÄĒ the residue extension is an
extension of finite fields, hence automatically separable), then the
different exponent of `Q` is at most `e ‚ąí 1`, stated as `Q^e ‚ą§ ūĚĒ°_{K/‚Ąö}`
(mathlib has the matching lower half `pow_sub_one_dvd_differentIdeal`).
Proof: write `pO_K = Q^e ¬∑ J` exactly (`Ideal.eq_prime_pow_mul_coprime`
plus the `normalizedFactors`-count characterization of `e`); the trace
form of the tame factor `O_K ‚ßł Q^e` over `ūĚĒĹ_p` is nonzero
(`exists_trace_ne_zero_of_isNilpotent`, with `dim = e¬∑f` by
`Ideal.Factors.finrank_pow_ramificationIdx` and `p ‚ą§ e`), so the CRT
lift of a trace-nonzero element supported on the `Q^e`-component has
`intTrace ‚ąČ (p)`, and `not_dvd_differentIdeal_of_intTrace_not_mem`
closes. -/
theorem not_pow_ramificationIdx_dvd_differentIdeal
    (K : Type*) [Field K] [NumberField K] (p : ‚Ąē) (hp : p.Prime)
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hmem : (p : NumberField.RingOfIntegers K) ‚ąą Q)
    (htame : ¬¨ (p ‚ą£ Ideal.ramificationIdx' (Ideal.span {(p : ‚Ą§)}) Q)) :
    ¬¨ Q ^ Ideal.ramificationIdx' (Ideal.span {(p : ‚Ą§)}) Q ‚ą£
      differentIdeal ‚Ą§ (NumberField.RingOfIntegers K) := by
  classical
  set R := NumberField.RingOfIntegers K with hRdef
  haveI := hQ
  -- the setup at `p`
  have hpZ : Prime ((p : ‚Ąē) : ‚Ą§) := Nat.prime_iff_prime_int.mp hp
  have hspan0 : (Ideal.span {((p : ‚Ąē) : ‚Ą§)} : Ideal ‚Ą§) ‚Č† ‚ä• := by
    simp only [Ne, Ideal.span_singleton_eq_bot]
    exact_mod_cast hp.ne_zero
  haveI hspanMax : (Ideal.span {((p : ‚Ąē) : ‚Ą§)} : Ideal ‚Ą§).IsMaximal :=
    (((Ideal.span_singleton_prime (by exact_mod_cast hp.ne_zero)).mpr
      hpZ).isMaximal hspan0)
  haveI hlies : Q.LiesOver (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) :=
    (Ideal.liesOver_span_iff hQ.ne_top hpZ).mpr (by exact_mod_cast hmem)
  have hmap0 : (Ideal.span {((p : ‚Ąē) : ‚Ą§)}).map (algebraMap ‚Ą§ R) ‚Č† ‚ä• :=
    Ideal.map_ne_bot_of_ne_bot hspan0
  have hQ0 : Q ‚Č† ‚ä• := ne_bot_of_le_ne_bot hmap0
    (Ideal.map_le_of_le_comap (Q.over_def (Ideal.span {((p : ‚Ąē) : ‚Ą§)})).le)
  haveI hQmax : Q.IsMaximal := hQ.isMaximal hQ0
  set e := Ideal.ramificationIdx' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q with hedef
  have he0 : e ‚Č† 0 :=
    Ideal.IsDedekindDomain.ramificationIdx'_ne_zero_of_liesOver Q hspan0
  -- the exact factorization `map p = Q ^ e * J` with `Q ‚äĒ J = ‚ä§`
  obtain ‚ü®J, hsup, hfac‚ü© := Ideal.eq_prime_pow_mul_coprime hmap0 Q
  rw [‚Üź Ideal.IsDedekindDomain.ramificationIdx'_eq_normalizedFactors_count
    hmap0 hQ hQ0, ‚Üź hedef] at hfac
  have hcop : IsCoprime (Q ^ e) J :=
    (Ideal.isCoprime_iff_sup_eq.mpr hsup).pow_left
  -- residue-quotient algebra structures
  letI : Algebra (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) (R ‚ßł Q ^ e) :=
    Ideal.Quotient.algebraQuotientOfLEComap
      (Ideal.map_le_iff_le_comap.mp (Ideal.le_of_dvd ‚ü®J, hfac‚ü©))
  letI : Algebra (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) (R ‚ßł J) :=
    Ideal.Quotient.algebraQuotientOfLEComap
      (Ideal.map_le_iff_le_comap.mp (Ideal.le_of_dvd
        ‚ü®Q ^ e, hfac.trans (mul_comm _ _)‚ü©))
  -- the CRT decomposition of `R ‚ßł pR`
  letI őĶ : (R ‚ßł (Ideal.span {((p : ‚Ąē) : ‚Ą§)}).map (algebraMap ‚Ą§ R))
      ‚ČÉ‚āź[‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}] ((R ‚ßł Q ^ e) √ó R ‚ßł J) :=
    { __ := (Ideal.quotEquivOfEq hfac).trans
        (Ideal.quotientMulEquivQuotientProd (Q ^ e) J hcop),
      commutes' := Quotient.ind fun _ => rfl }
  -- the maximal ideal of `R ‚ßł Q ^ e` and its residue field
  set m : Ideal (R ‚ßł Q ^ e) := Q.map (Ideal.Quotient.mk (Q ^ e)) with hmdef
  have hnilp : IsNilpotent m := ‚ü®e, by
    rw [hmdef, ‚Üź Ideal.map_pow, Ideal.zero_eq_bot, Ideal.map_quotient_self]‚ü©
  letI őĶ‚āā : ((R ‚ßł Q ^ e) ‚ßł m) ‚ČÉ+* R ‚ßł Q :=
    DoubleQuot.quotQuotEquivQuotOfLE (Ideal.pow_le_self he0)
  haveI hmmax : m.IsMaximal := Ideal.Quotient.maximal_of_isField m
    (őĶ‚āā.toMulEquiv.isField
      ((Ideal.Quotient.maximal_ideal_iff_isField_quotient Q).mp hQmax))
  letI őĶ‚āā‚āź : ((R ‚ßł Q ^ e) ‚ßł m) ‚ČÉ‚āź[‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}] (R ‚ßł Q) :=
    { __ := őĶ‚āā,
      commutes' := fun x => by
        obtain ‚ü®x, rfl‚ü© := Ideal.Quotient.mk_surjective x
        rfl }
  haveI hsep : Algebra.IsSeparable (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)})
      ((R ‚ßł Q ^ e) ‚ßł m) := by
    letI : Field (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) := Ideal.Quotient.field _
    letI : Field (R ‚ßł Q) := Ideal.Quotient.field Q
    haveI : Finite (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) :=
      Ring.HasFiniteQuotients.finiteQuotient hspan0
    haveI : Module.Finite ‚Ą§ (R ‚ßł Q) :=
      Module.Finite.of_surjective (Ideal.Quotient.mk‚āź ‚Ą§ Q).toLinearMap
        Ideal.Quotient.mk_surjective
    haveI : Module.Finite (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) (R ‚ßł Q) :=
      Module.Finite.of_restrictScalars_finite ‚Ą§ _ _
    haveI : Algebra.IsAlgebraic (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) (R ‚ßł Q) :=
      Algebra.IsAlgebraic.of_finite _ _
    exact AlgEquiv.Algebra.isSeparable őĶ‚āā‚āź.symm
  -- the dimension bookkeeping: `dim_F (R ‚ßł Q^e) = e * f`, `dim_F őļ = f`
  have hQmemF : Q ‚ąą (factors ((Ideal.span {((p : ‚Ąē) : ‚Ą§)}).map
      (algebraMap ‚Ą§ R))).toFinset := by
    rw [Multiset.mem_toFinset, factors_eq_normalizedFactors, ‚Üź Multiset.count_pos,
      ‚Üź Ideal.IsDedekindDomain.ramificationIdx'_eq_normalizedFactors_count hmap0 hQ hQ0]
    exact Nat.pos_of_ne_zero he0
  have hEF : Module.finrank (‚Ą§ ‚ßł Ideal.span {((p : ‚Ąē) : ‚Ą§)}) (R ‚ßł Q ^ e) =
      e * Ideal.inertiaDeg' (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) Q :=
    Ideal.Factors.finrank_pow_ramificationIdx
      (Ideal.span {((p : ‚Ąē) : ‚Ą§)}) ‚ü®Q, hQmemF‚ü©
