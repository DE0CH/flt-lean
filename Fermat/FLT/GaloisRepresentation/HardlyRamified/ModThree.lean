eigenvector for the SWITCHED quadratic field. -/
theorem exists_index_two_common_eigenvector {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (ŌÄ : őď ‚Ąö ‚Üí* Dickson.PGL 3)
    (hŌÄ : ‚ąÄ g, ŌÄ g = QuotientGroup.mk (u g))
    (őł : őď ‚Ąö ‚Üí* Multiplicative (ZMod 2))
    (hőłsurj : Function.Surjective őł)
    (hcomm : ‚ąÄ g h : őď ‚Ąö, őł g = 1 ‚Üí őł h = 1 ‚Üí ŌÄ g * ŌÄ h = ŌÄ h * ŌÄ g)
    (htr : ‚ąÄ g : őď ‚Ąö, őł g ‚Č† 1 ‚Üí
      LinearMap.trace k V
        ((MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V) g) = 0) :
    ‚ąÉ őł' : őď ‚Ąö ‚Üí* Multiplicative (ZMod 2),
      Function.Surjective őł' ‚ąß (‚ąÄ g : őď ‚Ąö, ŌĀ g = 1 ‚Üí őł' g = 1) ‚ąß
      ‚ąÉ v : Fin 2 ‚Üí Dickson.K 3, v ‚Č† 0 ‚ąß
        ‚ąÄ g : őď ‚Ąö, őł' g = 1 ‚Üí ‚ąÉ c : Dickson.K 3,
          Matrix.mulVec ((u g : GL (Fin 2) (Dickson.K 3)) :
            Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v = c ‚ÄĘ v := by
  classical
  by_cases hA : ‚ąÄ g h' : őď ‚Ąö, őł g = 1 ‚Üí őł h' = 1 ‚Üí
      (u g).val * (u h').val = (u h').val * (u g).val
  ¬∑ -- the honestly commuting case: `őł' = őł` works
    have h3k : (3 : k) = 0 := three_eq_zero_of_finite_padicIntThree_algebra
    have h2k : (2 : k) ‚Č† 0 := fun h =>
      one_ne_zero (őĪ := k) (by linear_combination h3k - h)
    have hfr : Module.finrank k V = 2 :=
      Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
    have htriv : ‚ąÄ g : őď ‚Ąö, ŌĀ g = 1 ‚Üí őł g = 1 := by
      intro g hg
      by_contra hne
      have h0 := htr g hne
      have h1 : (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V) g = 1 := hg
      rw [h1, LinearMap.trace_one, hfr] at h0
      exact h2k (by exact_mod_cast h0)
    refine ‚ü®őł, hőłsurj, htriv, ?_‚ü©
    by_cases hsc : ‚ąÄ h' : őď ‚Ąö, őł h' = 1 ‚Üí ‚ąÉ c : Dickson.K 3,
        (u h').val = c ‚ÄĘ (1 : Matrix (Fin 2) (Fin 2) (Dickson.K 3))
    ¬∑ -- every kernel matrix is scalar: any nonzero vector is common
      refine ‚ü®![1, 0], fun h => one_ne_zero (őĪ := Dickson.K 3)
        (by simpa using congrFun h 0), ?_‚ü©
      intro g hg
      obtain ‚ü®c, hc‚ü© := hsc g hg
      refine ‚ü®c, ?_‚ü©
      rw [hc, Matrix.smul_mulVec, Matrix.one_mulVec]
    ¬∑ -- some kernel matrix is nonscalar: its eigenline is common
      push Not at hsc
      obtain ‚ü®h‚āÄ, hh‚āÄ, hns‚ü© := hsc
      obtain ‚ü®s, hsev‚ü© :=
        Module.End.exists_eigenvalue (Matrix.mulVecLin (u h‚āÄ).val)
      obtain ‚ü®v, hv‚ü© := hsev.exists_hasEigenvector
      have hfv : Matrix.mulVec (u h‚āÄ).val v = s ‚ÄĘ v := by
        have h1 := Module.End.mem_eigenspace_iff.mp hv.1
        rwa [Matrix.mulVecLin_apply] at h1
      have hM0 : (u h‚āÄ).val - s ‚ÄĘ 1 ‚Č† 0 := by
        intro h0
        exact hns s (by rwa [sub_eq_zero] at h0)
      have hvker : Matrix.mulVec ((u h‚āÄ).val - s ‚ÄĘ 1) v = 0 := by
        rw [Matrix.sub_mulVec, hfv, Matrix.smul_mulVec, Matrix.one_mulVec, sub_self]
      refine ‚ü®v, hv.2, ?_‚ü©
      intro g hg
      have hcg := hA g h‚āÄ hg hh‚āÄ
      have hswap : ((u h‚āÄ).val - s ‚ÄĘ 1) * (u g).val =
          (u g).val * ((u h‚āÄ).val - s ‚ÄĘ 1) := by
        rw [sub_mul, mul_sub, smul_mul_assoc, one_mul, mul_smul_comm, mul_one, hcg]
      have hwker : Matrix.mulVec ((u h‚āÄ).val - s ‚ÄĘ 1)
          (Matrix.mulVec (u g).val v) = 0 := by
        rw [Matrix.mulVec_mulVec, hswap, ‚Üź Matrix.mulVec_mulVec, hvker,
          Matrix.mulVec_zero]
      exact exists_smul_eq_of_mulVec_eq_zero hM0 hvker hwker hv.2
  ¬∑ -- the Klein-four case: switch to the sign character of a fixed
    -- trace-zero involution-mod-scalars
    haveI : CharP (Dickson.K 3) 3 :=
      charP_of_injective_algebraMap
        (algebraMap (ZMod 3) (Dickson.K 3)).injective 3
    have h2F : (2 : Dickson.K 3) ‚Č† 0 := by
      intro h
      have h3 := (CharP.cast_eq_zero_iff (Dickson.K 3) 3 2).mp h
      norm_num at h3
    -- `u` of a `ŌĀ`-kernel element is the identity matrix
    have huone : ‚ąÄ g : őď ‚Ąö, ŌĀ g = 1 ‚Üí (u g).val = 1 := by
      intro g hg
      have h2 : (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V) g = 1 := hg
      have h1 : (Slop.OddRep.baseChange (AlgebraicClosure k)
          (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V)) g = 1 := by
        have h3 : (Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V)) g =
            ((MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V) g).baseChange
              (AlgebraicClosure k) := rfl
        rw [h3, h2, Module.End.one_eq_id, LinearMap.baseChange_id]
        rfl
      rw [hu g, h1, LinearMap.toMatrix_one]
      exact Matrix.map_one e (map_zero e) (map_one e)
    -- the Klein-four analysis: a trace-zero anticommuting-pair member,
    -- conjugation-fixed up to sign by the whole image
    have hklein :=
      exists_klein_pivot_of_noncommuting_kernel h2F u ŌÄ hŌÄ őł hőłsurj hcomm hA
    obtain ‚ü®f, htr0, hdetf, ‚ü®p, hp‚ü©, hdich‚ü© := hklein
    -- commuting and anticommuting with `f` are mutually exclusive
    have hexcl : ‚ąÄ g : őď ‚Ąö, (u g).val * f = f * (u g).val ‚Üí
        (u g).val * f = -(f * (u g).val) ‚Üí False := by
      intro g h1 h2
      have h3 : f * (u g).val = -(f * (u g).val) := h1.symm.trans h2
      have h5 : f * (u g).val = 0 := by
        have h6 : (2 : Dickson.K 3) ‚ÄĘ (f * (u g).val) = 0 := by
          rw [two_smul]
          exact add_eq_zero_iff_eq_neg.mpr h3
        rcases smul_eq_zero.mp h6 with h7 | h7
        ¬∑ exact absurd h7 h2F
        ¬∑ exact h7
      have h7 : Matrix.det (f * (u g).val) = 0 := by
        rw [h5]
        exact Matrix.det_zero
      rw [Matrix.det_mul] at h7
      rcases mul_eq_zero.mp h7 with h8 | h8
      ¬∑ exact hdetf h8
      ¬∑ exact ((Matrix.isUnit_iff_isUnit_det (u g).val).mp (u g).isUnit).ne_zero h8
    -- Cayley‚ÄďHamilton for the trace-zero `f`: `f¬≤ = (-det f) ‚ÄĘ 1`
    have hCH : f * f = (-Matrix.det f) ‚ÄĘ (1 : Matrix (Fin 2) (Fin 2) (Dickson.K 3)) := by
      have hCH0 := Matrix.aeval_self_charpoly f
      rw [Matrix.charpoly_fin_two, map_add, map_sub, map_pow, Polynomial.aeval_X,
        map_mul, Polynomial.aeval_C, htr0, map_zero, zero_mul, sub_zero,
        Polynomial.aeval_C, Algebra.algebraMap_eq_smul_one] at hCH0
      rw [‚Üź sq, neg_smul]
      exact eq_neg_of_add_eq_zero_left hCH0
    -- a square root of `-det f` and a singular translate of `f`
    obtain ‚ü®s, hs2‚ü© :=
      IsAlgClosed.exists_pow_nat_eq (-Matrix.det f) (n := 2) (by norm_num)
    have hfact : (f - s ‚ÄĘ 1) * (f + s ‚ÄĘ 1) = 0 := by
      have h1 : (f - s ‚ÄĘ 1) * (f + s ‚ÄĘ 1) =
          f * f - (s * s) ‚ÄĘ (1 : Matrix (Fin 2) (Fin 2) (Dickson.K 3)) := by
        simp only [mul_add, sub_mul, smul_mul_assoc, mul_smul_comm, one_mul,
          mul_one, smul_sub, smul_smul]
