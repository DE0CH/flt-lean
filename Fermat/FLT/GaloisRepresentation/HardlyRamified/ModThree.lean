      (fun z : ‚Ąā => Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ (z / 2)) s :=
    ContinuousAt.comp
      (g := fun w : ‚Ąā => Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ w)
      (f := fun z : ‚Ąā => z / 2) (continuousAt_const_cpow hd) hdiv2
  have hc2a : ContinuousAt (fun z : ‚Ąā => (Real.pi : ‚Ąā) ^ (-z / 2)) s :=
    ContinuousAt.comp (g := fun w : ‚Ąā => (Real.pi : ‚Ąā) ^ w)
      (f := fun z : ‚Ąā => -z / 2) (continuousAt_const_cpow hpi)
      ((continuous_id.neg.div_const (2 : ‚Ąā)).continuousAt)
  have hc2b : ContinuousAt (fun z : ‚Ąā => Complex.Gamma (z / 2)) s :=
    ContinuousAt.comp (g := Complex.Gamma) (f := fun z : ‚Ąā => z / 2)
      (Complex.differentiableAt_Gamma (s / 2) hhalf_ne).continuousAt hdiv2
  have hc3a : ContinuousAt (fun z : ‚Ąā => ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ (-z)) s :=
    ContinuousAt.comp (g := fun w : ‚Ąā => ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ w)
      (f := fun z : ‚Ąā => -z) (continuousAt_const_cpow h2pi)
      continuous_neg.continuousAt
  have hőď : ContinuousAt Complex.Gamma s :=
    (Complex.differentiableAt_Gamma s hs_ne).continuousAt
  show ContinuousAt (fun z : ‚Ąā =>
    Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ (z / 2) *
      ((Real.pi : ‚Ąā) ^ (-z / 2) * Complex.Gamma (z / 2)) ^
        NumberField.InfinitePlace.nrRealPlaces K *
      ((2 : ‚Ąā) * ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ (-z) * Complex.Gamma z) ^
        NumberField.InfinitePlace.nrComplexPlaces K) s
  exact (hc1.mul ((hc2a.mul hc2b).pow _)).mul
    (((continuousAt_const.mul hc3a).mul hőď).pow _)

/-- **Nonvanishing of the elementary factor on `re s > 0`** (PROVEN
2026-07-24): complex powers of the nonzero bases `|d_K|`, `ŌÄ`, `2ŌÄ`
never vanish (`Complex.cpow_ne_zero_iff`), and `őď` has no zeros on
`re > 0` (`Complex.Gamma_ne_zero_of_re_pos`) ‚ÄĒ the same factorwise
