/-- **The identityвҖ“antipode convolution cancels on the LEFT**
(PROVEN): `id вӢҶ S = 1` in the convolution monoid of a commutative
Hopf algebra. Mathlib has the other order
(`AlgHom.antipode_id_cancel`); this one reduces to the linear-level
`LinearMap.id_mul_antipode` the same way. -/
theorem toConv_id_mul_toConv_antipodeAlgHom
    {R A : Type*} [CommSemiring R] [CommSemiring A] [HopfAlgebra R A] :
    toConv (AlgHom.id R A) * toConv (HopfAlgebra.antipodeAlgHom R A) =
      (1 : WithConv (A вҶ’вӮҗ[R] A)) := by
  apply WithConv.ofConv_injective
  apply AlgHom.toLinearMap_injective
  apply WithConv.toConv_injective
  rw [AlgHom.toLinearMap_convMul, AlgHom.toLinearMap_convOne]
  simp [LinearMap.id_mul_antipode]

set_option backward.isDefEq.respectTransparency false in
/-- **Convolution right-inverse of a Hopf-algebra point** (PROVEN):
`ПҮ вӢҶ (ПҮ вҲҳ S) = 1` for any point `ПҮ : A вҶ’вӮҗ[R] C` of a commutative Hopf
algebra `A` with values in a commutative algebra `C` вҖ” the
postcomposition image of `id вӢҶ S = 1` under `ПҮ`, which distributes
over convolution. Used to invert the points of the generic fibre of a
Hopf package without a group instance on the bare-hom monoid. -/
theorem toConv_mul_toConv_comp_antipodeAlgHom
    {R A C : Type*} [CommSemiring R] [CommSemiring A] [HopfAlgebra R A]
    [CommSemiring C] [Algebra R C] (ПҮ : A вҶ’вӮҗ[R] C) :
    toConv ПҮ * toConv (ПҮ.comp (HopfAlgebra.antipodeAlgHom R A)) =
      (1 : WithConv (A вҶ’вӮҗ[R] C)) := by
  have h := AlgHom.comp_convMul_distrib ПҮ (toConv (AlgHom.id R A))
    (toConv (HopfAlgebra.antipodeAlgHom R A))
  rw [toConv_id_mul_toConv_antipodeAlgHom] at h
  have h1 : ПҮ.comp ((1 : WithConv (A вҶ’вӮҗ[R] A)).ofConv) =
      (1 : WithConv (A вҶ’вӮҗ[R] C)).ofConv := by
    rw [AlgHom.convOne_def, AlgHom.convOne_def, WithConv.ofConv_toConv,
      WithConv.ofConv_toConv, вҶҗ AlgHom.comp_assoc]
    congr 1
    refine AlgHom.ext fun r => ?_
    simp [Algebra.ofId_apply]
  rw [h1] at h
  have h2 : ПҮ.comp ((toConv (AlgHom.id R A)).ofConv) = ПҮ := AlgHom.comp_id ПҮ
  rw [h2] at h
  exact (WithConv.ofConv_injective h).symm

set_option backward.isDefEq.respectTransparency false in
/-- **Convolution value on an absorbed idempotent** (PROVEN): if the
comultiplication of an idempotent `eвӮҖ` absorbs `eвӮҖ вҠ— eвӮҖ` (that is,
`О”eвӮҖ В· (eвӮҖ вҠ— eвӮҖ) = eвӮҖ вҠ— eвӮҖ`, the defining property of a connected
counit idempotent), then two points taking the value `1` on `eвӮҖ`
convolve to a point taking the value `1` on `eвӮҖ`:
`(ПҮвӮҒ вӢҶ ПҮвӮӮ)(eвӮҖ) = Ој(О”eвӮҖ) = Ој(О”eвӮҖ)В·Ој(eвӮҖвҠ—eвӮҖ) = Ој(О”eвӮҖВ·(eвӮҖвҠ—eвӮҖ)) = 1`. -/
theorem convMul_apply_one_of_comul_absorbs
    {R G C : Type*} [CommRing R] [CommRing G] [Bialgebra R G]
    [CommRing C] [Algebra R C]
    (eвӮҖ : G)
    (hcomul : Coalgebra.comul (R := R) eвӮҖ * (eвӮҖ вҠ—вӮң[R] eвӮҖ) = eвӮҖ вҠ—вӮң[R] eвӮҖ)
    (ПҮвӮҒ ПҮвӮӮ : G вҶ’вӮҗ[R] C) (hвӮҒ : ПҮвӮҒ eвӮҖ = 1) (hвӮӮ : ПҮвӮӮ eвӮҖ = 1) :
    (toConv ПҮвӮҒ * toConv ПҮвӮӮ).ofConv eвӮҖ = 1 := by
  have happ : (toConv ПҮвӮҒ * toConv ПҮвӮӮ).ofConv eвӮҖ =
      Algebra.TensorProduct.lift ПҮвӮҒ ПҮвӮӮ (fun _ _ => Commute.all _ _)
        (Coalgebra.comul (R := R) eвӮҖ) :=
    AlgHom.convMul_apply (toConv ПҮвӮҒ) (toConv ПҮвӮӮ) eвӮҖ
  have hОјe : Algebra.TensorProduct.lift ПҮвӮҒ ПҮвӮӮ (fun _ _ => Commute.all _ _)
      (eвӮҖ вҠ—вӮң[R] eвӮҖ) = 1 := by
    rw [Algebra.TensorProduct.lift_tmul, hвӮҒ, hвӮӮ, one_mul]
  rw [happ]
  calc Algebra.TensorProduct.lift ПҮвӮҒ ПҮвӮӮ (fun _ _ => Commute.all _ _)
        (Coalgebra.comul (R := R) eвӮҖ)
      = Algebra.TensorProduct.lift ПҮвӮҒ ПҮвӮӮ (fun _ _ => Commute.all _ _)
          (Coalgebra.comul (R := R) eвӮҖ) *
        Algebra.TensorProduct.lift ПҮвӮҒ ПҮвӮӮ (fun _ _ => Commute.all _ _)
          (eвӮҖ вҠ—вӮң[R] eвӮҖ) := by rw [hОјe, mul_one]
    _ = Algebra.TensorProduct.lift ПҮвӮҒ ПҮвӮӮ (fun _ _ => Commute.all _ _)
          (Coalgebra.comul (R := R) eвӮҖ * (eвӮҖ вҠ—вӮң[R] eвӮҖ)) := (map_mul _ _ _).symm
    _ = 1 := by rw [hcomul, hОјe]

/-- **The connected counit idempotent of a finite flat Hopf order over
`в„ӨвӮғ`** (sorry node, 2026-07-24 вҖ” the henselian idempotent theory of
the connectedвҖ“Г©tale decomposition): a finite flat Hopf algebra `G`
over `рқ’ӘвӮғбөҘ вү… в„ӨвӮғ` carries a PRIMITIVE idempotent `eвӮҖ` with counit value
`1` whose comultiplication absorbs `eвӮҖ вҠ— eвӮҖ`. Intended proof: `рқ’ӘвӮғбөҘ` is
a complete (hence henselian) DVR, so the module-finite algebra `G` is
a finite product of local rings (its Noetherian spectrum has finitely
many connected components, and henselianity makes the factors local);
write `1 = ОЈ eбөў` with `eбөў` the primitive orthogonal idempotents.
Exactly one `eбөў` has `Оө(eбөў) = 1`: the values `Оө(eбөў)` are orthogonal
idempotents of the domain `рқ’ӘвӮғбөҘ` summing to `1`, so exactly one is `1`
and the rest are `0`; take `eвӮҖ` to be that one. Primitivity gives the
absorption dichotomy (`xВ·eвӮҖ` is an idempotent of the local ring
`GeвӮҖ`, hence `0` or `eвӮҖ`). For the comultiplication absorption:
`x вҶҰ О”(x)В·(eвӮҖ вҠ— eвӮҖ)` is an algebra map `G вҶ’ GeвӮҖ вҠ— GeвӮҖ`, and
`GeвӮҖ вҠ— GeвӮҖ` is LOCAL вҖ” `GeвӮҖ` is local with residue field `рқ”ҪвӮғ` (the
counit splits off the residue map), so `(GeвӮҖ вҠ— GeвӮҖ) вҠ— рқ”ҪвӮғ вү…
(GeвӮҖ вҠ— рқ”ҪвӮғ) вҠ—[рқ”ҪвӮғ] (GeвӮҖ вҠ— рқ”ҪвӮғ)` is local artinian, and `3` lies in the
Jacobson radical of the module-finite algebra `GeвӮҖ вҠ— GeвӮҖ` over the
complete `рқ’ӘвӮғбөҘ`; therefore the image `О”(eвӮҖ)В·(eвӮҖ вҠ— eвӮҖ)` is an
idempotent of a local ring, hence `0` or the identity `eвӮҖ вҠ— eвӮҖ`, and
the counit axiom `(Оө вҠ— Оө)(О”eвӮҖ) = Оө(eвӮҖ) = 1` rules out `0`. -/
theorem exists_connected_counit_idempotent_at_three
    (G : Type) [CommRing G]
    [HopfAlgebra рқ’ӘвӮғбөҘ G] [Module.Flat рқ’ӘвӮғбөҘ G] [Module.Finite рқ’ӘвӮғбөҘ G] :
    вҲғ eвӮҖ : G, IsIdempotentElem eвӮҖ вҲ§
      Coalgebra.counit (R := рқ’ӘвӮғбөҘ) eвӮҖ = (1 : рқ’ӘвӮғбөҘ) вҲ§
      (вҲҖ x : G, IsIdempotentElem x вҶ’ x * eвӮҖ = 0 вҲЁ x * eвӮҖ = eвӮҖ) вҲ§
      Coalgebra.comul (R := рқ’ӘвӮғбөҘ) eвӮҖ * (eвӮҖ вҠ—вӮң[рқ’ӘвӮғбөҘ] eвӮҖ) = eвӮҖ вҠ—вӮң[рқ’ӘвӮғбөҘ] eвӮҖ := by
  obtain вҹЁeвӮҖ, heвӮҖ, hОөвӮҖ, hmin, habsвҹ© :=
    Bialgebra.exists_connected_counit_idempotent (A := рқ’ӘвӮғбөҘ) (G := G)
  refine вҹЁeвӮҖ, heвӮҖ, hОөвӮҖ,
    fun x hx => mul_eq_zero_or_mul_eq_of_minimal heвӮҖ hОөвӮҖ hmin x hx, ?_вҹ©
  rwa [Bialgebra.comulAlgHom_apply] at habs

set_option backward.isDefEq.respectTransparency false in
