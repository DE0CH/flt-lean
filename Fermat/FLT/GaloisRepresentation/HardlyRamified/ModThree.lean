    have h2 : Оё' (g' * ПғвӮҖ) = 1 := by
      rw [map_mul]
      exact hker2 _ _ hne hПғвӮҖ
    have hNv : Matrix.mulVec N v = ПҮвӮҖ (ПғвӮҖвҒ»В№ * g') вҖў
        Matrix.mulVec ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v := by
      have hgrp : g' = ПғвӮҖ * (ПғвӮҖвҒ»В№ * g') := by group
      have hcomp : N = ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) *
          ((u (ПғвӮҖвҒ»В№ * g') : GL (Fin 2) (Dickson.K 3)) :
            Matrix (Fin 2) (Fin 2) (Dickson.K 3)) := by
        rw [hN]
        conv_lhs => rw [hgrp]
        rw [map_mul, Units.val_mul]
      rw [hcomp, вҶҗ Matrix.mulVec_mulVec, hПҮвӮҖ _ h1, Matrix.mulVec_smul]
    have hNw : Matrix.mulVec N (Matrix.mulVec
        ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v) = ПҮвӮҖ (g' * ПғвӮҖ) вҖў v := by
      have h := hПҮвӮҖ _ h2
      rw [map_mul, Units.val_mul, вҶҗ Matrix.mulVec_mulVec, вҶҗ hN] at h
      exact h
    set w : Fin 2 вҶ’ Dickson.K 3 := Matrix.mulVec
      ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v
    have hcross : v 0 * w 1 - w 0 * v 1 вү  0 := by
      intro hc
      apply hindep
      have hvi : v 0 вү  0 вҲЁ v 1 вү  0 := by
        by_contra hcon
        push Not at hcon
        exact hv (funext fun i => by fin_cases i; exacts [hcon.1, hcon.2])
      rcases hvi with h0 | hi1
      В· refine вҹЁw 0 / v 0, funext fun i => ?_вҹ©
        fin_cases i
