/-- **The inertia bridge at `2`** (FULLY PROVEN 2026-07-18 ‚ÄĒ completion
bookkeeping, stated up to conjugacy since the two local worlds involve
different choices of embedding of `‚ĄöŠĶÉň°ŠĶć`): every element of the local
inertia group at the place `prime_two` (phrased at the adic completion
of `‚Ąö`) has, up to conjugation in `őď ‚Ąö`, the same image as some element
of the inertia at `2` phrased over `‚Ąö_[2]` (via `Z2bar`). Content: the
continuous `‚Ąö`-algebra isomorphism `adicCompletion ‚Ąö v‚āā ‚ČÉ ‚Ąö_[2]`
(`Rat.HeightOneSpectrum.adicCompletion.padicEquiv`) induces an
isomorphism of the algebraic closures matching the two inertia
subgroups (the spectral valuation is preserved); the two resulting
embeddings of `‚ĄöŠĶÉň°ŠĶć` differ by an automorphism `c ‚ąą őď ‚Ąö`, which
conjugates one image onto the other. The conjugacy slack is harmless
downstream: quotient characters are conjugation-invariant. -/
theorem localInertia_two_eq_map_padic
    {ŌÉ : őď (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)}
    (hŌÉ : ŌÉ ‚ąą localInertiaGroup
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) :
    ‚ąÉ ŌĄ ‚ąą AddSubgroup.inertia
      ((IsLocalRing.maximalIdeal Z2bar).toAddSubgroup : AddSubgroup Z2bar)
      (őď ‚Ąö_[2]), ‚ąÉ c : őď ‚Ąö,
      Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) ŌÉ =
      c * Field.absoluteGaloisGroup.map (algebraMap ‚Ąö ‚Ąö_[2]) ŌĄ * c‚ĀĽ¬Ļ := by
  classical
  haveI h2f : Fact (Nat.Prime 2) := ‚ü®Nat.prime_two‚ü©
  -- (1) the completion at the place of `2` is `‚Ąö_[2]`
  haveI hfp : Fact ((Rat.HeightOneSpectrum.primesEquiv
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) : ‚Ąē).Prime :=
    ‚ü®(Rat.HeightOneSpectrum.primesEquiv
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat).2‚ü©
  have hprime : ((Rat.HeightOneSpectrum.primesEquiv
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) : ‚Ąē) = 2 := by
    show Rat.HeightOneSpectrum.natGenerator _ = 2
