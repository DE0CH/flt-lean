  have hN0 : N вү  0 := (Nat.ordCompl_pos 3 hcвӮҖ0).ne'
  have hN3 : В¬ 3 вҲЈ N := Nat.not_dvd_ordCompl Nat.prime_three hcвӮҖ0
  -- (4) split `N = 2^A В· m` with `m` odd and coprime to `3`
  set A : в„• := Nat.factorization N 2
  set m : в„• := ordCompl[2] N
  have hNm : 2 ^ A * m = N := Nat.ordProj_mul_ordCompl_eq_self N 2
  have hm0 : 0 < m := Nat.ordCompl_pos 2 hN0
  have hm2 : В¬ 2 вҲЈ m := Nat.not_dvd_ordCompl Nat.prime_two hN0
  have hmodd : Odd m := Nat.odd_iff.mpr (by omega)
  have hm3 : В¬ 3 вҲЈ m := fun h => hN3 (h.trans (Nat.ordCompl_dvd N 2))
  -- (5) the kernel of `ПҒ` as an OPEN subgroup (the leaf's `U`)
