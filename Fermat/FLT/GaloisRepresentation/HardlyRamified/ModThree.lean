    ¬∑ rintro y (rfl | rfl)
      ¬∑ exact ‚ü®1, map_one _‚ü©
      ¬∑ exact hDneg
  have hSidx : ((Matrix.GeneralLinearGroup.det).comp u.range.subtype).ker.index = 2 := by
    rw [Subgroup.index_ker, ‚Üź SetLike.coe_sort_coe, hDrange, Nat.card_coe_set_eq,
      Set.ncard_pair hone_ne]
  -- (4) the projection of `u.range` onto `ŌÄ.range`
  have hmemŌÄ : ‚ąÄ x : u.range,
      (QuotientGroup.mk' (Subgroup.center (GL (Fin 2) (Dickson.K 3)))).comp
        u.range.subtype x ‚ąą ŌÄ.range := by
    rintro ‚ü®x, hx‚ü©
    obtain ‚ü®g, rfl‚ü© := hx
