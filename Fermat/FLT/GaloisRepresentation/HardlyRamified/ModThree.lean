polynomial `g` such that `x` is a unit at `Q` whose residue class generates
the residue field as a `‚Ą§`-algebra (so `‚Ą§[x]` is dense modulo `Q`), while
`g(x)` has `Q`-valuation exactly `1`.  Construction: lift a generator `ő∂`
of the cyclic unit group of the finite residue field, take `g` an integral
lift of the minimal polynomial of `ő∂` over the prime field; then `g(x) ‚ąą Q`,
and if `g(x) ‚ąą Q¬≤`, replacing `x` by `x + ŌÄ` for a uniformizer `ŌÄ` corrects
the valuation because `g'(x)` is a unit at `Q` by separability of finite
fields (Taylor expansion / `Polynomial.binomExpansion`). -/
theorem exists_residue_generator_uniformizer
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q ‚Č† ‚ä•) :
    ‚ąÉ (x : NumberField.RingOfIntegers K) (g : Polynomial ‚Ą§),
      x ‚ąČ Q ‚ąß
      (‚ąÄ y : NumberField.RingOfIntegers K,
        ‚ąÉ h : Polynomial ‚Ą§, y - Polynomial.aeval x h ‚ąą Q) ‚ąß
      Polynomial.aeval x g ‚ąą Q ‚ąß Polynomial.aeval x g ‚ąČ Q ^ 2 := by
  classical
  set R := NumberField.RingOfIntegers K with hRdef
  haveI hQmax : Q.IsMaximal := hQ.isMaximal hQbot
  letI : Field (R ‚ßł Q) := Ideal.Quotient.field Q
  haveI : Finite (R ‚ßł Q) := Ring.HasFiniteQuotients.finiteQuotient hQbot
  -- a generator of the cyclic unit group of the residue field
  obtain ‚ü®ő∂, hő∂‚ü© := IsCyclic.exists_generator (őĪ := (R ‚ßł Q)ň£)
  set ő∂v : R ‚ßł Q := ((ő∂ : (R ‚ßł Q)ň£) : R ‚ßł Q) with hő∂vdef
  -- density modulo `Q` holds for ANY lift of `ő∂v`
  have hdensAny : ‚ąÄ x' : R, Ideal.Quotient.mk Q x' = ő∂v ‚Üí
      ‚ąÄ y : R, ‚ąÉ h : Polynomial ‚Ą§, y - Polynomial.aeval x' h ‚ąą Q := by
    intro x' hx' y
    by_cases hy : y ‚ąą Q
    ¬∑ exact ‚ü®0, by simpa using hy‚ü©
    ¬∑ have hy0 : Ideal.Quotient.mk Q y ‚Č† 0 := by
        simpa [Ideal.Quotient.eq_zero_iff_mem] using hy
      obtain ‚ü®u, hu‚ü© := isUnit_iff_ne_zero.mpr hy0
      obtain ‚ü®k, hk‚ü© := (Submonoid.mem_powers_iff u ő∂).mp
        (mem_powers_iff_mem_zpowers.mpr (hő∂ u))
      refine ‚ü®Polynomial.X ^ k, ?_‚ü©
      rw [‚Üź Ideal.Quotient.eq_zero_iff_mem, map_sub, map_pow, map_pow,
        Polynomial.aeval_X, hx']
      rw [‚Üź hu, ‚Üź hk, hő∂vdef]
      push_cast
      exact sub_self _
  -- the characteristic and the prime field
  set p : ‚Ąē := ringChar (R ‚ßł Q) with hpdef
  haveI : CharP (R ‚ßł Q) p := ringChar.charP _
  have hp : p.Prime := CharP.char_is_prime (R ‚ßł Q) p
  haveI : NeZero p := ‚ü®hp.ne_zero‚ü©
  haveI : Fact p.Prime := ‚ü®hp‚ü©
  letI : Algebra (ZMod p) (R ‚ßł Q) := ZMod.algebra _ p
  haveI : Module.Finite (ZMod p) (R ‚ßł Q) := Module.Finite.of_finite
  have hő∂vint : IsIntegral (ZMod p) ő∂v := IsIntegral.of_finite (ZMod p) ő∂v
  have hsep : (minpoly (ZMod p) ő∂v).Separable :=
    PerfectField.separable_of_irreducible (minpoly.irreducible hő∂vint)
  -- an integral lift of the minimal polynomial of `ő∂v` over the prime field
  set őľ : Polynomial (ZMod p) := minpoly (ZMod p) ő∂v with hőľdef
  obtain ‚ü®g, hg‚ü© := Polynomial.map_surjective (Int.castRingHom (ZMod p))
    ZMod.intCast_surjective őľ
  -- evaluation of integer polynomials at any lift of `ő∂v`
  have hEval : ‚ąÄ (x' : R) (e : Polynomial ‚Ą§), Ideal.Quotient.mk Q x' = ő∂v ‚Üí
      Ideal.Quotient.mk Q (Polynomial.aeval x' e) =
        Polynomial.aeval ő∂v (e.map (Int.castRingHom (ZMod p))) := by
    intro x' e hx'
    have h1 : Ideal.Quotient.mk Q (Polynomial.aeval x' e) =
        Polynomial.aeval (Ideal.Quotient.mk Q x') e :=
      (Polynomial.aeval_algHom_apply (Ideal.Quotient.mk Q).toIntAlgHom x' e).symm
    rw [h1, hx', Polynomial.aeval_def, Polynomial.aeval_def, Polynomial.eval‚āā_map]
    congr 1
    exact Subsingleton.elim _ _
  -- `g(x') ‚ąą Q` for any lift `x'`
  have hgmem : ‚ąÄ x' : R, Ideal.Quotient.mk Q x' = ő∂v ‚Üí
      Polynomial.aeval x' g ‚ąą Q := by
    intro x' hx'
    rw [‚Üź Ideal.Quotient.eq_zero_iff_mem, hEval x' g hx', hg]
    exact minpoly.aeval _ _
  -- `g'(x') ‚ąČ Q` for any lift `x'` (separability of finite fields)
  have hgder : ‚ąÄ x' : R, Ideal.Quotient.mk Q x' = ő∂v ‚Üí
      Polynomial.aeval x' (Polynomial.derivative g) ‚ąČ Q := by
    intro x' hx' hmem
    rw [‚Üź Ideal.Quotient.eq_zero_iff_mem, hEval _ _ hx',
      ‚Üź Polynomial.derivative_map, hg] at hmem
    exact hsep.aeval_derivative_ne_zero (minpoly.aeval _ _) hmem
  -- the lift of `ő∂v`
  obtain ‚ü®x, hx‚ü© := Ideal.Quotient.mk_surjective ő∂v
  have hxQ : ‚ąÄ x' : R, Ideal.Quotient.mk Q x' = ő∂v ‚Üí x' ‚ąČ Q := by
    intro x' hx' hmem
    rw [‚Üź Ideal.Quotient.eq_zero_iff_mem, hx', hő∂vdef] at hmem
    exact Units.ne_zero ő∂ hmem
  by_cases hx2 : Polynomial.aeval x g ‚ąČ Q ^ 2
  ¬∑ exact ‚ü®x, g, hxQ x hx, hdensAny x hx, hgmem x hx, hx2‚ü©
  ¬∑ push Not at hx2
    -- correct with a uniformizer
    obtain ‚ü®ŌÄ, hŌÄ1, hŌÄ2‚ü© := Ideal.exists_mem_pow_notMem_pow_succ Q hQbot
      hQmax.ne_top 1
    rw [pow_one] at hŌÄ1
    have hx' : Ideal.Quotient.mk Q (x + ŌÄ) = ő∂v := by
      rw [map_add, hx, Ideal.Quotient.eq_zero_iff_mem.mpr hŌÄ1, add_zero]
    obtain ‚ü®c, hc‚ü© := Polynomial.binomExpansion (g.map (algebraMap ‚Ą§ R)) x ŌÄ
    have hev : ‚ąÄ z : R, (g.map (algebraMap ‚Ą§ R)).eval z = Polynomial.aeval z g := by
      intro z
      rw [Polynomial.aeval_def, Polynomial.eval_map]
    have hev' : (Polynomial.derivative (g.map (algebraMap ‚Ą§ R))).eval x =
        Polynomial.aeval x (Polynomial.derivative g) := by
      rw [Polynomial.derivative_map, Polynomial.aeval_def, Polynomial.eval_map]
    rw [hev, hev, hev'] at hc
    refine ‚ü®x + ŌÄ, g, hxQ _ hx', hdensAny _ hx', hgmem _ hx', ?_‚ü©
    intro habs
    -- `ŌÄ * g'(x) = g(x+ŌÄ) - g(x) - c¬∑ŌÄ¬≤ ‚ąą Q¬≤` forces `ŌÄ ‚ąą Q¬≤` or `g'(x) ‚ąą Q`
    have hmem2 : ŌÄ * Polynomial.aeval x (Polynomial.derivative g) ‚ąą Q ^ 2 := by
      have h1 : ŌÄ * Polynomial.aeval x (Polynomial.derivative g) =
          Polynomial.aeval (x + ŌÄ) g - Polynomial.aeval x g - c * ŌÄ ^ 2 := by
        rw [hc]; ring
      rw [h1]
      refine Submodule.sub_mem _ (Submodule.sub_mem _ habs hx2) ?_
      exact Ideal.mul_mem_left _ c (by
        rw [sq, sq]
        exact Ideal.mul_mem_mul hŌÄ1 hŌÄ1)
    rcases Ideal.IsPrime.mem_pow_mul Q hmem2 with h | h
    ¬∑ exact hŌÄ2 (by simpa using h)
    ¬∑ exact hgder x hx h

/-- **All-level `Q`-adic density of `‚Ą§[x]`** (Serre, *Corps Locaux* III ¬ß6,
Prop. 12 globalized to the number ring): if `‚Ą§[x]` is dense modulo `Q` and
contains an element `g(x)` of `Q`-valuation exactly `1`, then `‚Ą§[x]` is dense
modulo every power `Q ^ j`.  Induction on `j` through the exact-power
identity `Q ^ j = (g(x)^j) + Q ^ (j+1)`, which holds because `g(x)` has
valuation exactly one at `Q` (write `(g(x)) = Q * C` with `C` coprime to `Q`
via `Ideal.eq_prime_pow_mul_coprime`; then
`(g(x)^j) ‚äĒ Q^(j+1) = Q^j * (C^j ‚äĒ Q) = Q^j`). -/
theorem exists_poly_sub_mem_pow_of_generator
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q ‚Č† ‚ä•)
    {x : NumberField.RingOfIntegers K} {g : Polynomial ‚Ą§}
    (hdens : ‚ąÄ y : NumberField.RingOfIntegers K,
      ‚ąÉ h : Polynomial ‚Ą§, y - Polynomial.aeval x h ‚ąą Q)
    (hg1 : Polynomial.aeval x g ‚ąą Q) (hg2 : Polynomial.aeval x g ‚ąČ Q ^ 2) :
    ‚ąÄ (j : ‚Ąē) (y : NumberField.RingOfIntegers K),
      ‚ąÉ h : Polynomial ‚Ą§, y - Polynomial.aeval x h ‚ąą Q ^ j := by
  classical
  haveI hQmax : Q.IsMaximal := hQ.isMaximal hQbot
  -- the exact-power identity
  have htbot : Ideal.span {Polynomial.aeval x g} ‚Č† ‚ä• := by
    rw [Ne, Ideal.span_singleton_eq_bot]
    intro h0
    rw [h0] at hg2
    exact hg2 (zero_mem _)
  obtain ‚ü®C, hCsup, hCeq‚ü© := Ideal.eq_prime_pow_mul_coprime htbot Q
  have hcount : Multiset.count Q
      (UniqueFactorizationMonoid.normalizedFactors
        (Ideal.span {Polynomial.aeval x g})) = 1 := by
    refine Ideal.count_normalizedFactors_eq (p := Q) ?_ ?_
    ¬∑ rwa [pow_one, Ideal.span_singleton_le_iff_mem]
    ¬∑ rw [Ideal.span_singleton_le_iff_mem, one_add_one_eq_two]
      exact hg2
  rw [hcount, pow_one] at hCeq
  have hkey : ‚ąÄ j : ‚Ąē, Q ^ j =
      Ideal.span {Polynomial.aeval x g ^ j} ‚äĒ Q ^ (j + 1) := by
    intro j
    have h1 : Ideal.span {Polynomial.aeval x g ^ j} = Q ^ j * C ^ j := by
      rw [‚Üź Ideal.span_singleton_pow, hCeq, mul_pow]
    have h2 : Q ^ (j + 1) = Q ^ j * Q := pow_succ Q j
    rw [h1, h2, ‚Üź Ideal.mul_sup]
    have h3 : C ^ j ‚äĒ Q = ‚ä§ := by
      have h4 : IsCoprime Q (C ^ j) :=
        (Ideal.isCoprime_iff_sup_eq.mpr hCsup).pow_right
      rw [sup_comm]
      exact Ideal.isCoprime_iff_sup_eq.mp h4
    rw [h3, Ideal.mul_top]
  -- induction on the level
  intro j
  induction j with
  | zero => exact fun y => ‚ü®0, by simp‚ü©
  | succ j ih =>
    intro y
    obtain ‚ü®h‚āĀ, hh‚āĀ‚ü© := ih y
    rw [hkey j] at hh‚āĀ
    obtain ‚ü®a, ha, b, hb, hab‚ü© := Submodule.mem_sup.mp hh‚āĀ
    obtain ‚ü®r, hr‚ü© := Ideal.mem_span_singleton'.mp ha
    obtain ‚ü®h‚āā, hh‚āā‚ü© := hdens r
    refine ‚ü®h‚āĀ + g ^ j * h‚āā, ?_‚ü©
    have hrw : y - Polynomial.aeval x (h‚āĀ + g ^ j * h‚āā) =
        Polynomial.aeval x g ^ j * (r - Polynomial.aeval x h‚āā) + b := by
      rw [map_add, map_mul, map_pow]
      have hab' : y - Polynomial.aeval x h‚āĀ = r * Polynomial.aeval x g ^ j + b := by
        rw [hr]; exact hab.symm
      linear_combination hab'
    rw [hrw]
    refine Submodule.add_mem _ ?_ hb
    have h5 := Ideal.mul_mem_mul (Ideal.pow_mem_pow hg1 j) hh‚āā
    rwa [‚Üź pow_succ] at h5

/-- **Rigidity of a primitive integral generator**: a `‚Ąö`-automorphism of the
Galois number field `K` fixing a primitive element (stated for the image of an
algebraic integer `őł` generating `K` as a `‚Ąö`-algebra) is the identity ‚ÄĒ
the equalizer of `ŌÉ` and `id` is a `‚Ąö`-subalgebra containing the generator,
hence everything. -/
theorem algEquiv_eq_one_of_algebraMap_fixed
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    {őł : NumberField.RingOfIntegers K}
    (hőł : Algebra.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} = ‚ä§)
    {ŌÉ : K ‚ČÉ‚āź[‚Ąö] K}
    (hfix : ŌÉ (algebraMap (NumberField.RingOfIntegers K) K őł) =
      algebraMap (NumberField.RingOfIntegers K) K őł) : ŌÉ = 1 := by
  have h2 : Algebra.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} ‚Č§
      AlgHom.equalizer ŌÉ.toAlgHom (AlgHom.id ‚Ąö K) :=
    Algebra.adjoin_le (Set.singleton_subset_iff.mpr hfix)
  refine AlgEquiv.ext fun y => ?_
  have hy : y ‚ąą Algebra.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} := by
    rw [hőł]; exact Algebra.mem_top
  exact h2 hy

/-- **Congruence propagation from a locally dense generator** (the key formal
step of Serre's Lemme IV ¬ß1 1, globalized): if `‚Ą§[őł]` is dense modulo `Q ^ j`,
`ŌÉ` stabilizes `Q`, and `ŌÉőł ‚Č° őł (mod Q ^ j)`, then `ŌÉ` lies in the inertia
subgroup of `Q ^ j` ‚ÄĒ i.e. `ŌÉy ‚Č° y (mod Q ^ j)` for EVERY algebraic integer
`y`.  Indeed `y ‚Č° h(őł)`, `ŌÉ(h(őł)) ‚ąí h(őł) = h(ŌÉőł) ‚ąí h(őł)` is divisible by
`ŌÉőł ‚ąí őł` (`Polynomial.sub_dvd_eval_sub`), and `ŌÉ` maps `Q ^ j` to itself. -/
theorem mem_inertia_pow_of_smul_sub_mem_of_dense
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (j : ‚Ąē)
    {őł : NumberField.RingOfIntegers K}
    (hdens : ‚ąÄ y : NumberField.RingOfIntegers K,
      ‚ąÉ h : Polynomial ‚Ą§, y - Polynomial.aeval őł h ‚ąą Q ^ j)
    {ŌÉ : K ‚ČÉ‚āź[‚Ąö] K} (hŌÉQ : ŌÉ ‚ÄĘ Q = Q) (hőł : ŌÉ ‚ÄĘ őł - őł ‚ąą Q ^ j) :
    ŌÉ ‚ąą (Q ^ j).inertia (K ‚ČÉ‚āź[‚Ąö] K) := by
  refine AddSubgroup.mem_inertia.mpr fun y => ?_
  rw [Submodule.mem_toAddSubgroup]
  obtain ‚ü®h, hh‚ü© := hdens y
  have hkey : ŌÉ ‚ÄĘ y - y =
      (ŌÉ ‚ÄĘ (y - Polynomial.aeval őł h) - (y - Polynomial.aeval őł h)) +
        (ŌÉ ‚ÄĘ Polynomial.aeval őł h - Polynomial.aeval őł h) := by
    rw [smul_sub]; ring
  rw [hkey]
  refine Submodule.add_mem _ (Submodule.sub_mem _ ?_ hh) ?_
  ¬∑ -- `ŌÉ` preserves `Q ^ j`
    have h1 : ŌÉ ‚ÄĘ (y - Polynomial.aeval őł h) ‚ąą ŌÉ ‚ÄĘ Q ^ j :=
      Ideal.smul_mem_pointwise_smul _ _ _ hh
    rwa [smul_pow' ŌÉ Q j, hŌÉQ] at h1
  ¬∑ -- the divisibility step
    have hcast : ŌÉ ‚ÄĘ Polynomial.aeval őł h = Polynomial.aeval (ŌÉ ‚ÄĘ őł) h :=
      (Polynomial.aeval_algHom_apply
        (MulSemiringAction.toRingHom (K ‚ČÉ‚āź[‚Ąö] K)
          (NumberField.RingOfIntegers K) ŌÉ).toIntAlgHom őł h).symm
    rw [hcast]
    have hdvd : (ŌÉ ‚ÄĘ őł - őł) ‚ą£
        (Polynomial.aeval (ŌÉ ‚ÄĘ őł) h - Polynomial.aeval őł h) := by
      have h2 := Polynomial.sub_dvd_eval_sub (ŌÉ ‚ÄĘ őł) őł
        (h.map (algebraMap ‚Ą§ (NumberField.RingOfIntegers K)))
      rwa [Polynomial.eval_map, Polynomial.eval_map,
        ‚Üź Polynomial.aeval_def, ‚Üź Polynomial.aeval_def] at h2
    obtain ‚ü®z, hz‚ü© := hdvd
    rw [hz]
    exact Ideal.mul_mem_right _ _ hőł

/-- **The master generator selection at `Q`** (the globalized monogenicity
input to Serre IV ¬ß1: a single algebraic integer that is simultaneously a
primitive element of `K/‚Ąö`, `Q`-adically dense to level `m`, and separates
`Q` from its conjugates): there is `őł ‚ąą ūĚďě K` with (i) `őł` generating `K` as
a `‚Ąö`-algebra, (ii) `‚Ą§[őł]` dense modulo `Q ^ m`, and (iii) `ŌÉőł ‚ČĘ őł (mod Q)`
for every `ŌÉ ‚ąą Gal(K/‚Ąö)` moving `Q`.  Construction: start from the
Serre-style residue generator (dense at all levels by
`exists_poly_sub_mem_pow_of_generator`), impose `őł ‚Č° x (mod Q^m)` and
`őł ‚Č° 0 (mod P)` at every conjugate `P ‚Č† Q` by CRT
(`IsDedekindDomain.exists_forall_sub_mem_ideal`), then perturb by integer
multiples `c¬∑N¬∑ő≥` of a primitive algebraic integer `ő≥` ‚ÄĒ with
`N = absNorm (Q^m ¬∑ ‚ąŹ P)` killing all congruences ‚ÄĒ and pick `c` by
pigeonhole on the finitely many intermediate fields of the Galois
extension `K/‚Ąö` so that the perturbed element is primitive. -/
theorem exists_dense_primitive_generator
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    [IsGalois ‚Ąö K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q ‚Č† ‚ä•) (m : ‚Ąē) (hm : m ‚Č† 0) :
    ‚ąÉ őł : NumberField.RingOfIntegers K,
      Algebra.adjoin ‚Ąö
        {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} = ‚ä§ ‚ąß
      (‚ąÄ y : NumberField.RingOfIntegers K,
        ‚ąÉ h : Polynomial ‚Ą§, y - Polynomial.aeval őł h ‚ąą Q ^ m) ‚ąß
      (‚ąÄ ŌÉ : K ‚ČÉ‚āź[‚Ąö] K, ŌÉ ‚ÄĘ Q ‚Č† Q ‚Üí ŌÉ ‚ÄĘ őł - őł ‚ąČ Q) := by
  classical
  haveI := hQ
  obtain ‚ü®x, g, hxQ, hdens1, hg1, hg2‚ü© :=
    exists_residue_generator_uniformizer K Q hQ hQbot
  have hdens := exists_poly_sub_mem_pow_of_generator K Q hQ hQbot hdens1 hg1 hg2
  -- the conjugate primes distinct from `Q`
  set S : Finset (Ideal (NumberField.RingOfIntegers K)) :=
    (Finset.univ.image (fun ŌÉ : K ‚ČÉ‚āź[‚Ąö] K => ŌÉ ‚ÄĘ Q)).erase Q with hSdef
  have hSbot : ‚ąÄ P ‚ąą S, P ‚Č† ‚ä• := by
    intro P hP
    obtain ‚ü®ŌÉ, -, rfl‚ü© := Finset.mem_image.mp (Finset.mem_of_mem_erase hP)
    intro h0
    apply hQbot
    have h1 := congrArg (fun I => ŌÉ‚ĀĽ¬Ļ ‚ÄĘ I) h0
    simpa using h1
  have hSprime : ‚ąÄ P ‚ąą S, P.IsPrime := by
    intro P hP
    obtain ‚ü®ŌÉ, -, rfl‚ü© := Finset.mem_image.mp (Finset.mem_of_mem_erase hP)
    infer_instance
  -- CRT: `őł‚āā ‚Č° x (mod Q^m)`, `őł‚āā ‚Č° 0 (mod P)` for all conjugates `P ‚Č† Q`
  have hprimeAll : ‚ąÄ P ‚ąą insert Q S, Prime P := by
    intro P hP
    rcases Finset.mem_insert.mp hP with rfl | hPS
    ¬∑ exact (Ideal.prime_iff_isPrime hQbot).mpr hQ
    ¬∑ exact (Ideal.prime_iff_isPrime (hSbot P hPS)).mpr (hSprime P hPS)
  obtain ‚ü®őł‚āā, hőł‚āā‚ü© := IsDedekindDomain.exists_forall_sub_mem_ideal
    (s := insert Q S) id (fun P => if P = Q then m else 1) hprimeAll
    (fun _ _ _ _ hne => hne)
    (fun P => if (P : Ideal (NumberField.RingOfIntegers K)) = Q then x else 0)
  have hőł‚āāQ : őł‚āā - x ‚ąą Q ^ m := by
    have h1 := hőł‚āā Q (Finset.mem_insert_self _ _)
    simpa using h1
  have hőł‚āāS : ‚ąÄ P ‚ąą S, őł‚āā ‚ąą P := by
    intro P hPS
    have hne := (Finset.mem_erase.mp hPS).1
    have h1 := hőł‚āā P (Finset.mem_insert_of_mem hPS)
    simpa [hne, pow_one] using h1
  -- the perturbation ideal, made opaque with exactly the needed interface
  obtain ‚ü®J, hJQ, hJS, hJbot‚ü© :
      ‚ąÉ J : Ideal (NumberField.RingOfIntegers K),
        J ‚Č§ Q ^ m ‚ąß (‚ąÄ P ‚ąą S, J ‚Č§ P) ‚ąß J ‚Č† ‚ä• := by
    refine ‚ü®Q ^ m * ‚ąŹ P ‚ąą S, P, Ideal.mul_le_right, ?_, ?_‚ü©
    ¬∑ intro P hPS
      refine le_trans Ideal.mul_le_left ?_
      rw [‚Üź Finset.prod_erase_mul _ _ hPS]
      exact Ideal.mul_le_left
    ¬∑ rw [‚Üź Ideal.zero_eq_bot]
      refine mul_ne_zero ?_ ?_
      ¬∑ exact pow_ne_zero m (by rw [Ideal.zero_eq_bot]; exact hQbot)
      ¬∑ rw [Finset.prod_ne_zero_iff]
        intro P hPS
        rw [Ideal.zero_eq_bot]
        exact hSbot P hPS
  haveI : Finite (NumberField.RingOfIntegers K ‚ßł J) :=
    Ring.HasFiniteQuotients.finiteQuotient hJbot
  have hN0 : Ideal.absNorm J ‚Č† 0 := (Ideal.absNorm_ne_zero_iff J).mpr ‚ÄĻ_‚Äļ
  have hNJ : ((Ideal.absNorm J : ‚Ąē) : NumberField.RingOfIntegers K) ‚ąą J :=
    Ideal.absNorm_mem J
  -- a primitive algebraic integer
  obtain ‚ü®őĪ, hőĪ‚ü© := Field.exists_primitive_element ‚Ąö K
  obtain ‚ü®d, hd0, hdint‚ü© := ((IsFractionRing.isAlgebraic_iff ‚Ą§ ‚Ąö K).mpr
    (Algebra.IsAlgebraic.isAlgebraic őĪ)).exists_integral_multiple
  obtain ‚ü®ő≥, hő≥K‚ü© : ‚ąÉ ő≥ : NumberField.RingOfIntegers K,
      algebraMap (NumberField.RingOfIntegers K) K ő≥ = d ‚ÄĘ őĪ :=
    ‚ü®‚ü®d ‚ÄĘ őĪ, hdint‚ü©, rfl‚ü©
  have hő≥top : IntermediateField.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K ő≥ : K)} = ‚ä§ := by
    rw [hő≥K, eq_top_iff, ‚Üź hőĪ]
    rw [IntermediateField.adjoin_le_iff, Set.singleton_subset_iff]
    have hd : ((d : ‚Ąö)) ‚Č† 0 := Int.cast_ne_zero.mpr hd0
    have hmem : (d ‚ÄĘ őĪ : K) ‚ąą IntermediateField.adjoin ‚Ąö {(d ‚ÄĘ őĪ : K)} :=
      IntermediateField.mem_adjoin_simple_self ‚Ąö _
    have h2 := (IntermediateField.adjoin ‚Ąö {(d ‚ÄĘ őĪ : K)}).smul_mem hmem
      (x := (d : ‚Ąö)‚ĀĽ¬Ļ)
    rwa [‚Üź Int.cast_smul_eq_zsmul ‚Ąö d őĪ, inv_smul_smul‚āÄ hd] at h2
  -- pigeonhole over the finitely many intermediate fields
  haveI : Finite (IntermediateField ‚Ąö K) :=
    Finite.of_equiv _ (IsGalois.intermediateFieldEquivSubgroup
      (F := ‚Ąö) (E := K)).symm.toEquiv
  obtain ‚ü®w, hwK, hwJ‚ü© : ‚ąÉ w : NumberField.RingOfIntegers K,
      algebraMap (NumberField.RingOfIntegers K) K w =
        ((Ideal.absNorm J : ‚Ąē) : K) *
          algebraMap (NumberField.RingOfIntegers K) K ő≥ ‚ąß
      w ‚ąą J :=
    ‚ü®((Ideal.absNorm J : ‚Ąē) : NumberField.RingOfIntegers K) * ő≥,
      by rw [map_mul, map_natCast], Ideal.mul_mem_right _ _ hNJ‚ü©
  obtain ‚ü®c‚āĀ, c‚āā, hcc, hFeq‚ü© := Finite.exists_ne_map_eq_of_infinite
    (fun c : ‚Ąē => IntermediateField.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K (őł‚āā + (c : ‚Ą§) ‚ÄĘ w) : K)})
  set őł : NumberField.RingOfIntegers K := őł‚āā + (c‚āĀ : ‚Ą§) ‚ÄĘ w with hőłdef
  set E : IntermediateField ‚Ąö K := IntermediateField.adjoin ‚Ąö
    {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} with hEdef
  -- the difference of the two lifts recovers `w`, hence `ő≥`, hence all of `K`
  have hwE : algebraMap (NumberField.RingOfIntegers K) K w ‚ąą E := by
    have h1 : algebraMap (NumberField.RingOfIntegers K) K
        (őł‚āā + (c‚āĀ : ‚Ą§) ‚ÄĘ w) ‚ąą E :=
      IntermediateField.mem_adjoin_simple_self ‚Ąö _
    have h2 : algebraMap (NumberField.RingOfIntegers K) K
        (őł‚āā + (c‚āā : ‚Ą§) ‚ÄĘ w) ‚ąą E := by
      rw [hFeq]
      exact IntermediateField.mem_adjoin_simple_self ‚Ąö _
    have h3 := E.sub_mem h1 h2
