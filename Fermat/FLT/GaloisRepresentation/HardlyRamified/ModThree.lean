      вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        О· (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 вҶ’
        b (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
