      (Filter.Eventually.of_forall fun x => ?_)
    have h12 : ((1 : в„Ӯ) / 2) = ((1 / 2 : в„қ) : в„Ӯ) := by push_cast; ring
    simp only [RCLike.re_to_complex, Complex.re_ofReal_mul, Complex.exp_re]
    congr 2
    В· simp [h12, Complex.mul_re, Complex.sub_re, Complex.ofReal_re,
        Complex.ofReal_im]
    В· simp [h12, Complex.mul_im, Complex.sub_im, Complex.ofReal_re,
        Complex.ofReal_im, hc]
  have hIsymm : (вҲ« x : в„қ, odlyzkoTestFn x / Real.cosh (x / 2) *
        (Real.exp (-(1 / 2) * x) * Real.cos (c * x))) =
      вҲ« x : в„қ, odlyzkoTestFn x / Real.cosh (x / 2) *
