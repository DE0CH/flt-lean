/-- **No common eigenvector under absolute irreducibility** (PROVEN
2026-07-23 вҖ” the transport bridge for the induced-structure glue of
the dihedral ray-class decomposition): if every matrix `u g` of the
transported representation has the SAME eigenvector `v вү  0` over
`Dickson.K 3`, then the vector of `(AlgebraicClosure k) вҠ— V` with
`e`-preimage coordinates `v` in the basis `b` spans a stable line,
contradicting absolute irreducibility (`isIrreducible_iff_forall`
plus `finrank_span_singleton = 1 вү  2`). -/
theorem no_common_eigenvector_of_absolutelyIrreducible {k : Type u}
    [Finite k] [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ПҒ : GaloisRep в„ҡ k V}
    (habs : Slop.OddRep.IsAbsolutelyIrreducible
      (MonoidHomClass.toMonoidHom ПҒ : Representation k (О“ в„ҡ) V))
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) вҠ—[k] V))
    (e : AlgebraicClosure k вүғ+* Dickson.K 3)
    (u : О“ в„ҡ вҶ’* GL (Fin 2) (Dickson.K 3))
    (hu : вҲҖ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ)) g)).map e)
    (v : Fin 2 вҶ’ Dickson.K 3) (hv : v вү  0)
    (hall : вҲҖ g : О“ в„ҡ, вҲғ c : Dickson.K 3,
      Matrix.mulVec ((u g : GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v = c вҖў v) :
    False := by
  classical
  set L := AlgebraicClosure k with hLdef
  set ПғПҒ : Representation L (О“ в„ҡ) (L вҠ—[k] V) :=
    Slop.OddRep.baseChange L (MonoidHomClass.toMonoidHom ПҒ) with hПғПҒdef
  have hirr : ПғПҒ.IsIrreducible := habs
  haveI : Module.Finite L (L вҠ—[k] V) := Module.Finite.base_change k L V
  have hfr2 : Module.finrank L (L вҠ—[k] V) = 2 := by
    rw [Module.finrank_baseChange]
    exact Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
  obtain вҹЁ-, hsubвҹ© := (Slop.OddRep.isIrreducible_iff_forall ПғПҒ).mp hirr
  -- the vector of `L вҠ— V` with `e`-preimage coordinates `v`
  set v'' : Fin 2 вҶ’ L := fun i => e.symm (v i) with hv''def
  set v' : L вҠ—[k] V := b.equivFun.symm v'' with hv'def
  have hreprv' : вҮ‘(b.repr v') = v'' := by
    have h1 : b.equivFun v' = v'' := by
      rw [hv'def, LinearEquiv.apply_symm_apply]
    exact h1
  have hv'0 : v' вү  0 := by
    intro h0
    apply hv
    have h1 : v'' = 0 := by
      rw [вҶҗ hreprv', h0, map_zero]
      rfl
    funext i
    have h2 : e.symm (v i) = 0 := congrFun h1 i
    have h3 := congrArg e h2
    rwa [RingEquiv.apply_symm_apply, map_zero] at h3
  -- every `ПғПҒ g` scales `v'`
  have hstab : вҲҖ g : О“ в„ҡ, вҲғ c' : L, ПғПҒ g v' = c' вҖў v' := by
    intro g
    obtain вҹЁc, hcвҹ© := hall g
    refine вҹЁe.symm c, ?_вҹ©
    have hcoord : вҲҖ i,
        Matrix.mulVec (LinearMap.toMatrix b b (ПғПҒ g)) (вҮ‘(b.repr v')) i =
        e.symm c * v'' i := by
      intro i
      have hterm : вҲҖ j, LinearMap.toMatrix b b (ПғПҒ g) i j * (b.repr v') j =
          e.symm (((u g : GL (Fin 2) (Dickson.K 3)) :
            Matrix (Fin 2) (Fin 2) (Dickson.K 3)) i j * v j) := by
        intro j
        rw [map_mul]
        congr 1
        В· rw [hu g, Matrix.map_apply]
          exact (RingEquiv.symm_apply_apply e _).symm
        В· exact congrFun hreprv' j
      calc Matrix.mulVec (LinearMap.toMatrix b b (ПғПҒ g)) (вҮ‘(b.repr v')) i
          = вҲ‘ j, LinearMap.toMatrix b b (ПғПҒ g) i j * (b.repr v') j :=
            Matrix.mulVec_apply_eq_sum _ _ _
        _ = вҲ‘ j, e.symm (((u g : GL (Fin 2) (Dickson.K 3)) :
              Matrix (Fin 2) (Fin 2) (Dickson.K 3)) i j * v j) :=
            Finset.sum_congr rfl fun j _ => hterm j
        _ = e.symm (вҲ‘ j, ((u g : GL (Fin 2) (Dickson.K 3)) :
              Matrix (Fin 2) (Fin 2) (Dickson.K 3)) i j * v j) :=
            (map_sum e.symm _ _).symm
        _ = e.symm ((Matrix.mulVec ((u g : GL (Fin 2) (Dickson.K 3)) :
              Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v) i) := by
            rw [Matrix.mulVec_apply_eq_sum]
        _ = e.symm ((c вҖў v) i) := by rw [hc]
        _ = e.symm (c * v i) := rfl
        _ = e.symm c * e.symm (v i) := map_mul e.symm _ _
        _ = e.symm c * v'' i := rfl
    apply b.repr.injective
    apply DFunLike.coe_injective
    rw [вҶҗ LinearMap.toMatrix_mulVec_repr b b (ПғПҒ g) v', map_smul]
    funext i
    rw [hcoord i, Finsupp.smul_apply,
      show (b.repr v') i = v'' i from congrFun hreprv' i, smul_eq_mul]
  -- the stable line contradicts irreducibility
  have hWinv : вҲҖ g : О“ в„ҡ, вҲҖ x вҲҲ Submodule.span L {v'},
      ПғПҒ g x вҲҲ Submodule.span L {v'} := by
    intro g x hx
    rw [Submodule.mem_span_singleton] at hx
    obtain вҹЁa, rflвҹ© := hx
    obtain вҹЁc', hc'вҹ© := hstab g
    rw [map_smul, hc', Submodule.mem_span_singleton]
    exact вҹЁa * c', by rw [smul_smul]вҹ©
  rcases hsub (Submodule.span L {v'}) hWinv with hW | hW
  В· apply hv'0
    have h1 : v' вҲҲ Submodule.span L {v'} :=
      Submodule.mem_span_singleton_self v'
    rw [hW] at h1
    exact (Submodule.mem_bot L).mp h1
  В· have h1 : Module.finrank L (Submodule.span L {v'}) = 1 :=
      finrank_span_singleton hv'0
    rw [hW, finrank_top, hfr2] at h1
    omega

