    simp [Matrix.sub_apply]
  have s01 : (N - ПҮвӮҖ g' вҖў 1) 0 1 = N 0 1 := by
    simp [Matrix.sub_apply]
  have s10 : (N - ПҮвӮҖ g' вҖў 1) 1 0 = N 1 0 := by
    simp [Matrix.sub_apply]
  have s11 : (N - ПҮвӮҖ g' вҖў 1) 1 1 = N 1 1 - ПҮвӮҖ g' := by
    simp [Matrix.sub_apply]
  rw [Matrix.det_fin_two, s00, s01, s10, s11] at hsing
  have hd2 : N 0 0 * N 1 1 - N 0 1 * N 1 0 = 1 := by
    rw [вҶҗ Matrix.det_fin_two]
    exact hNdet
  rw [Matrix.trace_fin_two] at htrN
  have hq : (ПҮвӮҖ g' - 1) ^ 2 = 0 := by
    linear_combination hsing - hd2 + ПҮвӮҖ g' * htrN
