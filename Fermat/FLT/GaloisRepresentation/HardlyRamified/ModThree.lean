    (hОё'x : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ” g x = x)
    (ПғвӮҖ : О“ в„ҡ) (hПғвӮҖ : Оё' ПғвӮҖ вү  1)
    (ПҮвӮҖ : О“ в„ҡ вҶ’ Dickson.K 3)
    (hПҮвӮҖ : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’
      Matrix.mulVec ((u g : GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v = ПҮвӮҖ g вҖў v)
    (hПҮne0 : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ПҮвӮҖ g вү  0)
    (hПҮmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ПҮвӮҖ (g * h) = ПҮвӮҖ g * ПҮвӮҖ h)
    (hПҮker : вҲҖ g : О“ в„ҡ, ПҒ g = 1 вҶ’ ПҮвӮҖ g = 1)
    (hПҮunr : вҲҖ (q : в„•) (hq : q.Prime), q вү  2 вҶ’ q вү  3 вҶ’
      вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        ПҮвӮҖ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1)
    (hindep : В¬ вҲғ c : Dickson.K 3,
      Matrix.mulVec ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v = c вҖў v)
    (h2unr : вҲҖ Пғ вҲҲ localInertiaGroup
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      Оё' (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 вҲ§
      ПҮвӮҖ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1)
    (hne : В¬ вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ПҮвӮҖ g = ПҮвӮҖ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ)) :
    False := by
  classical
