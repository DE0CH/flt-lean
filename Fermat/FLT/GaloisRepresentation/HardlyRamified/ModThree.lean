    0 ‚Č§ poitouPrimeTerm K := by
  refine mul_nonneg (by norm_num) (tsum_nonneg fun P => tsum_nonneg fun m => ?_)
  refine mul_nonneg (div_nonneg (Real.log_natCast_nonneg _) (by positivity)) ?_
  rw [odlyzkoTestFn]
