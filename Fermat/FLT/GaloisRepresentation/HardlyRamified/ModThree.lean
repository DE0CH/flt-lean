  have hqd' : ¬¨ (q : ‚Ą§) ‚ą£ d' := by
    rintro ‚ü®e, he‚ü©
    exact hqZ.not_unit (hdsq (q : ‚Ą§) ‚ü®e, by rw [hdd', he]; ring‚ü©)
  -- `x` is integral (its square is)
  have hxint : IsIntegral ‚Ą§ x := by
    refine IsIntegral.of_pow (n := 2) (by norm_num) ?_
    rw [hx2, (eq_intCast (algebraMap ‚Ą§ K) d).symm]
    exact isIntegral_algebraMap
  rw [show Q.inertia (K ‚ČÉ‚āź[‚Ąö] K) = Q.toAddSubgroup.inertia (K ‚ČÉ‚āź[‚Ąö] K)
    from rfl, AddSubgroup.mem_inertia]
  intro y
  rw [Submodule.mem_toAddSubgroup]
  -- the anti-fixed difference in `K`
  set yK : K := algebraMap (NumberField.RingOfIntegers K) K y
  set t : K := ŌÉ yK - yK with htdef
  have hŌÉŌÉ : ‚ąÄ z : K, ŌÉ (ŌÉ z) = z := by
    intro z
    have h := congrArg (fun g : K ‚ČÉ‚āź[‚Ąö] K => g z) hŌÉ2
    simpa [AlgEquiv.mul_apply] using h
  have htŌÉ : ŌÉ t = -t := by
    rw [htdef, map_sub, hŌÉŌÉ]
    ring
  have hyint : IsIntegral ‚Ą§ yK := y.2
  have htint : IsIntegral ‚Ą§ t :=
    (hyint.map (ŌÉ.toAlgHom.restrictScalars ‚Ą§)).sub hyint
  -- `t¬≤` is a rational integer
  obtain ‚ü®s, hs‚ü© : ‚ąÉ s : ‚Ą§, (s : K) = t ^ 2 := by
    have hfixsq : ‚ąÄ g : K ‚ČÉ‚āź[‚Ąö] K, g ‚ÄĘ (t ^ 2) = t ^ 2 := by
      intro g
      rcases huniv g with rfl | hgŌÉ
      ¬∑ rfl
      ¬∑ rw [hgŌÉ]
        show ŌÉ (t ^ 2) = t ^ 2
        rw [map_pow, htŌÉ]
        ring
    obtain ‚ü®s‚āÄ, hs‚āÄ‚ü© := Algebra.IsInvariant.isInvariant (A := ‚Ąö)
      (G := K ‚ČÉ‚āź[‚Ąö] K) (t ^ 2) hfixsq
    have hs‚āÄint : IsIntegral ‚Ą§ s‚āÄ := by
      rw [‚Üź isIntegral_algebraMap_iff (algebraMap ‚Ąö K).injective, hs‚āÄ]
      exact htint.pow 2
    obtain ‚ü®s, hsz‚ü© := IsIntegrallyClosed.isIntegral_iff.mp hs‚āÄint
    refine ‚ü®s, ?_‚ü©
    rw [show ((s : ‚Ą§) : K) = algebraMap ‚Ąö K ((s : ‚Ą§) : ‚Ąö) from
      (map_intCast (algebraMap ‚Ąö K) s).symm,
      show ((s : ‚Ą§) : ‚Ąö) = algebraMap ‚Ą§ ‚Ąö s from rfl, hsz, hs‚āÄ]
  -- `t¬∑x` is a rational integer
  obtain ‚ü®m, hm‚ü© : ‚ąÉ m : ‚Ą§, (m : K) = t * x := by
    have hfixm : ‚ąÄ g : K ‚ČÉ‚āź[‚Ąö] K, g ‚ÄĘ (t * x) = t * x := by
      intro g
      rcases huniv g with rfl | hgŌÉ
      ¬∑ rfl
      ¬∑ rw [hgŌÉ]
        show ŌÉ (t * x) = t * x
        rw [map_mul, htŌÉ, hxŌÉ]
        ring
    obtain ‚ü®m‚āÄ, hm‚āÄ‚ü© := Algebra.IsInvariant.isInvariant (A := ‚Ąö)
      (G := K ‚ČÉ‚āź[‚Ąö] K) (t * x) hfixm
    have hm‚āÄint : IsIntegral ‚Ą§ m‚āÄ := by
      rw [‚Üź isIntegral_algebraMap_iff (algebraMap ‚Ąö K).injective, hm‚āÄ]
      exact htint.mul hxint
    obtain ‚ü®m, hmz‚ü© := IsIntegrallyClosed.isIntegral_iff.mp hm‚āÄint
    refine ‚ü®m, ?_‚ü©
    rw [show ((m : ‚Ą§) : K) = algebraMap ‚Ąö K ((m : ‚Ą§) : ‚Ąö) from
      (map_intCast (algebraMap ‚Ąö K) m).symm,
      show ((m : ‚Ą§) : ‚Ąö) = algebraMap ‚Ą§ ‚Ąö m from rfl, hmz, hm‚āÄ]
  -- the norm relation `m¬≤ = d¬∑s`, and `q ‚ą£ s`
  have hrel : m ^ 2 = d * s := by
    have h1 : ((m ^ 2 : ‚Ą§) : K) = ((d * s : ‚Ą§) : K) := by
      push_cast
      rw [hm, hs, mul_pow, hx2]
      ring
    exact_mod_cast h1
  obtain ‚ü®s', hs'‚ü© : (q : ‚Ą§) ‚ą£ s := by
    have hqm : (q : ‚Ą§) ‚ą£ m := hqZ.dvd_of_dvd_pow (n := 2)
      ‚ü®d' * s, by rw [hrel, hdd']; ring‚ü©
    obtain ‚ü®m', hm'‚ü© := hqm
    have hq0 : ((q : ‚Ąē) : ‚Ą§) ‚Č† 0 := by exact_mod_cast hq.ne_zero
    have h3 : (q : ‚Ą§) * m' ^ 2 = d' * s := by
      apply mul_left_cancel‚āÄ hq0
      have h4 := hrel
      rw [hm', hdd'] at h4
      linear_combination h4
    rcases hqZ.dvd_mul.mp ‚ü®m' ^ 2, h3.symm‚ü© with h5 | h5
    ¬∑ exact absurd h5 hqd'
    ¬∑ exact h5
  -- conclude: `t¬≤ = q¬∑s'` lands in `Q`, hence so does `t`
  have hT2 : (ŌÉ ‚ÄĘ y - y) * (ŌÉ ‚ÄĘ y - y) =
      ((q : ‚Ąē) : NumberField.RingOfIntegers K) *
        ((s' : ‚Ą§) : NumberField.RingOfIntegers K) := by
    have hgoal : t * t = ((q : ‚Ąē) : K) * ((s' : ‚Ą§) : K) := by
      rw [‚Üź pow_two, ‚Üź hs, hs']
      push_cast
      ring
    apply NumberField.RingOfIntegers.ext
    push_cast
    exact hgoal
