      (v' := fun x : в„қ => Complex.exp (((t * x : в„қ) : в„Ӯ) * Complex.I)) ?_ ?_ ?_ ?_ ?_ ?_
    В· exact (Complex.continuous_ofReal.comp
        ((continuous_const.add (continuous_id.div_const _)).mul hqcont)).continuousOn
    В· exact ((Complex.continuous_exp.comp (by fun_prop)).div_const _).continuousOn
    В· exact fun x _ => (hrвӮҒder x).ofReal_comp
    В· exact fun x _ => hvder x
    В· exact (Complex.continuous_ofReal.comp hrdвӮҒcont).intervalIntegrable _ _
    В· exact (Complex.continuous_exp.comp (by fun_prop)).intervalIntegrable _ _
  have hibpвӮӮ : (вҲ« x in (0:в„қ)..6, (((1 - x / 6) * q x : в„қ) : в„Ӯ) *
        Complex.exp (((t * x : в„қ) : в„Ӯ) * Complex.I)) =
      (((1 - (6:в„қ) / 6) * q 6 : в„қ) : в„Ӯ) *
        (Complex.exp (((t * (6:в„қ) : в„қ) : в„Ӯ) * Complex.I) / ((t : в„Ӯ) * Complex.I)) -
      (((1 - (0:в„қ) / 6) * q 0 : в„қ) : в„Ӯ) *
        (Complex.exp (((t * (0:в„қ) : в„қ) : в„Ӯ) * Complex.I) / ((t : в„Ӯ) * Complex.I)) -
      вҲ« x in (0:в„қ)..6, ((rdвӮӮ x : в„қ) : в„Ӯ) *
        (Complex.exp (((t * x : в„қ) : в„Ӯ) * Complex.I) / ((t : в„Ӯ) * Complex.I)) := by
    refine intervalIntegral.integral_mul_deriv_eq_deriv_mul_of_hasDerivAt
      (u := fun x : в„қ => (((1 - x / 6) * q x : в„қ) : в„Ӯ))
      (v := fun x : в„қ => Complex.exp (((t * x : в„қ) : в„Ӯ) * Complex.I) / ((t : в„Ӯ) * Complex.I))
      (u' := fun x : в„қ => ((rdвӮӮ x : в„қ) : в„Ӯ))
      (v' := fun x : в„қ => Complex.exp (((t * x : в„қ) : в„Ӯ) * Complex.I)) ?_ ?_ ?_ ?_ ?_ ?_
    В· exact (Complex.continuous_ofReal.comp
        ((continuous_const.sub (continuous_id.div_const _)).mul hqcont)).continuousOn
    В· exact ((Complex.continuous_exp.comp (by fun_prop)).div_const _).continuousOn
    В· exact fun x _ => (hrвӮӮder x).ofReal_comp
    В· exact fun x _ => hvder x
    В· exact (Complex.continuous_ofReal.comp hrdвӮӮcont).intervalIntegrable _ _
    В· exact (Complex.continuous_exp.comp (by fun_prop)).intervalIntegrable _ _
  have hq0 : ((1 + (0:в„қ) / 6) * q 0 : в„қ) = 1 := by
    simp [hq]
  have hqm6 : ((1 + (-6:в„қ) / 6) * q (-6) : в„қ) = 0 := by
    norm_num
  have hq6 : ((1 - (6:в„қ) / 6) * q 6 : в„қ) = 0 := by
    norm_num
  have hq0' : ((1 - (0:в„қ) / 6) * q 0 : в„қ) = 1 := by
    simp [hq]
  have hval : poitouPhi (5 / 4 + t * Complex.I) =
      -(вҲ« x in (-6:в„қ)..0, ((rdвӮҒ x : в„қ) : в„Ӯ) *
        (Complex.exp (((t * x : в„қ) : в„Ӯ) * Complex.I) / ((t : в„Ӯ) * Complex.I)))
      - вҲ« x in (0:в„қ)..6, ((rdвӮӮ x : в„қ) : в„Ӯ) *
