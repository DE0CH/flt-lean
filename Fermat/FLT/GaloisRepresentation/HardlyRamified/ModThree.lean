/-- **`őĺ_K(1) ‚Č† 0`: the class-number-formula residue** (PROVEN
2026-07-24 ‚ÄĒ preliminary leaf (b‚āÄŠĶĘ) of the decomposition of
`DedekindContinuation.weil_explicit_formula_F`; Poitou p. 6-01
"Pr√©liminaires", the `t = 0` boundary case).  Proof:
`őĺ(1) = lim_{ŌÉ‚Üí1‚Āļ} ŌÉ(ŌÉ‚ąí1)¬∑|d|^{ŌÉ/2}¬∑őď_‚ĄĚ(ŌÉ)^{r‚āĀ}¬∑őď_‚Ąā(ŌÉ)^{r‚āā}¬∑ő∂_K(ŌÉ)`
along real `ŌÉ ‚Üď 1`, by continuity of `xi` (from `differentiable`)
and `eq_of_one_lt_re`; the pin's Dirichlet class number formula
`NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT` with
`NumberField.dedekindZeta_residue_pos` makes
`(ŌÉ‚ąí1)¬∑ő∂_K(ŌÉ) ‚Üí residue ‚Č† 0` while the remaining factor
`ŌÉ¬∑G_K(ŌÉ)` tends to the nonzero `G_K(1)`
(`dedekindGammaFactor_continuousAt`/`_ne_zero`), so `őĺ(1)` is a
product of nonzero numbers by uniqueness of limits.  Note `funcEq` at
`s = 1` gives `őĺ(0) = őĺ(1)`, so this leaf also rules out a zero at
`0`. -/
theorem DedekindContinuation.xi_one_ne_zero {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    pkg.xi 1 ‚Č† 0 := by
  have hcoe : Filter.Tendsto (fun ŌÉ : ‚ĄĚ => (ŌÉ : ‚Ąā))
      (nhdsWithin 1 (Set.Ioi 1)) (nhds (1 : ‚Ąā)) := by
    have h := Complex.continuous_ofReal.tendsto (1 : ‚ĄĚ)
    rw [Complex.ofReal_one] at h
    exact h.mono_left nhdsWithin_le_nhds
  have hG : Filter.Tendsto (fun ŌÉ : ‚ĄĚ => (ŌÉ : ‚Ąā) * dedekindGammaFactor K (ŌÉ : ‚Ąā))
      (nhdsWithin 1 (Set.Ioi 1)) (nhds (dedekindGammaFactor K 1)) := by
    have h := ((continuousAt_id.mul (dedekindGammaFactor_continuousAt K
      (by simp : (0 : ‚ĄĚ) < (1 : ‚Ąā).re))).tendsto).comp hcoe
    simpa only [Function.comp_def, Pi.mul_apply, id_eq, one_mul] using h
  have hres := NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT K
  have hxi : Filter.Tendsto (fun ŌÉ : ‚ĄĚ => pkg.xi (ŌÉ : ‚Ąā))
      (nhdsWithin 1 (Set.Ioi 1))
      (nhds (dedekindGammaFactor K 1 *
        (NumberField.dedekindZeta_residue K : ‚Ąā))) := by
    refine (hG.mul hres).congr' ?_
    filter_upwards [self_mem_nhdsWithin] with ŌÉ hŌÉ
    rw [pkg.xi_eq_dedekindGammaFactor
      (by rw [Complex.ofReal_re]; exact hŌÉ : 1 < ((ŌÉ : ‚Ąā)).re)]
    ring
  have hxc : Filter.Tendsto (fun ŌÉ : ‚ĄĚ => pkg.xi (ŌÉ : ‚Ąā))
      (nhdsWithin 1 (Set.Ioi 1)) (nhds (pkg.xi 1)) := by
    have h := (pkg.differentiable 1).continuousAt.tendsto.comp hcoe
    simpa only [Function.comp_def] using h
  rw [tendsto_nhds_unique hxc hxi]
  exact mul_ne_zero (dedekindGammaFactor_ne_zero K (by simp))
    (by exact_mod_cast NumberField.dedekindZeta_residue_ne_zero K)

/-- **`őĺ_K(1 + it) ‚Č† 0` for `t ‚Č† 0`: de la Vall√©e Poussin** (PROVEN
2026-07-24 ‚ÄĒ preliminary leaf (b‚āÄŠĶĘŠĶĘ) of the decomposition of
`DedekindContinuation.weil_explicit_formula_F`; Poitou p. 6-01
"Pr√©liminaires", the `t ‚Č† 0` boundary case).  Proof: suppose
`őĺ(1+it) = 0` and let `x ‚Üď 0`.  The Mertens `3-4-1` inequality
`norm_dedekindZeta_product_ge_one` (the transplant of mathlib's
`riemannZeta_ne_zero_of_one_le_re` skeleton from
`Mathlib.NumberTheory.LSeries.Nonvanishing` onto the Dedekind Euler
product of the Chebotarev development) gives
`1 ‚Č§ |ő∂_K(1+x)|¬≥¬∑|ő∂_K(1+x+it)|‚Āī¬∑|ő∂_K(1+x+2it)|`.  Rewrite the right
side as `|x¬∑ő∂_K(1+x)|¬≥ ¬∑ |ő∂_K(1+x+it)/x|‚Āī ¬∑ |ő∂_K(1+x+2it)| ¬∑ x`:
through `őĺ = s(s‚ąí1)¬∑G_K¬∑ő∂_K` with the elementary factor continuous
and nonzero near the boundary points (`dedekindGammaFactor_*`), the
first factor tends to the class-number-formula residue cubed
(`NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT`), the second
to `|őĺ'(1+it)/E(1+it)|‚Āī` by the slope characterization of the
derivative at the putative zero (`hasDerivAt_iff_tendsto_slope`), the
third to a finite value, and the trailing `x` to `0` ‚ÄĒ so the whole
product tends to `0`, contradicting `‚Č• 1`: a zero of order `‚Č• 1` at
`1 + it` makes the `4`-th power vanish to order `4`, beating the
order-`3` pole of `ő∂_K(ŌÉ)¬≥`. -/
theorem DedekindContinuation.xi_ne_zero_of_re_eq_one_of_im_ne_zero {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K)
    (t : ‚ĄĚ) (ht : t ‚Č† 0) :
    pkg.xi (1 + t * Complex.I) ‚Č† 0 := by
  intro hzero
  -- continuity and nonvanishing of the full elementary factor
  have hE_cont : ‚ąÄ w : ‚Ąā, 0 < w.re ‚Üí
      ContinuousAt (fun z : ‚Ąā => z * (z - 1) * dedekindGammaFactor K z) w :=
    fun w hw => (continuousAt_id.mul (continuousAt_id.sub continuousAt_const)).mul
      (dedekindGammaFactor_continuousAt K hw)
  have hE_ne : ‚ąÄ w : ‚Ąā, 0 < w.re ‚Üí w ‚Č† 0 ‚Üí w ‚Č† 1 ‚Üí
      w * (w - 1) * dedekindGammaFactor K w ‚Č† 0 := fun w hw h0 h1 =>
    mul_ne_zero (mul_ne_zero h0 (sub_ne_zero.mpr h1))
      (dedekindGammaFactor_ne_zero K hw)
  -- real parts along the two shifted vertical lines
  have hre‚āĀ : ‚ąÄ x : ‚ĄĚ, (1 + (x : ‚Ąā) + t * Complex.I).re = 1 + x := by
    intro x
    simp [Complex.add_re, Complex.mul_re]
  have hre‚āā : ‚ąÄ x : ‚ĄĚ, (1 + (x : ‚Ąā) + 2 * t * Complex.I).re = 1 + x := by
    intro x
    simp [Complex.add_re, Complex.mul_re, Complex.mul_im]
  -- the two boundary points avoid `0` and `1`
  have hz‚āĀre : (0 : ‚ĄĚ) < (1 + (t : ‚Ąā) * Complex.I).re := by
    norm_num [Complex.add_re, Complex.mul_re]
  have hz‚āāre : (0 : ‚ĄĚ) < (1 + 2 * (t : ‚Ąā) * Complex.I).re := by
    norm_num [Complex.add_re, Complex.mul_re, Complex.mul_im]
  have hz‚āĀ0 : (1 + (t : ‚Ąā) * Complex.I) ‚Č† 0 := by
    intro h
    have h0 := congrArg Complex.re h
    norm_num [Complex.add_re, Complex.mul_re] at h0
  have hz‚āĀ1 : (1 + (t : ‚Ąā) * Complex.I) ‚Č† 1 := by
    intro h
    have h1 := congrArg Complex.im h
    norm_num [Complex.add_im, Complex.mul_im] at h1
    exact ht h1
  have hz‚āā0 : (1 + 2 * (t : ‚Ąā) * Complex.I) ‚Č† 0 := by
    intro h
    have h0 := congrArg Complex.re h
    norm_num [Complex.add_re, Complex.mul_re, Complex.mul_im] at h0
  have hz‚āā1 : (1 + 2 * (t : ‚Ąā) * Complex.I) ‚Č† 1 := by
    intro h
    have h1 := congrArg Complex.im h
    norm_num [Complex.add_im, Complex.mul_im, Complex.mul_re] at h1
    exact ht h1
  -- filter maps as `x ‚Üď 0`
  have hcoe0 : Filter.Tendsto (fun x : ‚ĄĚ => (x : ‚Ąā))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (0 : ‚Ąā)) := by
    have h := Complex.continuous_ofReal.tendsto (0 : ‚ĄĚ)
    rw [Complex.ofReal_zero] at h
    exact h.mono_left nhdsWithin_le_nhds
  have hm‚āĀ : Filter.Tendsto (fun x : ‚ĄĚ => 1 + (x : ‚Ąā) + t * Complex.I)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (1 + (t : ‚Ąā) * Complex.I)) := by
    have h := (hcoe0.const_add (1 : ‚Ąā)).add_const ((t : ‚Ąā) * Complex.I)
    simpa only [add_zero] using h
  have hm‚āā : Filter.Tendsto (fun x : ‚ĄĚ => 1 + (x : ‚Ąā) + 2 * t * Complex.I)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (1 + 2 * (t : ‚Ąā) * Complex.I)) := by
    have h := (hcoe0.const_add (1 : ‚Ąā)).add_const (2 * (t : ‚Ąā) * Complex.I)
    simpa only [add_zero] using h
  -- the residue factor `x¬∑ő∂_K(1+x) ‚Üí residue`
  have hmap1 : Filter.Tendsto (fun x : ‚ĄĚ => 1 + x) (nhdsWithin 0 (Set.Ioi 0))
      (nhdsWithin 1 (Set.Ioi 1)) := by
    rw [tendsto_nhdsWithin_iff]
    refine ‚ü®?_, ?_‚ü©
    ¬∑ have h := ((Filter.tendsto_id (x := nhds (0 : ‚ĄĚ))).const_add
        (1 : ‚ĄĚ)).mono_left (nhdsWithin_le_nhds (s := Set.Ioi (0 : ‚ĄĚ)))
      simpa using h
    ¬∑ filter_upwards [self_mem_nhdsWithin] with x hx
      simpa using (hx : (0 : ‚ĄĚ) < x)
  have hres0 : Filter.Tendsto
      (fun x : ‚ĄĚ => (x : ‚Ąā) * NumberField.dedekindZeta K (1 + x))
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (NumberField.dedekindZeta_residue K : ‚Ąā)) := by
    have h := (NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT K).comp hmap1
    simp only [Function.comp_def] at h
    refine h.congr fun x => ?_
    push_cast
    ring
  -- the slope factor `őĺ(1+x+it)/x ‚Üí őĺ'(1+it)` at the putative zero
  have hslope : Filter.Tendsto
      (fun x : ‚ĄĚ => pkg.xi (1 + (x : ‚Ąā) + t * Complex.I) / (x : ‚Ąā))
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (deriv pkg.xi (1 + (t : ‚Ąā) * Complex.I))) := by
    have hd : HasDerivAt pkg.xi (deriv pkg.xi (1 + (t : ‚Ąā) * Complex.I))
        (1 + (t : ‚Ąā) * Complex.I) :=
      (pkg.differentiable (1 + (t : ‚Ąā) * Complex.I)).hasDerivAt
    have hmapc : Filter.Tendsto (fun x : ‚ĄĚ => 1 + (x : ‚Ąā) + t * Complex.I)
        (nhdsWithin 0 (Set.Ioi 0))
        (nhdsWithin (1 + (t : ‚Ąā) * Complex.I) {(1 + (t : ‚Ąā) * Complex.I)}Š∂ú) := by
      rw [tendsto_nhdsWithin_iff]
      refine ‚ü®hm‚āĀ, ?_‚ü©
      filter_upwards [self_mem_nhdsWithin] with x hx
      simp only [Set.mem_compl_iff, Set.mem_singleton_iff]
      intro h
      have hx0 : (x : ‚Ąā) = 0 := by linear_combination h
      rw [Complex.ofReal_eq_zero] at hx0
      exact ne_of_gt (hx : (0 : ‚ĄĚ) < x) hx0
    have h := (hasDerivAt_iff_tendsto_slope.mp hd).comp hmapc
    simp only [Function.comp_def] at h
    refine h.congr fun x => ?_
    rw [slope_def_field, hzero, sub_zero]
    congr 1
    ring
  -- the two elementary-factor limits
  have hE‚āĀ : Filter.Tendsto (fun x : ‚ĄĚ =>
      (1 + (x : ‚Ąā) + t * Complex.I) * ((1 + (x : ‚Ąā) + t * Complex.I) - 1) *
        dedekindGammaFactor K (1 + (x : ‚Ąā) + t * Complex.I))
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds ((1 + (t : ‚Ąā) * Complex.I) * ((1 + (t : ‚Ąā) * Complex.I) - 1) *
        dedekindGammaFactor K (1 + (t : ‚Ąā) * Complex.I))) := by
    have h := (hE_cont _ hz‚āĀre).tendsto.comp hm‚āĀ
    simpa only [Function.comp_def] using h
  have hE‚āā : Filter.Tendsto (fun x : ‚ĄĚ =>
      (1 + (x : ‚Ąā) + 2 * t * Complex.I) *
        ((1 + (x : ‚Ąā) + 2 * t * Complex.I) - 1) *
        dedekindGammaFactor K (1 + (x : ‚Ąā) + 2 * t * Complex.I))
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds ((1 + 2 * (t : ‚Ąā) * Complex.I) *
        ((1 + 2 * (t : ‚Ąā) * Complex.I) - 1) *
        dedekindGammaFactor K (1 + 2 * (t : ‚Ąā) * Complex.I))) := by
    have h := (hE_cont _ hz‚āāre).tendsto.comp hm‚āā
    simpa only [Function.comp_def] using h
  -- the vanishing-to-first-order zeta factor
  have hzeta‚āĀ : Filter.Tendsto (fun x : ‚ĄĚ =>
      NumberField.dedekindZeta K (1 + (x : ‚Ąā) + t * Complex.I) / (x : ‚Ąā))
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (deriv pkg.xi (1 + (t : ‚Ąā) * Complex.I) /
        ((1 + (t : ‚Ąā) * Complex.I) * ((1 + (t : ‚Ąā) * Complex.I) - 1) *
          dedekindGammaFactor K (1 + (t : ‚Ąā) * Complex.I)))) := by
    refine (hslope.div hE‚āĀ (hE_ne _ hz‚āĀre hz‚āĀ0 hz‚āĀ1)).congr' ?_
    filter_upwards [self_mem_nhdsWithin] with x hx
    simp only [Pi.div_apply]
    have hre : 1 < (1 + (x : ‚Ąā) + t * Complex.I).re := by
      rw [hre‚āĀ x]
      linarith [Set.mem_Ioi.mp hx]
    have hs0 : (1 + (x : ‚Ąā) + t * Complex.I) ‚Č† 0 := by
      intro h
      rw [h] at hre
      norm_num [Complex.zero_re] at hre
    have hs1 : (1 + (x : ‚Ąā) + t * Complex.I) ‚Č† 1 := by
      intro h
      rw [h] at hre
      norm_num [Complex.one_re] at hre
    rw [pkg.xi_eq_dedekindGammaFactor hre, div_right_comm,
      mul_div_cancel_left‚āÄ _ (hE_ne _ (lt_trans zero_lt_one hre) hs0 hs1)]
  -- the bounded zeta factor
  have hzeta‚āā : Filter.Tendsto (fun x : ‚ĄĚ =>
      NumberField.dedekindZeta K (1 + (x : ‚Ąā) + 2 * t * Complex.I))
      (nhdsWithin 0 (Set.Ioi 0))
      (nhds (pkg.xi (1 + 2 * (t : ‚Ąā) * Complex.I) /
        ((1 + 2 * (t : ‚Ąā) * Complex.I) * ((1 + 2 * (t : ‚Ąā) * Complex.I) - 1) *
          dedekindGammaFactor K (1 + 2 * (t : ‚Ąā) * Complex.I)))) := by
    have hxi‚āā : Filter.Tendsto
        (fun x : ‚ĄĚ => pkg.xi (1 + (x : ‚Ąā) + 2 * t * Complex.I))
        (nhdsWithin 0 (Set.Ioi 0))
        (nhds (pkg.xi (1 + 2 * (t : ‚Ąā) * Complex.I))) := by
      have h := (pkg.differentiable
        (1 + 2 * (t : ‚Ąā) * Complex.I)).continuousAt.tendsto.comp hm‚āā
      simpa only [Function.comp_def] using h
    refine (hxi‚āā.div hE‚āā (hE_ne _ hz‚āāre hz‚āā0 hz‚āā1)).congr' ?_
    filter_upwards [self_mem_nhdsWithin] with x hx
    simp only [Pi.div_apply]
    have hre : 1 < (1 + (x : ‚Ąā) + 2 * t * Complex.I).re := by
      rw [hre‚āā x]
      linarith [Set.mem_Ioi.mp hx]
    have hs0 : (1 + (x : ‚Ąā) + 2 * t * Complex.I) ‚Č† 0 := by
      intro h
      rw [h] at hre
      norm_num [Complex.zero_re] at hre
    have hs1 : (1 + (x : ‚Ąā) + 2 * t * Complex.I) ‚Č† 1 := by
      intro h
      rw [h] at hre
      norm_num [Complex.one_re] at hre
    rw [pkg.xi_eq_dedekindGammaFactor hre,
      mul_div_cancel_left‚āÄ _ (hE_ne _ (lt_trans zero_lt_one hre) hs0 hs1)]
  -- the whole comparison product tends to `0` ‚Ä¶
  have hxlim : Filter.Tendsto (fun x : ‚ĄĚ => x) (nhdsWithin 0 (Set.Ioi 0))
      (nhds (0 : ‚ĄĚ)) :=
    Filter.tendsto_id.mono_left nhdsWithin_le_nhds
  have hprod : Filter.Tendsto (fun x : ‚ĄĚ =>
      ‚ÄĖ(x : ‚Ąā) * NumberField.dedekindZeta K (1 + x)‚ÄĖ ^ 3 *
        ‚ÄĖNumberField.dedekindZeta K (1 + (x : ‚Ąā) + t * Complex.I) / (x : ‚Ąā)‚ÄĖ ^ 4 *
        ‚ÄĖNumberField.dedekindZeta K (1 + (x : ‚Ąā) + 2 * t * Complex.I)‚ÄĖ * x)
      (nhdsWithin 0 (Set.Ioi 0)) (nhds 0) := by
    have h := (((hres0.norm.pow 3).mul (hzeta‚āĀ.norm.pow 4)).mul
      hzeta‚āā.norm).mul hxlim
    simpa only [mul_zero] using h
  -- ‚Ä¶ but the `3-4-1` inequality keeps it `‚Č• 1`
  have hge : ‚ąÄŠ∂† x : ‚ĄĚ in nhdsWithin 0 (Set.Ioi 0),
      1 ‚Č§ ‚ÄĖ(x : ‚Ąā) * NumberField.dedekindZeta K (1 + x)‚ÄĖ ^ 3 *
        ‚ÄĖNumberField.dedekindZeta K (1 + (x : ‚Ąā) + t * Complex.I) / (x : ‚Ąā)‚ÄĖ ^ 4 *
        ‚ÄĖNumberField.dedekindZeta K (1 + (x : ‚Ąā) + 2 * t * Complex.I)‚ÄĖ * x := by
    filter_upwards [self_mem_nhdsWithin] with x hx
    have hx0 : (0 : ‚ĄĚ) < x := hx
    calc (1 : ‚ĄĚ)
        ‚Č§ ‚ÄĖNumberField.dedekindZeta K (1 + x) ^ 3 *
            NumberField.dedekindZeta K (1 + x + t * Complex.I) ^ 4 *
            NumberField.dedekindZeta K (1 + x + 2 * t * Complex.I)‚ÄĖ :=
