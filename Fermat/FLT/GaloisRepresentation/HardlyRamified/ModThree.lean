(Serre's lower-numbering ramification group `G_i`, *Corps Locaux* IV
¬ß1, spelled with mathlib's `Ideal.inertia` applied to the power
`Q^(i+1)`) is the trivial subgroup.  Proof: a nontrivial
`ŌÉ ‚ąą Gal(K/‚Ąö)` moves some element of `K`, hence ‚ÄĒ writing it as a
ratio of algebraic integers (`IsFractionRing.div_surjective`) ‚ÄĒ some
algebraic integer `x`; the Krull intersection theorem
(`Ideal.iInf_pow_eq_bot_of_isDomain`) in the Noetherian domain `ūĚďě K`
then yields a level `m` with `ŌÉ ‚ÄĘ x ‚ąí x ‚ąČ Q ^ (m + 1)`, excluding `ŌÉ`
from level `m`; the sup of these finitely many levels over the finite
group `Gal(K/‚Ąö)` bounds the whole filtration. -/
theorem exists_pow_inertia_eq_bot
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQtop : Q ‚Č† ‚ä§) :
    ‚ąÉ n : ‚Ąē, (Q ^ (n + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K) = ‚ä• := by
  classical
  have hKrull : (‚®Ö m : ‚Ąē, Q ^ m) = ‚ä• := Ideal.iInf_pow_eq_bot_of_isDomain Q hQtop
  -- each nontrivial automorphism is excluded at some level
  have hmove : ‚ąÄ ŌÉ : K ‚ČÉ‚āź[‚Ąö] K, ŌÉ ‚Č† 1 ‚Üí
      ‚ąÉ m : ‚Ąē, ŌÉ ‚ąČ (Q ^ (m + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K) := by
    intro ŌÉ hŌÉ
    -- `ŌÉ` moves some algebraic integer
    have hx : ‚ąÉ x : NumberField.RingOfIntegers K, ŌÉ ‚ÄĘ x ‚Č† x := by
      by_contra hfix
      push Not at hfix
      apply hŌÉ
      refine AlgEquiv.ext fun y => ?_
      obtain ‚ü®a, b, hb, rfl‚ü© :=
        IsFractionRing.div_surjective (A := NumberField.RingOfIntegers K) y
      have ha : ŌÉ (algebraMap (NumberField.RingOfIntegers K) K a) =
          algebraMap (NumberField.RingOfIntegers K) K a :=
        congrArg (algebraMap (NumberField.RingOfIntegers K) K) (hfix a)
      have hbfix : ŌÉ (algebraMap (NumberField.RingOfIntegers K) K b) =
          algebraMap (NumberField.RingOfIntegers K) K b :=
        congrArg (algebraMap (NumberField.RingOfIntegers K) K) (hfix b)
      rw [AlgEquiv.one_apply, map_div‚āÄ, ha, hbfix]
    obtain ‚ü®x, hxne‚ü© := hx
    have hz : ŌÉ ‚ÄĘ x - x ‚Č† 0 := sub_ne_zero.mpr hxne
    have hout : ‚ąÉ m : ‚Ąē, ŌÉ ‚ÄĘ x - x ‚ąČ Q ^ m := by
      by_contra hall
      push Not at hall
      refine hz ?_
      have hmemi : ŌÉ ‚ÄĘ x - x ‚ąą (‚®Ö m : ‚Ąē, Q ^ m) :=
        (Submodule.mem_iInf _).mpr hall
