          (őł‚āā + (c‚āĀ : ‚Ą§) ‚ÄĘ w) -
        algebraMap (NumberField.RingOfIntegers K) K (őł‚āā + (c‚āā : ‚Ą§) ‚ÄĘ w) =
        ((c‚āĀ : ‚Ą§) - (c‚āā : ‚Ą§)) ‚ÄĘ
          algebraMap (NumberField.RingOfIntegers K) K w := by
      rw [‚Üź map_sub, ‚Üź map_zsmul]
      congr 1
