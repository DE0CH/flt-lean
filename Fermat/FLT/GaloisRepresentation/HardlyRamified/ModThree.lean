/-- **The ramified quadratic extension `в„ҡвӮғбөҘ(О¶вӮғ)` at finite level**
(sorry node, isolated 2026-07-23 вҖ” the finite-level content of the
ramification witness below; everything profinite is already assembled
on top of it): there are a finite Galois subextension `N` of the
algebraic closure of the `3`-adic completion, a primitive cube root
`О¶ вҲҲ N`, and an automorphism `П„` of `N` with `П„ О¶ = О¶ВІ` lying in the
finite-level inertia (trivial action modulo the maximal ideal of the
integral closure of `рқ’ӘбөҘ` in `N`). Intended proof: `О¶ вҲү в„ҡвӮғбөҘ` вҖ” else
`x = 2О¶ + 1 вҲҲ в„ҡвӮғбөҘ` has `xВІ = вҲ’3`, and `рқ”ӘбөҘ = (3)`
(`maximalIdeal_adicCompletionIntegers_eq_span`) gives `x вҲҲ рқ’ӘбөҘ`
(integrally closed), `x вҲҲ рқ”ӘбөҘ`, `x = 3y`, `3yВІ = вҲ’1`, so `вҲ’1 вҲҲ рқ”ӘбөҘ`,
absurd вҖ” hence `N := в„ҡвӮғбөҘвҹ®О¶вҹҜ` is quadratic (minpoly `XВІ + X + 1`,
irreducible as a rootless quadratic) and Galois (both roots `О¶, О¶ВІ`
lie in `N`); its automorphism group is `{1, П„}` with `П„ О¶ = О¶ВІ`
(`IsGalois.card_aut_eq_finrank`); and `П„` is inertial: for integral
`y` with `s = П„ y вҲ’ y` one has `П„ s = вҲ’s`, so `sВІ` and `sВ·(2О¶+1)` are
Galois-invariant integral elements of `в„ҡвӮғбөҘ`, hence in `рқ’ӘбөҘ`, with
`(sВ·(2О¶+1))ВІ = вҲ’3 sВІ`; primality of `рқ”ӘбөҘ = (3)` then forces
`sВІ вҲҲ 3рқ’ӘбөҘ вҠҶ рқ”Ә(IntegralClosure)`, and `s вҲҲ рқ”Ә` since the maximal
ideal of the (local) integral closure is prime вҖ” the local analogue
of the proven `mem_inertia_of_dvd_squarefree`. -/
theorem exists_finite_level_inertia_swap_three :
    вҲғ (N : IntermediateField
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
        (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)))
      (П„ : N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] N)
      (О¶ : AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat))
      (hО¶N : О¶ вҲҲ N),
      FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N вҲ§
      IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N вҲ§
      IsPrimitiveRoot О¶ 3 вҲ§
      ((П„ вҹЁО¶, hО¶Nвҹ© : N) : AlgebraicClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) = О¶ ^ 2 вҲ§
      П„ вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
        (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] N) := by
  classical
  -- a primitive cube root of the local closure
  obtain вҹЁО¶Q, hО¶Qвҹ© := HasEnoughRootsOfUnity.exists_primitiveRoot
    (AlgebraicClosure в„ҡ) 3
  set О¶ : AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) :=
    AlgebraicClosure.map (algebraMap в„ҡ
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) О¶Q with hО¶def
  have hО¶prim : IsPrimitiveRoot О¶ 3 :=
    hО¶Q.map_of_injective (RingHom.injective _)
  have hО¶rel : О¶ ^ 2 + О¶ + 1 = 0 := by
    have h := hО¶prim.geom_sum_eq_zero (by norm_num)
    rw [Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ,
      Finset.sum_range_zero, pow_zero, pow_one] at h
    linear_combination h
  -- the quadratic `XВІ + X + 1` over the completion
  set p : Polynomial (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) :=
    Polynomial.X ^ 2 + Polynomial.X + 1 with hpdef
  have hpmonic : p.Monic := by rw [hpdef]; monicity!
  have hpnat : p.natDegree = 2 := by rw [hpdef]; compute_degree!
  have hО¶aeval : Polynomial.aeval О¶ p = 0 := by
    rw [hpdef]
    simp only [map_add, map_pow, Polynomial.aeval_X, map_one]
    exact hО¶rel
  have hО¶int : IsIntegral (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) О¶ :=
    вҹЁp, hpmonic, by rwa [вҶҗ Polynomial.aeval_def]вҹ©
  have hpirr : Irreducible p := by
    refine Polynomial.irreducible_of_degree_le_three_of_not_isRoot ?_ ?_
    В· rw [hpnat]; decide
    В· intro x hx
      have hx0 : x ^ 2 + x + 1 = 0 := by
        have h := hx
        rw [hpdef] at h
        simpa [Polynomial.IsRoot] using h
      exact no_root_sq_add_self_add_one_adicCompletion_three x hx0
  have hmin : minpoly (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) О¶ = p :=
    (minpoly.eq_of_irreducible_of_monic hpirr hО¶aeval hpmonic).symm
  -- the quadratic extension `N = в„ҡвӮғбөҘ(О¶)`
  haveI hfd : FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion
      в„ҡ Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      (IntermediateField.adjoin (IsDedekindDomain.HeightOneSpectrum.adicCompletion
        в„ҡ Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) {О¶}) :=
    IntermediateField.adjoin.finiteDimensional hО¶int
  have hfr2 : Module.finrank (IsDedekindDomain.HeightOneSpectrum.adicCompletion
      в„ҡ Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      (IntermediateField.adjoin (IsDedekindDomain.HeightOneSpectrum.adicCompletion
        в„ҡ Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) {О¶}) = 2 := by
    rw [IntermediateField.adjoin.finrank hО¶int, hmin, hpnat]
  set A := IntermediateField.AdjoinSimple.gen
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) О¶ with hAdef
  have hAcoe : (algebraMap _ (AlgebraicClosure
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat))) A = О¶ :=
    IntermediateField.AdjoinSimple.algebraMap_gen _ _
  have hArel : A ^ 2 + A + 1 = 0 := by
    apply RingHom.injective (algebraMap _ (AlgebraicClosure
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)))
    rw [map_add, map_add, map_pow, map_one, map_zero, hAcoe]
    exact hО¶rel
  have hAaeval : Polynomial.aeval A p = 0 := by
    rw [hpdef]
    simp only [map_add, map_pow, Polynomial.aeval_X, map_one]
    exact hArel
  -- `p` splits in `N` with roots `A` and `B = вҲ’1 вҲ’ A`
  set B := -1 - A with hBdef
  have hCA : (Polynomial.C A) ^ 2 + Polynomial.C A + 1 = 0 := by
    have h := congrArg Polynomial.C hArel
    rw [map_add, map_add, map_pow, map_one, map_zero] at h
    exact h
  have hfac : p.map (algebraMap _ _) =
      (Polynomial.X - Polynomial.C A) * (Polynomial.X - Polynomial.C B) := by
    have hCB : Polynomial.C B = -1 - Polynomial.C A := by
      rw [hBdef, map_sub, map_neg, map_one]
    rw [hpdef, Polynomial.map_add, Polynomial.map_add, Polynomial.map_pow,
      Polynomial.map_X, Polynomial.map_one, hCB]
    linear_combination hCA
  have hsplits : (p.map (algebraMap
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      (IntermediateField.adjoin (IsDedekindDomain.HeightOneSpectrum.adicCompletion
        в„ҡ Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) {О¶}))).Splits := by
    rw [hfac]
