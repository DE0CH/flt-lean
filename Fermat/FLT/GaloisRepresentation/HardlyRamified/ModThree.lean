  set g : (K ‚ČÉ‚āź[‚Ąö] K) ‚Üí ‚Ąē := fun ŌÉ => if h : ŌÉ = 1 then 0 else f ŌÉ h with hg
  refine ‚ü®Finset.univ.sup g, ?_‚ü©
