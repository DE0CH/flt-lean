      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e) :
    ‚ąÄ ŌÉ ‚ąą localInertiaGroup Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      (((u (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) ŌÉ) :
        GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) - 1) ^ 2 = 0 := by
  classical
  intro ŌÉ hŌÉ
  obtain ‚ü®ŌĄ, hŌĄ, c, heq‚ü© := localInertia_two_eq_map_padic hŌÉ
  set g' : őď ‚Ąö := Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) ŌÉ
  set m : őď ‚Ąö := Field.absoluteGaloisGroup.map (algebraMap ‚Ąö ‚Ąö_[2]) ŌĄ
