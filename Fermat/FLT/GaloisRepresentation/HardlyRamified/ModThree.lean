noncomputable def poitouF (x : ‚ĄĚ) : ‚ĄĚ := odlyzkoTestFn x / Real.cosh (x / 2)

/-- **The schoolbook divided-zeros counting inequality** (PROVEN
2026-07-24, the Jensen-free counting core of
`DedekindContinuation.zero_count_window`): if an entire `f : ‚Ąā ‚Üí ‚Ąā`
satisfies `f c ‚Č† 0`, is bounded by `M` on the circle `‚ÄĖz ‚ąí c‚ÄĖ = R`,
and `t` is a finite set of points of the closed disc `‚ÄĖz ‚ąí c‚ÄĖ ‚Č§ r`
(`0 < r < R`) whose total `analyticOrderNatAt` is at least `k`, then
`((R ‚ąí r)/r)^k ¬∑ ‚ÄĖf c‚ÄĖ ‚Č§ M` ‚ÄĒ so the multiplicity-weighted zero count
of the small disc is at most `log(M/‚ÄĖf c‚ÄĖ)/log((R ‚ąí r)/r)`.  The
mathlib pin has no analytic Jensen formula and no Hadamard
factorization, so the count is manufactured from the
Cauchy/max-modulus toolkit.  Proof: induction on `k`, dividing off one
zero per step by `dslope`: if `f ŌĀ = 0` then
`f = (¬∑ ‚ąí ŌĀ) * dslope f ŌĀ` EXACTLY (`sub_smul_dslope_of_zero`) with
`dslope f ŌĀ` again entire (the removable-singularity lemma
`Complex.differentiableOn_dslope`), the division dropping
`analyticOrderNatAt` at `ŌĀ` by one (`analyticOrderAt_mul` against the
order-`1` linear factor) and fixing it elsewhere; each divided linear
factor is `‚Č• R ‚ąí r` on the circle and `‚Č§ r` at the centre, and the
base case `k = 0` is the maximum-modulus principle
`Complex.norm_le_of_forall_mem_frontier_norm_le`. -/
theorem sum_analyticOrderNatAt_le_of_frontier_norm_le
    {f : ‚Ąā ‚Üí ‚Ąā} {c : ‚Ąā} {r R M : ‚ĄĚ} {t : Finset ‚Ąā} {k : ‚Ąē}
    (hf : Differentiable ‚Ąā f) (hr : 0 < r) (hrR : r < R) (hfc : f c ‚Č† 0)
    (hM : ‚ąÄ z : ‚Ąā, ‚ÄĖz - c‚ÄĖ = R ‚Üí ‚ÄĖf z‚ÄĖ ‚Č§ M)
    (ht : ‚ąÄ ŌĀ ‚ąą t, ‚ÄĖŌĀ - c‚ÄĖ ‚Č§ r)
    (hk : k ‚Č§ ‚ąĎ ŌĀ ‚ąą t, analyticOrderNatAt f ŌĀ) :
    ((R - r) / r) ^ k * ‚ÄĖf c‚ÄĖ ‚Č§ M := by
  induction k generalizing f M with
  | zero =>
    have hb : ‚ąÄ z ‚ąą frontier (Metric.ball c R), ‚ÄĖf z‚ÄĖ ‚Č§ M := by
      intro z hz
      rw [frontier_ball c (by linarith : (0 : ‚ĄĚ) < R).ne'] at hz
      exact hM z (by rwa [Metric.mem_sphere, dist_eq_norm] at hz)
    simpa using Complex.norm_le_of_forall_mem_frontier_norm_le
      Metric.isBounded_ball hf.diffContOnCl hb
      (subset_closure (Metric.mem_ball_self (by linarith : (0 : ‚ĄĚ) < R)))
  | succ k ih =>
    have hRr : (0 : ‚ĄĚ) < R - r := by linarith
    obtain ‚ü®ŌĀ, hŌĀt, hŌĀ‚ü© : ‚ąÉ ŌĀ ‚ąą t, analyticOrderNatAt f ŌĀ ‚Č† 0 :=
      Finset.exists_ne_zero_of_sum_ne_zero (by omega)
    have hfŌĀ : f ŌĀ = 0 := apply_eq_zero_of_analyticOrderNatAt_ne_zero hŌĀ
    set g : ‚Ąā ‚Üí ‚Ąā := dslope f ŌĀ with hg_def
    have hg_diff : Differentiable ‚Ąā g := by
      rw [hg_def, ‚Üź differentiableOn_univ]
      exact (Complex.differentiableOn_dslope Filter.univ_mem).mpr hf.differentiableOn
    have hfactor : ‚ąÄ z : ‚Ąā, f z = (z - ŌĀ) * g z := fun z => by
      rw [hg_def, ‚Üź smul_eq_mul, sub_smul_dslope_of_zero hfŌĀ]
    have hgc_ne : g c ‚Č† 0 := fun h => hfc (by rw [hfactor c, h, mul_zero])
    have hMg : ‚ąÄ z : ‚Ąā, ‚ÄĖz - c‚ÄĖ = R ‚Üí ‚ÄĖg z‚ÄĖ ‚Č§ M / (R - r) := by
      intro z hz
      have hzŌĀ : R - r ‚Č§ ‚ÄĖz - ŌĀ‚ÄĖ := by
        have h1 : ‚ÄĖz - c‚ÄĖ - ‚ÄĖŌĀ - c‚ÄĖ ‚Č§ ‚ÄĖz - c - (ŌĀ - c)‚ÄĖ := norm_sub_norm_le _ _
        rw [sub_sub_sub_cancel_right, hz] at h1
        have h2 := ht ŌĀ hŌĀt
        linarith
      rw [le_div_iff‚āÄ hRr]
      calc ‚ÄĖg z‚ÄĖ * (R - r) ‚Č§ ‚ÄĖg z‚ÄĖ * ‚ÄĖz - ŌĀ‚ÄĖ :=
            mul_le_mul_of_nonneg_left hzŌĀ (norm_nonneg _)
        _ = ‚ÄĖf z‚ÄĖ := by rw [hfactor z, norm_mul, mul_comm]
        _ ‚Č§ M := hM z hz
    -- order bookkeeping: dividing by the linear factor drops the order
    -- at `ŌĀ` by exactly one and leaves all other orders unchanged
    have hfan : ‚ąÄ z : ‚Ąā, AnalyticAt ‚Ąā f z := fun z => hf.analyticAt z
    have hgan : ‚ąÄ z : ‚Ąā, AnalyticAt ‚Ąā g z := fun z => hg_diff.analyticAt z
    have hforder : ‚ąÄ z : ‚Ąā, analyticOrderAt f z ‚Č† ‚ä§ := by
      intro z
      have h0 : analyticOrderAt f c ‚Č† ‚ä§ := by
        rw [analyticOrderAt_eq_zero.mpr (Or.inr hfc)]
        simp
      exact AnalyticOnNhd.analyticOrderAt_ne_top_of_isPreconnected
        (fun w _ => hfan w) isPreconnected_univ (Set.mem_univ c) (Set.mem_univ z) h0
    have horder_split : ‚ąÄ ŌÉ : ‚Ąā, analyticOrderAt f ŌÉ =
        analyticOrderAt (fun w : ‚Ąā => w - ŌĀ) ŌÉ + analyticOrderAt g ŌÉ := by
      intro ŌÉ
      have hfg : f = (fun w : ‚Ąā => w - ŌĀ) * g := by
        funext z
        rw [Pi.mul_apply]
        exact hfactor z
      rw [hfg]
      exact analyticOrderAt_mul (by fun_prop) (hgan ŌÉ)
    have hgorder_ne_top : ‚ąÄ ŌÉ : ‚Ąā, analyticOrderAt g ŌÉ ‚Č† ‚ä§ := by
      intro ŌÉ h
      apply hforder ŌÉ
      rw [horder_split ŌÉ, h, add_top]
    have hnat_ne : ‚ąÄ ŌÉ : ‚Ąā, ŌÉ ‚Č† ŌĀ ‚Üí
        analyticOrderNatAt g ŌÉ = analyticOrderNatAt f ŌÉ := by
      intro ŌÉ hŌÉ
      have h1 := horder_split ŌÉ
      rw [(analyticOrderAt_eq_zero (ūĚēú := ‚Ąā) (f := fun w : ‚Ąā => w - ŌĀ)
          (z‚āÄ := ŌÉ)).mpr (Or.inr (sub_ne_zero.mpr hŌÉ)), zero_add] at h1
      simp [analyticOrderNatAt, h1]
    have hnat_ŌĀ : analyticOrderNatAt f ŌĀ = analyticOrderNatAt g ŌĀ + 1 := by
      have h1 := horder_split ŌĀ
      have h2 : analyticOrderAt (fun w : ‚Ąā => w - ŌĀ) ŌĀ = 1 := by
        simpa using analyticOrderAt_centeredMonomial (ūĚēú := ‚Ąā) (z‚āÄ := ŌĀ) (n := 1)
      rw [h2] at h1
      simp only [analyticOrderNatAt, h1]
      rw [add_comm, ENat.toNat_add (hgorder_ne_top ŌĀ) (by simp)]
      simp
    have hsum_g : k ‚Č§ ‚ąĎ ŌÉ ‚ąą t, analyticOrderNatAt g ŌÉ := by
      have h1 := (Finset.add_sum_erase t (analyticOrderNatAt f) hŌĀt).symm
      have h2 := (Finset.add_sum_erase t (analyticOrderNatAt g) hŌĀt).symm
      have h3 : ‚ąĎ ŌÉ ‚ąą t.erase ŌĀ, analyticOrderNatAt f ŌÉ
          = ‚ąĎ ŌÉ ‚ąą t.erase ŌĀ, analyticOrderNatAt g ŌÉ :=
        Finset.sum_congr rfl fun ŌÉ hŌÉ => (hnat_ne ŌÉ (Finset.ne_of_mem_erase hŌÉ)).symm
      omega
    have hIH := ih hg_diff hgc_ne hMg hsum_g
    have hcŌĀ : ‚ÄĖc - ŌĀ‚ÄĖ ‚Č§ r := by rw [norm_sub_rev]; exact ht ŌĀ hŌĀt
    have hq_pos : (0 : ‚ĄĚ) < (R - r) / r := div_pos hRr hr
    have hr0 : r ‚Č† 0 := ne_of_gt hr
    calc ((R - r) / r) ^ (k + 1) * ‚ÄĖf c‚ÄĖ
        = ((R - r) / r) ^ (k + 1) * (‚ÄĖc - ŌĀ‚ÄĖ * ‚ÄĖg c‚ÄĖ) := by
          rw [hfactor c, norm_mul]
      _ ‚Č§ ((R - r) / r) ^ (k + 1) * (r * ‚ÄĖg c‚ÄĖ) := by
          have h4 := mul_le_mul_of_nonneg_right hcŌĀ (norm_nonneg (g c))
