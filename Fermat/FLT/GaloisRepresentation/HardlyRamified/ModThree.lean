  intro M hMfd hMfix d hd
  refine two_mul_local_differentIdeal_exponent_add_two_le_of_flat_at_three
    V hV hПҒ b e u hu M ?_ d hd
  intro Пғ hПғ x hx
  refine hMfix Пғ ?_ x hx
  rw [hfix]
  exact MonoidHom.mem_ker.mpr hПғ

