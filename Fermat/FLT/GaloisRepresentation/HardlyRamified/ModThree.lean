/-- **Finite-level tame ramification at `2`, with the Frobenius
conjugation clause** (PROVEN 2026-07-24 by specializing the generic
`exists_finite_level_tame_generator_of_frobenius` above at residue
characteristic `2`, mirroring the at-`3` specialization
`exists_finite_level_tame_generator_three` below; the genuine
local-structure core of the abelian at-`2` unramifiedness assembly
`localInertia_two_eq_one_of_no_two_torsion` below; Serre, *Corps
Locaux* IV В§1вҖ“2): for every finite Galois subextension `N` of the
algebraic closure of `в„ҡвӮӮбөҘ` there is a finite-level inertia element `t`
such that (a) every finite-level inertia element agrees with a power
of `t` up to an element of `2`-power order вҖ” the wild inertia `P` is
the (normal) `2`-Sylow of the inertia `I`, the tame quotient `I/P` is
CYCLIC (it embeds into the multiplicative group of the residue field
of `N` via `Пғ вҶҰ Пғ(ПҖ)/ПҖ` for a uniformizer `ПҖ`), `t` is any preimage
of a generator, and the error `(tбөҗ)вҒ»В№Пғ` lies in `P` вҖ” and (b) some
automorphism `ПҶ` of `N` (any Frobenius lift) conjugates `t` into `tВІ`
up to an element of `2`-power order: the tame character is
Frobenius-semilinear, `ПҶtПҶвҒ»В№ вүЎ t^q (mod P)` with
`q = |рқ’ӘбөҘ/рқ”ӘбөҘ| = |рқ”ҪвӮӮ| = 2`. The specialization supplies: faithfulness
of the Galois action on the integral closure (fraction-field
denominator clearing), `2 вҲҲ рқ”Ә` (lying over `рқ”ӘбөҘ = (2)`), and a
Frobenius lift acting as squaring on the residue field
(`Ideal.Quotient.stabilizerHom_surjective` against the squaring
automorphism, which is `ОәбөҘ`-linear because `|ОәбөҘ| = 2` by
`natCard_residue_quotient_toHeightOneSpectrum`). -/
theorem exists_finite_level_tame_frobenius_generator_two
    (N : IntermediateField
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)
        (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)))
    [FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N]
    [IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N] :
    вҲғ t вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
        (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N),
      (вҲҖ Пғ вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
          (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
            Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
          (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N),
        вҲғ m j : в„•, ((t ^ m)вҒ»В№ * Пғ) ^ 2 ^ j = 1) вҲ§
      (вҲғ ПҶ : N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N,
        вҲғ j : в„•, (ПҶ * t * ПҶвҒ»В№ * (t ^ 2)вҒ»В№) ^ 2 ^ j = 1) := by
  classical
  -- `2` lies in the maximal ideal downstairs, hence upstairs
  have h2O : (2 : OvвӮӮ) вҲҲ IsLocalRing.maximalIdeal OvвӮӮ := by
    rw [maximalIdeal_adicCompletionIntegers_eq_span Nat.prime_two]
    exact_mod_cast Ideal.mem_span_singleton_self ((2 : в„•) : OvвӮӮ)
  have h2R : (2 : IntegralClosure OvвӮӮ N) вҲҲ
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N) := by
    have h2 := (Ideal.mem_of_liesOver
      (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N))
      (IsLocalRing.maximalIdeal OvвӮӮ) (2 : OvвӮӮ)).mp h2O
    rwa [map_ofNat] at h2
  -- faithfulness of the Galois action on the integral closure
  haveI : IsFractionRing (IntegralClosure OvвӮӮ N) N :=
    IsIntegralClosure.isFractionRing_of_finite_extension OvвӮӮ KvвӮӮ N
      (IntegralClosure OvвӮӮ N)
  have halgmapinj : Function.Injective (algebraMap OvвӮӮ N) := by
    rw [IsScalarTower.algebraMap_eq OvвӮӮ KvвӮӮ N]
    exact (algebraMap KvвӮӮ N).injective.comp (IsFractionRing.injective OvвӮӮ KvвӮӮ)
  haveI : Module.IsTorsionFree OvвӮӮ N :=
    Module.isTorsionFree_iff_algebraMap_injective.mpr halgmapinj
  have hfaith : вҲҖ g : N вүғвӮҗ[KvвӮӮ] N,
      (вҲҖ a : IntegralClosure OvвӮӮ N, g вҖў a = a) вҶ’ g = 1 := by
    intro g hg
    refine AlgEquiv.ext fun x => ?_
    have halg : IsAlgebraic OvвӮӮ x :=
      (IsFractionRing.isAlgebraic_iff OvвӮӮ KvвӮӮ N).mpr
        (Algebra.IsAlgebraic.isAlgebraic x)
    obtain вҹЁc, hc0, hcxвҹ© := halg.exists_integral_multiple
    have hfix : g вҖў (c вҖў x) = c вҖў x := by
      have h1 := congrArg Subtype.val (hg вҹЁc вҖў x, hcxвҹ©)
      rwa [IntegralClosure.coe_smul] at h1
    rw [smul_comm] at hfix
    have hgx : g вҖў x = x := smul_right_injective N hc0 hfix
    simpa [AlgEquiv.smul_def] using hgx
  -- the residue field downstairs has two elements
  haveI hOmax : (IsLocalRing.maximalIdeal OvвӮӮ).IsMaximal :=
    IsLocalRing.maximalIdeal.isMaximal _
  have hcard : Nat.card (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ) = 2 := by
    have h1 := natCard_residue_quotient_toHeightOneSpectrum Nat.prime_two
    rwa [IsLocalRing.eq_maximalIdeal (Ideal.IsMaximal.under OvвӮӮ
      (IsLocalRing.maximalIdeal
        (IntegralClosure OvвӮӮ (AlgebraicClosure KvвӮӮ))))] at h1
  haveI hfinbase : Finite (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ) :=
    Nat.finite_of_card_ne_zero (by rw [hcard]; norm_num)
  have hpowq : вҲҖ y : OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ, y ^ 2 = y := by
    haveI : Fintype (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ) := Fintype.ofFinite _
    letI : Field (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ) :=
      Ideal.Quotient.field (IsLocalRing.maximalIdeal OvвӮӮ)
    intro y
    have h := FiniteField.pow_card y
    rwa [show Fintype.card (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ) = 2 from by
      rw [вҶҗ Nat.card_eq_fintype_card, hcard]] at h
  -- the residue field upstairs: characteristic `2`, finite
  haveI hRmax : (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)).IsMaximal :=
    IsLocalRing.maximalIdeal.isMaximal _
  have h20 : ((2 : в„•) : (IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) = 0 := by
    rw [вҶҗ map_natCast (Ideal.Quotient.mk
      (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)))]
    exact Ideal.Quotient.eq_zero_iff_mem.mpr (by exact_mod_cast h2R)
  haveI : CharP ((IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) 2 := by
    have h := CharP.ringChar_of_prime_eq_zero Nat.prime_two h20
    haveI := ringChar.charP ((IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N))
    exact CharP.congr _ h
  haveI : ExpChar ((IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) 2 :=
    ExpChar.prime Nat.prime_two
  haveI : Module.Finite OvвӮӮ (IntegralClosure OvвӮӮ N) :=
    IsIntegralClosure.finite OvвӮӮ KvвӮӮ N (IntegralClosure OvвӮӮ N)
  haveI : Module.Finite OvвӮӮ ((IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) :=
    Module.Finite.of_surjective
      (Ideal.Quotient.mkвӮҗ OvвӮӮ
        (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N))).toLinearMap
      (Ideal.Quotient.mkвӮҗ_surjective OvвӮӮ _)
  haveI : Module.Finite (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ)
      ((IntegralClosure OvвӮӮ N) в§ё
        IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) :=
    Module.Finite.of_restrictScalars_finite OvвӮӮ _ _
  haveI hfinQ : Finite ((IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) :=
    Module.finite_of_finite (OvвӮӮ в§ё IsLocalRing.maximalIdeal OvвӮӮ)
  -- the squaring automorphism of the residue field upstairs
  have hbij : Function.Bijective (frobenius ((IntegralClosure OvвӮӮ N) в§ё
      IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N)) 2) :=
    Finite.injective_iff_bijective.mp (frobenius_inj _ 2)
  have hfrE_apply : вҲҖ z, (RingEquiv.ofBijective _ hbij) z = z ^ 2 := fun z => rfl
  obtain вҹЁПҶ', hПҶ'вҹ© := Ideal.Quotient.stabilizerHom_surjective (N вүғвӮҗ[KvвӮӮ] N)
    (IsLocalRing.maximalIdeal OvвӮӮ)
    (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N))
    (AlgEquiv.ofRingEquiv (f := RingEquiv.ofBijective _ hbij)
      (fun y => by rw [hfrE_apply, вҶҗ map_pow, hpowq y]))
  have hПҶfrob : вҲҖ x : IntegralClosure OvвӮӮ N,
      (ПҶ' : N вүғвӮҗ[KvвӮӮ] N) вҖў x - x ^ 2 вҲҲ
        IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N) := by
    intro x
    have h1 : Ideal.Quotient.stabilizerHom
        (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N))
        (IsLocalRing.maximalIdeal OvвӮӮ) (N вүғвӮҗ[KvвӮӮ] N) ПҶ'
        (Ideal.Quotient.mk _ x) =
        Ideal.Quotient.mk _ ((ПҶ' : N вүғвӮҗ[KvвӮӮ] N) вҖў x) := rfl
    have h2 : Ideal.Quotient.stabilizerHom
        (IsLocalRing.maximalIdeal (IntegralClosure OvвӮӮ N))
        (IsLocalRing.maximalIdeal OvвӮӮ) (N вүғвӮҗ[KvвӮӮ] N) ПҶ'
        (Ideal.Quotient.mk _ x) = (Ideal.Quotient.mk _ x) ^ 2 := by
      rw [hПҶ']
      exact hfrE_apply _
    refine Ideal.Quotient.eq.mp ?_
    rw [вҶҗ h1, h2, map_pow]
  obtain вҹЁt, htmem, hgen, hjвҹ© :=
    exists_finite_level_tame_generator_of_frobenius hfaith Nat.prime_two
      (by exact_mod_cast h2R) (ПҶ' : N вүғвӮҗ[KvвӮӮ] N) hПҶfrob
  exact вҹЁt, htmem, hgen, (ПҶ' : N вүғвӮҗ[KvвӮӮ] N), hjвҹ©

end TameGeneratorGeneric

/-- **Finite-level tame ramification at `2`** (PROVEN 2026-07-24 by
forgetting the Frobenius clause of the strengthening
`exists_finite_level_tame_frobenius_generator_two` above вҖ” the at-`2`
twin of the at-`3` finite-level leaf
`exists_finite_level_tame_generator_three`; Serre, *Corps Locaux* IV
В§1вҖ“2): for every finite Galois subextension `N` of the algebraic
closure of `в„ҡвӮӮбөҘ` there is a finite-level inertia element `t` such
that every finite-level inertia element agrees with a power of `t` up
to an element of `2`-power order вҖ” the wild inertia `P` is the
(normal) `2`-Sylow of the inertia `I`, the tame quotient `I/P` is
CYCLIC (it embeds into the multiplicative group of the residue field
of `N` via `Пғ вҶҰ Пғ(ПҖ)/ПҖ` for a uniformizer `ПҖ`), `t` is any preimage
of a generator, and the error `(tбөҗ)вҒ»В№Пғ` lies in `P`. (No Frobenius
clause is needed at `2`: the downstream consumer kills the wild error
against cube-triviality rather than against commutativity.) -/
theorem exists_finite_level_tame_generator_two
    (N : IntermediateField
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)
        (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)))
    [FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N]
    [IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N] :
    вҲғ t вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
        (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N),
      вҲҖ Пғ вҲҲ (IsLocalRing.maximalIdeal (IntegralClosure
          (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
            Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
          (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N),
        вҲғ m j : в„•, ((t ^ m)вҒ»В№ * Пғ) ^ 2 ^ j = 1 := by
  obtain вҹЁt, htmem, hgen, -вҹ© := exists_finite_level_tame_frobenius_generator_two N
  exact вҹЁt, htmem, hgenвҹ©

