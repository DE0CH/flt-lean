theorem hasFlatProlongationAt_three_of_isFlatAt
    {k : Type u} [Finite k] [Field k] [Algebra ‚Ą§_[3] k]
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    {ŌĀ : GaloisRep ‚Ąö k V}
    (hflat : ŌĀ.IsFlatAt Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) :
    ŌĀ.HasFlatProlongationAt
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat := by
  classical
  set v := Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat
  -- flatness at the open ideal `‚ä•` of the discrete field `k`
  have h0 := hflat.cond ‚ä• (isOpen_discrete _)
