    have hlog2 : Real.log 2 ‚Č§ Real.log ‚ÄĖs‚ÄĖ := Real.log_le_log two_pos hs
    have hX1 : 1 ‚Č§ ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ := by
      have h4 : (1:‚ĄĚ) ‚Č§ Real.log 4 := by
        rw [Real.le_log_iff_exp_le (by norm_num)]
        exact (lt_trans Real.exp_one_lt_d9 (by norm_num)).le
      have h24 : (2:‚ĄĚ) * Real.log 2 = Real.log 4 := by
        rw [show (4:‚ĄĚ) = 2 ^ 2 by norm_num, Real.log_pow]
        push_cast
        ring
      have h2s : 2 * Real.log 2 ‚Č§ ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ :=
        mul_le_mul hs hlog2 (Real.log_nonneg (by norm_num)) (by linarith)
      linarith
    calc ‚ÄĖ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), Z C s‚ÄĖ
        ‚Č§ ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), ‚ÄĖZ C s‚ÄĖ :=
          norm_sum_le _ _
      _ ‚Č§ ‚ąĎ _C : ClassGroup (NumberField.RingOfIntegers K),
            Real.exp (M * ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) :=
          Finset.sum_le_sum fun C _ => le_trans (hB C s hs)
            (Real.exp_le_exp.mpr
              (mul_le_mul_of_nonneg_right
                (mul_le_mul_of_nonneg_right (Finset.le_sup' B (Finset.mem_univ C))
                  (by linarith)) hlogs0.le))
      _ = h * Real.exp (M * ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) := by
          rw [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, hhdef]
      _ ‚Č§ Real.exp ((M + Real.log h + 1) * ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) := by
          have hh0 : (0:‚ĄĚ) < h := lt_of_lt_of_le one_pos hh1
          have hexp : h * Real.exp (M * ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) =
              Real.exp (Real.log h + M * ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) := by
            rw [Real.exp_add, Real.exp_log hh0]
          rw [hexp, Real.exp_le_exp]
          have hkey : (Real.log h + 1) * 1 ‚Č§
              (Real.log h + 1) * (‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) :=
            mul_le_mul_of_nonneg_left hX1 (by linarith)
          nlinarith [hkey]

/-- **Euler-product nonvanishing of the Dedekind zeta Dirichlet series
