    intro hmem
    obtain ‚ü®r, hr‚ü© := IntermediateField.mem_bot.mp hmem
    have h1 : ŌÉ x‚āĀ = x‚āĀ := by rw [‚Üź hr]; exact ŌÉ.commutes r
    rw [hx‚āĀŌÉ] at h1
    have h2 : x‚āĀ + x‚āĀ = 0 := add_eq_zero_iff_eq_neg.mpr h1.symm
