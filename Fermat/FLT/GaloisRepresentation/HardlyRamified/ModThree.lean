          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) :
        GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) - 1) ^ 2 = 0 := by
  classical
  intro Пғ hПғ
  obtain вҹЁП„, hП„, c, heqвҹ© := localInertia_two_eq_map_padic hПғ
  set g' : О“ в„ҡ := Field.absoluteGaloisGroup.map (algebraMap в„ҡ
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ
  set m : О“ в„ҡ := Field.absoluteGaloisGroup.map (algebraMap в„ҡ в„ҡ_[2]) П„
    with hm
  -- (1) the determinant of `ПҒ g'` is `1`: it is the mod-3 cyclotomic
  -- character, conjugation-invariant and trivial on the inertia at `2`
  have hdetk : LinearMap.det (ПҒ g' : Module.End k V) = 1 := by
    have h := hПҒ.det g'
    rw [GaloisRep.det_apply] at h
    have hconj : cyclotomicCharacter (AlgebraicClosure в„ҡ) 3 g'.toRingEquiv =
        cyclotomicCharacter (AlgebraicClosure в„ҡ) 3 m.toRingEquiv := by
      rw [heq,
        show (c * m * cвҒ»В№).toRingEquiv =
          c.toRingEquiv * m.toRingEquiv * (c.toRingEquiv)вҒ»В№ from rfl,
        map_mul, map_mul, map_inv,
        mul_comm (cyclotomicCharacter (AlgebraicClosure в„ҡ) 3 c.toRingEquiv),
        mul_assoc, mul_inv_cancel, mul_one]
    rw [h, hconj]
    exact cyclotomicCharacter_algebraMap_eq_one_of_inertia_two (k := k) hП„
  -- (2) the tame structure at `2`: the functional `ПҖвӮӮ` is `ПҒ m`-invariant,
  -- so its conjugate `ПҖ'` is `ПҒ g'`-invariant and surjective
  obtain вҹЁПҖвӮӮ, hПҖsurj, Оҙ, hОҙвҹ© := hПҒ.isTameAtTwo
  have hОҙП„ : Оҙ П„ = 1 := by
    have h := (hОҙ П„ 0).2.1 hП„
    rwa [GaloisRep.ker, MonoidHom.mem_ker] at h
  have hПҖm : вҲҖ x : V, ПҖвӮӮ (ПҒ m x) = ПҖвӮӮ x := by
    intro x
    have h := (hОҙ П„ x).1
    rw [GaloisRep.map_apply, вҶҗ hm] at h
    rw [h, hОҙП„, Module.End.one_apply]
  set ПҖ' : V вҶ’вӮ—[k] k := ПҖвӮӮ.comp (ПҒ cвҒ»В№ : Module.End k V) with hПҖ'
  have hПҖ'surj : Function.Surjective ПҖ' := by
    intro r
    obtain вҹЁx, hxвҹ© := hПҖsurj r
    refine вҹЁПҒ c x, ?_вҹ©
    rw [hПҖ', LinearMap.comp_apply]
    have hcc : (ПҒ cвҒ»В№) ((ПҒ c) x) = x := by
      rw [вҶҗ Module.End.mul_apply, вҶҗ map_mul, inv_mul_cancel, map_one,
        Module.End.one_apply]
    rw [hcc, hx]
  have hПҖ'inv : вҲҖ x : V, ПҖ' (ПҒ g' x) = ПҖ' x := by
    intro x
    rw [hПҖ', LinearMap.comp_apply, LinearMap.comp_apply]
    have h1 : (ПҒ cвҒ»В№ : Module.End k V) * ПҒ g' =
        ПҒ m * (ПҒ cвҒ»В№ : Module.End k V) := by
      rw [вҶҗ map_mul, вҶҗ map_mul, heq]
      congr 1
      group
    have h2 := congrArg (fun F : Module.End k V => F x) h1
    simp only [Module.End.mul_apply] at h2
    rw [h2, hПҖm]
  -- (3) hence `det (ПҒ g' - 1) = 0`: the row of `ПҖ'`-values is a nonzero
  -- kernel covector of its matrix
  have hfr : Module.finrank k V = 2 :=
    Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
  have hdet0 : LinearMap.det ((ПҒ g' : Module.End k V) - 1) = 0 := by
    set bk : Module.Basis (Fin 2) k V := Module.finBasisOfFinrankEq k V hfr
    rw [вҶҗ LinearMap.det_toMatrix bk, вҶҗ Matrix.exists_vecMul_eq_zero_iff]
    refine вҹЁfun i => ПҖ' (bk i), ?_, ?_вҹ©
    В· intro h0
      obtain вҹЁx, hxвҹ© := hПҖ'surj 1
      have hzero : вҲҖ i, ПҖ' (bk i) = 0 := fun i => congrFun h0 i
      have hpx : ПҖ' x = 0 := by
        rw [вҶҗ bk.sum_repr x, map_sum]
        simp [map_smul, hzero]
      rw [hx] at hpx
      exact one_ne_zero hpx
    В· funext j
      simp only [Matrix.vecMul, dotProduct, LinearMap.toMatrix_apply,
        Pi.zero_apply]
      have hterm : вҲҖ i : Fin 2,
          ПҖ' (bk i) * (bk.repr (((ПҒ g' : Module.End k V) - 1) (bk j))) i =
          ПҖ' ((bk.repr (((ПҒ g' : Module.End k V) - 1) (bk j))) i вҖў bk i) := by
        intro i
        rw [map_smul, smul_eq_mul, mul_comm]
      rw [Finset.sum_congr rfl fun i _ => hterm i, вҶҗ map_sum, bk.sum_repr]
      simp only [LinearMap.sub_apply, Module.End.one_apply, map_sub, hПҖ'inv,
        sub_self]
  -- (4) transport both determinants to the matrix `N = u g'` over `K 3`
  set N : Matrix (Fin 2) (Fin 2) (Dickson.K 3) :=
    ((u g' : GL (Fin 2) (Dickson.K 3)) : Matrix (Fin 2) (Fin 2) (Dickson.K 3))
    with hN
  have hПғПҒ : вҲҖ g : О“ в„ҡ, (Slop.OddRep.baseChange (AlgebraicClosure k)
      (MonoidHomClass.toMonoidHom ПҒ)) g =
      LinearMap.baseChange (AlgebraicClosure k) (ПҒ g) := fun g => rfl
  have hNval : N = (LinearMap.toMatrix b b
      (LinearMap.baseChange (AlgebraicClosure k) (ПҒ g'))).map e := by
    rw [hN, hu g', hПғПҒ]
  have hdet_transport : вҲҖ f : Module.End k V,
      ((LinearMap.toMatrix b b
        (LinearMap.baseChange (AlgebraicClosure k) f)).map e).det =
      e (algebraMap k (AlgebraicClosure k) (LinearMap.det f)) := by
    intro f
    rw [show (LinearMap.toMatrix b b
        (LinearMap.baseChange (AlgebraicClosure k) f)).map вҮ‘e =
      (e : AlgebraicClosure k вҶ’+* Dickson.K 3).mapMatrix
        (LinearMap.toMatrix b b (LinearMap.baseChange (AlgebraicClosure k) f))
      from rfl]
    rw [вҶҗ RingHom.map_det]
    rw [LinearMap.det_toMatrix, LinearMap.det_baseChange]
    rfl
  have hNdet : N.det = 1 := by
    rw [hNval, hdet_transport, hdetk, map_one, map_one]
  have hNsub : N - 1 = (LinearMap.toMatrix b b (LinearMap.baseChange
      (AlgebraicClosure k) ((ПҒ g' : Module.End k V) - 1))).map e := by
    rw [hNval]
    have h1 : LinearMap.baseChange (AlgebraicClosure k)
        (1 : Module.End k V) =
        (LinearMap.id : (AlgebraicClosure k) вҠ—[k] V
          вҶ’вӮ—[AlgebraicClosure k] (AlgebraicClosure k) вҠ—[k] V) := by
      rw [show ((1 : Module.End k V) : V вҶ’вӮ—[k] V) = LinearMap.id from rfl,
        LinearMap.baseChange_id]
    have hpt : вҲҖ j : Fin 2, (LinearMap.baseChange (AlgebraicClosure k)
        ((ПҒ g' : Module.End k V) - 1)) (b j) =
        (LinearMap.baseChange (AlgebraicClosure k) (ПҒ g')) (b j) - b j := by
      intro j
      rw [LinearMap.baseChange_sub, LinearMap.sub_apply, h1,
        LinearMap.id_apply]
    ext i j
    simp only [Matrix.sub_apply, Matrix.map_apply, Matrix.one_apply,
      LinearMap.toMatrix_apply, hpt, map_sub, Finsupp.sub_apply,
      Module.Basis.repr_self, Finsupp.single_apply]
    split
    В· rename_i hij
      simp [hij]
    В· rename_i hij
      rw [if_neg (fun h => hij h.symm)]
      simp
  have hNone : (N - 1).det = 0 := by
    rw [hNsub, hdet_transport, hdet0, map_zero, map_zero]
  -- (5) the two determinants force tracelessness of the singular `N вҲ’ 1`
  have hdetM : (N - 1) 0 0 * (N - 1) 1 1 - (N - 1) 0 1 * (N - 1) 1 0 = 0 := by
    rw [вҶҗ Matrix.det_fin_two]
    exact hNone
  have htrM : (N - 1) 0 0 + (N - 1) 1 1 = 0 := by
    have e00 : (N - 1) 0 0 = N 0 0 - 1 := by simp [Matrix.sub_apply]
    have e01 : (N - 1) 0 1 = N 0 1 := by simp [Matrix.sub_apply]
    have e10 : (N - 1) 1 0 = N 1 0 := by simp [Matrix.sub_apply]
    have e11 : (N - 1) 1 1 = N 1 1 - 1 := by simp [Matrix.sub_apply]
    have hd1 : N 0 0 * N 1 1 - N 0 1 * N 1 0 = 1 := by
      rw [вҶҗ Matrix.det_fin_two]
      exact hNdet
    have hd0 := hdetM
    rw [e00, e01, e10, e11] at hd0
    rw [e00, e11]
    linear_combination hd1 - hd0
  -- (6) the 2Г—2 CayleyвҖ“Hamilton identity entrywise: a traceless singular
  -- 2Г—2 matrix squares to zero
  ext i j
  rw [pow_two, Matrix.mul_apply, Fin.sum_univ_two, Matrix.zero_apply]
  fin_cases i <;> fin_cases j <;> simp only [Fin.zero_eta, Fin.mk_one]
  В· linear_combination (N - 1) 0 0 * htrM - hdetM
  В· linear_combination (N - 1) 0 1 * htrM
  В· linear_combination (N - 1) 1 0 * htrM
  В· linear_combination (N - 1) 1 1 * htrM - hdetM

/-- **Cube-triviality of the local inertia image at `2`** (DECOMPOSED
2026-07-24 вҖ” the unipotence content is the sorry node
`map_localInertiaGroup_at_two_sub_one_sq_eq_zero` above; the
characteristic-`3` computation is proven here): every element of the
local inertia at `2` maps under the matrix form `u` to an element of
`GLвӮӮ(рқ”ҪМ„вӮғ)` whose cube is `1`.  Glue: for `N := g вҲ’ 1` with `NВІ = 0`,
`gВі = (N + 1)Ві = NВі + 3NВІ + 3N + 1 = 1` since `3 = 0` in
characteristic `3` and `NВі = NВІВ·N = 0`. -/
theorem map_localInertiaGroup_at_two_pow_three_eq_one {k : Type u} [Finite k]
    [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ПҒ : GaloisRep в„ҡ k V}
    (hПҒ : IsHardlyRamified (show Odd 3 by decide) hV ПҒ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) вҠ—[k] V))
    (e : AlgebraicClosure k вүғ+* Dickson.K 3)
    (u : О“ в„ҡ вҶ’* GL (Fin 2) (Dickson.K 3))
    (hu : вҲҖ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ)) g)).map e) :
    вҲҖ Пғ вҲҲ localInertiaGroup Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      (u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ)) ^ 3 = 1 := by
  intro Пғ hПғ
  have hN := map_localInertiaGroup_at_two_sub_one_sq_eq_zero V hV hПҒ b e u hu Пғ hПғ
  apply Units.ext
  rw [Units.val_pow_eq_pow_val, Units.val_one]
  set M : Matrix (Fin 2) (Fin 2) (Dickson.K 3) :=
    ((u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) :
      GL (Fin 2) (Dickson.K 3)) : Matrix (Fin 2) (Fin 2) (Dickson.K 3)) with hMdef
  have h3 : (3 : Matrix (Fin 2) (Fin 2) (Dickson.K 3)) = 0 := by
    exact_mod_cast CharP.cast_eq_zero (Matrix (Fin 2) (Fin 2) (Dickson.K 3)) 3
  have hcube : (M - 1) ^ 3 = 0 := by
    rw [pow_succ, hN, zero_mul]
  calc M ^ 3
      = (M - 1) ^ 3 + 3 * (M - 1) ^ 2 + 3 * (M - 1) + 1 := by noncomm_ring
    _ = 1 := by rw [hcube, h3]; simp

