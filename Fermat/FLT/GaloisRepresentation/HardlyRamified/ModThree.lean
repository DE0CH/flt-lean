/-- **The connectedвҖ“Г©tale inertia subgroup at `3`** (DECOMPOSED
2026-07-23 into the Hopf-package leaf
`exists_connectedEtale_subgroup_of_hopf_package` above вҖ” the
finite-flat/Raynaud content; the flatness-to-package assembly is
PROVEN here): the space of a representation FLAT at `3` (over a
finite char-3 coefficient field) carries an additive subgroup `U`
such that (i) every inertia displacement `ПҒ(Пғ)v вҲ’ v` lies in `U`,
and (ii) `U` contains no nonzero inertia-fixed vector. Assembly:
`ПҒ.IsFlatAt` at the open ideal `вҠҘ` of the discrete field `k`
produces the `GaloisRep.HasFlatProlongationAt` package for the
base change `ПҒ вҠ— (k в§ё вҠҘ)`; the coefficient collapse
`k в§ё вҠҘ вүғ+* k` (`RingEquiv.quotientBot`) induces a
`О“ в„ҡвӮғбөҘ`-equivariant additive isomorphism
`(k в§ё вҠҘ) вҠ—[k] V вүғ+ V` (tensor `congr` + `lid`), along which
`HasFlatProlongationAt.of_equiv` transports the package to `ПҒ`
itself; the leaf consumes the explicit package. -/
theorem exists_connectedEtale_subgroup_at_three
    {k : Type u} [Finite k] [Field k] [Algebra в„Ө_[3] k]
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    {ПҒ : GaloisRep в„ҡ k V}
    (hflat : ПҒ.IsFlatAt Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) :
    вҲғ U : AddSubgroup V,
      (вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat, вҲҖ v : V,
        ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ) v - v вҲҲ U) вҲ§
      (вҲҖ u вҲҲ U, (вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat,
        ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ) u = u) вҶ’
        u = 0) := by
  classical
  set v := Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat
  -- flatness at the open ideal `вҠҘ` of the discrete field `k`
  have h0 := hflat.cond вҠҘ (isOpen_discrete _)
  -- the coefficient collapse `k в§ё вҠҘ вүғвӮ—[k] k`
  let ПҶq : (k в§ё (вҠҘ : Ideal k)) вүғ+* k := RingEquiv.quotientBot k
  have hПҶalg : вҲҖ r : k, ПҶq (algebraMap k (k в§ё (вҠҘ : Ideal k)) r) = r :=
    fun _ => rfl
  let ПҶlin : (k в§ё (вҠҘ : Ideal k)) вүғвӮ—[k] k :=
    { ПҶq.toAddEquiv with
      map_smul' := fun r x => by
        show ПҶq (r вҖў x) = r вҖў ПҶq x
        rw [Algebra.smul_def, Algebra.smul_def, map_mul, hПҶalg,
          Algebra.algebraMap_self_apply] }
  -- the equivariant space identification `(k в§ё вҠҘ) вҠ—[k] V вүғ+ V`
  let e : (((ПҒ.baseChange (k в§ё (вҠҘ : Ideal k))).toLocal v).Space вүғ+
      ((ПҒ.toLocal v).Space)) :=
    ((TensorProduct.congr ПҶlin (LinearEquiv.refl k V)).trans
      (TensorProduct.lid k V)).toAddEquiv
  have he : вҲҖ (g : О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
      (x : ((ПҒ.baseChange (k в§ё (вҠҘ : Ideal k))).toLocal v).Space),
      e (g вҖў x) = g вҖў e x := by
    intro g x
    show e (((ПҒ.baseChange (k в§ё (вҠҘ : Ideal k))).toLocal v) g x) =
      ((ПҒ.toLocal v) g) (e x)
    induction x using TensorProduct.induction_on with
    | zero => simp
    | add a b ha hb => simp only [map_add, ha, hb]
    | tmul c y =>
      show ((TensorProduct.congr ПҶlin (LinearEquiv.refl k V)).trans
          (TensorProduct.lid k V)) (c вҠ—вӮң[k] ((ПҒ.toLocal v) g y)) =
        ((ПҒ.toLocal v) g) (((TensorProduct.congr ПҶlin
          (LinearEquiv.refl k V)).trans (TensorProduct.lid k V)) (c вҠ—вӮң[k] y))
      simp only [LinearEquiv.trans_apply, TensorProduct.congr_tmul,
        LinearEquiv.refl_apply, TensorProduct.lid_tmul, map_smul]
  -- transport the package to `ПҒ` itself and hand it to the leaf
  have hpro : ПҒ.HasFlatProlongationAt v := h0.of_equiv _ e he
  obtain вҹЁG, i1, i2, i3, i4, i5, f, hbijвҹ© := hpro
  letI := i1
  letI := i2
  letI := i3
  letI := i4
  letI := i5
  exact exists_connectedEtale_subgroup_of_hopf_package V (ПҒ := ПҒ) G f hbij

