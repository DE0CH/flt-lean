  calc вҲ‘ k вҲҲ Finset.Icc 1 n, classIdealCount K C k
      = вҲ‘ k : Finset.Icc 1 n, classIdealCount K C (k : в„•) :=
        (Finset.sum_coe_sort (Finset.Icc 1 n) (classIdealCount K C)).symm
    _ = Nat.card (ОЈ k : Finset.Icc 1 n,
          {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
            Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = (k : в„•) вҲ§
