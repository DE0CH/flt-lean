    simpa [AlgEquiv.mul_apply] using h
  have hx‚āĀŌÉ : ŌÉ x‚āĀ = -x‚āĀ := by
    rw [hx‚āĀdef, map_sub, hŌÉŌÉ]
    ring
  have hx‚āĀ0 : x‚āĀ ‚Č† 0 := by
    intro h0
    have hŌÉőĪ : ŌÉ őĪ = őĪ := (sub_eq_zero.mp (hx‚āĀdef ‚Ėł h0)).symm
    have hfixőĪ : ‚ąÄ g : K ‚ČÉ‚āź[‚Ąö] K, g ‚ÄĘ őĪ = őĪ := by
