        (GL (Fin 2) (Dickson.K 3)))).comp u.range.subtype) ŌÄ.range hmemŌÄ) := by
    rintro ‚ü®y, hy‚ü©
    obtain ‚ü®g, rfl‚ü© := hy
    exact ‚ü®‚ü®u g, ‚ü®g, rfl‚ü©‚ü©, Subtype.ext (hŌÄ g).symm‚ü©
  -- (5) assemble via the counting core
  refine card_ge_48_of_index_two_kernel _ hSidx _ hŌąsurj
    (dickson_exceptional_subgroup_card hcase) ?_
  -- the lift obstruction: an element of the determinant-one part over
  -- an involution of `ŌÄ.range` cannot square to `1`
  intro s hsS hord2 hcontra
  have hŌąne : MonoidHom.codRestrict ((QuotientGroup.mk' (Subgroup.center
      (GL (Fin 2) (Dickson.K 3)))).comp u.range.subtype) ŌÄ.range hmemŌÄ s ‚Č† 1 := by
    intro h1
    rw [h1, orderOf_one] at hord2
