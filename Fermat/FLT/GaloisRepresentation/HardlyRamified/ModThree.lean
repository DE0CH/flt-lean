    have hval_lt : ((PadicInt.toZModPow 1)
        ((cyclotomicCharacter (AlgebraicClosure в„ҡ) 3
          (g'.toRingEquiv) : в„Ө_[3]ЛЈ) : в„Ө_[3])).val < 3 ^ 1 :=
      ZMod.val_lt _
