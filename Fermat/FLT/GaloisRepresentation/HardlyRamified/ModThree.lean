  -- leaf, one top layer at a time
  have hkey : вҲҖ B : в„•, (вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g ^ 2 ^ B = 1) вҶ’
      вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g = 1 := by
    intro B
    induction B with
    | zero =>
      intro hB g hg
      simpa using hB g hg
    | succ B ih =>
      intro hB
      have hquad : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g ^ 2 ^ B = 1 := by
        intro g hg
        refine anti_invariant_quadratic_character_eq_one_ray_class V hV hПҒ Оё'
          htriv' d hd x hx hОё'x ПғвӮҖ hПғвӮҖ (fun g' => ОҪ g' ^ 2 ^ B)
          ?_ ?_ ?_ ?_ ?_ ?_ g hg
        В· intro g' h' hg' hh'
          rw [hОҪmul g' h' hg' hh', mul_pow]
        В· intro g' hg'
          exact pow_ne_zero _ (hОҪne0 g' hg')
        В· intro g' hg'
          rw [hОҪanti g' hg', inv_pow]
        В· intro g' hПҒ1
          rw [hОҪker g' hПҒ1, one_pow]
        В· intro g' hg'
          rw [вҶҗ pow_mul, вҶҗ pow_succ]
          exact hB g' hg'
        В· intro q hq hq3 c Пғ hПғ hОё
          rw [hОҪunr' q hq hq3 c Пғ hПғ hОё, one_pow]
      exact ih hquad
  exact hkey A hstep1

