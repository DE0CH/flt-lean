            show (c * m * cвҒ»В№).toRingEquiv =
              c.toRingEquiv * m.toRingEquiv * (c.toRingEquiv)вҒ»В№ from rfl,
            map_mul, map_mul, map_inv,
            mul_comm (cyclotomicCharacter (AlgebraicClosure в„ҡ) 3
              c.toRingEquiv),
            mul_assoc, mul_inv_cancel, mul_one]
        rw [hconj]
        exact cyclotomicCharacter_algebraMap_eq_one_of_inertia_two (k := k) hП„
      В· exact cyclotomicCharacter_algebraMap_eq_one_of_inertia_ne_two_three
          q hq hq2 hq3 hПғ
    have hprod := hПҮprod gПғ hОё1
    rw [RingHom.comp_apply, RingHom.comp_apply, hcyc, map_one, map_one,
      hПҮ1, one_mul] at hprod
    rw [hОҪdef]
    simp only
    rw [hПҮ1, hprod, inv_one, mul_one]
  -- (6) the ray-class leaf: `ОҪ = 1` on `H`, i.e. `ПҮвӮҖ = ПҮвӮҖ^{ПғвӮҖ}`
  intro g hg
  have h1 := anti_equivariant_ratio_character_eq_one_ray_class V hV hПҒ Оё'
    htriv' d hd x hx hОё'x ПғвӮҖ hПғвӮҖ ОҪ hОҪmul hОҪne0 hОҪanti hОҪker hОҪord hОҪunr g hg
  rw [hОҪdef] at h1
  simp only at h1
  have hne := hПҮne0 _ (hHconj g hg)
  field_simp [hne] at h1
  exact h1

