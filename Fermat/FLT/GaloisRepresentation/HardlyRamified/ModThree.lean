    _ = Nat.card ((C : ClassGroup (NumberField.RingOfIntegers K)) √ó
          {I : {I : (Ideal (NumberField.RingOfIntegers K))‚Āį //
            Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} //
