/-- **Units of `‚Ą§‚āÉ` map to `¬Ī1` in characteristic 3** (PROVEN
2026-07-22): a `3`-adic unit is `‚Č° 1` or `2 (mod 3)`
(`PadicInt.zmodRepr`), and any ring homomorphism to a char-3 ring
kills the maximal ideal `(3)`. -/
theorem padic_three_ringHom_pm_one {R : Type*} [CommRing R] [CharP R 3]
    (f : ‚Ą§_[3] ‚Üí+* R) (x : ‚Ą§_[3]ň£) :
    f (x : ‚Ą§_[3]) = 1 ‚ą® f (x : ‚Ą§_[3]) = -1 := by
  haveI : Fact (Nat.Prime 3) := ‚ü®Nat.prime_three‚ü©
  have hspec := PadicInt.zmodRepr_spec (x : ‚Ą§_[3])
  have hfx : f (x : ‚Ą§_[3]) = ((PadicInt.zmodRepr (x : ‚Ą§_[3]) : ‚Ąē) : R) := by
    have hmem := hspec.2
    rw [PadicInt.maximalIdeal_eq_span_p, Ideal.mem_span_singleton] at hmem
    obtain ‚ü®w, hw‚ü© := hmem
    have h0 : f ((x : ‚Ą§_[3]) - (PadicInt.zmodRepr (x : ‚Ą§_[3]) : ‚Ąē)) = 0 := by
      rw [hw, map_mul]
      have h31 : f ((3 : ‚Ąē) : ‚Ą§_[3]) = 0 := by
        rw [map_natCast, CharP.cast_eq_zero R 3]
      rw [h31, zero_mul]
    rw [map_sub, sub_eq_zero] at h0
    rw [h0, map_natCast]
  have hne0 : PadicInt.zmodRepr (x : ‚Ą§_[3]) ‚Č† 0 := by
    intro h0
    have hmem : (x : ‚Ą§_[3]) ‚ąą IsLocalRing.maximalIdeal ‚Ą§_[3] := by
      have h1 := hspec.2
      rwa [h0, Nat.cast_zero, sub_zero] at h1
    exact mem_nonunits_iff.mp ((IsLocalRing.mem_maximalIdeal _).mp hmem) (Units.isUnit x)
  have h12 : PadicInt.zmodRepr (x : ‚Ą§_[3]) = 1 ‚ą® PadicInt.zmodRepr (x : ‚Ą§_[3]) = 2 := by
    omega
  rcases h12 with h | h
  ¬∑ left
    rw [hfx, h, Nat.cast_one]
  ¬∑ right
    rw [hfx, h]
    have h30 : ((3 : ‚Ąē) : R) = 0 := CharP.cast_eq_zero R 3
    push_cast at h30 ‚äĘ
    linear_combination h30

/-- **The 48-element counting core** (PROVEN 2026-07-22): a finite
group `N` with an index-two subgroup `S` (the determinant-one part)
and a homomorphism `Ōą` onto `P` (the projectivization) has order
`‚Č• 48`, provided (i) every subgroup of `P` of index `‚Č§ 2` ‚ÄĒ in
particular the image of `S` ‚ÄĒ is even of order `‚Č• 12`, and (ii) no
element of `S` over an involution of `P` squares to `1` (the
`‚ąí1 ‚ąą SL‚āā` lift). Chain:
`|N| = 2¬∑|S| = 2¬∑|Ōą(S)|¬∑|ker(Ōą|_S)| ‚Č• 2¬∑12¬∑2 = 48` ‚ÄĒ the kernel is
nontrivial because Cauchy's theorem puts an involution in `Ōą(S)`,
whose lift `s` has `s¬≤ ‚ąą ker(Ōą|_S) \ {1}` by (ii). -/
theorem card_ge_48_of_index_two_kernel {N P : Type*} [Group N] [Finite N] [Group P]
    (S : Subgroup N) (hSidx : S.index = 2)
    (Ōą : N ‚Üí* P) (hŌą : Function.Surjective Ōą)
    (hcase : ‚ąÄ H : Subgroup P, H.index ‚ą£ 2 ‚Üí 2 ‚ą£ Nat.card H ‚ąß 12 ‚Č§ Nat.card H)
    (hlift : ‚ąÄ s : N, s ‚ąą S ‚Üí orderOf (Ōą s) = 2 ‚Üí s * s ‚Č† 1) :
    48 ‚Č§ Nat.card N := by
  haveI : Fact (Nat.Prime 2) := ‚ü®Nat.prime_two‚ü©
  haveI : Finite P := Finite.of_surjective Ōą hŌą
  obtain ‚ü®hH'even, hH'12‚ü© := hcase (S.map Ōą) (hSidx ‚Ėł S.index_map_dvd hŌą)
  obtain ‚ü®y, hy2‚ü© := exists_prime_orderOf_dvd_card' (G := S.map Ōą) 2 hH'even
  have hzord : orderOf (y : P) = 2 := by
    rw [‚Üź hy2]
    exact orderOf_injective (S.map Ōą).subtype (S.map Ōą).subtype_injective y
  obtain ‚ü®s, hsS, hsz‚ü© := Subgroup.mem_map.mp y.2
  have hs2ker : Ōą (s * s) = 1 := by
    rw [map_mul, hsz, ‚Üź pow_two, ‚Üź hzord]
    exact pow_orderOf_eq_one _
  have hs2ne : s * s ‚Č† 1 := hlift s hsS (by rw [hsz]; exact hzord)
  have hrange : (Ōą.comp S.subtype).range = S.map Ōą := by
    ext w
    constructor
    ¬∑ rintro ‚ü®t, rfl‚ü©
      exact Subgroup.mem_map.mpr ‚ü®(t : N), t.2, rfl‚ü©
    ¬∑ intro hw
      obtain ‚ü®t, ht, rfl‚ü© := Subgroup.mem_map.mp hw
      exact ‚ü®‚ü®t, ht‚ü©, rfl‚ü©
  have hcardS : Nat.card S = Nat.card (S.map Ōą) * Nat.card (Ōą.comp S.subtype).ker := by
    have h1 := Subgroup.card_eq_card_quotient_mul_card_subgroup (Ōą.comp S.subtype).ker
    rw [Nat.card_congr (QuotientGroup.quotientKerEquivRange (Ōą.comp S.subtype)).toEquiv,
      hrange] at h1
    exact h1
  have hker2 : 2 ‚Č§ Nat.card (Ōą.comp S.subtype).ker := by
    have hmem : (‚ü®s, hsS‚ü© : S) * ‚ü®s, hsS‚ü© ‚ąą (Ōą.comp S.subtype).ker := by
      rw [MonoidHom.mem_ker]
      exact hs2ker
    haveI : Nontrivial (Ōą.comp S.subtype).ker :=
      ‚ü®‚ü®‚ü®(‚ü®s, hsS‚ü© : S) * ‚ü®s, hsS‚ü©, hmem‚ü©, 1, fun hcontra => hs2ne (by
        have h0 := congrArg (fun w : (Ōą.comp S.subtype).ker => ((w : S) : N)) hcontra
        simpa using h0)‚ü©‚ü©
    exact Finite.one_lt_card
  have hfin := S.card_mul_index
  rw [hSidx, hcardS] at hfin
  calc (48 : ‚Ąē) = 12 * 2 * 2 := by norm_num
    _ ‚Č§ Nat.card (S.map Ōą) * Nat.card (Ōą.comp S.subtype).ker * 2 :=
        Nat.mul_le_mul (Nat.mul_le_mul hH'12 hker2) le_rfl
    _ = Nat.card N := hfin

