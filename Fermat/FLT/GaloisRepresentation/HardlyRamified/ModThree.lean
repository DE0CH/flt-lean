/-- **Commutative-valued characters without `2`-torsion are
unramified at `2`** (DECOMPOSED 2026-07-24 into the finite-level
Frobenius-tame leaf `exists_finite_level_tame_frobenius_generator_two`
above; the profinite assembly is PROVEN, mirroring
`exists_localInertia_three_generator`): a homomorphism of `О“ в„ҡ` with
open kernel into a commutative group without `2`-torsion kills the
image of the whole local inertia at `2`. Assembly: the composite with
`О“ в„ҡвӮӮбөҘ вҶ’ О“ в„ҡ` factors through a finite Galois level `N`
(`krullTopology_mem_nhds_one_iff_of_normal` +
`MonoidHom.liftOfSurjective` over
`AlgEquiv.restrictNormalHom_surjective`); the finite-level leaf hands
a tame generator `tМ„` and a Frobenius `ПҶ` with `ПҶtМ„ПҶвҒ»В№ вүЎ tМ„ВІ` modulo
`2`-power-order errors; in the abelian `2`-torsion-free target the
errors die and conjugation is trivial, so `f tМ„ = (f tМ„)ВІ`, i.e.
`f tМ„ = 1`; every finite-level inertia element is `tМ„^m` times a
`2`-power-order error, so its image is `1`, and
`restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_two` maps the
full local inertia into the finite level. This is the profinite form
of "abelian extensions of `в„ҡвӮӮ` are unramified at the tame level":
the tame relation `ПҶП„ПҶвҒ»В№ = П„^q` abelianizes to `П„^{q-1} = П„^{2-1} =
П„ = 1`. -/
theorem localInertia_two_eq_one_of_no_two_torsion {A : Type*} [CommGroup A]
    (h2 : вҲҖ a : A, a ^ 2 = 1 вҶ’ a = 1)
    (u : О“ в„ҡ вҶ’* A) (hopen : IsOpen (u.ker : Set (О“ в„ҡ))) :
    вҲҖ Пғ вҲҲ localInertiaGroup Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 := by
  classical
  set v := Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat
  set Emb := Field.absoluteGaloisGroup.map (algebraMap в„ҡ
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
  -- `2`-power-order elements die in the `2`-torsion-free target
  have h2pow : вҲҖ (a : A) (j : в„•), a ^ 2 ^ j = 1 вҶ’ a = 1 := by
    intro a j
    induction j with
    | zero => intro h; simpa using h
    | succ n ih =>
      intro h
      apply ih
      apply h2
      rw [вҶҗ pow_mul, вҶҗ pow_succ]
      exact h
  -- the open kernel of the composite contains a finite Galois level
  have hopen' : IsOpen (((u.comp Emb.toMonoidHom).ker :
      Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
      Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) := by
    have hpre : (((u.comp Emb.toMonoidHom).ker :
        Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
        Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) =
        Emb вҒ»В№' (u.ker : Set (О“ в„ҡ)) := rfl
    rw [hpre]
    exact hopen.preimage Emb.continuous
  have hnhds : (((u.comp Emb.toMonoidHom).ker :
      Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
      Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) вҲҲ
      nhds (1 : О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)) :=
    hopen'.mem_nhds (one_mem _)
  obtain вҹЁN, hfdN, hnormN, hleвҹ© :=
    (krullTopology_mem_nhds_one_iff_of_normal
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
      _).mp hnhds
  haveI := hfdN
  haveI := hnormN
  haveI : Algebra.IsSeparable
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  haveI : IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N := вҹЁвҹ©
  -- the composite factors through the finite Galois group
  have hsurj : Function.Surjective (AlgEquiv.restrictNormalHom N :
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)
        вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v]
      AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)) вҶ’*
      (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N)) :=
    AlgEquiv.restrictNormalHom_surjective _
  have hkerle : (AlgEquiv.restrictNormalHom (F :=
      IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N).ker вүӨ
      (u.comp Emb.toMonoidHom).ker := by
    rw [IntermediateField.restrictNormalHom_ker]
    intro g hg
    exact hle hg
  set f : (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N) вҶ’* A :=
    (AlgEquiv.restrictNormalHom N).liftOfSurjective hsurj
      вҹЁu.comp Emb.toMonoidHom, hkerleвҹ©
  have hf : вҲҖ Пғ, f (AlgEquiv.restrictNormalHom N Пғ) = u (Emb Пғ) := fun Пғ =>
    MonoidHom.liftOfRightInverse_comp_apply _ _ _ _ Пғ
  -- the finite-level tame generator dies: Frobenius conjugation is
  -- trivial in the abelian target, so `f tМ„ = (f tМ„)ВІ`
  obtain вҹЁtbar, htbarI, htbargen, ПҶ, j0, hПҶвҹ© :=
    exists_finite_level_tame_frobenius_generator_two N
  have hft : f tbar = 1 := by
    have h1 : f (ПҶ * tbar * ПҶвҒ»В№ * (tbar ^ 2)вҒ»В№) = 1 :=
      h2pow _ j0 (by rw [вҶҗ map_pow, hПҶ, map_one])
    rw [map_mul, map_mul, map_mul, map_inv, map_inv, map_pow] at h1
    have hconj : f ПҶ * f tbar * (f ПҶ)вҒ»В№ = f tbar := by
      rw [mul_comm (f ПҶ) (f tbar), mul_assoc, mul_inv_cancel, mul_one]
    rw [hconj] at h1
    have h2' : f tbar = f tbar ^ 2 := mul_inv_eq_one.mp h1
    have h3' : f tbar * (f tbar)вҒ»В№ = f tbar ^ 2 * (f tbar)вҒ»В№ :=
      congrArg (fun x => x * (f tbar)вҒ»В№) h2'
    rw [mul_inv_cancel, pow_two, mul_assoc, mul_inv_cancel, mul_one] at h3'
    exact h3'.symm
  -- every inertia element maps to a power of `f tМ„ = 1`
  intro Пғ hПғ
  obtain вҹЁm, j, hmjвҹ© := htbargen (AlgEquiv.restrictNormalHom N Пғ)
    (restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_two N Пғ hПғ)
  have h1 : f ((tbar ^ m)вҒ»В№ * AlgEquiv.restrictNormalHom N Пғ) = 1 :=
    h2pow _ j (by rw [вҶҗ map_pow, hmj, map_one])
  rw [map_mul, map_inv, map_pow] at h1
  calc u (Emb Пғ) = f (AlgEquiv.restrictNormalHom N Пғ) := (hf Пғ).symm
    _ = (f tbar) ^ m := (inv_mul_eq_one.mp h1).symm
    _ = 1 := by rw [hft, one_pow]

/-- **Minkowski's discriminant bound at degree `6`** (PROVEN
2026-07-24 вҖ” the concrete arithmetic core of the `в„ҡ(вҲҡ-3)` ray-class
elimination below): a sextic number field has `|d_K| > 432 = 2вҒҙВ·3Ві`.
This is mathlib's geometry-of-numbers bound
`NumberField.abs_discr_ge'` вҖ” `|d_K| вүҘ n^{2n}/((4/ПҖ)^{2rвӮӮ}В·(n!)ВІ)`
вҖ” evaluated at `n = 6` against the WORST signature (totally complex,
`2rвӮӮ вүӨ 6`, and `4/ПҖ > 1`), where it reads
`|d_K| вүҘ 6В№ВІВ·ПҖвҒ¶/(4вҒ¶В·720ВІ) = 985.3вҖҰ`, already with the crude `ПҖ > 3`:
`6В№ВІВ·3вҒ¶ = 1586874322944 > 432В·4вҒ¶В·720ВІ = 917294284800`. Note `432` is
exactly the tame bound `2^{n(1-1/3)}В·3^{n(1-1/2)}` at `n = 6` вҖ” the
largest discriminant a sextic field unramified outside `{2, 3}`,
tame of `e вҲЈ 3` at `2` and `e вҲЈ 2` at `3`, could have вҖ” so this
lemma says NO such field exists; it replaces the conductor-`(2)`
ray-class computation `Cl_{(2)}(в„ҡ(вҲҡ-3)) = 1` (which mathlib cannot
state) by a pure discriminant comparison. -/
theorem minkowski_sextic_discr_bound (K : Type*) [Field K] [NumberField K]
    (h6 : Module.finrank в„ҡ K = 6) :
    (432 : в„Ө) < |NumberField.discr K| := by
  have h := NumberField.abs_discr_ge' K
  rw [h6] at h
  have hpi4 : (1 : в„қ) вүӨ 4 / Real.pi := by
    rw [le_div_iffвӮҖ Real.pi_pos]
    linarith [Real.pi_le_four]
  have hr2 : 2 * NumberField.InfinitePlace.nrComplexPlaces K вүӨ 6 := by
    have := NumberField.InfinitePlace.card_add_two_mul_card_eq_rank K
    omega
  have hmono : (4 / Real.pi) ^ (2 * NumberField.InfinitePlace.nrComplexPlaces K) вүӨ
      (4 / Real.pi) ^ (6 : в„•) :=
    pow_le_pow_rightвӮҖ hpi4 hr2
  have hfact : ((6 : в„•).factorial : в„қ) = 720 := by norm_num [Nat.factorial]
  have key : (432 : в„қ) < ((6 : в„•) : в„қ) ^ (2 * 6) /
      ((4 / Real.pi) ^ (2 * NumberField.InfinitePlace.nrComplexPlaces K) *
        ((6 : в„•).factorial : в„қ) ^ 2) := by
    rw [hfact]
    have h2 : ((6 : в„•) : в„қ) ^ (2 * 6) = 2176782336 := by norm_num
    rw [h2, lt_div_iffвӮҖ (by positivity)]
    have hb : (4 / Real.pi) ^ (2 * NumberField.InfinitePlace.nrComplexPlaces K) вүӨ
        (4 / 3) ^ (6 : в„•) := by
      refine hmono.trans ?_
      gcongr
      linarith [Real.pi_gt_three]
    calc (432 : в„қ) *
          ((4 / Real.pi) ^ (2 * NumberField.InfinitePlace.nrComplexPlaces K) * 720 ^ 2)
        вүӨ 432 * ((4 / 3) ^ (6 : в„•) * 720 ^ 2) := by gcongr
      _ < 2176782336 := by norm_num
  have hlt : (432 : в„қ) < |(NumberField.discr K : в„қ)| := by
    calc (432 : в„қ) < _ := key
      _ вүӨ _ := h
      _ = |(NumberField.discr K : в„қ)| := by push_cast; ring
  exact_mod_cast hlt

/-- **LagrangeвҖ“Cauchy exponent bound, order-`6` ambient, exponent
`3`** (PROVEN 2026-07-24 вҖ” group-theoretic glue for the sextic
elimination): a subgroup of a group of order `6` all of whose
elements are cubes of the identity has order dividing `3`. Lagrange
gives `#X вҲЈ 6`; if `2 вҲЈ #X` Cauchy produces an element of order `2`,
which the exponent-`3` hypothesis forces to be trivial вҖ” so `#X` is
an odd divisor of `6`. -/
theorem card_dvd_three_of_card_six_of_cube_eq_one {Q : Type*} [Group Q]
    (hQ : Nat.card Q = 6) (X : Subgroup Q)
    (hexp : вҲҖ x : Q, x вҲҲ X вҶ’ x ^ 3 = 1) : Nat.card X вҲЈ 3 := by
  haveI : Finite Q := Nat.finite_of_card_ne_zero (by omega)
  have hdvd : Nat.card X вҲЈ 6 := hQ в–ё Subgroup.card_subgroup_dvd_card X
  have h2 : В¬ (2 вҲЈ Nat.card X) := by
    intro h2
    haveI : Fact (Nat.Prime 2) := вҹЁNat.prime_twoвҹ©
    have := Fintype.ofFinite X
    rw [Nat.card_eq_fintype_card] at h2
    obtain вҹЁy, hyвҹ© := exists_prime_orderOf_dvd_card (G := X) 2 h2
    have hy3 : y ^ 3 = 1 := by
      have h := hexp y.1 y.2
      ext
      push_cast
      exact h
    have hy2 : y ^ 2 = 1 := by
      rw [вҶҗ hy]
      exact pow_orderOf_eq_one y
    have hy1 : y = 1 := by
      have hh : y ^ 3 = y ^ 2 * y := by rw [pow_succ]
      rw [hy3, hy2, one_mul] at hh
      exact hh.symm
    rw [hy1] at hy
    simp at hy
  have hpos : 0 < Nat.card X := Nat.card_pos
  have hle : Nat.card X вүӨ 6 := Nat.le_of_dvd (by norm_num) hdvd
  interval_cases h : (Nat.card X) <;> revert hdvd h2 <;> decide

/-- **LagrangeвҖ“Cauchy exponent bound, order-`6` ambient, exponent
`2`** (PROVEN 2026-07-24 вҖ” the mirror of
`card_dvd_three_of_card_six_of_cube_eq_one`): a subgroup of a group
of order `6` all of whose elements square to the identity has order
dividing `2`. -/
theorem card_dvd_two_of_card_six_of_sq_eq_one {Q : Type*} [Group Q]
    (hQ : Nat.card Q = 6) (X : Subgroup Q)
    (hexp : вҲҖ x : Q, x вҲҲ X вҶ’ x ^ 2 = 1) : Nat.card X вҲЈ 2 := by
  haveI : Finite Q := Nat.finite_of_card_ne_zero (by omega)
  have hdvd : Nat.card X вҲЈ 6 := hQ в–ё Subgroup.card_subgroup_dvd_card X
  have h3 : В¬ (3 вҲЈ Nat.card X) := by
    intro h3
    haveI : Fact (Nat.Prime 3) := вҹЁNat.prime_threeвҹ©
    have := Fintype.ofFinite X
    rw [Nat.card_eq_fintype_card] at h3
    obtain вҹЁy, hyвҹ© := exists_prime_orderOf_dvd_card (G := X) 3 h3
    have hy2 : y ^ 2 = 1 := by
      have h := hexp y.1 y.2
      ext
