/-- **Coordinates from a non-proportional pair** (PROVEN 2026-07-23 вҖ”
elementary 2Г—2 linear algebra for the induced-structure glue of the
dihedral ray-class decomposition): if `v вү  0` and `w` is not a scalar
multiple of `v`, then every vector of `Fin 2 вҶ’ F` is a linear
combination of `v` and `w`. Cramer-style explicit coefficients over
the nonzero cross-determinant `v 0 * w 1 - v 1 * w 0`. -/
theorem exists_smul_add_smul_of_not_proportional {F : Type*} [Field F]
    {v w : Fin 2 вҶ’ F} (hv : v вү  0)
    (hnp : В¬ вҲғ c : F, w = c вҖў v) (x : Fin 2 вҶ’ F) :
    вҲғ Оұ ОІ : F, x = Оұ вҖў v + ОІ вҖў w := by
  classical
  have hcross : v 0 * w 1 - v 1 * w 0 вү  0 := by
    intro h
    apply hnp
    have hvi : v 0 вү  0 вҲЁ v 1 вү  0 := by
      by_contra hcon
      push Not at hcon
      refine hv (funext fun i => ?_)
      fin_cases i
      В· exact hcon.1
      В· exact hcon.2
    rcases hvi with h0 | h1
    В· refine вҹЁw 0 / v 0, funext fun i => ?_вҹ©
      fin_cases i
      В· exact (div_mul_cancelвӮҖ (w 0) h0).symm
      В· show w 1 = w 0 / v 0 * v 1
        field_simp
        linear_combination h
    В· refine вҹЁw 1 / v 1, funext fun i => ?_вҹ©
      fin_cases i
      В· show w 0 = w 1 / v 1 * v 0
        field_simp
        linear_combination -h
      В· exact (div_mul_cancelвӮҖ (w 1) h1).symm
  refine вҹЁ(x 0 * w 1 - x 1 * w 0) / (v 0 * w 1 - v 1 * w 0),
    (v 0 * x 1 - v 1 * x 0) / (v 0 * w 1 - v 1 * w 0),
    funext fun i => ?_вҹ©
  fin_cases i
  В· show x 0 = (x 0 * w 1 - x 1 * w 0) / (v 0 * w 1 - v 1 * w 0) * v 0 +
      (v 0 * x 1 - v 1 * x 0) / (v 0 * w 1 - v 1 * w 0) * w 0
    rw [div_mul_eq_mul_div, div_mul_eq_mul_div, вҶҗ add_div,
      eq_div_iff hcross]
    ring
  В· show x 1 = (x 0 * w 1 - x 1 * w 0) / (v 0 * w 1 - v 1 * w 0) * v 1 +
      (v 0 * x 1 - v 1 * x 0) / (v 0 * w 1 - v 1 * w 0) * w 1
    rw [div_mul_eq_mul_div, div_mul_eq_mul_div, вҶҗ add_div,
      eq_div_iff hcross]
    ring

