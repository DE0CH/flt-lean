  obtain ‚ü®ő∂, hő∂‚ü© := HasEnoughRootsOfUnity.exists_primitiveRoot
    (AlgebraicClosure ‚Ąö) 3
  have hzprim : IsPrimitiveRoot
      (AlgebraicClosure.map (algebraMap ‚Ąö ‚Ąö_[2]) ő∂) 3 :=
    hő∂.map_of_injective (AlgebraicClosure.map (algebraMap ‚Ąö ‚Ąö_[2])).injective
  set z : AlgebraicClosure ‚Ąö_[2] :=
    AlgebraicClosure.map (algebraMap ‚Ąö ‚Ąö_[2]) ő∂
  have hz3 : z ^ 3 = 1 := hzprim.pow_eq_one
