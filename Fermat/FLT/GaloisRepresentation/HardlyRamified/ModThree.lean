/-- **The tame generator of the inertia image at `3`** (DECOMPOSED
2026-07-23 into the finite-level tame-ramification leaf
`exists_finite_level_tame_generator_three` above; the profinite
assembly is PROVEN): for a character `ПҮ` of `О“ в„ҡ` with open kernel,
valued in a commutative group without `3`-torsion, the image under
`ПҮ вҲҳ (О“ в„ҡвӮғбөҘ вҶ’ О“ в„ҡ)` of the local inertia at `3` is generated by a
single element whose square is `1`. Assembly: the open kernel of
`ПҮ вҲҳ Emb` contains (Krull topology,
`krullTopology_mem_nhds_one_iff_of_normal`) the fixing subgroup of a
finite Galois level `N`, so the composite factors through a genuine
homomorphism `f` on `Gal(N/в„ҡвӮғбөҘ)` (`MonoidHom.liftOfSurjective` over
`AlgEquiv.restrictNormalHom_surjective`); the finite-level leaf hands
a tame generator `tМ„` whose `3`-power-order errors die under `f`
(`h3` iterated), so `f` is `вҹЁf tМ„вҹ©`-valued on the finite-level
inertia; the restriction lemma
`restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_three` maps
the full local inertia INTO the finite level, and the compactness
lifting `exists_mem_localInertiaGroup_restrictNormalHom_eq` lifts
`tМ„` back to the sought profinite witness `t`; Frobenius conjugation
`ПҶtМ„ПҶвҒ»В№ вүЎ tМ„Ві` gives `(f tМ„)Ві = f tМ„` since `A` is abelian, i.e.
`(f tМ„)ВІ = 1`. -/
theorem exists_localInertia_three_generator {A : Type*} [CommGroup A]
    (h3 : вҲҖ a : A, a ^ 3 = 1 вҶ’ a = 1)
    (ПҮ : О“ в„ҡ вҶ’* A) (hopen : IsOpen (ПҮ.ker : Set (О“ в„ҡ))) :
    вҲғ t вҲҲ localInertiaGroup
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat,
      (ПҮ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) t)) ^ 2 = 1 вҲ§
      вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat,
        вҲғ m : в„•, ПҮ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ) =
          (ПҮ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) t)) ^ m := by
  classical
  set v := Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat
  set Emb := Field.absoluteGaloisGroup.map (algebraMap в„ҡ
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
  -- `3`-power-order elements die in the `3`-torsion-free target
  have h3pow : вҲҖ (a : A) (j : в„•), a ^ 3 ^ j = 1 вҶ’ a = 1 := by
    intro a j
    induction j with
    | zero => intro h; simpa using h
    | succ n ih =>
      intro h
      apply ih
      apply h3
      rw [вҶҗ pow_mul, вҶҗ pow_succ]
      exact h
  -- the open kernel of the composite contains a finite Galois level
  have hopen' : IsOpen (((ПҮ.comp Emb.toMonoidHom).ker :
      Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
      Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) := by
    have hpre : (((ПҮ.comp Emb.toMonoidHom).ker :
        Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
        Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) =
        Emb вҒ»В№' (ПҮ.ker : Set (О“ в„ҡ)) := rfl
    rw [hpre]
    exact hopen.preimage Emb.continuous
  have hnhds : (((ПҮ.comp Emb.toMonoidHom).ker :
      Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
      Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) вҲҲ
      nhds (1 : О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)) :=
    hopen'.mem_nhds (one_mem _)
  obtain вҹЁN, hfdN, hnormN, hleвҹ© :=
    (krullTopology_mem_nhds_one_iff_of_normal
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
      _).mp hnhds
  haveI := hfdN
  haveI := hnormN
  haveI : Algebra.IsSeparable
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  haveI : IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N := вҹЁвҹ©
  -- the composite character factors through the finite Galois group
  have hsurj : Function.Surjective (AlgEquiv.restrictNormalHom N :
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)
        вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v]
      AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)) вҶ’*
      (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N)) :=
    AlgEquiv.restrictNormalHom_surjective _
  have hkerle : (AlgEquiv.restrictNormalHom (F :=
      IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N).ker вүӨ
      (ПҮ.comp Emb.toMonoidHom).ker := by
    rw [IntermediateField.restrictNormalHom_ker]
    intro g hg
    exact hle hg
  set f : (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N) вҶ’* A :=
    (AlgEquiv.restrictNormalHom N).liftOfSurjective hsurj
      вҹЁПҮ.comp Emb.toMonoidHom, hkerleвҹ©
  have hf : вҲҖ Пғ, f (AlgEquiv.restrictNormalHom N Пғ) = ПҮ (Emb Пғ) := fun Пғ =>
    MonoidHom.liftOfRightInverse_comp_apply _ _ _ _ Пғ
  -- the finite-level tame generator and its profinite lift
  obtain вҹЁtbar, htbarI, htbargen, ПҶ, j0, hПҶвҹ© :=
    exists_finite_level_tame_generator_three N
  obtain вҹЁt, htmem, htresвҹ© :=
    exists_mem_localInertiaGroup_restrictNormalHom_eq v N tbar htbarI
  have hПҮt : ПҮ (Emb t) = f tbar := by
    rw [вҶҗ htres]
    exact (hf t).symm
  -- Frobenius conjugation forces the square to be `1`
  have hsq : (ПҮ (Emb t)) ^ 2 = 1 := by
    have h1 : f (ПҶ * tbar * ПҶвҒ»В№ * (tbar ^ 3)вҒ»В№) = 1 :=
      h3pow _ j0 (by rw [вҶҗ map_pow, hПҶ, map_one])
    rw [map_mul, map_mul, map_mul, map_inv, map_inv, map_pow] at h1
    have hconj : f ПҶ * f tbar * (f ПҶ)вҒ»В№ = f tbar := by
      rw [mul_comm (f ПҶ) (f tbar), mul_assoc, mul_inv_cancel, mul_one]
    rw [hconj] at h1
    have h2 : f tbar = f tbar ^ 3 := mul_inv_eq_one.mp h1
    have h3' : (f tbar)вҒ»В№ * f tbar ^ 3 = f tbar ^ 2 := by group
    rw [hПҮt, вҶҗ h3', вҶҗ h2, inv_mul_cancel]
  refine вҹЁt, htmem, hsq, ?_вҹ©
  -- generation: every inertia element maps to a power of `ПҮ (Emb t)`
  intro Пғ hПғ
  obtain вҹЁm, j, hmjвҹ© := htbargen (AlgEquiv.restrictNormalHom N Пғ)
    (restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_three N Пғ hПғ)
  refine вҹЁm, ?_вҹ©
  have h1 : f ((tbar ^ m)вҒ»В№ * AlgEquiv.restrictNormalHom N Пғ) = 1 :=
    h3pow _ j (by rw [вҶҗ map_pow, hmj, map_one])
  rw [map_mul, map_inv, map_pow] at h1
  calc ПҮ (Emb Пғ) = f (AlgEquiv.restrictNormalHom N Пғ) := (hf Пғ).symm
    _ = (f tbar) ^ m := (inv_mul_eq_one.mp h1).symm
    _ = (ПҮ (Emb t)) ^ m := by rw [hПҮt]

/-- **`в„ҡвӮғбөҘ` contains no cube root of unity besides `1`** (PROVEN
2026-07-23 вҖ” the no-root input to the finite-level leaf below): the
polynomial `XВІ + X + 1` has no root in the `3`-adic completion. A
root `r` gives `x = 2r + 1` with `xВІ = вҲ’3`; `x` is integral over the
(integrally closed) valuation ring `рқ’ӘбөҘ`, so `x вҲҲ рқ’ӘбөҘ`; then
`xВІ вҲҲ рқ”ӘбөҘ = (3)` (`maximalIdeal_adicCompletionIntegers_eq_span`)
forces `x = 3y` by primality, whence `3yВІ = вҲ’1` puts the unit `вҲ’1`
in the maximal ideal вҖ” absurd. -/
theorem no_root_sq_add_self_add_one_adicCompletion_three
    (r : IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) :
    r ^ 2 + r + 1 вү  0 := by
  intro hroot
  have hx2 : (2 * r + 1) ^ 2 = -3 := by linear_combination 4 * hroot
  -- `2r + 1` is integral over the valuation ring, hence in it
  have hxint : IsIntegral (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) (2 * r + 1) := by
    refine вҹЁPolynomial.X ^ 2 + Polynomial.C 3,
      Polynomial.monic_X_pow_add_C _ two_ne_zero, ?_вҹ©
    rw [Polynomial.evalвӮӮ_add, Polynomial.evalвӮӮ_pow, Polynomial.evalвӮӮ_X,
      Polynomial.evalвӮӮ_C, map_ofNat]
    linear_combination hx2
  obtain вҹЁX, hXвҹ© := IsIntegrallyClosed.isIntegral_iff.mp hxint
  -- the valuation-ring-level equation `XВІ = вҲ’3`
  have hX2 : X ^ 2 = -3 := by
    apply IsFractionRing.injective
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
    rw [map_pow, hX, map_neg, map_ofNat]
    exact hx2
  -- descend along `рқ”ӘбөҘ = (3)`
  have hspan := maximalIdeal_adicCompletionIntegers_eq_span Nat.prime_three
  have hXm : X вҲҲ IsLocalRing.maximalIdeal
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) := by
    have hsq : X ^ 2 вҲҲ IsLocalRing.maximalIdeal
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) := by
      rw [hspan, Ideal.mem_span_singleton]
      exact вҹЁ-1, by rw [hX2]; push_cast; ringвҹ©
    exact (IsLocalRing.maximalIdeal.isMaximal _).isPrime.mem_of_pow_mem _ hsq
  rw [hspan, Ideal.mem_span_singleton] at hXm
  obtain вҹЁY, hYвҹ© := hXm
  have h3ne : ((3 : в„•) : IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) вү  0 := by
    intro h
    have h2 := congrArg (algebraMap
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) h
    rw [map_natCast, map_zero] at h2
    norm_num at h2
  have h3Y : 3 * Y ^ 2 = -1 := by
    have h9 : ((3 : в„•) : IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) * (3 * Y ^ 2) =
        ((3 : в„•) : IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) * (-1) := by
      have h4 := hX2
      rw [hY] at h4
      push_cast at h4 вҠў
      linear_combination h4
    exact mul_left_cancelвӮҖ h3ne h9
  -- the unit `вҲ’1` cannot lie in the maximal ideal
  have hunit : (-1 : IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) вҲҲ
      IsLocalRing.maximalIdeal
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) := by
    rw [hspan, Ideal.mem_span_singleton]
    exact вҹЁY ^ 2, by push_cast; linear_combination -h3Yвҹ©
  exact (IsLocalRing.maximalIdeal.isMaximal _).ne_top
    (Ideal.eq_top_of_isUnit_mem _ hunit isUnit_one.neg)

