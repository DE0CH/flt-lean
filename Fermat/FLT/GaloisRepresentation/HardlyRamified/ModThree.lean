theorem two_mul_local_differentIdeal_exponent_add_two_le_of_hopf_package
    (G : Type) [CommRing G] [HopfAlgebra рқ’ӘвӮғбөҘ G]
    [Module.Flat рқ’ӘвӮғбөҘ G] [Module.Finite рқ’ӘвӮғбөҘ G]
    [Algebra.Etale в„ҡвӮғбөҘ (в„ҡвӮғбөҘ вҠ—[рқ’ӘвӮғбөҘ] G)]
