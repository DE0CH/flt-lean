    obtain ‚ü®h, hh‚ü© := hdens m y
    refine ‚ü®h, ?_‚ü©
    have hdvd : (őł - x) ‚ą£ (Polynomial.aeval őł h - Polynomial.aeval x h) := by
      have h2 := Polynomial.sub_dvd_eval_sub őł x
        (h.map (algebraMap ‚Ą§ (NumberField.RingOfIntegers K)))
      rwa [Polynomial.eval_map, Polynomial.eval_map,
        ‚Üź Polynomial.aeval_def, ‚Üź Polynomial.aeval_def] at h2
    obtain ‚ü®z, hz‚ü© := hdvd
    have h3 : y - Polynomial.aeval őł h =
        (y - Polynomial.aeval x h) - (őł - x) * z := by
      rw [‚Üź hz]; ring
