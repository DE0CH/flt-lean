surjective, so `K ‚Č† ‚Ąö`). -/
theorem exists_sqrt_of_quadratic_character_unramified_outside_two_three
    (őł : őď ‚Ąö ‚Üí* Multiplicative (ZMod 2))
    (hőłsurj : Function.Surjective őł)
    (hopen : IsOpen (őł.ker : Set (őď ‚Ąö)))
    (hunram : ‚ąÄ (q : ‚Ąē) (hq : q.Prime), q ‚Č† 2 ‚Üí q ‚Č† 3 ‚Üí
      ‚ąÄ ŌÉ ‚ąą localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        őł (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
            hq.toHeightOneSpectrumRingOfIntegersRat)) ŌÉ) = 1) :
    ‚ąÉ d : ‚Ą§,
      (d = -1 ‚ą® d = 2 ‚ą® d = -2 ‚ą® d = 3 ‚ą® d = -3 ‚ą® d = 6 ‚ą® d = -6) ‚ąß
      ‚ąÉ x : AlgebraicClosure ‚Ąö, x ^ 2 = (d : AlgebraicClosure ‚Ąö) ‚ąß
        ‚ąÄ g : őď ‚Ąö, őł g = 1 ‚ÜĒ g x = x := by
  classical
  -- the fixed field of `ker őł` is a degree-2 Galois number field
  haveI hnorm : őł.ker.Normal := őł.normal_ker
  have hclosed : IsClosed (őł.ker : Set (őď ‚Ąö)) :=
    Subgroup.isClosed_of_isOpen őł.ker hopen
  haveI halgQ : Algebra.IsAlgebraic ‚Ąö (AlgebraicClosure ‚Ąö) :=
    AlgebraicClosure.isAlgebraic ‚Ąö
  haveI hacQ : IsAlgClosure ‚Ąö (AlgebraicClosure ‚Ąö) :=
    ‚ü®inferInstance, halgQ‚ü©
  haveI hnormQ : Normal ‚Ąö (AlgebraicClosure ‚Ąö) :=
    IsAlgClosure.normal ‚Ąö (AlgebraicClosure ‚Ąö)
  haveI hsepQ : Algebra.IsSeparable ‚Ąö (AlgebraicClosure ‚Ąö) :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  haveI hgalQ : IsGalois ‚Ąö (AlgebraicClosure ‚Ąö) := ‚ü®‚ü©
  set K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö) :=
    IntermediateField.fixedField (E := AlgebraicClosure ‚Ąö) őł.ker
  have hfix : K.fixingSubgroup = őł.ker :=
    InfiniteGalois.fixingSubgroup_fixedField ‚ü®őł.ker, hclosed‚ü©
  haveI hfd : FiniteDimensional ‚Ąö K :=
    (InfiniteGalois.isOpen_iff_finite K).mp (by rw [hfix]; exact hopen)
  haveI hgalK : IsGalois ‚Ąö K := (InfiniteGalois.normal_iff_isGalois K).mp
    (by rw [hfix]; exact hnorm)
  haveI : NumberField K := ‚ü®‚ü©
  have hrank : Module.finrank ‚Ąö K = 2 := by
    have e1 : (őď ‚Ąö) ‚ßł őł.ker ‚ČÉ* ((IntermediateField.fixedField
        ((‚ü®őł.ker, hclosed‚ü© : ClosedSubgroup (őď ‚Ąö)) : Subgroup (őď ‚Ąö))) ‚ČÉ‚āź[‚Ąö]
          (IntermediateField.fixedField
            ((‚ü®őł.ker, hclosed‚ü© : ClosedSubgroup (őď ‚Ąö)) : Subgroup (őď ‚Ąö)))) :=
      InfiniteGalois.normalAutEquivQuotient ‚ü®őł.ker, hclosed‚ü©
    have e2 : (őď ‚Ąö) ‚ßł őł.ker ‚ČÉ* Multiplicative (ZMod 2) :=
      QuotientGroup.quotientKerEquivOfSurjective őł hőłsurj
    have hcard1 : Nat.card (K ‚ČÉ‚āź[‚Ąö] K) = Module.finrank ‚Ąö K :=
      IsGalois.card_aut_eq_finrank ‚Ąö K
    have h2 : Nat.card (Multiplicative (ZMod 2)) = 2 := by
      simp [Nat.card_eq_fintype_card]
    rw [‚Üź hcard1]
    exact (((Nat.card_congr e1.toEquiv).symm).trans
      (Nat.card_congr e2.toEquiv)).trans h2
  -- the quadratic generator `x` with `x¬≤ = d` squarefree
  obtain ‚ü®ŌÉ, x, d, hŌÉ1, hŌÉ2, huniv, hxŌÉ, hxbot, hdsq, hx2‚ü© :=
    exists_quadratic_generator K hrank
  -- no prime `q ‚ąČ {2, 3}` divides `d`
  have hprime : ‚ąÄ p : ‚Ąē, p.Prime ‚Üí p ‚Č† 2 ‚Üí p ‚Č† 3 ‚Üí ¬¨ ((p : ‚Ą§) ‚ą£ d) := by
    intro p hp hp2 hp3 hpd
    -- the local inertia image at `p` fixes `K`
    have hle : Subgroup.map (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
          hp.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom
        (localInertiaGroup hp.toHeightOneSpectrumRingOfIntegersRat)
        ‚Č§ K.fixingSubgroup := by
      rintro g ‚ü®ŌĄ, hŌĄ, rfl‚ü©
      rw [hfix]
      exact MonoidHom.mem_ker.mpr (hunram p hp hp2 hp3 ŌĄ hŌĄ)
    -- a prime of `ūĚďě K` above `p`
    haveI := IsIntegralClosure.isIntegral_algebra ‚Ą§
      (A := NumberField.RingOfIntegers K) K
    have hpZ : Prime ((p : ‚Ą§)) := Nat.prime_iff_prime_int.mp hp
    haveI hPspan : (Ideal.span {((p : ‚Ą§))} : Ideal ‚Ą§).IsPrime :=
      (Ideal.span_singleton_prime (by exact_mod_cast hp.ne_zero)).mpr hpZ
    have hker : RingHom.ker (algebraMap ‚Ą§ (NumberField.RingOfIntegers K)) ‚Č§
        Ideal.span {((p : ‚Ą§))} := by
      intro z hz
      have hz0 : algebraMap ‚Ą§ (NumberField.RingOfIntegers K) z = 0 := hz
      have hzK : algebraMap ‚Ą§ K z = 0 := by
        rw [IsScalarTower.algebraMap_eq ‚Ą§ (NumberField.RingOfIntegers K) K,
          RingHom.comp_apply, hz0, map_zero]
      have hz' : (z : ‚Ą§) = 0 := by
        exact_mod_cast (by simpa using hzK : ((z : ‚Ą§) : K) = 0)
      rw [hz']
      exact Ideal.zero_mem _
    obtain ‚ü®Q, hQprime, hQcomap‚ü© :=
      Ideal.exists_ideal_over_prime_of_isIntegral_of_isDomain
        (S := NumberField.RingOfIntegers K) (Ideal.span {((p : ‚Ą§))}) hker
    haveI := hQprime
    have hpQ : ((p : ‚Ąē) : NumberField.RingOfIntegers K) ‚ąą Q := by
      have hmem : ((p : ‚Ą§)) ‚ąą Ideal.span {((p : ‚Ą§))} := Ideal.subset_span rfl
      rw [‚Üź hQcomap] at hmem
      simpa using Ideal.mem_comap.mp hmem
    -- trivial inertia (the dictionary) vs. nontrivial inertia (the leaf)
    have hbot : Q.inertia (K ‚ČÉ‚āź[‚Ąö] K) = ‚ä• :=
      inertia_eq_bot_of_le_fixingSubgroup K hp hle Q hpQ
    have hmem : ŌÉ ‚ąą Q.inertia (K ‚ČÉ‚āź[‚Ąö] K) :=
      mem_inertia_of_dvd_squarefree K ŌÉ hŌÉ2 huniv x hxŌÉ hdsq hx2 hp hpd Q hpQ
    rw [hbot] at hmem
    exact hŌÉ1 (Subgroup.mem_bot.mp hmem)
  -- enumeration: `d` squarefree with prime divisors in `{2,3}`, `d ‚Č† 1`
  have hd7 : d = -1 ‚ą® d = 2 ‚ą® d = -2 ‚ą® d = 3 ‚ą® d = -3 ‚ą® d = 6 ‚ą® d = -6 := by
    have hd0 : d ‚Č† 0 := hdsq.ne_zero
    have hd1 : d ‚Č† 1 := by
      intro h
      rw [h] at hx2
      have h0 : (x - 1) * (x + 1) = 0 := by
        push_cast at hx2
        linear_combination hx2
      rcases mul_eq_zero.mp h0 with h1 | h1
      ¬∑ exact hxbot (by rw [sub_eq_zero.mp h1]; exact one_mem _)
      ¬∑ exact hxbot (by
          rw [eq_neg_of_add_eq_zero_left h1]
          exact neg_mem (one_mem _))
    set n : ‚Ąē := d.natAbs with hn
    have hsub : n.primeFactors ‚äÜ ({2, 3} : Finset ‚Ąē) := by
      intro p hp
      rw [Nat.mem_primeFactors] at hp
      obtain ‚ü®hpp, hpd, -‚ü© := hp
      rw [Finset.mem_insert, Finset.mem_singleton]
      by_contra hne
      push Not at hne
      refine hprime p hpp hne.1 hne.2 ?_
      exact dvd_trans (Int.natCast_dvd_natCast.mpr hpd)
        (Int.natAbs_dvd.mpr dvd_rfl)
    have hdvd6 : n ‚ą£ 6 := by
      have hsqf : Squarefree n := Int.squarefree_natAbs.mpr hdsq
      calc n = ‚ąŹ p ‚ąą n.primeFactors, p :=
            (Nat.prod_primeFactors_of_squarefree hsqf).symm
        _ ‚ą£ ‚ąŹ p ‚ąą ({2, 3} : Finset ‚Ąē), p :=
            Finset.prod_dvd_prod_of_subset _ _ _ hsub
        _ = 6 := by decide
    have habs : n = 1 ‚ą® n = 2 ‚ą® n = 3 ‚ą® n = 6 := by
      have h1 : 0 < n := Int.natAbs_pos.mpr hd0
      have h6 : n ‚Č§ 6 := Nat.le_of_dvd (by norm_num) hdvd6
      interval_cases n <;> revert hdvd6 <;> decide
    have heq : d = (n : ‚Ą§) ‚ą® d = -(n : ‚Ą§) := Int.natAbs_eq d
    rcases habs with h | h | h | h <;> rw [h] at heq <;> omega
  -- packaging: the square root in `‚ĄöŠĶÉň°ŠĶć` and the character dictionary
  refine ‚ü®d, hd7, (x : AlgebraicClosure ‚Ąö), ?_, ?_‚ü©
  ¬∑ have h1 := congrArg (algebraMap K (AlgebraicClosure ‚Ąö)) hx2
    rw [map_pow, map_intCast] at h1
    exact h1
  ¬∑ intro g
    constructor
    ¬∑ intro hg
      have hgker : g ‚ąą K.fixingSubgroup := by
        rw [hfix]
        exact MonoidHom.mem_ker.mpr hg
      exact (K.mem_fixingSubgroup_iff g).mp hgker
        (x : AlgebraicClosure ‚Ąö) x.2
    ¬∑ intro hgx
      -- `K = ‚Ąö(x)`, so fixing `x` fixes `K` pointwise
      have hxQ : IsIntegral ‚Ąö ((x : AlgebraicClosure ‚Ąö)) :=
        Algebra.IsIntegral.isIntegral _
      haveI : FiniteDimensional ‚Ąö
          (IntermediateField.adjoin ‚Ąö {(x : AlgebraicClosure ‚Ąö)}) :=
        IntermediateField.adjoin.finiteDimensional hxQ
      have hadj : IntermediateField.adjoin ‚Ąö {(x : AlgebraicClosure ‚Ąö)} = K := by
        have hle : IntermediateField.adjoin ‚Ąö {(x : AlgebraicClosure ‚Ąö)} ‚Č§ K :=
          IntermediateField.adjoin_le_iff.mpr (by
            intro z hz
            rw [Set.mem_singleton_iff] at hz
            rw [hz]
            exact x.2)
        refine IntermediateField.eq_of_le_of_finrank_le hle ?_
        rw [hrank]
        have hne1 : Module.finrank ‚Ąö
            (IntermediateField.adjoin ‚Ąö {(x : AlgebraicClosure ‚Ąö)}) ‚Č† 1 := by
          rw [Ne, IntermediateField.finrank_eq_one_iff]
          intro hbot
          have hxmem : (x : AlgebraicClosure ‚Ąö) ‚ąą
              IntermediateField.adjoin ‚Ąö {(x : AlgebraicClosure ‚Ąö)} :=
            IntermediateField.mem_adjoin_simple_self ‚Ąö _
          rw [hbot, IntermediateField.mem_bot] at hxmem
          obtain ‚ü®r, hr‚ü© := hxmem
          apply hxbot
          rw [IntermediateField.mem_bot]
          refine ‚ü®r, ?_‚ü©
          apply Subtype.ext
          rw [‚Üź hr]
          exact (IsScalarTower.algebraMap_apply ‚Ąö K (AlgebraicClosure ‚Ąö) r).symm
        have hpos : 0 < Module.finrank ‚Ąö
            (IntermediateField.adjoin ‚Ąö {(x : AlgebraicClosure ‚Ąö)}) :=
          Module.finrank_pos
        omega
      have hfixadj : ‚ąÄ z ‚ąą IntermediateField.adjoin ‚Ąö
          {(x : AlgebraicClosure ‚Ąö)}, g z = z := by
        intro z hz
        induction hz using IntermediateField.adjoin_induction with
        | mem u hu =>
          rw [Set.mem_singleton_iff] at hu
