    { carrier := {g : О“ в„ҡ | ПҒ g = 1}
      one_mem' := map_one ПҒ
      mul_mem' := fun {a b} ha hb => by
        have ha' : ПҒ a = 1 := ha
        have hb' : ПҒ b = 1 := hb
        show ПҒ (a * b) = 1
        rw [map_mul, ha', hb', mul_one]
      inv_mem' := fun {a} ha => by
        have ha' : ПҒ a = 1 := ha
        show ПҒ aвҒ»В№ = 1
        have h1 : ПҒ aвҒ»В№ * ПҒ a = 1 := by
          rw [вҶҗ map_mul, inv_mul_cancel, map_one]
        rw [ha', mul_one] at h1
        exact h1 }
  have hKopen : IsOpen (KПҒ : Set (О“ в„ҡ)) :=
    isOpen_setOf_galoisRep_eq_one ПҒ hfinV
  -- (6) the odd part dies in the representation-free ray-class leaf
  have hstep1 : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g ^ 2 ^ A = 1 := by
    intro g hg
    refine odd_order_character_eq_one_ray_class Оё' d hd x hx hОё'x
      (fun g' => ОҪ g' ^ 2 ^ A) ?_ ?_ KПҒ hKopen ?_ ?_ ?_ g hg
    В· intro g' h' hg' hh'
      rw [hОҪmul g' h' hg' hh', mul_pow]
    В· intro g' hg'
      exact pow_ne_zero _ (hОҪne0 g' hg')
    В· intro g' hg'K
      have hПҒ1 : ПҒ g' = 1 := hg'K
      exact вҹЁhtriv' g' hПҒ1, by rw [hОҪker g' hПҒ1, one_pow]вҹ©
    В· intro g' hg'
      exact вҹЁm, hm0, hmodd, hm3, by rw [вҶҗ pow_mul, hNm]; exact hNexp g' hg'вҹ©
    В· intro q hq hq3 c Пғ hПғ hОё
      rw [hОҪunr' q hq hq3 c Пғ hПғ hОё, one_pow]
