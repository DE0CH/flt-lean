/-- **The exceptional projective images force a matrix image of order
`‚Č• 48`** (PROVEN 2026-07-22 ‚ÄĒ the group-theoretic half of the
root-discriminant elimination): if the projective image `ŌÄ.range` of a
mod-3 hardly ramified representation is one of the five exceptional
Dickson groups, then the matrix image `u.range` has cardinality
`‚Č• 48`. Argument: `det ‚ąė u` takes only the values `¬Ī1` (the
determinant is the mod-3 cyclotomic character, and units of `‚Ą§‚āÉ` map
to `¬Ī1` in characteristic `3`), and the value `‚ąí1` is attained at
complex conjugation (`exists_conj_cyclotomicCharacter_three`), so the
determinant-one part `S ‚Č§ u.range` has index exactly `2`; the counting
core `card_ge_48_of_index_two_kernel` applies to
`Ōą : u.range ‚Üí ŌÄ.range` with the per-case subgroup bound
`dickson_exceptional_subgroup_card` and the Cayley‚ÄďHamilton lift
obstruction `gl2_sq_ne_one_of_notMem_center`. -/
theorem card_matrixRange_ge_of_exceptional {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (ŌÄ : őď ‚Ąö ‚Üí* Dickson.PGL 3)
    (hŌÄ : ‚ąÄ g, ŌÄ g = QuotientGroup.mk (u g))
    (hcase :
      (Nonempty (ŌÄ.range ‚ČÉ* alternatingGroup (Fin 4))) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* Equiv.Perm (Fin 4))) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* alternatingGroup (Fin 5))) ‚ą®
      (‚ąÉ m : ‚Ąē, m ‚Č• 1 ‚ąß Nonempty (ŌÄ.range ‚ČÉ*
        Matrix.ProjectiveSpecialLinearGroup (Fin 2) (GaloisField 3 m))) ‚ą®
      (‚ąÉ m : ‚Ąē, m ‚Č• 1 ‚ąß Nonempty (ŌÄ.range ‚ČÉ*
        (GL (Fin 2) (GaloisField 3 m) ‚ßł
          Subgroup.center (GL (Fin 2) (GaloisField 3 m)))))) :
    48 ‚Č§ Nat.card u.range := by
  classical
  -- (0) the matrix image is finite: `u` factors through the finite
  -- monoid `End k V`
  haveI : Finite V := Module.finite_of_finite k
  haveI hfinN : Finite u.range := by
    haveI : Finite (Module.End k V) :=
      Finite.of_injective _ DFunLike.coe_injective
    have hdep : ‚ąÄ g‚āĀ g‚āā : őď ‚Ąö, (MonoidHomClass.toMonoidHom ŌĀ) g‚āĀ =
        (MonoidHomClass.toMonoidHom ŌĀ) g‚āā ‚Üí u g‚āĀ = u g‚āā := by
      intro g‚āĀ g‚āā h12
      apply Units.ext
      rw [hu, hu]
      show ((LinearMap.toMatrix b b
        (((MonoidHomClass.toMonoidHom ŌĀ) g‚āĀ).baseChange (AlgebraicClosure k))).map e) =
        ((LinearMap.toMatrix b b
        (((MonoidHomClass.toMonoidHom ŌĀ) g‚āā).baseChange (AlgebraicClosure k))).map e)
      rw [h12]
    let G' : Module.End k V ‚Üí GL (Fin 2) (Dickson.K 3) := fun T =>
      if h : ‚ąÉ g, (MonoidHomClass.toMonoidHom ŌĀ) g = T then u h.choose else 1
    have huG : ‚ąÄ g, u g = G' ((MonoidHomClass.toMonoidHom ŌĀ) g) := by
      intro g
      have hex : ‚ąÉ g', (MonoidHomClass.toMonoidHom ŌĀ) g' =
          (MonoidHomClass.toMonoidHom ŌĀ) g := ‚ü®g, rfl‚ü©
      show u g = dite _ _ _
      rw [dif_pos hex]
      exact (hdep _ _ hex.choose_spec).symm
    have hsub : Set.range u ‚äÜ Set.range G' := by
      rintro _ ‚ü®g, rfl‚ü©
      exact ‚ü®_, (huG g).symm‚ü©
    exact ((Set.finite_range G').subset hsub).to_subtype
  -- (1) the determinant of the matrix action is the mod-3 cyclotomic
  -- character pushed to `ūĚĒĹŐĄ‚āÉ`
  have hdet_val : ‚ąÄ g : őď ‚Ąö,
      ((Matrix.GeneralLinearGroup.det (u g) : (Dickson.K 3)ň£) : Dickson.K 3) =
        ((e : AlgebraicClosure k ‚Üí+* Dickson.K 3).comp
          ((algebraMap k (AlgebraicClosure k)).comp (algebraMap ‚Ą§_[3] k)))
          ((cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 g.toRingEquiv : ‚Ą§_[3]ň£) : ‚Ą§_[3]) := by
    intro g
    calc ((Matrix.GeneralLinearGroup.det (u g) : (Dickson.K 3)ň£) : Dickson.K 3)
        = ((u g : GL (Fin 2) (Dickson.K 3)) :
            Matrix (Fin 2) (Fin 2) (Dickson.K 3)).det := rfl
      _ = ((LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e).det := by rw [hu g]
      _ = e ((LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ)) g)).det) :=
          (RingEquiv.map_det e _).symm
      _ = e (LinearMap.det ((Slop.OddRep.baseChange (AlgebraicClosure k)
            (MonoidHomClass.toMonoidHom ŌĀ)) g)) := by rw [LinearMap.det_toMatrix]
      _ = e (algebraMap k (AlgebraicClosure k)
            (LinearMap.det ((MonoidHomClass.toMonoidHom ŌĀ :
              Representation k (őď ‚Ąö) V) g))) := by
          rw [show (Slop.OddRep.baseChange (AlgebraicClosure k)
              (MonoidHomClass.toMonoidHom ŌĀ)) g =
            ((MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V) g).baseChange
              (AlgebraicClosure k) from rfl, LinearMap.det_baseChange]
      _ = _ := by
          have hdg := hŌĀ.det g
          rw [GaloisRep.det_apply] at hdg
          rw [show LinearMap.det ((MonoidHomClass.toMonoidHom ŌĀ :
              Representation k (őď ‚Ąö) V) g) = LinearMap.det (ŌĀ g) from rfl, hdg]
          rfl
  -- (2) hence the determinant character on `u.range` takes only the
  -- values `¬Ī1` ‚Ä¶
  have h2ne : (2 : Dickson.K 3) ‚Č† 0 := by
    intro h
    have h3ne : ((2 : ‚Ąē) : Dickson.K 3) ‚Č† 0 := by
      rw [Ne, CharP.cast_eq_zero_iff (Dickson.K 3) 3]
      omega
    exact h3ne (by push_cast; exact h)
  have hDpm : ‚ąÄ x : u.range,
      (Matrix.GeneralLinearGroup.det).comp u.range.subtype x = 1 ‚ą®
      (Matrix.GeneralLinearGroup.det).comp u.range.subtype x = -1 := by
    rintro ‚ü®x, hx‚ü©
    obtain ‚ü®g, rfl‚ü© := hx
    rcases padic_three_ringHom_pm_one ((e : AlgebraicClosure k ‚Üí+* Dickson.K 3).comp
        ((algebraMap k (AlgebraicClosure k)).comp (algebraMap ‚Ą§_[3] k)))
        (cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 g.toRingEquiv) with h | h
    ¬∑ left
      apply Units.ext
      rw [Units.val_one]
      exact (hdet_val g).trans h
    ¬∑ right
      apply Units.ext
      rw [Units.val_neg, Units.val_one]
      exact (hdet_val g).trans h
  -- ‚Ä¶ and attains `‚ąí1` at complex conjugation
  have hDneg : ‚ąÉ x : u.range,
      (Matrix.GeneralLinearGroup.det).comp u.range.subtype x = -1 := by
    obtain ‚ü®c, -, hcŌá‚ü© := exists_conj_cyclotomicCharacter_three
    refine ‚ü®‚ü®u c, ‚ü®c, rfl‚ü©‚ü©, ?_‚ü©
    apply Units.ext
    rw [Units.val_neg, Units.val_one]
    exact (hdet_val c).trans (by rw [hcŌá, map_neg, map_one])
  -- (3) so the determinant-one part of `u.range` has index exactly 2
  have hone_ne : (1 : (Dickson.K 3)ň£) ‚Č† -1 := by
    intro h
    apply h2ne
    have hval := congrArg Units.val h
    rw [Units.val_one, Units.val_neg, Units.val_one] at hval
    linear_combination hval
  have hDrange : (((Matrix.GeneralLinearGroup.det).comp u.range.subtype).range :
      Set (Dickson.K 3)ň£) = {1, -1} := by
    apply Set.Subset.antisymm
