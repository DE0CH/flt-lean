/-- **The procyclic-tame-inertia generator at `2`** (DECOMPOSED
2026-07-24 into the finite-level tame-ramification leaf
`exists_finite_level_tame_generator_two` above; the profinite
assembly is PROVEN, mirroring the at-`3` assembly
`exists_localInertia_three_generator` below): for a homomorphism `u`
of `О“ в„ҡ` with open kernel whose values on the mapped local inertia at
`2` all cube to `1`, the image of the local inertia at `2` is
generated by a single element. Assembly: the open kernel of
`u вҲҳ Emb` contains (Krull topology,
`krullTopology_mem_nhds_one_iff_of_normal`) the fixing subgroup of a
finite Galois level `N`, so the composite factors through a genuine
homomorphism `f` on `Gal(N/в„ҡвӮӮбөҘ)` (`MonoidHom.liftOfSurjective` over
`AlgEquiv.restrictNormalHom_surjective`); the finite-level leaf hands
a tame generator `tМ„` whose errors have `2`-power order; each error,
lying in the finite-level inertia, lifts by the compactness lifting
`exists_mem_localInertiaGroup_restrictNormalHom_eq` to a full local
inertia element, so its `f`-image also cubes to `1` (`hcube`) and
hence dies (`gcd(2^j, 3) = 1`); so `f` is `вҹЁf tМ„вҹ©`-valued on the
finite-level inertia, into which the restriction lemma
`restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_two` maps the
full local inertia, and the compactness lifting of `tМ„` itself
produces the sought profinite witness `t`. -/
theorem exists_localInertia_two_generator_of_cube_one {G' : Type*} [Group G']
    (u : О“ в„ҡ вҶ’* G') (hopen : IsOpen (u.ker : Set (О“ в„ҡ)))
    (hcube : вҲҖ Пғ вҲҲ localInertiaGroup
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      (u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ)) ^ 3 = 1) :
    вҲғ t вҲҲ localInertiaGroup Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
        вҲғ m : в„•, u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) =
          (u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) t)) ^ m := by
  classical
  set v := Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat
  set Emb := Field.absoluteGaloisGroup.map (algebraMap в„ҡ
    (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
  -- an element of `2`-power order which also cubes to `1` is trivial
  have h23 : вҲҖ (a : G') (j : в„•), a ^ 3 = 1 вҶ’ a ^ 2 ^ j = 1 вҶ’ a = 1 := by
    intro a j h3 h2
    have hd := Nat.dvd_gcd (orderOf_dvd_of_pow_eq_one h3)
      (orderOf_dvd_of_pow_eq_one h2)
    have hco : Nat.gcd 3 (2 ^ j) = 1 :=
      Nat.Coprime.pow_right j (by norm_num)
    rw [hco, Nat.dvd_one] at hd
    exact orderOf_eq_one_iff.mp hd
  -- the open kernel of the composite contains a finite Galois level
  have hopen' : IsOpen (((u.comp Emb.toMonoidHom).ker :
      Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
      Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) := by
    have hpre : (((u.comp Emb.toMonoidHom).ker :
        Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
        Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) =
        Emb вҒ»В№' (u.ker : Set (О“ в„ҡ)) := rfl
    rw [hpre]
    exact hopen.preimage Emb.continuous
  have hnhds : (((u.comp Emb.toMonoidHom).ker :
      Subgroup (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) :
      Set (О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))) вҲҲ
      nhds (1 : О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)) :=
    hopen'.mem_nhds (one_mem _)
  obtain вҹЁN, hfdN, hnormN, hleвҹ© :=
    (krullTopology_mem_nhds_one_iff_of_normal
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
      _).mp hnhds
  haveI := hfdN
  haveI := hnormN
  haveI : Algebra.IsSeparable
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N :=
    Algebra.IsAlgebraic.isSeparable_of_perfectField
  haveI : IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N := вҹЁвҹ©
  -- the composite factors through the finite Galois group
  have hsurj : Function.Surjective (AlgEquiv.restrictNormalHom N :
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)
        вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v]
      AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v)) вҶ’*
      (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N)) :=
    AlgEquiv.restrictNormalHom_surjective _
  have hkerle : (AlgEquiv.restrictNormalHom (F :=
      IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v) N).ker вүӨ
      (u.comp Emb.toMonoidHom).ker := by
    rw [IntermediateField.restrictNormalHom_ker]
    intro g hg
    exact hle hg
  set f : (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N) вҶ’* G' :=
    (AlgEquiv.restrictNormalHom N).liftOfSurjective hsurj
      вҹЁu.comp Emb.toMonoidHom, hkerleвҹ©
  have hf : вҲҖ Пғ, f (AlgEquiv.restrictNormalHom N Пғ) = u (Emb Пғ) := fun Пғ =>
    MonoidHom.liftOfRightInverse_comp_apply _ _ _ _ Пғ
  -- the finite-level tame generator and its profinite lift
  obtain вҹЁtbar, htbarI, htbargenвҹ© := exists_finite_level_tame_generator_two N
  obtain вҹЁt, htmem, htresвҹ© :=
    exists_mem_localInertiaGroup_restrictNormalHom_eq v N tbar htbarI
  have hut : u (Emb t) = f tbar := by
    rw [вҶҗ htres]
    exact (hf t).symm
  refine вҹЁt, htmem, ?_вҹ©
  -- generation: every inertia element maps to a power of `u (Emb t)`
  intro Пғ hПғ
  obtain вҹЁm, j, hmjвҹ© := htbargen (AlgEquiv.restrictNormalHom N Пғ)
    (restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_two N Пғ hПғ)
  refine вҹЁm, ?_вҹ©
  -- the wild error lies in the finite-level inertia, so it lifts to the
  -- full local inertia and its image cubes to `1` while having `2`-power
  -- order: it dies
  have hwI : (tbar ^ m)вҒ»В№ * AlgEquiv.restrictNormalHom N Пғ вҲҲ
      (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ v) N)).inertia
        (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v] N) :=
    mul_mem (inv_mem (pow_mem htbarI m))
      (restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_two N Пғ hПғ)
  obtain вҹЁw, hwmem, hwresвҹ© :=
    exists_mem_localInertiaGroup_restrictNormalHom_eq v N _ hwI
  have hfw3 : (f ((tbar ^ m)вҒ»В№ * AlgEquiv.restrictNormalHom N Пғ)) ^ 3 = 1 := by
    rw [вҶҗ hwres, hf w]
    exact hcube w hwmem
  have hfw2 : (f ((tbar ^ m)вҒ»В№ * AlgEquiv.restrictNormalHom N Пғ)) ^ 2 ^ j = 1 := by
    rw [вҶҗ map_pow, hmj, map_one]
  have hfw : f ((tbar ^ m)вҒ»В№ * AlgEquiv.restrictNormalHom N Пғ) = 1 :=
    h23 _ j hfw3 hfw2
  rw [map_mul, map_inv, map_pow] at hfw
  calc u (Emb Пғ) = f (AlgEquiv.restrictNormalHom N Пғ) := (hf Пғ).symm
    _ = (f tbar) ^ m := (inv_mul_eq_one.mp hfw).symm
    _ = (u (Emb t)) ^ m := by rw [hut]

/-- **The local inertia image at `2` has order dividing `3`**
(DECOMPOSED 2026-07-23 into the two sorry nodes above вҖ” the
representation-theoretic cube-triviality
`map_localInertiaGroup_at_two_pow_three_eq_one` and the
local-structure generator leaf
`exists_localInertia_two_generator_of_cube_one`; the glue is proven
here): the image under the matrix form `u` of the local inertia at
`2` is a subgroup of `GLвӮӮ(рқ”ҪМ„вӮғ)` of order dividing `3`.  Glue: `ker u`
is open (`ker ПҒ вүӨ ker u` by `hu`, and `ker ПҒ` is open by continuity
and finiteness of `V`), so the generator leaf applies: the image is
contained in `вҹЁaвҹ©` for `a` the image of the generator `t`, and
`#вҹЁaвҹ© = orderOf a вҲЈ 3` since `aВі = 1` by the cube-triviality leaf. -/
theorem card_map_localInertiaGroup_at_two_dvd_three {k : Type u} [Finite k]
    [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ПҒ : GaloisRep в„ҡ k V}
    (hПҒ : IsHardlyRamified (show Odd 3 by decide) hV ПҒ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) вҠ—[k] V))
    (e : AlgebraicClosure k вүғ+* Dickson.K 3)
    (u : О“ в„ҡ вҶ’* GL (Fin 2) (Dickson.K 3))
    (hu : вҲҖ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ)) g)).map e) :
    Nat.card (Subgroup.map u
      (Subgroup.map (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom
        (localInertiaGroup Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat))) вҲЈ 3 := by
  classical
  haveI hfinV : Finite V := Module.finite_of_finite k
  -- `ker u` is open: `ker ПҒ вүӨ ker u` and `ker ПҒ` is open
  have htriv : вҲҖ g : О“ в„ҡ, ПҒ g = 1 вҶ’ u g = 1 := by
    intro g hg
    apply Units.ext
    rw [Units.val_one, hu g]
    have h1 : (Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ)) g =
        ((MonoidHomClass.toMonoidHom ПҒ :
          Representation k (О“ в„ҡ) V) g).baseChange (AlgebraicClosure k) := rfl
    have h2 : (MonoidHomClass.toMonoidHom ПҒ :
        Representation k (О“ в„ҡ) V) g = 1 := hg
    rw [h1, h2, Module.End.one_eq_id, LinearMap.baseChange_id,
      вҶҗ Module.End.one_eq_id, LinearMap.toMatrix_one,
      Matrix.map_one _ (map_zero e) (map_one e)]
  let KПҒ : Subgroup (О“ в„ҡ) :=
    { carrier := {g | ПҒ g = 1}
      one_mem' := map_one ПҒ
      mul_mem' := by
        intro a b ha hb
        show ПҒ (a * b) = 1
        rw [map_mul, ha, hb, mul_one]
      inv_mem' := by
        intro a ha
        show ПҒ aвҒ»В№ = 1
        have h1 : ПҒ aвҒ»В№ * ПҒ a = 1 := by
          rw [вҶҗ map_mul, inv_mul_cancel, map_one]
        rwa [ha, mul_one] at h1 }
  have hKПҒ_open : IsOpen (KПҒ : Set (О“ в„ҡ)) :=
    isOpen_setOf_galoisRep_eq_one ПҒ hfinV
  have hker : KПҒ вүӨ u.ker := fun g hg => MonoidHom.mem_ker.mpr (htriv g hg)
  have hopen : IsOpen (u.ker : Set (О“ в„ҡ)) :=
    Subgroup.isOpen_mono hker hKПҒ_open
  -- the cube-triviality and the generator
  have hcube := map_localInertiaGroup_at_two_pow_three_eq_one V hV hПҒ b e u hu
  obtain вҹЁt, htmem, hgenвҹ© :=
    exists_localInertia_two_generator_of_cube_one u hopen hcube
  set a : GL (Fin 2) (Dickson.K 3) :=
    u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) t)
  -- the image subgroup is contained in `вҹЁaвҹ©`
  have hS : Subgroup.map u
      (Subgroup.map (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom
        (localInertiaGroup Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) вүӨ
      Subgroup.zpowers a := by
    rintro x hx
    rw [Subgroup.mem_map] at hx
    obtain вҹЁy, hy, rflвҹ© := hx
    rw [Subgroup.mem_map] at hy
    obtain вҹЁПғ, hПғ, rflвҹ© := hy
    obtain вҹЁm, hmвҹ© := hgen Пғ hПғ
    have hm' : u ((Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom Пғ) =
        a ^ m := hm
    refine Subgroup.mem_zpowers_iff.mpr вҹЁ(m : в„Ө), ?_вҹ©
    rw [zpow_natCast]
    exact hm'.symm
  -- `#вҹЁaвҹ© = orderOf a вҲЈ 3` since `aВі = 1`
  have ha3 : a ^ 3 = 1 := hcube t htmem
  have hcard : Nat.card (Subgroup.zpowers a) вҲЈ 3 := by
    rw [Nat.card_zpowers]
    exact orderOf_dvd_of_pow_eq_one ha3
  exact (Subgroup.card_dvd_of_le hS).trans hcard

/-- **The inertia order at `2` divides `3`** (DECOMPOSED 2026-07-23
into the two sorry nodes above вҖ” the quantitative local-to-global
transport `inertia_card_dvd_of_map_localInertiaGroup_card_dvd` (pure
algebraic number theory) and the representation-theoretic image bound
`card_map_localInertiaGroup_at_two_dvd_three` (pure local
representation theory); the glue is proven here): the ideal-inertia
subgroup in `Gal(K/в„ҡ)` of any prime `Q` of `рқ“һ K` above `2` has order
dividing `3`. -/
theorem kernel_field_inertia_card_at_two_dvd_three {k : Type u} [Finite k]
    [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ПҒ : GaloisRep в„ҡ k V}
    (hПҒ : IsHardlyRamified (show Odd 3 by decide) hV ПҒ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) вҠ—[k] V))
    (e : AlgebraicClosure k вүғ+* Dickson.K 3)
    (u : О“ в„ҡ вҶ’* GL (Fin 2) (Dickson.K 3))
    (hu : вҲҖ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ)) g)).map e)
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    [IsGalois в„ҡ K] (hfix : K.fixingSubgroup = u.ker)
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hmem : ((2 : в„•) : NumberField.RingOfIntegers K) вҲҲ Q) :
    Nat.card (Q.inertia (K вүғвӮҗ[в„ҡ] K)) вҲЈ 3 :=
  inertia_card_dvd_of_map_localInertiaGroup_card_dvd K u hfix
    Nat.prime_two Q hQ hmem 3
    (card_map_localInertiaGroup_at_two_dvd_three V hV hПҒ b e u hu)

section DifferentTransport

open scoped Pointwise

/-- **Automorphism-invariance of the different ideal** (PROVEN
2026-07-23 вҖ” the ideal-theoretic transport input to the
Fontaine-at-`3` conjugacy reduction below): a `в„ҡ`-automorphism of a
number field `F` fixes the different ideal `рқ”Ў_{F/в„ҡ}` (as an ideal of
`рқ“һ F`, under the pointwise action). Immediate from
`smul_differentIdeal_eq` of `Fermat.FLT.FreyCurve.InertiaCardTransport`,
proven there for an arbitrary `A`-algebra automorphism
(`map_differentIdeal_eq_of_algEquiv`): the trace form is invariant
under the induced automorphism of the fraction field
(`Algebra.trace_eq_of_algEquiv`), so the automorphism permutes the
trace-dual lattice and hence fixes its inverse ideal. -/
theorem smul_differentIdeal {F : Type*} [Field F] [NumberField F]
    (Пғ : F вүғвӮҗ[в„ҡ] F) :
    Пғ вҖў differentIdeal в„Ө (NumberField.RingOfIntegers F) =
      differentIdeal в„Ө (NumberField.RingOfIntegers F) :=
  smul_differentIdeal_eq Пғ

/-- **Eventual triviality of the lower-numbering ramification
filtration** (PROVEN 2026-07-24 вҖ” the level-selection input for the
Fontaine decomposition of the wild different bound below): for any
proper ideal `Q` of `рқ“һ K`, some level of the filtration
`i вҶҰ inertia(Q^(i+1)) = {Пғ вҲҲ Gal(K/в„ҡ) | вҲҖ x вҲҲ рқ“һ K, Пғx вҲ’ x вҲҲ Q^(i+1)}`
(Serre's lower-numbering ramification group `G_i`, *Corps Locaux* IV
В§1, spelled with mathlib's `Ideal.inertia` applied to the power
`Q^(i+1)`) is the trivial subgroup.  Proof: a nontrivial
`Пғ вҲҲ Gal(K/в„ҡ)` moves some element of `K`, hence вҖ” writing it as a
ratio of algebraic integers (`IsFractionRing.div_surjective`) вҖ” some
algebraic integer `x`; the Krull intersection theorem
(`Ideal.iInf_pow_eq_bot_of_isDomain`) in the Noetherian domain `рқ“һ K`
then yields a level `m` with `Пғ вҖў x вҲ’ x вҲү Q ^ (m + 1)`, excluding `Пғ`
from level `m`; the sup of these finitely many levels over the finite
group `Gal(K/в„ҡ)` bounds the whole filtration. -/
theorem exists_pow_inertia_eq_bot
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQtop : Q вү  вҠӨ) :
    вҲғ n : в„•, (Q ^ (n + 1)).inertia (K вүғвӮҗ[в„ҡ] K) = вҠҘ := by
  classical
  have hKrull : (вЁ… m : в„•, Q ^ m) = вҠҘ := Ideal.iInf_pow_eq_bot_of_isDomain Q hQtop
  -- each nontrivial automorphism is excluded at some level
  have hmove : вҲҖ Пғ : K вүғвӮҗ[в„ҡ] K, Пғ вү  1 вҶ’
      вҲғ m : в„•, Пғ вҲү (Q ^ (m + 1)).inertia (K вүғвӮҗ[в„ҡ] K) := by
    intro Пғ hПғ
    -- `Пғ` moves some algebraic integer
    have hx : вҲғ x : NumberField.RingOfIntegers K, Пғ вҖў x вү  x := by
      by_contra hfix
      push Not at hfix
      apply hПғ
      refine AlgEquiv.ext fun y => ?_
      obtain вҹЁa, b, hb, rflвҹ© :=
        IsFractionRing.div_surjective (A := NumberField.RingOfIntegers K) y
      have ha : Пғ (algebraMap (NumberField.RingOfIntegers K) K a) =
          algebraMap (NumberField.RingOfIntegers K) K a :=
        congrArg (algebraMap (NumberField.RingOfIntegers K) K) (hfix a)
      have hbfix : Пғ (algebraMap (NumberField.RingOfIntegers K) K b) =
          algebraMap (NumberField.RingOfIntegers K) K b :=
        congrArg (algebraMap (NumberField.RingOfIntegers K) K) (hfix b)
      rw [AlgEquiv.one_apply, map_divвӮҖ, ha, hbfix]
    obtain вҹЁx, hxneвҹ© := hx
    have hz : Пғ вҖў x - x вү  0 := sub_ne_zero.mpr hxne
    have hout : вҲғ m : в„•, Пғ вҖў x - x вҲү Q ^ m := by
      by_contra hall
      push Not at hall
      refine hz ?_
      have hmemi : Пғ вҖў x - x вҲҲ (вЁ… m : в„•, Q ^ m) :=
        (Submodule.mem_iInf _).mpr hall
      rwa [hKrull, Ideal.mem_bot] at hmemi
    obtain вҹЁm, hmвҹ© := hout
    refine вҹЁm, fun hmem' => hm ?_вҹ©
    have h1 : Пғ вҖў x - x вҲҲ Q ^ (m + 1) := by
      have h2 := AddSubgroup.mem_inertia.mp hmem' x
      rwa [Submodule.mem_toAddSubgroup] at h2
    exact Ideal.pow_le_pow_right (Nat.le_succ m) h1
  -- the sup of the exclusion levels over the finite group
  choose f hf using hmove
  set g : (K вүғвӮҗ[в„ҡ] K) вҶ’ в„• := fun Пғ => if h : Пғ = 1 then 0 else f Пғ h with hg
  refine вҹЁFinset.univ.sup g, ?_вҹ©
  rw [Subgroup.eq_bot_iff_forall]
  intro Пғ hПғ
  by_contra hПғ1
  have hgПғ : f Пғ hПғ1 вүӨ Finset.univ.sup g := by
    have h1 : g Пғ = f Пғ hПғ1 := dif_neg hПғ1
    exact h1 в–ё Finset.le_sup (Finset.mem_univ Пғ)
  have hle : Q ^ (Finset.univ.sup g + 1) вүӨ Q ^ (f Пғ hПғ1 + 1) :=
    Ideal.pow_le_pow_right (Nat.add_le_add_right hgПғ 1)
  refine hf Пғ hПғ1 (AddSubgroup.mem_inertia.mpr fun x => ?_)
  have h2 := AddSubgroup.mem_inertia.mp hПғ x
  rw [Submodule.mem_toAddSubgroup] at h2 вҠў
  exact hle h2

/-- **A Serre-style residue generator with a uniformizing polynomial value**
(Serre, *Corps Locaux* III В§6, proof of Prop. 12, globalized): at a nonzero
prime `Q` of `рқ“һ K` there is an algebraic integer `x` and an integer
polynomial `g` such that `x` is a unit at `Q` whose residue class generates
the residue field as a `в„Ө`-algebra (so `в„Ө[x]` is dense modulo `Q`), while
`g(x)` has `Q`-valuation exactly `1`.  Construction: lift a generator `О¶`
of the cyclic unit group of the finite residue field, take `g` an integral
lift of the minimal polynomial of `О¶` over the prime field; then `g(x) вҲҲ Q`,
and if `g(x) вҲҲ QВІ`, replacing `x` by `x + ПҖ` for a uniformizer `ПҖ` corrects
the valuation because `g'(x)` is a unit at `Q` by separability of finite
fields (Taylor expansion / `Polynomial.binomExpansion`). -/
theorem exists_residue_generator_uniformizer
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q вү  вҠҘ) :
    вҲғ (x : NumberField.RingOfIntegers K) (g : Polynomial в„Ө),
      x вҲү Q вҲ§
      (вҲҖ y : NumberField.RingOfIntegers K,
        вҲғ h : Polynomial в„Ө, y - Polynomial.aeval x h вҲҲ Q) вҲ§
      Polynomial.aeval x g вҲҲ Q вҲ§ Polynomial.aeval x g вҲү Q ^ 2 := by
  classical
  set R := NumberField.RingOfIntegers K with hRdef
  haveI hQmax : Q.IsMaximal := hQ.isMaximal hQbot
  letI : Field (R в§ё Q) := Ideal.Quotient.field Q
  haveI : Finite (R в§ё Q) := Ring.HasFiniteQuotients.finiteQuotient hQbot
  -- a generator of the cyclic unit group of the residue field
  obtain вҹЁО¶, hО¶вҹ© := IsCyclic.exists_generator (Оұ := (R в§ё Q)ЛЈ)
  set О¶v : R в§ё Q := ((О¶ : (R в§ё Q)ЛЈ) : R в§ё Q) with hО¶vdef
  -- density modulo `Q` holds for ANY lift of `О¶v`
  have hdensAny : вҲҖ x' : R, Ideal.Quotient.mk Q x' = О¶v вҶ’
      вҲҖ y : R, вҲғ h : Polynomial в„Ө, y - Polynomial.aeval x' h вҲҲ Q := by
    intro x' hx' y
    by_cases hy : y вҲҲ Q
    В· exact вҹЁ0, by simpa using hyвҹ©
    В· have hy0 : Ideal.Quotient.mk Q y вү  0 := by
        simpa [Ideal.Quotient.eq_zero_iff_mem] using hy
      obtain вҹЁu, huвҹ© := isUnit_iff_ne_zero.mpr hy0
      obtain вҹЁk, hkвҹ© := (Submonoid.mem_powers_iff u О¶).mp
        (mem_powers_iff_mem_zpowers.mpr (hО¶ u))
      refine вҹЁPolynomial.X ^ k, ?_вҹ©
      rw [вҶҗ Ideal.Quotient.eq_zero_iff_mem, map_sub, map_pow, map_pow,
        Polynomial.aeval_X, hx']
      rw [вҶҗ hu, вҶҗ hk, hО¶vdef]
      push_cast
      exact sub_self _
  -- the characteristic and the prime field
  set p : в„• := ringChar (R в§ё Q) with hpdef
  haveI : CharP (R в§ё Q) p := ringChar.charP _
  have hp : p.Prime := CharP.char_is_prime (R в§ё Q) p
  haveI : NeZero p := вҹЁhp.ne_zeroвҹ©
  haveI : Fact p.Prime := вҹЁhpвҹ©
  letI : Algebra (ZMod p) (R в§ё Q) := ZMod.algebra _ p
  haveI : Module.Finite (ZMod p) (R в§ё Q) := Module.Finite.of_finite
  have hО¶vint : IsIntegral (ZMod p) О¶v := IsIntegral.of_finite (ZMod p) О¶v
  have hsep : (minpoly (ZMod p) О¶v).Separable :=
    PerfectField.separable_of_irreducible (minpoly.irreducible hО¶vint)
  -- an integral lift of the minimal polynomial of `О¶v` over the prime field
  set Ој : Polynomial (ZMod p) := minpoly (ZMod p) О¶v with hОјdef
  obtain вҹЁg, hgвҹ© := Polynomial.map_surjective (Int.castRingHom (ZMod p))
    ZMod.intCast_surjective Ој
  -- evaluation of integer polynomials at any lift of `О¶v`
  have hEval : вҲҖ (x' : R) (e : Polynomial в„Ө), Ideal.Quotient.mk Q x' = О¶v вҶ’
      Ideal.Quotient.mk Q (Polynomial.aeval x' e) =
        Polynomial.aeval О¶v (e.map (Int.castRingHom (ZMod p))) := by
    intro x' e hx'
    have h1 : Ideal.Quotient.mk Q (Polynomial.aeval x' e) =
        Polynomial.aeval (Ideal.Quotient.mk Q x') e :=
      (Polynomial.aeval_algHom_apply (Ideal.Quotient.mk Q).toIntAlgHom x' e).symm
    rw [h1, hx', Polynomial.aeval_def, Polynomial.aeval_def, Polynomial.evalвӮӮ_map]
    congr 1
    exact Subsingleton.elim _ _
  -- `g(x') вҲҲ Q` for any lift `x'`
  have hgmem : вҲҖ x' : R, Ideal.Quotient.mk Q x' = О¶v вҶ’
      Polynomial.aeval x' g вҲҲ Q := by
    intro x' hx'
    rw [вҶҗ Ideal.Quotient.eq_zero_iff_mem, hEval x' g hx', hg]
    exact minpoly.aeval _ _
  -- `g'(x') вҲү Q` for any lift `x'` (separability of finite fields)
  have hgder : вҲҖ x' : R, Ideal.Quotient.mk Q x' = О¶v вҶ’
      Polynomial.aeval x' (Polynomial.derivative g) вҲү Q := by
    intro x' hx' hmem
    rw [вҶҗ Ideal.Quotient.eq_zero_iff_mem, hEval _ _ hx',
      вҶҗ Polynomial.derivative_map, hg] at hmem
    exact hsep.aeval_derivative_ne_zero (minpoly.aeval _ _) hmem
  -- the lift of `О¶v`
  obtain вҹЁx, hxвҹ© := Ideal.Quotient.mk_surjective О¶v
  have hxQ : вҲҖ x' : R, Ideal.Quotient.mk Q x' = О¶v вҶ’ x' вҲү Q := by
    intro x' hx' hmem
    rw [вҶҗ Ideal.Quotient.eq_zero_iff_mem, hx', hО¶vdef] at hmem
    exact Units.ne_zero О¶ hmem
  by_cases hx2 : Polynomial.aeval x g вҲү Q ^ 2
  В· exact вҹЁx, g, hxQ x hx, hdensAny x hx, hgmem x hx, hx2вҹ©
  В· push Not at hx2
    -- correct with a uniformizer
    obtain вҹЁПҖ, hПҖ1, hПҖ2вҹ© := Ideal.exists_mem_pow_notMem_pow_succ Q hQbot
      hQmax.ne_top 1
    rw [pow_one] at hПҖ1
    have hx' : Ideal.Quotient.mk Q (x + ПҖ) = О¶v := by
      rw [map_add, hx, Ideal.Quotient.eq_zero_iff_mem.mpr hПҖ1, add_zero]
    obtain вҹЁc, hcвҹ© := Polynomial.binomExpansion (g.map (algebraMap в„Ө R)) x ПҖ
    have hev : вҲҖ z : R, (g.map (algebraMap в„Ө R)).eval z = Polynomial.aeval z g := by
      intro z
      rw [Polynomial.aeval_def, Polynomial.eval_map]
    have hev' : (Polynomial.derivative (g.map (algebraMap в„Ө R))).eval x =
        Polynomial.aeval x (Polynomial.derivative g) := by
      rw [Polynomial.derivative_map, Polynomial.aeval_def, Polynomial.eval_map]
    rw [hev, hev, hev'] at hc
    refine вҹЁx + ПҖ, g, hxQ _ hx', hdensAny _ hx', hgmem _ hx', ?_вҹ©
    intro habs
    -- `ПҖ * g'(x) = g(x+ПҖ) - g(x) - cВ·ПҖВІ вҲҲ QВІ` forces `ПҖ вҲҲ QВІ` or `g'(x) вҲҲ Q`
    have hmem2 : ПҖ * Polynomial.aeval x (Polynomial.derivative g) вҲҲ Q ^ 2 := by
      have h1 : ПҖ * Polynomial.aeval x (Polynomial.derivative g) =
          Polynomial.aeval (x + ПҖ) g - Polynomial.aeval x g - c * ПҖ ^ 2 := by
        rw [hc]; ring
      rw [h1]
      refine Submodule.sub_mem _ (Submodule.sub_mem _ habs hx2) ?_
      exact Ideal.mul_mem_left _ c (by
        rw [sq, sq]
        exact Ideal.mul_mem_mul hПҖ1 hПҖ1)
    rcases Ideal.IsPrime.mem_pow_mul Q hmem2 with h | h
    В· exact hПҖ2 (by simpa using h)
    В· exact hgder x hx h

/-- **All-level `Q`-adic density of `в„Ө[x]`** (Serre, *Corps Locaux* III В§6,
Prop. 12 globalized to the number ring): if `в„Ө[x]` is dense modulo `Q` and
contains an element `g(x)` of `Q`-valuation exactly `1`, then `в„Ө[x]` is dense
modulo every power `Q ^ j`.  Induction on `j` through the exact-power
identity `Q ^ j = (g(x)^j) + Q ^ (j+1)`, which holds because `g(x)` has
valuation exactly one at `Q` (write `(g(x)) = Q * C` with `C` coprime to `Q`
via `Ideal.eq_prime_pow_mul_coprime`; then
`(g(x)^j) вҠ” Q^(j+1) = Q^j * (C^j вҠ” Q) = Q^j`). -/
theorem exists_poly_sub_mem_pow_of_generator
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q вү  вҠҘ)
    {x : NumberField.RingOfIntegers K} {g : Polynomial в„Ө}
    (hdens : вҲҖ y : NumberField.RingOfIntegers K,
      вҲғ h : Polynomial в„Ө, y - Polynomial.aeval x h вҲҲ Q)
    (hg1 : Polynomial.aeval x g вҲҲ Q) (hg2 : Polynomial.aeval x g вҲү Q ^ 2) :
    вҲҖ (j : в„•) (y : NumberField.RingOfIntegers K),
      вҲғ h : Polynomial в„Ө, y - Polynomial.aeval x h вҲҲ Q ^ j := by
  classical
  haveI hQmax : Q.IsMaximal := hQ.isMaximal hQbot
  -- the exact-power identity
  have htbot : Ideal.span {Polynomial.aeval x g} вү  вҠҘ := by
    rw [Ne, Ideal.span_singleton_eq_bot]
    intro h0
    rw [h0] at hg2
    exact hg2 (zero_mem _)
  obtain вҹЁC, hCsup, hCeqвҹ© := Ideal.eq_prime_pow_mul_coprime htbot Q
  have hcount : Multiset.count Q
      (UniqueFactorizationMonoid.normalizedFactors
        (Ideal.span {Polynomial.aeval x g})) = 1 := by
    refine Ideal.count_normalizedFactors_eq (p := Q) ?_ ?_
    В· rwa [pow_one, Ideal.span_singleton_le_iff_mem]
    В· rw [Ideal.span_singleton_le_iff_mem, one_add_one_eq_two]
      exact hg2
  rw [hcount, pow_one] at hCeq
  have hkey : вҲҖ j : в„•, Q ^ j =
      Ideal.span {Polynomial.aeval x g ^ j} вҠ” Q ^ (j + 1) := by
    intro j
    have h1 : Ideal.span {Polynomial.aeval x g ^ j} = Q ^ j * C ^ j := by
      rw [вҶҗ Ideal.span_singleton_pow, hCeq, mul_pow]
    have h2 : Q ^ (j + 1) = Q ^ j * Q := pow_succ Q j
    rw [h1, h2, вҶҗ Ideal.mul_sup]
    have h3 : C ^ j вҠ” Q = вҠӨ := by
      have h4 : IsCoprime Q (C ^ j) :=
        (Ideal.isCoprime_iff_sup_eq.mpr hCsup).pow_right
      rw [sup_comm]
      exact Ideal.isCoprime_iff_sup_eq.mp h4
    rw [h3, Ideal.mul_top]
  -- induction on the level
  intro j
  induction j with
  | zero => exact fun y => вҹЁ0, by simpвҹ©
  | succ j ih =>
    intro y
    obtain вҹЁhвӮҒ, hhвӮҒвҹ© := ih y
    rw [hkey j] at hhвӮҒ
    obtain вҹЁa, ha, b, hb, habвҹ© := Submodule.mem_sup.mp hhвӮҒ
    obtain вҹЁr, hrвҹ© := Ideal.mem_span_singleton'.mp ha
    obtain вҹЁhвӮӮ, hhвӮӮвҹ© := hdens r
    refine вҹЁhвӮҒ + g ^ j * hвӮӮ, ?_вҹ©
    have hrw : y - Polynomial.aeval x (hвӮҒ + g ^ j * hвӮӮ) =
        Polynomial.aeval x g ^ j * (r - Polynomial.aeval x hвӮӮ) + b := by
      rw [map_add, map_mul, map_pow]
      have hab' : y - Polynomial.aeval x hвӮҒ = r * Polynomial.aeval x g ^ j + b := by
        rw [hr]; exact hab.symm
      linear_combination hab'
    rw [hrw]
    refine Submodule.add_mem _ ?_ hb
    have h5 := Ideal.mul_mem_mul (Ideal.pow_mem_pow hg1 j) hhвӮӮ
    rwa [вҶҗ pow_succ] at h5

/-- **Rigidity of a primitive integral generator**: a `в„ҡ`-automorphism of the
Galois number field `K` fixing a primitive element (stated for the image of an
algebraic integer `Оё` generating `K` as a `в„ҡ`-algebra) is the identity вҖ”
the equalizer of `Пғ` and `id` is a `в„ҡ`-subalgebra containing the generator,
hence everything. -/
theorem algEquiv_eq_one_of_algebraMap_fixed
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    {Оё : NumberField.RingOfIntegers K}
    (hОё : Algebra.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} = вҠӨ)
    {Пғ : K вүғвӮҗ[в„ҡ] K}
    (hfix : Пғ (algebraMap (NumberField.RingOfIntegers K) K Оё) =
      algebraMap (NumberField.RingOfIntegers K) K Оё) : Пғ = 1 := by
  have h2 : Algebra.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} вүӨ
      AlgHom.equalizer Пғ.toAlgHom (AlgHom.id в„ҡ K) :=
    Algebra.adjoin_le (Set.singleton_subset_iff.mpr hfix)
  refine AlgEquiv.ext fun y => ?_
  have hy : y вҲҲ Algebra.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} := by
    rw [hОё]; exact Algebra.mem_top
  exact h2 hy

/-- **Congruence propagation from a locally dense generator** (the key formal
step of Serre's Lemme IV В§1 1, globalized): if `в„Ө[Оё]` is dense modulo `Q ^ j`,
`Пғ` stabilizes `Q`, and `ПғОё вүЎ Оё (mod Q ^ j)`, then `Пғ` lies in the inertia
subgroup of `Q ^ j` вҖ” i.e. `Пғy вүЎ y (mod Q ^ j)` for EVERY algebraic integer
`y`.  Indeed `y вүЎ h(Оё)`, `Пғ(h(Оё)) вҲ’ h(Оё) = h(ПғОё) вҲ’ h(Оё)` is divisible by
`ПғОё вҲ’ Оё` (`Polynomial.sub_dvd_eval_sub`), and `Пғ` maps `Q ^ j` to itself. -/
theorem mem_inertia_pow_of_smul_sub_mem_of_dense
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (j : в„•)
    {Оё : NumberField.RingOfIntegers K}
    (hdens : вҲҖ y : NumberField.RingOfIntegers K,
      вҲғ h : Polynomial в„Ө, y - Polynomial.aeval Оё h вҲҲ Q ^ j)
    {Пғ : K вүғвӮҗ[в„ҡ] K} (hПғQ : Пғ вҖў Q = Q) (hОё : Пғ вҖў Оё - Оё вҲҲ Q ^ j) :
    Пғ вҲҲ (Q ^ j).inertia (K вүғвӮҗ[в„ҡ] K) := by
  refine AddSubgroup.mem_inertia.mpr fun y => ?_
  rw [Submodule.mem_toAddSubgroup]
  obtain вҹЁh, hhвҹ© := hdens y
  have hkey : Пғ вҖў y - y =
      (Пғ вҖў (y - Polynomial.aeval Оё h) - (y - Polynomial.aeval Оё h)) +
        (Пғ вҖў Polynomial.aeval Оё h - Polynomial.aeval Оё h) := by
    rw [smul_sub]; ring
  rw [hkey]
  refine Submodule.add_mem _ (Submodule.sub_mem _ ?_ hh) ?_
  В· -- `Пғ` preserves `Q ^ j`
    have h1 : Пғ вҖў (y - Polynomial.aeval Оё h) вҲҲ Пғ вҖў Q ^ j :=
      Ideal.smul_mem_pointwise_smul _ _ _ hh
    rwa [smul_pow' Пғ Q j, hПғQ] at h1
  В· -- the divisibility step
    have hcast : Пғ вҖў Polynomial.aeval Оё h = Polynomial.aeval (Пғ вҖў Оё) h :=
      (Polynomial.aeval_algHom_apply
        (MulSemiringAction.toRingHom (K вүғвӮҗ[в„ҡ] K)
          (NumberField.RingOfIntegers K) Пғ).toIntAlgHom Оё h).symm
    rw [hcast]
    have hdvd : (Пғ вҖў Оё - Оё) вҲЈ
        (Polynomial.aeval (Пғ вҖў Оё) h - Polynomial.aeval Оё h) := by
      have h2 := Polynomial.sub_dvd_eval_sub (Пғ вҖў Оё) Оё
        (h.map (algebraMap в„Ө (NumberField.RingOfIntegers K)))
      rwa [Polynomial.eval_map, Polynomial.eval_map,
        вҶҗ Polynomial.aeval_def, вҶҗ Polynomial.aeval_def] at h2
    obtain вҹЁz, hzвҹ© := hdvd
    rw [hz]
    exact Ideal.mul_mem_right _ _ hОё

/-- **The master generator selection at `Q`** (the globalized monogenicity
input to Serre IV В§1: a single algebraic integer that is simultaneously a
primitive element of `K/в„ҡ`, `Q`-adically dense to level `m`, and separates
`Q` from its conjugates): there is `Оё вҲҲ рқ“һ K` with (i) `Оё` generating `K` as
a `в„ҡ`-algebra, (ii) `в„Ө[Оё]` dense modulo `Q ^ m`, and (iii) `ПғОё вүў Оё (mod Q)`
for every `Пғ вҲҲ Gal(K/в„ҡ)` moving `Q`.  Construction: start from the
Serre-style residue generator (dense at all levels by
`exists_poly_sub_mem_pow_of_generator`), impose `Оё вүЎ x (mod Q^m)` and
`Оё вүЎ 0 (mod P)` at every conjugate `P вү  Q` by CRT
(`IsDedekindDomain.exists_forall_sub_mem_ideal`), then perturb by integer
multiples `cВ·NВ·Оі` of a primitive algebraic integer `Оі` вҖ” with
`N = absNorm (Q^m В· вҲҸ P)` killing all congruences вҖ” and pick `c` by
pigeonhole on the finitely many intermediate fields of the Galois
extension `K/в„ҡ` so that the perturbed element is primitive. -/
theorem exists_dense_primitive_generator
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    [IsGalois в„ҡ K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q вү  вҠҘ) (m : в„•) (hm : m вү  0) :
    вҲғ Оё : NumberField.RingOfIntegers K,
      Algebra.adjoin в„ҡ
        {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} = вҠӨ вҲ§
      (вҲҖ y : NumberField.RingOfIntegers K,
        вҲғ h : Polynomial в„Ө, y - Polynomial.aeval Оё h вҲҲ Q ^ m) вҲ§
      (вҲҖ Пғ : K вүғвӮҗ[в„ҡ] K, Пғ вҖў Q вү  Q вҶ’ Пғ вҖў Оё - Оё вҲү Q) := by
  classical
  haveI := hQ
  obtain вҹЁx, g, hxQ, hdens1, hg1, hg2вҹ© :=
    exists_residue_generator_uniformizer K Q hQ hQbot
  have hdens := exists_poly_sub_mem_pow_of_generator K Q hQ hQbot hdens1 hg1 hg2
  -- the conjugate primes distinct from `Q`
  set S : Finset (Ideal (NumberField.RingOfIntegers K)) :=
    (Finset.univ.image (fun Пғ : K вүғвӮҗ[в„ҡ] K => Пғ вҖў Q)).erase Q with hSdef
  have hSbot : вҲҖ P вҲҲ S, P вү  вҠҘ := by
    intro P hP
    obtain вҹЁПғ, -, rflвҹ© := Finset.mem_image.mp (Finset.mem_of_mem_erase hP)
    intro h0
    apply hQbot
    have h1 := congrArg (fun I => ПғвҒ»В№ вҖў I) h0
    simpa using h1
  have hSprime : вҲҖ P вҲҲ S, P.IsPrime := by
    intro P hP
    obtain вҹЁПғ, -, rflвҹ© := Finset.mem_image.mp (Finset.mem_of_mem_erase hP)
    infer_instance
  -- CRT: `ОёвӮӮ вүЎ x (mod Q^m)`, `ОёвӮӮ вүЎ 0 (mod P)` for all conjugates `P вү  Q`
  have hprimeAll : вҲҖ P вҲҲ insert Q S, Prime P := by
    intro P hP
    rcases Finset.mem_insert.mp hP with rfl | hPS
    В· exact (Ideal.prime_iff_isPrime hQbot).mpr hQ
    В· exact (Ideal.prime_iff_isPrime (hSbot P hPS)).mpr (hSprime P hPS)
  obtain вҹЁОёвӮӮ, hОёвӮӮвҹ© := IsDedekindDomain.exists_forall_sub_mem_ideal
    (s := insert Q S) id (fun P => if P = Q then m else 1) hprimeAll
    (fun _ _ _ _ hne => hne)
    (fun P => if (P : Ideal (NumberField.RingOfIntegers K)) = Q then x else 0)
  have hОёвӮӮQ : ОёвӮӮ - x вҲҲ Q ^ m := by
    have h1 := hОёвӮӮ Q (Finset.mem_insert_self _ _)
    simpa using h1
  have hОёвӮӮS : вҲҖ P вҲҲ S, ОёвӮӮ вҲҲ P := by
    intro P hPS
    have hne := (Finset.mem_erase.mp hPS).1
    have h1 := hОёвӮӮ P (Finset.mem_insert_of_mem hPS)
    simpa [hne, pow_one] using h1
  -- the perturbation ideal, made opaque with exactly the needed interface
  obtain вҹЁJ, hJQ, hJS, hJbotвҹ© :
      вҲғ J : Ideal (NumberField.RingOfIntegers K),
        J вүӨ Q ^ m вҲ§ (вҲҖ P вҲҲ S, J вүӨ P) вҲ§ J вү  вҠҘ := by
    refine вҹЁQ ^ m * вҲҸ P вҲҲ S, P, Ideal.mul_le_right, ?_, ?_вҹ©
    В· intro P hPS
      refine le_trans Ideal.mul_le_left ?_
      rw [вҶҗ Finset.prod_erase_mul _ _ hPS]
      exact Ideal.mul_le_left
    В· rw [вҶҗ Ideal.zero_eq_bot]
      refine mul_ne_zero ?_ ?_
      В· exact pow_ne_zero m (by rw [Ideal.zero_eq_bot]; exact hQbot)
      В· rw [Finset.prod_ne_zero_iff]
        intro P hPS
        rw [Ideal.zero_eq_bot]
        exact hSbot P hPS
  haveI : Finite (NumberField.RingOfIntegers K в§ё J) :=
    Ring.HasFiniteQuotients.finiteQuotient hJbot
  have hN0 : Ideal.absNorm J вү  0 := (Ideal.absNorm_ne_zero_iff J).mpr вҖ№_вҖә
  have hNJ : ((Ideal.absNorm J : в„•) : NumberField.RingOfIntegers K) вҲҲ J :=
    Ideal.absNorm_mem J
  -- a primitive algebraic integer
  obtain вҹЁОұ, hОұвҹ© := Field.exists_primitive_element в„ҡ K
  obtain вҹЁd, hd0, hdintвҹ© := ((IsFractionRing.isAlgebraic_iff в„Ө в„ҡ K).mpr
    (Algebra.IsAlgebraic.isAlgebraic Оұ)).exists_integral_multiple
  obtain вҹЁОі, hОіKвҹ© : вҲғ Оі : NumberField.RingOfIntegers K,
      algebraMap (NumberField.RingOfIntegers K) K Оі = d вҖў Оұ :=
    вҹЁвҹЁd вҖў Оұ, hdintвҹ©, rflвҹ©
  have hОіtop : IntermediateField.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K Оі : K)} = вҠӨ := by
    rw [hОіK, eq_top_iff, вҶҗ hОұ]
    rw [IntermediateField.adjoin_le_iff, Set.singleton_subset_iff]
    have hd : ((d : в„ҡ)) вү  0 := Int.cast_ne_zero.mpr hd0
    have hmem : (d вҖў Оұ : K) вҲҲ IntermediateField.adjoin в„ҡ {(d вҖў Оұ : K)} :=
      IntermediateField.mem_adjoin_simple_self в„ҡ _
    have h2 := (IntermediateField.adjoin в„ҡ {(d вҖў Оұ : K)}).smul_mem hmem
      (x := (d : в„ҡ)вҒ»В№)
    rwa [вҶҗ Int.cast_smul_eq_zsmul в„ҡ d Оұ, inv_smul_smulвӮҖ hd] at h2
  -- pigeonhole over the finitely many intermediate fields
  haveI : Finite (IntermediateField в„ҡ K) :=
    Finite.of_equiv _ (IsGalois.intermediateFieldEquivSubgroup
      (F := в„ҡ) (E := K)).symm.toEquiv
  obtain вҹЁw, hwK, hwJвҹ© : вҲғ w : NumberField.RingOfIntegers K,
      algebraMap (NumberField.RingOfIntegers K) K w =
        ((Ideal.absNorm J : в„•) : K) *
          algebraMap (NumberField.RingOfIntegers K) K Оі вҲ§
      w вҲҲ J :=
    вҹЁ((Ideal.absNorm J : в„•) : NumberField.RingOfIntegers K) * Оі,
      by rw [map_mul, map_natCast], Ideal.mul_mem_right _ _ hNJвҹ©
  obtain вҹЁcвӮҒ, cвӮӮ, hcc, hFeqвҹ© := Finite.exists_ne_map_eq_of_infinite
    (fun c : в„• => IntermediateField.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K (ОёвӮӮ + (c : в„Ө) вҖў w) : K)})
  set Оё : NumberField.RingOfIntegers K := ОёвӮӮ + (cвӮҒ : в„Ө) вҖў w with hОёdef
  set E : IntermediateField в„ҡ K := IntermediateField.adjoin в„ҡ
    {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} with hEdef
  -- the difference of the two lifts recovers `w`, hence `Оі`, hence all of `K`
  have hwE : algebraMap (NumberField.RingOfIntegers K) K w вҲҲ E := by
    have h1 : algebraMap (NumberField.RingOfIntegers K) K
        (ОёвӮӮ + (cвӮҒ : в„Ө) вҖў w) вҲҲ E :=
      IntermediateField.mem_adjoin_simple_self в„ҡ _
    have h2 : algebraMap (NumberField.RingOfIntegers K) K
        (ОёвӮӮ + (cвӮӮ : в„Ө) вҖў w) вҲҲ E := by
      rw [hFeq]
      exact IntermediateField.mem_adjoin_simple_self в„ҡ _
    have h3 := E.sub_mem h1 h2
    have h4 : algebraMap (NumberField.RingOfIntegers K) K
          (ОёвӮӮ + (cвӮҒ : в„Ө) вҖў w) -
        algebraMap (NumberField.RingOfIntegers K) K (ОёвӮӮ + (cвӮӮ : в„Ө) вҖў w) =
        ((cвӮҒ : в„Ө) - (cвӮӮ : в„Ө)) вҖў
          algebraMap (NumberField.RingOfIntegers K) K w := by
      rw [вҶҗ map_sub, вҶҗ map_zsmul]
      congr 1
      rw [sub_smul]
      ring
    rw [h4] at h3
    have hz : ((cвӮҒ : в„Ө) - (cвӮӮ : в„Ө)) вү  0 :=
      sub_ne_zero.mpr (by exact_mod_cast hcc)
    have hzQ : (((cвӮҒ : в„Ө) - (cвӮӮ : в„Ө) : в„Ө) : в„ҡ) вү  0 := Int.cast_ne_zero.mpr hz
    have h5 := E.smul_mem h3
      (x := ((((cвӮҒ : в„Ө) - (cвӮӮ : в„Ө) : в„Ө) : в„ҡ))вҒ»В№)
    rwa [вҶҗ Int.cast_smul_eq_zsmul в„ҡ ((cвӮҒ : в„Ө) - (cвӮӮ : в„Ө)), inv_smul_smulвӮҖ hzQ]
      at h5
  have hОіE : algebraMap (NumberField.RingOfIntegers K) K Оі вҲҲ E := by
    have hNK : ((Ideal.absNorm J : в„•) : K) вү  0 := by
      exact_mod_cast hN0
    have h1 : algebraMap (NumberField.RingOfIntegers K) K Оі =
        (((Ideal.absNorm J : в„•) : K))вҒ»В№ *
          algebraMap (NumberField.RingOfIntegers K) K w := by
      rw [hwK, вҶҗ mul_assoc, inv_mul_cancelвӮҖ hNK, one_mul]
    rw [h1]
    refine E.mul_mem ?_ hwE
    have h2 : (((Ideal.absNorm J : в„•) : K))вҒ»В№ =
        algebraMap в„ҡ K (((Ideal.absNorm J : в„•) : в„ҡ))вҒ»В№ := by
      rw [map_invвӮҖ, map_natCast]
    rw [h2]
    exact E.algebraMap_mem _
  have hEtop : E = вҠӨ := by
    rw [eq_top_iff, вҶҗ hОіtop, IntermediateField.adjoin_le_iff,
      Set.singleton_subset_iff]
    exact hОіE
  -- primitivity, in `Algebra.adjoin` form
  have hОёtop : Algebra.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} = вҠӨ := by
    have hint : IsIntegral в„ҡ
        (algebraMap (NumberField.RingOfIntegers K) K Оё : K) :=
      IsIntegral.of_finite в„ҡ _
    rw [вҶҗ IntermediateField.adjoin_simple_toSubalgebra_of_isAlgebraic
      hint.isAlgebraic, вҶҗ hEdef, hEtop]
    rfl
  -- the congruence `Оё вүЎ x (mod Q^m)`
  have hОёx : Оё - x вҲҲ Q ^ m := by
    have h2 : (cвӮҒ : в„Ө) вҖў w вҲҲ Q ^ m := hJQ (zsmul_mem hwJ _)
    have h3 : Оё - x = (ОёвӮӮ - x) + (cвӮҒ : в„Ө) вҖў w := by
      rw [hОёdef]; ring
    rw [h3]
    exact Submodule.add_mem _ hОёвӮӮQ h2
  have hОёQ : Оё вҲү Q := by
    intro hmem
    apply hxQ
    have h1 : Оё - x вҲҲ Q := Ideal.pow_le_self hm hОёx
    have h2 : x = Оё - (Оё - x) := by ring
    rw [h2]
    exact Submodule.sub_mem _ hmem h1
  refine вҹЁОё, hОёtop, ?_, ?_вҹ©
  В· -- density modulo `Q ^ m`
    intro y
    obtain вҹЁh, hhвҹ© := hdens m y
    refine вҹЁh, ?_вҹ©
    have hdvd : (Оё - x) вҲЈ (Polynomial.aeval Оё h - Polynomial.aeval x h) := by
      have h2 := Polynomial.sub_dvd_eval_sub Оё x
        (h.map (algebraMap в„Ө (NumberField.RingOfIntegers K)))
      rwa [Polynomial.eval_map, Polynomial.eval_map,
        вҶҗ Polynomial.aeval_def, вҶҗ Polynomial.aeval_def] at h2
    obtain вҹЁz, hzвҹ© := hdvd
    have h3 : y - Polynomial.aeval Оё h =
        (y - Polynomial.aeval x h) - (Оё - x) * z := by
      rw [вҶҗ hz]; ring
    rw [h3]
    exact Submodule.sub_mem _ hh (Ideal.mul_mem_right _ _ hОёx)
  В· -- conjugate separation
    intro Пғ hПғQ hmem
    have hin : ПғвҒ»В№ вҖў Q вҲҲ S := by
      rw [hSdef]
      refine Finset.mem_erase.mpr
        вҹЁ?_, Finset.mem_image.mpr вҹЁПғвҒ»В№, Finset.mem_univ _, rflвҹ©вҹ©
      intro h0
      apply hПғQ
      have h1 := congrArg (fun I => Пғ вҖў I) h0
      simpa using h1.symm
    have hОёP : Оё вҲҲ ПғвҒ»В№ вҖў Q := by
      have h1 : ОёвӮӮ вҲҲ ПғвҒ»В№ вҖў Q := hОёвӮӮS _ hin
      have h2 : (cвӮҒ : в„Ө) вҖў w вҲҲ ПғвҒ»В№ вҖў Q := zsmul_mem (hJS _ hin hwJ) _
      rw [hОёdef]
      exact Submodule.add_mem _ h1 h2
    have hПғОё : Пғ вҖў Оё вҲҲ Q := by
      have h1 : Пғ вҖў Оё вҲҲ Пғ вҖў ПғвҒ»В№ вҖў Q :=
        Ideal.smul_mem_pointwise_smul _ _ _ hОёP
      rwa [smul_inv_smul] at h1
    apply hОёQ
    have h2 : Оё = Пғ вҖў Оё - (Пғ вҖў Оё - Оё) := by ring
    rw [h2]
    exact Submodule.sub_mem _ hПғОё hmem

open scoped Classical in
/-- **The derivative of the minimal polynomial as a product of conjugate
differences** (Serre, *Corps Locaux* III В§6 Cor. 2 input, global form): for
a primitive algebraic integer `Оё` of the Galois number field `K/в„ҡ`,
`f'(Оё) = вҲҸ_{Пғ вү  1} (Оё вҲ’ ПғОё)` in `рқ“һ K`, where `f = minpoly в„Ө Оё`.  Indeed
`minpoly в„ҡ Оё` splits in `K` with simple roots exactly the `#Gal(K/в„ҡ)`
distinct conjugates `ПғОё` (primitivity makes `Пғ вҶҰ ПғОё` injective), so its
image in `K[X]` is the Lagrange nodal polynomial of the conjugates, whose
derivative at the node `Оё` is the product of the differences
(`Lagrange.eval_nodal_derivative_eval_node_eq`). -/
theorem aeval_derivative_minpoly_eq_prod_sub_smul
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    [IsGalois в„ҡ K]
    (Оё : NumberField.RingOfIntegers K)
    (hОё : Algebra.adjoin в„ҡ
      {(algebraMap (NumberField.RingOfIntegers K) K Оё : K)} = вҠӨ) :
    Polynomial.aeval Оё (Polynomial.derivative (minpoly в„Ө Оё)) =
      вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), (Оё - Пғ вҖў Оё) := by
  have hint : IsIntegral в„Ө Оё := Algebra.IsIntegral.isIntegral Оё
  have hintK : IsIntegral в„ҡ
      (algebraMap (NumberField.RingOfIntegers K) K Оё : K) :=
    IsIntegral.of_finite в„ҡ _
  set ОёK : K := algebraMap (NumberField.RingOfIntegers K) K Оё with hОёKdef
  set v : (K вүғвӮҗ[в„ҡ] K) вҶ’ K := fun Пғ => Пғ ОёK with hvdef
  -- injectivity of the conjugate map
  have hvinj : Function.Injective v := by
    intro Пғ П„ hПғП„
    have h1 : (П„вҒ»В№ * Пғ) ОёK = ОёK := by
      have h2 : П„вҒ»В№ (Пғ ОёK) = П„вҒ»В№ (П„ ОёK) := congrArg _ hПғП„
      rwa [вҶҗ AlgEquiv.mul_apply, вҶҗ AlgEquiv.mul_apply, inv_mul_cancel,
        AlgEquiv.one_apply] at h2
    have h3 : П„вҒ»В№ * Пғ = 1 := algEquiv_eq_one_of_algebraMap_fixed K hОё h1
    rw [вҶҗ one_mul Пғ, вҶҗ mul_inv_cancel П„, mul_assoc, h3, mul_one]
  -- the mapped minimal polynomial
  set P : Polynomial K :=
    (minpoly в„ҡ ОёK).map (algebraMap в„ҡ K) with hPdef
  have hPmonic : P.Monic := (minpoly.monic hintK).map _
  have hPsplits : P.Splits := by
    rw [hPdef]
    exact Normal.splits inferInstance ОёK
  have hPdeg : P.natDegree = Fintype.card (K вүғвӮҗ[в„ҡ] K) := by
    have hadj : IntermediateField.adjoin в„ҡ {ОёK} = вҠӨ := by
      refine IntermediateField.toSubalgebra_injective ?_
      rw [IntermediateField.adjoin_simple_toSubalgebra_of_isAlgebraic
        hintK.isAlgebraic, IntermediateField.top_toSubalgebra]
      exact hОё
    have hdeg : (minpoly в„ҡ ОёK).natDegree = Module.finrank в„ҡ K := by
      rw [вҶҗ IntermediateField.adjoin.finrank hintK, hadj]
      exact IntermediateField.finrank_top'
    have h2 : P.natDegree = (minpoly в„ҡ ОёK).natDegree := by
      rw [hPdef]
      exact Polynomial.natDegree_map_eq_of_injective
        (algebraMap в„ҡ K).injective _
    rw [h2, hdeg, вҶҗ Nat.card_eq_fintype_card]
    exact (IsGalois.card_aut_eq_finrank в„ҡ K).symm
  -- the roots of `P` are exactly the conjugates
  have hroots : P.roots = Finset.univ.val.map v := by
    symm
    refine Multiset.eq_of_le_of_card_le ?_ ?_
    В· rw [Multiset.le_iff_count]
      intro a
      by_cases ha : a вҲҲ Finset.univ.val.map v
      В· rw [Multiset.count_eq_one_of_mem
          (Finset.univ.nodup.map hvinj) ha]
        rw [Nat.one_le_iff_ne_zero, Ne, Multiset.count_eq_zero,
          not_not]
        obtain вҹЁПғ, -, rflвҹ© := Multiset.mem_map.mp ha
        rw [Polynomial.mem_roots (hPmonic.ne_zero)]
        rw [Polynomial.IsRoot, hPdef, Polynomial.eval_map,
          вҶҗ Polynomial.aeval_def, hvdef]
        have h2 : Polynomial.aeval (Пғ ОёK) (minpoly в„ҡ ОёK) =
            Пғ (Polynomial.aeval ОёK (minpoly в„ҡ ОёK)) :=
          Polynomial.aeval_algHom_apply Пғ.toAlgHom ОёK (minpoly в„ҡ ОёK)
        rw [h2, minpoly.aeval, map_zero]
      В· rw [Multiset.count_eq_zero_of_notMem ha]
        exact Nat.zero_le _
    В· rw [Multiset.card_map, вҶҗ Finset.card_def, Finset.card_univ,
        Polynomial.splits_iff_card_roots.mp hPsplits, hPdeg]
  -- `P` is the nodal polynomial of the conjugates
  have hnodal : P = Lagrange.nodal Finset.univ v := by
    rw [hPsplits.eq_prod_roots_of_monic hPmonic,
      hroots, Lagrange.nodal, Finset.prod_eq_multiset_prod,
      Multiset.map_map]
    rfl
  -- evaluate the derivative at the node `1`
  have hKeval : Polynomial.eval ОёK (Polynomial.derivative P) =
      вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), (ОёK - v Пғ) := by
    have h1 : ОёK = v 1 := by rw [hvdef]; rfl
    rw [hnodal, h1, Lagrange.eval_nodal_derivative_eval_node_eq
      (Finset.mem_univ 1), Lagrange.eval_nodal]
  -- pull everything back to `рқ“һ K`
  apply FaithfulSMul.algebraMap_injective (NumberField.RingOfIntegers K) K
  have hLHS : algebraMap (NumberField.RingOfIntegers K) K
      (Polynomial.aeval Оё (Polynomial.derivative (minpoly в„Ө Оё))) =
      Polynomial.eval ОёK (Polynomial.derivative P) := by
    have h1 : algebraMap (NumberField.RingOfIntegers K) K
        (Polynomial.aeval Оё (Polynomial.derivative (minpoly в„Ө Оё))) =
        Polynomial.aeval ОёK (Polynomial.derivative (minpoly в„Ө Оё)) := by
      rw [hОёKdef]
      exact (Polynomial.aeval_algebraMap_apply K Оё _).symm
    rw [h1, hPdef, minpoly.isIntegrallyClosed_eq_field_fractions в„ҡ K hint,
      Polynomial.derivative_map, Polynomial.derivative_map,
      Polynomial.eval_map, Polynomial.evalвӮӮ_map, Polynomial.aeval_def]
    congr 1
  rw [hLHS, hKeval, map_prod]
  refine Finset.prod_congr rfl fun Пғ _ => ?_
  rw [map_sub, hvdef, hОёKdef]
  congr 1

open scoped Classical in
/-- **The double count of the ramification filtration** (Serre, *Corps
Locaux* IV В§1, proof of Prop. 4): summing over the nontrivial `Пғ` the number
of levels `i < n` at which `Пғ вҲҲ G_i = inertia(Q^(i+1))` equals
`ОЈ_{i<n} (#G_i вҲ’ 1)` вҖ” count the pairs `(Пғ, i)` with `Пғ вҲҲ G_i \ {1}` both
ways. -/
theorem sum_card_filter_inertia_eq
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (n : в„•) :
    вҲ‘ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K),
      ((Finset.range n).filter
        (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card =
    вҲ‘ i вҲҲ Finset.range n,
      (Nat.card ((Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K)) - 1) := by
  simp only [Finset.card_filter]
  rw [Finset.sum_comm]
  refine Finset.sum_congr rfl fun i _ => ?_
  rw [show (вҲ‘ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K),
      if Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K) then 1 else 0) =
      ((Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K)).filter
        (fun Пғ => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card from
    (Finset.card_filter
      (fun Пғ => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))
      (Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K))).symm]
  have h2 : (Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K)).filter
      (fun Пғ => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K)) =
      (Finset.univ.filter
        (fun Пғ => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).erase 1 :=
    Finset.filter_erase _ _ _
  rw [h2, Finset.card_erase_of_mem
    (Finset.mem_filter.mpr вҹЁFinset.mem_univ _, Subgroup.one_mem _вҹ©)]
  congr 1
  rw [Nat.card_eq_fintype_card]
  exact (Fintype.card_subtype
    (fun Пғ => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).symm

/-- **The different-exponent bound through the lower ramification
filtration** (PROVEN 2026-07-24 вҖ” leaf (a) of the decomposition of the
wild Fontaine bound below; Serre, *Corps Locaux* IV В§1 Prop. 4, `вүӨ`
direction, proven GLOBALLY, avoiding the completion entirely): if `Q^d`
divides the different ideal `рқ”Ў_{K/в„ҡ}` at a nonzero prime `Q` of the
Galois number field `K/в„ҡ`, then `d вүӨ ОЈ_{i<n} (#G_i вҲ’ 1)`, where
`G_i = inertia(Q^(i+1)) = {Пғ вҲҲ Gal(K/в„ҡ) | вҲҖ x вҲҲ рқ“һ K, Пғx вҲ’ x вҲҲ Q^(i+1)}`
is the `i`-th lower-numbering ramification group at `Q` and the level
`n` already has `G_n = вҠҘ` (so the truncated sum is the full one).
Proof: choose the master generator `Оё` of
`exists_dense_primitive_generator` вҖ” a primitive algebraic integer with
`в„Ө[Оё]` dense modulo `Q^(n+2)` and `ПғОё вүў Оё (mod Q)` for every `Пғ` moving
`Q` (Serre's III В§6 Prop. 12 residue-generator-plus-uniformizer
construction, CRT against the conjugate primes, and a pigeonhole over
the finitely many intermediate fields for primitivity).  The different
divides `(f'(Оё))` (mathlib's `conductor_mul_differentIdeal`), and
`f'(Оё) = вҲҸ_{Пғвү 1} (Оё вҲ’ ПғОё)` since the minimal polynomial is the Lagrange
nodal polynomial of the conjugates
(`aeval_derivative_minpoly_eq_prod_sub_smul`).  Each factor lies in `Q`
to order at most `#{i < n : Пғ вҲҲ G_i}`: a congruence `ПғОё вүЎ Оё (mod
Q^(i+1))` propagates to all of `рқ“һ K` by density
(`mem_inertia_pow_of_smul_sub_mem_of_dense`), so an exponent beyond the
count would either put `Пғ` into `G_n = вҠҘ` or overfill the count.
Unique factorization collects the factor bounds into
`d вүӨ ОЈ_{Пғвү 1} #{i<n : Пғ вҲҲ G_i}`, and the double count
`sum_card_filter_inertia_eq` converts the total to
`ОЈ_{i<n} (#G_i вҲ’ 1)`. -/
theorem le_sum_card_inertia_pow_of_pow_dvd_differentIdeal
    (K : IntermediateField в„ҡ (AlgebraicClosure в„ҡ)) [NumberField K]
    [IsGalois в„ҡ K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q вү  вҠҘ)
    (n : в„•) (hn : (Q ^ (n + 1)).inertia (K вүғвӮҗ[в„ҡ] K) = вҠҘ)
    (d : в„•) (hd : Q ^ d вҲЈ differentIdeal в„Ө (NumberField.RingOfIntegers K)) :
    d вүӨ вҲ‘ i вҲҲ Finset.range n,
      (Nat.card ((Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K)) - 1) := by
  classical
  haveI := hQ
  haveI : Q.IsMaximal := hQ.isMaximal hQbot
  -- the master generator at level `n + 2`
  obtain вҹЁОё, hОёtop, hОёdens, hОёconjвҹ© :=
    exists_dense_primitive_generator K Q hQ hQbot (n + 2) (by omega)
  -- the product formula
  have hprod := aeval_derivative_minpoly_eq_prod_sub_smul K Оё hОёtop
  -- the different divides the span of `f'(Оё)`
  have hdiv : differentIdeal в„Ө (NumberField.RingOfIntegers K) вҲЈ
      Ideal.span
        {Polynomial.aeval Оё (Polynomial.derivative (minpoly в„Ө Оё))} :=
    вҹЁconductor в„Ө Оё, by
      rw [mul_comm]
      exact (conductor_mul_differentIdeal в„Ө в„ҡ K Оё hОёtop).symmвҹ©
  -- the per-`Пғ` bound: `Оё вҲ’ ПғОё вҲү Q^{#{i<n : Пғ вҲҲ G_i} + 1}`
  have hnotmem : вҲҖ Пғ : K вүғвӮҗ[в„ҡ] K, Пғ вү  1 вҶ’
      Оё - Пғ вҖў Оё вҲү Q ^ (((Finset.range n).filter
        (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card + 1) := by
    intro Пғ hПғ1 hmem
    have hmQ : Пғ вҖў Оё - Оё вҲҲ Q := by
      have h1 : Оё - Пғ вҖў Оё вҲҲ Q := Ideal.pow_le_self (Nat.succ_ne_zero _) hmem
      have h2 : Пғ вҖў Оё - Оё = -(Оё - Пғ вҖў Оё) := by ring
      rw [h2]
      exact Submodule.neg_mem _ h1
    have hПғQ : Пғ вҖў Q = Q := by
      by_contra hne
      exact hОёconj Пғ hne hmQ
    have hmle : ((Finset.range n).filter
        (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card вүӨ n :=
      le_trans (Finset.card_filter_le _ _) (le_of_eq (Finset.card_range n))
    have hGi : вҲҖ i, i вүӨ ((Finset.range n).filter
        (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card вҶ’
        Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K) := by
      intro i hi
      refine mem_inertia_pow_of_smul_sub_mem_of_dense K Q (i + 1)
        (Оё := Оё) ?_ hПғQ ?_
      В· intro y
        obtain вҹЁh, hhвҹ© := hОёdens y
        exact вҹЁh, Ideal.pow_le_pow_right (by omega) hhвҹ©
      В· have h1 : Оё - Пғ вҖў Оё вҲҲ Q ^ (i + 1) :=
          Ideal.pow_le_pow_right (by omega) hmem
        have h2 : Пғ вҖў Оё - Оё = -(Оё - Пғ вҖў Оё) := by ring
        rw [h2]
        exact Submodule.neg_mem _ h1
    rcases eq_or_lt_of_le hmle with heq | hlt
    В· have h1 := hGi n heq.ge
      rw [hn] at h1
      exact hПғ1 (Subgroup.mem_bot.mp h1)
    В· have hsub : Finset.range (((Finset.range n).filter
          (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card + 1) вҠҶ
          (Finset.range n).filter
            (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K)) := by
        intro i hi
        rw [Finset.mem_range] at hi
        exact Finset.mem_filter.mpr
          вҹЁFinset.mem_range.mpr (by omega), hGi i (by omega)вҹ©
      have h2 := Finset.card_le_card hsub
      rw [Finset.card_range] at h2
      omega
  -- extract the exact power of `Q` from each factor
  have hstep : вҲҖ Пғ : K вүғвӮҗ[в„ҡ] K,
      вҲғ (c : в„•) (C : Ideal (NumberField.RingOfIntegers K)),
        IsCoprime Q C вҲ§ (Пғ вү  1 вҶ’
          c вүӨ ((Finset.range n).filter
            (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card вҲ§
          Ideal.span {Оё - Пғ вҖў Оё} = Q ^ c * C) := by
    intro Пғ
    by_cases hПғ1 : Пғ = 1
    В· exact вҹЁ0, вҠӨ, Ideal.isCoprime_iff_sup_eq.mpr (sup_top_eq Q),
        fun h => absurd hПғ1 hвҹ©
    В· have hne0 : Оё - Пғ вҖў Оё вү  0 := by
        intro h0
        refine hПғ1 (algEquiv_eq_one_of_algebraMap_fixed K hОёtop ?_)
        have h1 : Пғ вҖў Оё = Оё := (sub_eq_zero.mp h0).symm
        have h2 : algebraMap (NumberField.RingOfIntegers K) K (Пғ вҖў Оё) =
            Пғ (algebraMap (NumberField.RingOfIntegers K) K Оё) := rfl
        rw [вҶҗ h2, h1]
      have hspanbot : Ideal.span {Оё - Пғ вҖў Оё} вү  вҠҘ := by
        rw [Ne, Ideal.span_singleton_eq_bot]
        exact hne0
      obtain вҹЁC, hCsup, hCeqвҹ© := Ideal.eq_prime_pow_mul_coprime hspanbot Q
      refine вҹЁ_, C, Ideal.isCoprime_iff_sup_eq.mpr hCsup, fun _ => вҹЁ?_, hCeqвҹ©вҹ©
      by_contra hgt
      push Not at hgt
      have h1 : Q ^ (((Finset.range n).filter
          (fun i => Пғ вҲҲ (Q ^ (i + 1)).inertia (K вүғвӮҗ[в„ҡ] K))).card + 1) вҲЈ
          Ideal.span {Оё - Пғ вҖў Оё} :=
        dvd_trans (pow_dvd_pow Q (by omega)) вҹЁC, hCeqвҹ©
      exact hnotmem Пғ hПғ1 (Ideal.dvd_span_singleton.mp h1)
  choose cfun Cfun hCcop hrest using hstep
  -- factor the product
  have hspanprod : Ideal.span
      {Polynomial.aeval Оё (Polynomial.derivative (minpoly в„Ө Оё))} =
      вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K),
        Ideal.span {Оё - Пғ вҖў Оё} := by
    rw [hprod, Ideal.prod_span_singleton]
  have hfactored : вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K),
      Ideal.span {Оё - Пғ вҖў Оё} =
      Q ^ (вҲ‘ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), cfun Пғ) *
        вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), Cfun Пғ := by
    rw [вҶҗ Finset.prod_pow_eq_pow_sum, вҶҗ Finset.prod_mul_distrib]
    refine Finset.prod_congr rfl fun Пғ hПғ => ?_
    exact ((hrest Пғ) (Finset.mem_erase.mp hПғ).1).2
  have hQd : Q ^ d вҲЈ
      Q ^ (вҲ‘ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), cfun Пғ) *
        вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), Cfun Пғ := by
    rw [вҶҗ hfactored, вҶҗ hspanprod]
    exact dvd_trans hd hdiv
  have hcop : IsCoprime (Q ^ d)
      (вҲҸ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), Cfun Пғ) :=
    IsCoprime.pow_left (IsCoprime.prod_right fun Пғ _ => hCcop Пғ)
  have hQd2 : Q ^ d вҲЈ
      Q ^ (вҲ‘ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), cfun Пғ) :=
    hcop.dvd_of_dvd_mul_right hQd
  have hdle : d вүӨ вҲ‘ Пғ вҲҲ Finset.univ.erase (1 : K вүғвӮҗ[в„ҡ] K), cfun Пғ := by
    have hQ0 : (Q : Ideal (NumberField.RingOfIntegers K)) вү  0 := by
      rw [Ideal.zero_eq_bot]
      exact hQbot
    have hQu : В¬ IsUnit Q := by
      rw [Ideal.isUnit_iff]
      exact hQ.ne_top
    exact (pow_dvd_pow_iff hQ0 hQu).mp hQd2
  refine le_trans hdle (le_trans (Finset.sum_le_sum fun Пғ hПғ =>
    ((hrest Пғ) (Finset.mem_erase.mp hПғ).1).1) ?_)
  exact (sum_card_filter_inertia_eq K Q n).le

/-- **The filtration-sum divisibility into the different ideal** (sorry
node, created 2026-07-24 вҖ” the `вүҘ` direction of Serre, *Corps Locaux*
IV В§1 Prop. 4, twin of the `вүӨ`-direction leaf
`le_sum_card_inertia_pow_of_pow_dvd_differentIdeal` above; together
they say `v_Q(рқ”Ў_{K/в„ҡ}) = ОЈ_{iвүҘ0} (#G_i вҲ’ 1)`, but only one direction
each is consumed): the power of a nonzero prime `Q` of the Galois
number field `K/в„ҡ` by the truncated lower-ramification sum
`ОЈ_{i<n} (#G_i вҲ’ 1)`, where
`G_i = inertia(Q^(i+1)) = {Пғ вҲҲ Gal(K/в„ҡ) | вҲҖ x вҲҲ рқ“һ K, Пғx вҲ’ x вҲҲ Q^(i+1)}`,
divides the different ideal `рқ”Ў_{K/в„ҡ}` вҖ” for EVERY truncation level `n`
(no triviality hypothesis on `G_n`: the untruncated sum is `v_Q(рқ”Ў)`
and the terms are nonnegative, so every truncation divides).  Intended
proof, dual to leaf (a) above: pass to the completion `K_Q/в„ҡ_p`, where
the global groups `G_i` coincide with the local ones by density and
the extension of complete DVRs is monogenic, `рқ’Ә_{K_Q} = в„Ө_p[Оё]`
(*Corps Locaux* III В§6 Prop. 12); the local different is generated by
