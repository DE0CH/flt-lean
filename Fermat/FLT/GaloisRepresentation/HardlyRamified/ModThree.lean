      sub_ne_zero.mpr (by exact_mod_cast hcc)
    have hzQ : (((c‚āĀ : ‚Ą§) - (c‚āā : ‚Ą§) : ‚Ą§) : ‚Ąö) ‚Č† 0 := Int.cast_ne_zero.mpr hz
    have h5 := E.smul_mem h3
      (x := ((((c‚āĀ : ‚Ą§) - (c‚āā : ‚Ą§) : ‚Ą§) : ‚Ąö))‚ĀĽ¬Ļ)
    rwa [‚Üź Int.cast_smul_eq_zsmul ‚Ąö ((c‚āĀ : ‚Ą§) - (c‚āā : ‚Ą§)), inv_smul_smul‚āÄ hzQ]
      at h5
  have hő≥E : algebraMap (NumberField.RingOfIntegers K) K ő≥ ‚ąą E := by
    have hNK : ((Ideal.absNorm J : ‚Ąē) : K) ‚Č† 0 := by
      exact_mod_cast hN0
    have h1 : algebraMap (NumberField.RingOfIntegers K) K ő≥ =
        (((Ideal.absNorm J : ‚Ąē) : K))‚ĀĽ¬Ļ *
          algebraMap (NumberField.RingOfIntegers K) K w := by
      rw [hwK, ‚Üź mul_assoc, inv_mul_cancel‚āÄ hNK, one_mul]
    rw [h1]
    refine E.mul_mem ?_ hwE
    have h2 : (((Ideal.absNorm J : ‚Ąē) : K))‚ĀĽ¬Ļ =
        algebraMap ‚Ąö K (((Ideal.absNorm J : ‚Ąē) : ‚Ąö))‚ĀĽ¬Ļ := by
      rw [map_inv‚āÄ, map_natCast]
    rw [h2]
    exact E.algebraMap_mem _
  have hEtop : E = ‚ä§ := by
    rw [eq_top_iff, ‚Üź hő≥top, IntermediateField.adjoin_le_iff,
      Set.singleton_subset_iff]
    exact hő≥E
  -- primitivity, in `Algebra.adjoin` form
  have hőłtop : Algebra.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} = ‚ä§ := by
    have hint : IsIntegral ‚Ąö
        (algebraMap (NumberField.RingOfIntegers K) K őł : K) :=
      IsIntegral.of_finite ‚Ąö _
    rw [‚Üź IntermediateField.adjoin_simple_toSubalgebra_of_isAlgebraic
      hint.isAlgebraic, ‚Üź hEdef, hEtop]
