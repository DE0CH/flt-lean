      Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} := .of_equiv _ e0.symm
  calc ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), classIdealCount K C n
      = ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K),
          Nat.card {I : {I : (Ideal (NumberField.RingOfIntegers K))‚Āį //
            Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} //
