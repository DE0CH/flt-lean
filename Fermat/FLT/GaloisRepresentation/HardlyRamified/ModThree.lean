/-- **Inertia congruence for convolution values** (PROVEN): for `Пғ` in
the local inertia group at `3` and two `рқ’ӘвӮғбөҘ`-points `ПҮ, ПҲ` of a
module-finite Hopf order `G` (whose values are automatically integral
over `рқ’ӘвӮғбөҘ`), the paired lift values of `(Пғ вҲҳ ПҮ, ПҲ)` and of `(ПҮ, ПҲ)`
agree on every tensor modulo the maximal ideal of the integral
closure of `рқ’ӘвӮғбөҘ` in `в„ҡвӮғбөҘбөғЛЎбөҚ`: inertia moves integral values only
within the maximal ideal (the DEFINING property of
`localInertiaGroup`), and the difference on a pure tensor is an
`рқ”Ә`-multiple of an integral value. -/
theorem lift_sub_lift_mem_of_localInertiaGroup_three
    (G : Type) [CommRing G]
    [HopfAlgebra рқ’ӘвӮғбөҘ G] [Module.Finite рқ’ӘвӮғбөҘ G]
    (Пғ : О“ (в„ҡвӮғбөҘ))
    (hПғ : Пғ вҲҲ localInertiaGroup
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
    (ПҮ ПҲ : G вҶ’вӮҗ[рқ’ӘвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ) (t : G вҠ—[рқ’ӘвӮғбөҘ] G) :
    Algebra.TensorProduct.lift ((Пғ.toAlgHom.restrictScalars рқ’ӘвӮғбөҘ).comp ПҮ) ПҲ
        (fun _ _ => Commute.all _ _) t -
      Algebra.TensorProduct.lift ПҮ ПҲ (fun _ _ => Commute.all _ _) t вҲҲ
      Submodule.map (Algebra.linearMap (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ) в„ҡвӮғбөҘбөғЛЎбөҚ)
        (IsLocalRing.maximalIdeal (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ)) := by
  haveI : Algebra.IsIntegral рқ’ӘвӮғбөҘ G := Algebra.IsIntegral.of_finite рқ’ӘвӮғбөҘ G
  induction t using TensorProduct.induction_on with
  | zero =>
    simp only [map_zero, sub_self]
    exact Submodule.zero_mem _
  | add x y hx hy =>
    rw [map_add, map_add, add_sub_add_comm]
    exact Submodule.add_mem _ hx hy
  | tmul a b =>
    rw [Algebra.TensorProduct.lift_tmul, Algebra.TensorProduct.lift_tmul]
    have ha : IsIntegral рқ’ӘвӮғбөҘ (ПҮ a) :=
      (Algebra.IsIntegral.isIntegral (R := рқ’ӘвӮғбөҘ) a).map ПҮ
    have hb : IsIntegral рқ’ӘвӮғбөҘ (ПҲ b) :=
      (Algebra.IsIntegral.isIntegral (R := рқ’ӘвӮғбөҘ) b).map ПҲ
    set xa : IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ := вҹЁПҮ a, haвҹ©
    set xb : IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ := вҹЁПҲ b, hbвҹ©
    have hin := AddSubgroup.mem_inertia.mp hПғ xa
    rw [Submodule.mem_toAddSubgroup] at hin
    have hval : algebraMap (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ) в„ҡвӮғбөҘбөғЛЎбөҚ
        (Пғ вҖў xa - xa) = Пғ (ПҮ a) - ПҮ a := by
      rw [map_sub]
      congr 1
    have hkey : ((Пғ.toAlgHom.restrictScalars рқ’ӘвӮғбөҘ).comp ПҮ) a * ПҲ b -
        ПҮ a * ПҲ b =
        xb вҖў (algebraMap (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ) в„ҡвӮғбөҘбөғЛЎбөҚ
          (Пғ вҖў xa - xa)) := by
      rw [hval, Algebra.smul_def]
      show Пғ (ПҮ a) * ПҲ b - ПҮ a * ПҲ b = ПҲ b * (Пғ (ПҮ a) - ПҮ a)
      ring
    rw [hkey]
    exact Submodule.smul_mem _ _ (Submodule.mem_map_of_mem hin)

/-- **Inertia-fixed points of the connected part are trivial at `3`**
(sorry node, 2026-07-24 вҖ” the Raynaud `e = 1 < p вҲ’ 1` core): a
geometric point `ПҶ` of the generic fibre of a finite flat Hopf order
`G` over `рқ’ӘвӮғбөҘ вү… в„ӨвӮғ` which (a) lies in the connected component (value
`1` on the connected counit idempotent `eвӮҖ`), (b) has convolution
order dividing `3`, and (c) is fixed by the local inertia at `3`, is
the identity point. Intended proof (Raynaud 1974; Serre, Duke 1987,
В§5.4; Tate, "Finite flat group schemes", in
CornellвҖ“SilvermanвҖ“Stevens): an inertia-fixed point has values in the
fixed field `(в„ҡвӮғбөҘбөғЛЎбөҚ)^I = в„ҡвӮғвҒҝКі` (infinite Galois correspondence), and
by integrality over the module-finite Hopf order in the valuation
ring `рқ’ӘвҒҝКі = W(рқ”ҪМ„вӮғ)`, which is absolutely unramified (`e = 1`). The
hypothesis `ПҶ(eвӮҖ) = 1` places the point in the connected component
`Spec (GeвӮҖ)`, whose special fibre is local artinian, so the point
reduces to the identity modulo the maximal ideal. The schematic
closure of the subgroup generated by the generic point is a finite
flat closed subgroup scheme of `Spec (GeвӮҖ)`, CONNECTED (quotients of
the local ring `GeвӮҖ` stay local) and killed by `3` (the point has
order dividing `3`); by the OortвҖ“Tate classification of order-`3`
group schemes over the absolutely unramified `рқ’ӘвҒҝКі` вҖ” at
`e = 1 < 2 = p вҲ’ 1` only `ОјвӮғ` (connected; no nontrivial point over
`в„ҡвӮғвҒҝКі`, since `О¶вӮғ` generates a ramified extension) and `в„Ө/3` (Г©tale,
excluded by connectedness) occur вҖ” each composition factor of the
closure kills the point, and unwinding the filtration gives `ПҶ = Оө`.
-/
theorem inertiaFixed_connected_point_eq_one_at_three
    (G : Type) [CommRing G]
    [HopfAlgebra рқ’ӘвӮғбөҘ G] [Module.Flat рқ’ӘвӮғбөҘ G] [Module.Finite рқ’ӘвӮғбөҘ G]
    (eвӮҖ : G) (heвӮҖ : IsIdempotentElem eвӮҖ)
    (hОөвӮҖ : Coalgebra.counit (R := рқ’ӘвӮғбөҘ) eвӮҖ = (1 : рқ’ӘвӮғбөҘ))
    (hprimвӮҖ : вҲҖ x : G, IsIdempotentElem x вҶ’ x * eвӮҖ = 0 вҲЁ x * eвӮҖ = eвӮҖ)
    (hcomulвӮҖ : Coalgebra.comul (R := рқ’ӘвӮғбөҘ) eвӮҖ * (eвӮҖ вҠ—вӮң[рқ’ӘвӮғбөҘ] eвӮҖ) =
      eвӮҖ вҠ—вӮң[рқ’ӘвӮғбөҘ] eвӮҖ)
    (ПҶ : в„ҡвӮғбөҘ вҠ—[рқ’ӘвӮғбөҘ] G вҶ’вӮҗ[в„ҡвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ)
    (hПҶe : ПҶ ((1 : в„ҡвӮғбөҘ) вҠ—вӮң[рқ’ӘвӮғбөҘ] eвӮҖ) = 1)
    (hord : ПҶ * ПҶ * ПҶ = 1)
    (hfix : вҲҖ Пғ вҲҲ localInertiaGroup
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat, Пғ вҖў ПҶ = ПҶ) :
    ПҶ = 1 := by
  sorry

set_option backward.isDefEq.respectTransparency false in
set_option synthInstance.maxHeartbeats 1000000 in
set_option maxHeartbeats 4000000 in
/-- **The connectedвҖ“Г©tale inertia subgroup of a Hopf package at `3`**
(DECOMPOSED 2026-07-24 into the henselian idempotent leaf
`exists_connected_counit_idempotent_at_three` and the Raynaud leaf
`inertiaFixed_connected_point_eq_one_at_three` above; the
connected-part subgroup construction, the inertia-displacement
absorption, and the convolution/points plumbing are PROVEN here):
given an EXPLICIT finite flat Hopf algebra `G` over
`рқ’ӘбөҘ вү… в„ӨвӮғ` with Г©tale generic fibre whose geometric points are
`О“ в„ҡвӮғбөҘ`-equivariantly identified with the space `V` of `ПҒ` (the
witness packaged by `GaloisRep.HasFlatProlongationAt`), the space
carries an additive subgroup `U` вҖ” intended: the image under `f` of
the points of the connected part `GвҒ°` вҖ” such that (i) every inertia
displacement `ПҒ(Пғ)v вҲ’ v` lies in `U`, and (ii) `U` contains no
nonzero inertia-fixed vector. Intended proof (Raynaud 1974; Serre,
Duke 1987, В§5.4): for (i), the Г©tale quotient `G/GвҒ°` of the
connectedвҖ“Г©tale sequence is finite Г©tale over the henselian local
`в„ӨвӮғ`, so its points are defined over the maximal unramified extension
and inertia fixes them; hence every inertia displacement dies in the
Г©tale points and lands in `U = ker(V вҶ’ (G/GвҒ°)-points)`
(left-exactness of points). For (ii): `GвҒ°` is killed by `3` (its
generic fibre is вҖ” the points are `3`-torsion since `V` is a char-3
space вҖ” and `рқ’Ә(GвҒ°)` is `в„ӨвӮғ`-free), and the schematic closures of a
local-Galois composition series of its generic fibre filter `GвҒ°` by
finite flat closed subgroups with CONNECTED simple graded pieces
(quotients of the local ring `рқ’Ә(GвҒ°)` stay local); a nonzero
inertia-fixed vector in `U` would make the points of some graded
piece unramified (the inertia-fixed points form a local-Galois
submodule, so by simplicity the whole piece), hence the piece Г©tale
by Raynaud's criterion at `e = 1 < 2 = p вҲ’ 1` вҖ” an unramified finite
flat group scheme killed by `p` over `в„Ө_p` is Г©tale вҖ” contradicting
connectedness. Concretely, at order `3` the OortвҖ“Tate list over `в„ӨвӮғ`
contains only `в„Ө/3`-forms (Г©tale, unramified points) and `ОјвӮғ`-forms
(connected, inertia acting through the nontrivial quadratic tame
character `ПҮвӮғ mod 3`). -/
theorem exists_connectedEtale_subgroup_of_hopf_package
    {k : Type u} [Finite k] [Field k] [Algebra в„Ө_[3] k]
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    {ПҒ : GaloisRep в„ҡ k V}
    (G : Type) [CommRing G]
    [HopfAlgebra (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) G]
    [Module.Flat (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) G]
    [Module.Finite (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) G]
    [Algebra.Etale (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      ((IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) вҠ—[
        IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] G)]
    (f : Additive ((IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) вҠ—[
        IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat] G вҶ’вӮҗ[
        IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat]
        AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) вҶ’+[
        О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)]
      ((ПҒ.toLocal
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat).Space))
    (hf : Function.Bijective f) :
    вҲғ U : AddSubgroup V,
      (вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat, вҲҖ v : V,
        ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ) v - v вҲҲ U) вҲ§
      (вҲҖ u вҲҲ U, (вҲҖ Пғ вҲҲ localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat,
        ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
            (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
              Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ) u = u) вҶ’
        u = 0) := by
  classical
  -- the connected counit idempotent of the Hopf order
  obtain вҹЁeвӮҖ, heвӮҖ, hОөвӮҖ, hprimвӮҖ, hcomulвӮҖвҹ© :=
    exists_connected_counit_idempotent_at_three G
  -- the points identification as an equivalence
  let g := Equiv.ofBijective f hf
  have hfs : вҲҖ x : V, f (g.symm x) = x := fun x => g.apply_symm_apply x
  have hgs_add : вҲҖ u w : V, g.symm (u + w) = g.symm u + g.symm w := by
    intro u w
    apply g.injective
    show f (g.symm (u + w)) = f (g.symm u + g.symm w)
    rw [map_add f, hfs, hfs, hfs]
  have hgs_zero : g.symm (0 : V) = 0 := by
    apply g.injective
    show f (g.symm (0 : V)) = f 0
    rw [map_zero f, hfs]
  -- the coefficient field has characteristic `3`
  have h3V : вҲҖ u : V, u + u + u = 0 := by
    intro u
    have h3k : (3 : k) = 0 := three_eq_zero_of_finite_padicIntThree_algebra
    have h1 : ((3 : в„•) : k) вҖў u = (3 : в„•) вҖў u := Nat.cast_smul_eq_nsmul k 3 u
    rw [show ((3 : в„•) : k) = (3 : k) from by norm_cast, h3k, zero_smul] at h1
    have h2 : (3 : в„•) вҖў u = u + u + u := by
      rw [show (3 : в„•) = 2 + 1 from rfl, add_nsmul, two_nsmul, one_nsmul]
    rw [вҶҗ h2]
    exact h1.symm
  -- the two spellings of the local action agree: ring homs out of `в„ҡ`
  -- are unique, so the `algebraMap` baked into `toLocal` is the one of
  -- the statement
  have hbridge : вҲҖ (П„ : О“ (в„ҡвӮғбөҘ)) (w : V),
      (ПҒ.toLocal Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) П„ w =
      ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) П„) w := by
    intro П„ w
    rw [GaloisRep.toLocal_apply]
    exact congrArg (fun (h : в„ҡ вҶ’+* (в„ҡвӮғбөҘ)) =>
      ПҒ (Field.absoluteGaloisGroup.map h П„) w) (Subsingleton.elim _ _)
  -- the connected-part subgroup: vectors whose point takes the value
  -- `1` on the connected counit idempotent
  refine вҹЁ{
      carrier := {u : V |
        (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
          (Additive.toMul (g.symm u)) eвӮҖ = 1}
      zero_mem' := ?_
      add_mem' := ?_
      neg_mem' := ?_ }, ?_, ?_вҹ©
  В· -- closure under addition: the comultiplication absorbs `eвӮҖ вҠ— eвӮҖ`
    intro u w hu hw
    show (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
      (Additive.toMul (g.symm (u + w))) eвӮҖ = 1
    rw [hgs_add, toMul_add, vendored_mul_eq_convMul,
      liftEquiv_symm_convMul]
    exact convMul_apply_one_of_comul_absorbs eвӮҖ hcomulвӮҖ _ _ hu hw
  В· -- `0` is the counit point, whose value on `eвӮҖ` is `Оө(eвӮҖ) = 1`
    show (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
      (Additive.toMul (g.symm (0 : V))) eвӮҖ = 1
    rw [hgs_zero, toMul_zero, vendored_one_eq_convOne,
      liftEquiv_symm_convOne]
    show algebraMap рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ (Coalgebra.counit (R := рқ’ӘвӮғбөҘ) eвӮҖ) = 1
    rw [hОөвӮҖ, map_one]
  В· -- closure under negation: `-u = u + u` in characteristic `3`
    intro u hu
    have hneg : -u = u + u := neg_eq_of_add_eq_zero_left (h3V u)
    show (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
      (Additive.toMul (g.symm (-u))) eвӮҖ = 1
    rw [hneg, hgs_add, toMul_add, vendored_mul_eq_convMul,
      liftEquiv_symm_convMul]
    exact convMul_apply_one_of_comul_absorbs eвӮҖ hcomulвӮҖ _ _ hu hu
  В· -- (i) every inertia displacement lies in the connected part: the
    -- displacement point is `(ПғвҲҳПҮ) вӢҶ ПҮвҒ»В№`, congruent to `1` modulo the
    -- maximal ideal (inertia moves integral values within `рқ”Ә`), and
    -- its idempotent value on `eвӮҖ` is `0` or `1` вҖ” so it is `1`
    intro Пғ hПғ u
    set d : V := ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) Пғ) u - u
      with hd
    show (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
      (Additive.toMul (g.symm d)) eвӮҖ = 1
    set ПҮu : G вҶ’вӮҗ[рқ’ӘвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ := (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
      (Additive.toMul (g.symm u)) with hПҮu
    set Оҙd : G вҶ’вӮҗ[рқ’ӘвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ := (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm
      (Additive.toMul (g.symm d)) with hОҙd
    -- the displacement point multiplies the point of `u` into its
    -- inertia translate
    have hXd : g.symm d + g.symm u = Пғ вҖў g.symm u := by
      apply g.injective
      show f (g.symm d + g.symm u) = f (Пғ вҖў g.symm u)
      rw [map_add f, map_smul f, hfs, hfs]
      show d + u = (ПҒ.toLocal
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) Пғ u
      rw [hbridge, hd, sub_add_cancel]
    have hDПҶ : Additive.toMul (g.symm d) * Additive.toMul (g.symm u) =
        Пғ вҖў Additive.toMul (g.symm u) := by
      have h1 := congrArg Additive.toMul hXd
      have h2 : Additive.toMul (Пғ вҖў g.symm u) =
          Пғ вҖў Additive.toMul (g.symm u) := rfl
      rw [toMul_add, h2] at h1
      exact h1
    -- transport to the `рқ’ӘвӮғбөҘ`-points: `Оҙ вӢҶ ПҮ = ПғвҲҳПҮ`
    have h3 := congrArg (AlgHom.liftEquiv рқ’ӘвӮғбөҘ в„ҡвӮғбөҘ G в„ҡвӮғбөҘбөғЛЎбөҚ).symm hDПҶ
    rw [vendored_mul_eq_convMul, liftEquiv_symm_convMul] at h3
    rw [show Пғ вҖў Additive.toMul (g.symm u) =
        (Пғ.toAlgHom : в„ҡвӮғбөҘбөғЛЎбөҚ вҶ’вӮҗ[в„ҡвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ).comp (Additive.toMul (g.symm u))
        from AlgHom.ext fun _ => rfl, liftEquiv_symm_comp] at h3
    rw [вҶҗ hПҮu, вҶҗ hОҙd] at h3
    have h4 : toConv Оҙd * toConv ПҮu =
        toConv ((Пғ.toAlgHom.restrictScalars рқ’ӘвӮғбөҘ).comp ПҮu) := by
      have h4a := congrArg WithConv.toConv h3
      rwa [WithConv.toConv_ofConv] at h4a
    -- cancel `ПҮ` on the right through the antipode inverse
    have h5 : toConv Оҙd =
        toConv ((Пғ.toAlgHom.restrictScalars рқ’ӘвӮғбөҘ).comp ПҮu) *
          toConv (ПҮu.comp (HopfAlgebra.antipodeAlgHom рқ’ӘвӮғбөҘ G)) := by
      rw [вҶҗ h4, mul_assoc, toConv_mul_toConv_comp_antipodeAlgHom, mul_one]
    have h6 : Оҙd eвӮҖ =
        Algebra.TensorProduct.lift ((Пғ.toAlgHom.restrictScalars рқ’ӘвӮғбөҘ).comp ПҮu)
          (ПҮu.comp (HopfAlgebra.antipodeAlgHom рқ’ӘвӮғбөҘ G))
          (fun _ _ => Commute.all _ _) (Coalgebra.comul (R := рқ’ӘвӮғбөҘ) eвӮҖ) := by
      have h7 := congrArg WithConv.ofConv h5
      rw [WithConv.ofConv_toConv] at h7
      rw [h7]
      exact AlgHom.convMul_apply _ _ eвӮҖ
    -- the corresponding value of `ПҮ вӢҶ ПҮвҒ»В№ = 1` is `Оө(eвӮҖ) = 1`
    have h8 : Algebra.TensorProduct.lift ПҮu
        (ПҮu.comp (HopfAlgebra.antipodeAlgHom рқ’ӘвӮғбөҘ G))
        (fun _ _ => Commute.all _ _) (Coalgebra.comul (R := рқ’ӘвӮғбөҘ) eвӮҖ) = 1 := by
      have h9 := AlgHom.convMul_apply (toConv ПҮu)
        (toConv (ПҮu.comp (HopfAlgebra.antipodeAlgHom рқ’ӘвӮғбөҘ G))) eвӮҖ
      rw [toConv_mul_toConv_comp_antipodeAlgHom] at h9
      rw [вҶҗ h9]
      show algebraMap рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ (Coalgebra.counit (R := рқ’ӘвӮғбөҘ) eвӮҖ) = 1
      rw [hОөвӮҖ, map_one]
    -- the inertia congruence: `Оҙ(eвӮҖ) вүЎ 1` modulo the maximal ideal
    have h10 := lift_sub_lift_mem_of_localInertiaGroup_three G Пғ hПғ ПҮu
      (ПҮu.comp (HopfAlgebra.antipodeAlgHom рқ’ӘвӮғбөҘ G))
      (Coalgebra.comul (R := рқ’ӘвӮғбөҘ) eвӮҖ)
    rw [h8, вҶҗ h6] at h10
    -- the value is an idempotent of a field, hence `0` or `1`; the
    -- congruence rules out `0`
    have h11 : Оҙd eвӮҖ * Оҙd eвӮҖ = Оҙd eвӮҖ := by
      rw [вҶҗ map_mul, heвӮҖ.eq]
    have h12 : Оҙd eвӮҖ * (Оҙd eвӮҖ - 1) = 0 := by
      rw [mul_sub, h11, mul_one, sub_self]
    rcases mul_eq_zero.mp h12 with h13 | h13
    В· exfalso
      rw [h13, zero_sub] at h10
      have h14 : (1 : в„ҡвӮғбөҘбөғЛЎбөҚ) вҲҲ
          Submodule.map (Algebra.linearMap (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ) в„ҡвӮғбөҘбөғЛЎбөҚ)
            (IsLocalRing.maximalIdeal (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ)) := by
        have h15 := Submodule.neg_mem _ h10
        rwa [neg_neg] at h15
      obtain вҹЁm, hm, hm1вҹ© := h14
      have hm2 : m = 1 := by
        apply Subtype.ext
        exact hm1
      rw [hm2] at hm
      exact (IsLocalRing.maximalIdeal.isMaximal
        (IntegralClosure рқ’ӘвӮғбөҘ в„ҡвӮғбөҘбөғЛЎбөҚ)).ne_top
        (Ideal.eq_top_of_isUnit_mem _ hm isUnit_one)
    В· exact sub_eq_zero.mp h13
  В· -- (ii) an inertia-fixed vector of the connected part is zero: its
    -- point is an inertia-fixed connected point of order dividing `3`,
    -- which the Raynaud leaf forces to be the identity
    intro u hu hufix
    have hПҶe : Additive.toMul (g.symm u) ((1 : в„ҡвӮғбөҘ) вҠ—вӮң[рқ’ӘвӮғбөҘ] eвӮҖ) = 1 := hu
    have hord : Additive.toMul (g.symm u) * Additive.toMul (g.symm u) *
        Additive.toMul (g.symm u) = 1 := by
      have h0 : g.symm u + g.symm u + g.symm u = 0 := by
        rw [вҶҗ hgs_add, вҶҗ hgs_add, h3V u, hgs_zero]
      have h1 := congrArg Additive.toMul h0
      rwa [toMul_add, toMul_add, toMul_zero] at h1
    have hfixПҶ : вҲҖ Пғ вҲҲ localInertiaGroup
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat,
        Пғ вҖў Additive.toMul (g.symm u) = Additive.toMul (g.symm u) := by
      intro Пғ hПғ
      have h1 : Пғ вҖў g.symm u = g.symm u := by
        apply g.injective
        show f (Пғ вҖў g.symm u) = f (g.symm u)
        rw [map_smul f, hfs]
        show (ПҒ.toLocal
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) Пғ u = u
        rw [hbridge]
        exact hufix Пғ hПғ
      have h2 : Additive.toMul (Пғ вҖў g.symm u) =
          Пғ вҖў Additive.toMul (g.symm u) := rfl
      rw [вҶҗ h2, h1]
    have hone := inertiaFixed_connected_point_eq_one_at_three G eвӮҖ heвӮҖ hОөвӮҖ
      hprimвӮҖ hcomulвӮҖ (Additive.toMul (g.symm u)) hПҶe hord hfixПҶ
    have hX : g.symm u = 0 := by
      have h1 : Additive.toMul (g.symm u) =
          Additive.toMul (0 : Additive (в„ҡвӮғбөҘ вҠ—[рқ’ӘвӮғбөҘ] G вҶ’вӮҗ[в„ҡвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ)) := by
        rw [toMul_zero]
        exact hone
      exact Additive.toMul.injective h1
    calc u = f (g.symm u) := (hfs u).symm
      _ = f 0 := by rw [hX]
      _ = 0 := map_zero f

end ConnectedEtaleHopfPackage

