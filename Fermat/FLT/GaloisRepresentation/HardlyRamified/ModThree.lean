      exact lt_irrefl _ hdiffval
  -- transport: `g'` fixes `О¶` in `в„ҡбөғЛЎбөҚ`
  have hfix : g' О¶ = О¶ := by
    apply (AlgebraicClosure.map (algebraMap в„ҡ в„ҡ_[2])).injective
    rw [hg']
