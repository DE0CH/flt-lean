    (b : О“ в„ҡ вҶ’ k)
    (hbadd : вҲҖ g h : О“ в„ҡ, О· g = 1 вҶ’ О· h = 1 вҶ’ b (g * h) = b g + b h)
    (U : Subgroup (О“ в„ҡ)) (hUopen : IsOpen (U : Set (О“ в„ҡ)))
