theorem DedekindContinuation.xi_window_ratio_bound {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    ‚ąÉ A : ‚Ąē, 0 < A ‚ąß ‚ąÄ T : ‚ĄĚ, 2 ‚Č§ T ‚Üí ‚ąÄ z : ‚Ąā,
      ‚ÄĖz - (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ = 6 ‚Üí
      ‚ÄĖpkg.xi z‚ÄĖ ‚Č§ T ^ A * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ := by
  obtain ‚ü®C‚āÄ, hC‚āÄ, h‚āÄ‚ü© := pkg.xi_window_ratio_bound_of_le_eight
  obtain ‚ü®C‚āĀ, hC‚āĀ, B‚āĀ, h‚āĀ‚ü© := pkg.xi_window_le_xiFactor
  obtain ‚ü®C‚āā, hC‚āā, B‚āā, h‚āā‚ü© := dedekindXiFactor_window_ratio K
  obtain ‚ü®m, hm, hmlow‚ü© := dedekindZeta_norm_lower_of_re_eq_two K
  obtain ‚ü®k, hk‚ü© := pow_unbounded_of_one_lt (max C‚āÄ (C‚āĀ * C‚āā / m))
    (by norm_num : (1 : ‚ĄĚ) < 2)
  refine ‚ü®B‚āĀ + B‚āā + k + 1, by omega, ?_‚ü©
  intro T hT z hz
  have hT1 : (1 : ‚ĄĚ) ‚Č§ T := by linarith
  have hT0 : (0 : ‚ĄĚ) < T := by linarith
  have hxic : (0 : ‚ĄĚ) ‚Č§ ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ := norm_nonneg _
  have h2k : (2 : ‚ĄĚ) ^ k ‚Č§ T ^ k := pow_le_pow_left‚āÄ (by norm_num) hT k
  rcases le_or_gt T 8 with hT8 | hT8
  ¬∑ -- bounded heights: the compactness constant, absorbed into `T ^ k`
    calc ‚ÄĖpkg.xi z‚ÄĖ
        ‚Č§ C‚āÄ * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ := h‚āÄ T hT hT8 z hz
      _ ‚Č§ 2 ^ k * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_right
            (le_trans (le_max_left _ _) hk.le) hxic
      _ ‚Č§ T ^ k * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_right h2k hxic
      _ ‚Č§ T ^ (B‚āĀ + B‚āā + k + 1) * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_right
            (pow_le_pow_right‚āÄ hT1 (by omega)) hxic
  ¬∑ -- tall windows: Phragm√©n‚ÄďLindel√∂f √ó őď-ratio √ó Euler lower bound
    have hT8' : (8 : ‚ĄĚ) ‚Č§ T := hT8.le
    have hcre : ((2 : ‚Ąā) + (T : ‚Ąā) * Complex.I).re = 2 := by simp
    have hEc : m * ‚ÄĖdedekindXiFactor K (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ ‚Č§
        ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ := by
      rw [pkg.xi_eq_xiFactor_mul_dedekindZeta _ (by rw [hcre]; norm_num),
        norm_mul, mul_comm m]
      exact mul_le_mul_of_nonneg_left (hmlow _ hcre) (norm_nonneg _)
    calc ‚ÄĖpkg.xi z‚ÄĖ
        ‚Č§ C‚āĀ * T ^ B‚āĀ * ‚ÄĖdedekindXiFactor K z‚ÄĖ := h‚āĀ T hT8' z hz
      _ ‚Č§ C‚āĀ * T ^ B‚āĀ * (C‚āā * T ^ B‚āā *
            ‚ÄĖdedekindXiFactor K (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ) :=
          mul_le_mul_of_nonneg_left (h‚āā T hT8' z hz)
            (mul_nonneg hC‚āĀ.le (pow_nonneg hT0.le _))
      _ = C‚āĀ * C‚āā / m * T ^ (B‚āĀ + B‚āā) *
            (m * ‚ÄĖdedekindXiFactor K (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ) := by
          rw [pow_add]
          field_simp [hm.ne']
      _ ‚Č§ C‚āĀ * C‚āā / m * T ^ (B‚āĀ + B‚āā) *
            ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_left hEc
            (mul_nonneg (div_nonneg (mul_nonneg hC‚āĀ.le hC‚āā.le) hm.le)
              (pow_nonneg hT0.le _))
      _ ‚Č§ 2 ^ k * T ^ (B‚āĀ + B‚āā) *
            ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_right
              (le_trans (le_max_right _ _) hk.le)
              (pow_nonneg hT0.le _)) hxic
      _ ‚Č§ T ^ k * T ^ (B‚āĀ + B‚āā) *
            ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_right h2k (pow_nonneg hT0.le _)) hxic
      _ = T ^ (B‚āĀ + B‚āā + k) * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ := by
          rw [‚Üź pow_add, add_comm k (B‚āĀ + B‚āā)]
      _ ‚Č§ T ^ (B‚āĀ + B‚āā + k + 1) * ‚ÄĖpkg.xi (2 + (T : ‚Ąā) * Complex.I)‚ÄĖ :=
          mul_le_mul_of_nonneg_right
            (pow_le_pow_right‚āÄ hT1 (Nat.le_succ _)) hxic

/-- **Landau's window count: `O(log T)` zeros of `őĺ_K` at height `T`,
with multiplicity** (DECOMPOSED 2026-07-24, counting core PROVEN ‚ÄĒ
leaf (a) of the decomposition of
`DedekindContinuation.fejer_zero_sum_tendsto`): there is a constant
`C > 0` such that for every `T ‚Č• 2`, every finite set of points whose
ordinates lie within `1` of `¬ĪT` carries total `mult` at most
`C¬∑log T`.  (Points of `mult = 0` contribute nothing, so no zero-set
membership hypothesis is needed; the set-of-zeros form follows by
summing over `finite_truncation` truncations.)  This is
`N(T+1) ‚ąí N(T) = O(log T)` of E. Landau, *Algebraische Zahlen*,
p. 122, quoted by Poitou p. 6-02; the contour leaf
`DedekindContinuation.weil_explicit_formula_F` consumes it through its
`hcount` hypothesis (horizontal edges through zero-free heights,
Borel‚ÄďCarath√©odory partial fractions for `őĺ'/őĺ`).

PROOF (realized here): let `c = 2 + iT`, `r = 5/2`, `R = 6`.  Every
strip point with `|im s ‚ąí T| ‚Č§ 1` lies in the disc `‚ÄĖs ‚ąí c‚ÄĖ ‚Č§ r`
(distance `‚Č§ ‚ąö5 < 5/2`), and every strip point with
`|im s + T| ‚Č§ 1` in the disc around `cŐĄ = 2 ‚ąí iT`; `mult` equals
`analyticOrderNatAt` on the strip (`mult_mem_strip`).  The Jensen-free
counting core `sum_analyticOrderNatAt_le_of_frontier_norm_le`
(divided-zeros factorization by `dslope` + maximum modulus) turns the
boundary/centre ratio bound of the remaining analytic leaf
`DedekindContinuation.xi_window_ratio_bound` ‚ÄĒ `‚ÄĖőĺ‚ÄĖ ‚Č§ T^A¬∑‚ÄĖőĺ(c)‚ÄĖ` on
`‚ÄĖz ‚ąí c‚ÄĖ = 6` ‚ÄĒ into `(7/5)^k¬∑‚ÄĖőĺ(c)‚ÄĖ ‚Č§ T^A¬∑‚ÄĖőĺ(c)‚ÄĖ` for the window
count `k` at `+T`; `őĺ(c) ‚Č† 0` by `ne_zero_of_one_lt_re`, and taking
`Real.log` gives `k ‚Č§ A¬∑log T/log(7/5)`.  The `‚ąíT` window is
transported to `+T` by `conj_symm` (an isometry on the circle and on
the centre value), so `C = 2A/log(7/5)` works. -/
theorem DedekindContinuation.zero_count_window {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    ‚ąÉ C : ‚ĄĚ, 0 < C ‚ąß ‚ąÄ T : ‚ĄĚ, 2 ‚Č§ T ‚Üí ‚ąÄ s : Finset ‚Ąā,
      (‚ąÄ ŌĀ ‚ąą s, |(|ŌĀ.im| - T)| ‚Č§ 1) ‚Üí
      ‚ąĎ ŌĀ ‚ąą s, (pkg.mult ŌĀ : ‚ĄĚ) ‚Č§ C * Real.log T := by
  classical
  obtain ‚ü®A, hApos, hA‚ü© := pkg.xi_window_ratio_bound
  have hlog75 : (0 : ‚ĄĚ) < Real.log (7 / 5) := Real.log_pos (by norm_num)
  have hAr : (0 : ‚ĄĚ) < A := by exact_mod_cast hApos
  refine ‚ü®2 * (A : ‚ĄĚ) / Real.log (7 / 5), div_pos (by linarith) hlog75, ?_‚ü©
  intro T hT s hs
  have hlogT : (0 : ‚ĄĚ) < Real.log T := Real.log_pos (by linarith)
  have hAP := hA T hT
  -- the two disc centres at heights `¬ĪT`
  set cP : ‚Ąā := 2 + (T : ‚Ąā) * Complex.I with hcP_def
  set cM : ‚Ąā := 2 - (T : ‚Ąā) * Complex.I with hcM_def
  have hreP : cP.re = 2 := by simp [hcP_def]
  have himP : cP.im = T := by simp [hcP_def]
  have hreM : cM.re = 2 := by simp [hcM_def]
  have himM : cM.im = -T := by simp [hcM_def]
  have hxiP : pkg.xi cP ‚Č† 0 := pkg.ne_zero_of_one_lt_re _ (by rw [hreP]; norm_num)
  have hxiM : pkg.xi cM ‚Č† 0 := pkg.ne_zero_of_one_lt_re _ (by rw [hreM]; norm_num)
  have hconj : (starRingEnd ‚Ąā) cP = cM := by
    simp [hcP_def, hcM_def, Complex.ext_iff]
  have hconj' : (starRingEnd ‚Ąā) cM = cP := by
    simp [hcP_def, hcM_def, Complex.ext_iff]
  have hnorm_c : ‚ÄĖpkg.xi cM‚ÄĖ = ‚ÄĖpkg.xi cP‚ÄĖ := by
    rw [‚Üź hconj, pkg.conj_symm, RCLike.norm_conj]
  -- the ratio bound on the mirror disc, by Schwarz reflection
  have hAM : ‚ąÄ z : ‚Ąā, ‚ÄĖz - cM‚ÄĖ = 6 ‚Üí ‚ÄĖpkg.xi z‚ÄĖ ‚Č§ T ^ A * ‚ÄĖpkg.xi cM‚ÄĖ := by
    intro z hz
    have h1 : ‚ÄĖ(starRingEnd ‚Ąā) z - cP‚ÄĖ = 6 := by
      rw [‚Üź hconj', ‚Üź map_sub, RCLike.norm_conj]
      exact hz
    have h2 := hAP _ h1
    rw [pkg.conj_symm z, RCLike.norm_conj] at h2
    rw [hnorm_c]
    exact h2
  -- the per-disc count from the Jensen-free counting core
  have key : ‚ąÄ c : ‚Ąā, pkg.xi c ‚Č† 0 ‚Üí
      (‚ąÄ z : ‚Ąā, ‚ÄĖz - c‚ÄĖ = 6 ‚Üí ‚ÄĖpkg.xi z‚ÄĖ ‚Č§ T ^ A * ‚ÄĖpkg.xi c‚ÄĖ) ‚Üí
      ‚ąÄ u : Finset ‚Ąā, (‚ąÄ ŌĀ ‚ąą u, ‚ÄĖŌĀ - c‚ÄĖ ‚Č§ 5 / 2) ‚Üí
      ‚ąĎ ŌĀ ‚ąą u, (analyticOrderNatAt pkg.xi ŌĀ : ‚ĄĚ)
        ‚Č§ (A : ‚ĄĚ) * Real.log T / Real.log (7 / 5) := by
    intro c hc hMb u hu
    have hcount := sum_analyticOrderNatAt_le_of_frontier_norm_le
      pkg.differentiable (by norm_num : (0 : ‚ĄĚ) < 5 / 2)
      (by norm_num : (5 : ‚ĄĚ) / 2 < 6) hc hMb hu le_rfl
    have h75 : ((6 : ‚ĄĚ) - 5 / 2) / (5 / 2) = 7 / 5 := by norm_num
    rw [h75] at hcount
    have hxin : (0 : ‚ĄĚ) < ‚ÄĖpkg.xi c‚ÄĖ := norm_pos_iff.mpr hc
    have hk75 : ((7 : ‚ĄĚ) / 5) ^ (‚ąĎ ŌĀ ‚ąą u, analyticOrderNatAt pkg.xi ŌĀ) ‚Č§ T ^ A :=
      le_of_mul_le_mul_right hcount hxin
    have hlogk := Real.log_le_log (by positivity) hk75
    rw [Real.log_pow, Real.log_pow] at hlogk
    rw [le_div_iff‚āÄ hlog75]
    push_cast at hlogk ‚äĘ
    exact hlogk
  -- points within `1` of `¬ĪT` and of positive multiplicity lie in the discs
  have hdist : ‚ąÄ c ŌĀ : ‚Ąā, c.re = 2 ‚Üí 0 < ŌĀ.re ‚Üí ŌĀ.re < 1 ‚Üí
      |ŌĀ.im - c.im| ‚Č§ 1 ‚Üí ‚ÄĖŌĀ - c‚ÄĖ ‚Č§ 5 / 2 := by
    intro c ŌĀ hcre hre0 hre1 him
    have habs := abs_le.mp him
    have hsq : ‚ÄĖŌĀ - c‚ÄĖ ^ 2 ‚Č§ (5 / 2 : ‚ĄĚ) ^ 2 := by
      rw [Complex.sq_norm, Complex.normSq_apply, Complex.sub_re, Complex.sub_im, hcre]
      nlinarith [habs.1, habs.2]
    nlinarith [hsq, norm_nonneg (ŌĀ - c)]
  have hmult_eq : ‚ąÄ ŌĀ : ‚Ąā, pkg.mult ŌĀ ‚Č† 0 ‚Üí
      pkg.mult ŌĀ = analyticOrderNatAt pkg.xi ŌĀ := by
    intro ŌĀ h
    have hst := pkg.mult_mem_strip h
    simp only [DedekindContinuation.mult]
    rw [if_pos hst]
  -- restrict to points of nonzero multiplicity and split by hemisphere
  set sf := s.filter (fun ŌĀ => pkg.mult ŌĀ ‚Č† 0) with hsf_def
  have hstep1 : ‚ąĎ ŌĀ ‚ąą sf, (pkg.mult ŌĀ : ‚ĄĚ) = ‚ąĎ ŌĀ ‚ąą s, (pkg.mult ŌĀ : ‚ĄĚ) := by
    rw [hsf_def]
    exact Finset.sum_filter_of_ne fun ŌĀ _ hŌĀ h => hŌĀ (by rw [h]; norm_num)
  have hsplit := Finset.sum_filter_add_sum_filter_not sf (fun ŌĀ => 0 ‚Č§ ŌĀ.im)
      (fun ŌĀ => (pkg.mult ŌĀ : ‚ĄĚ))
  have hup : ‚ąĎ ŌĀ ‚ąą sf.filter (fun ŌĀ => 0 ‚Č§ ŌĀ.im), (pkg.mult ŌĀ : ‚ĄĚ)
      ‚Č§ (A : ‚ĄĚ) * Real.log T / Real.log (7 / 5) := by
    have hmem : ‚ąÄ ŌĀ ‚ąą sf.filter (fun ŌĀ => 0 ‚Č§ ŌĀ.im), ‚ÄĖŌĀ - cP‚ÄĖ ‚Č§ 5 / 2 := by
      intro ŌĀ hŌĀ
      rw [Finset.mem_filter] at hŌĀ
      obtain ‚ü®hŌĀsf, hŌĀim‚ü© := hŌĀ
      rw [hsf_def, Finset.mem_filter] at hŌĀsf
      obtain ‚ü®hŌĀs, hŌĀm‚ü© := hŌĀsf
      obtain ‚ü®h0, h1‚ü© := pkg.mult_mem_strip hŌĀm
      refine hdist cP ŌĀ hreP h0 h1 ?_
      rw [himP]
      have h2 := hs ŌĀ hŌĀs
      rwa [abs_of_nonneg hŌĀim] at h2
    calc ‚ąĎ ŌĀ ‚ąą sf.filter (fun ŌĀ => 0 ‚Č§ ŌĀ.im), (pkg.mult ŌĀ : ‚ĄĚ)
        = ‚ąĎ ŌĀ ‚ąą sf.filter (fun ŌĀ => 0 ‚Č§ ŌĀ.im),
            (analyticOrderNatAt pkg.xi ŌĀ : ‚ĄĚ) := by
          refine Finset.sum_congr rfl fun ŌĀ hŌĀ => ?_
          rw [Finset.mem_filter] at hŌĀ
          have hŌĀm : pkg.mult ŌĀ ‚Č† 0 := by
            have h3 := hŌĀ.1
            rw [hsf_def, Finset.mem_filter] at h3
            exact h3.2
          rw [hmult_eq ŌĀ hŌĀm]
      _ ‚Č§ (A : ‚ĄĚ) * Real.log T / Real.log (7 / 5) := key cP hxiP hAP _ hmem
  have hlow : ‚ąĎ ŌĀ ‚ąą sf.filter (fun ŌĀ => ¬¨0 ‚Č§ ŌĀ.im), (pkg.mult ŌĀ : ‚ĄĚ)
      ‚Č§ (A : ‚ĄĚ) * Real.log T / Real.log (7 / 5) := by
    have hmem : ‚ąÄ ŌĀ ‚ąą sf.filter (fun ŌĀ => ¬¨0 ‚Č§ ŌĀ.im), ‚ÄĖŌĀ - cM‚ÄĖ ‚Č§ 5 / 2 := by
      intro ŌĀ hŌĀ
      rw [Finset.mem_filter] at hŌĀ
      obtain ‚ü®hŌĀsf, hŌĀim‚ü© := hŌĀ
      rw [hsf_def, Finset.mem_filter] at hŌĀsf
      obtain ‚ü®hŌĀs, hŌĀm‚ü© := hŌĀsf
      obtain ‚ü®h0, h1‚ü© := pkg.mult_mem_strip hŌĀm
      refine hdist cM ŌĀ hreM h0 h1 ?_
      rw [himM]
      have h2 := hs ŌĀ hŌĀs
      rw [abs_of_neg (not_le.mp hŌĀim)] at h2
      rw [show ŌĀ.im - -T = -(-ŌĀ.im - T) by ring, abs_neg]
      exact h2
    calc ‚ąĎ ŌĀ ‚ąą sf.filter (fun ŌĀ => ¬¨0 ‚Č§ ŌĀ.im), (pkg.mult ŌĀ : ‚ĄĚ)
        = ‚ąĎ ŌĀ ‚ąą sf.filter (fun ŌĀ => ¬¨0 ‚Č§ ŌĀ.im),
            (analyticOrderNatAt pkg.xi ŌĀ : ‚ĄĚ) := by
          refine Finset.sum_congr rfl fun ŌĀ hŌĀ => ?_
          rw [Finset.mem_filter] at hŌĀ
          have hŌĀm : pkg.mult ŌĀ ‚Č† 0 := by
            have h3 := hŌĀ.1
            rw [hsf_def, Finset.mem_filter] at h3
            exact h3.2
          rw [hmult_eq ŌĀ hŌĀm]
      _ ‚Č§ (A : ‚ĄĚ) * Real.log T / Real.log (7 / 5) := key cM hxiM hAM _ hmem
  rw [‚Üź hstep1, ‚Üź hsplit]
  have hlog75' : Real.log (7 / 5) ‚Č† 0 := ne_of_gt hlog75
  have hC : 2 * ((A : ‚ĄĚ) * Real.log T / Real.log (7 / 5))
      = 2 * (A : ‚ĄĚ) / Real.log (7 / 5) * Real.log T := by
    field_simp
  linarith [hup, hlow, hC]

/-- **The folded vertical-edge functional of Poitou's contour**
(definition, 2026-07-24 ‚ÄĒ introduced in the decomposition of
`DedekindContinuation.weil_explicit_formula_F`): the value at
truncation height `T` of BOTH vertical edges of the rectangle
`[‚ąí1/4, 5/4] √ó [‚ąíT, T]`, folded onto the right edge `re s = 5/4`,

`E(T) = ŌÄ‚ĀĽ¬Ļ ¬∑ ‚ąę_{‚ąíT}^{T} Re[ő¶(5/4 + it) ¬∑ (őĺ'/őĺ)(5/4 + it)] dt`.

Why this is the whole contour up to vanishing edges: the functional
equation `funcEq` gives `(őĺ'/őĺ)(1 ‚ąí s) = ‚ąí(őĺ'/őĺ)(s)` and evenness of
`F` gives `ő¶(1 ‚ąí s) = ő¶(s)`, so under `s ‚Ü¶ 1 ‚ąí s` (which maps the
left edge `re s = ‚ąí1/4` onto the right edge reversed) the integrand
`ő¶¬∑őĺ'/őĺ` is odd-symmetric and the left edge contributes exactly the
same as the right; `conj_symm` makes the folded value real, whence
the `Re` inside.  The normalization `ŌÄ‚ĀĽ¬Ļ = 2¬∑(2ŌÄ)‚ĀĽ¬Ļ` carries the
factor `2` of the fold and the `i` of `ds = i¬∑dt` against the
`(2ŌÄi)‚ĀĽ¬Ļ` of the residue theorem.  Consumed by the two limit leaves
`DedekindContinuation.zero_sum_sub_poitouEdge_tendsto_zero` (the
truncated zero sum equals `E(T)` up to vanishing horizontal edges)
and `DedekindContinuation.poitouEdge_tendsto` (the `T ‚Üí ‚ąě`
evaluation of `E(T)` by Poitou's Propositions 2‚Äď3). -/
noncomputable def DedekindContinuation.poitouEdge {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) (T : ‚ĄĚ) : ‚ĄĚ :=
  Real.pi‚ĀĽ¬Ļ * ‚ąę t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      (deriv pkg.xi (5 / 4 + t * Complex.I) /
        pkg.xi (5 / 4 + t * Complex.I))).re

/-- **The archimedean elementary factor of the completed Dedekind
zeta** (definition, 2026-07-24 ‚ÄĒ shared helper of the two boundary
leaves `DedekindContinuation.xi_one_ne_zero` and
`DedekindContinuation.xi_ne_zero_of_re_eq_one_of_im_ne_zero`):
`G_K(s) = |d_K|^{s/2}¬∑őď_‚ĄĚ(s)^{r‚āĀ}¬∑őď_‚Ąā(s)^{r‚āā}`, so that the field
`eq_of_one_lt_re` of `DedekindContinuation` reads
`őĺ_K(s) = s(s‚ąí1)¬∑G_K(s)¬∑ő∂_K(s)` on `re s > 1`
(`DedekindContinuation.xi_eq_dedekindGammaFactor` below).  Separating
this factor out is what both boundary leaves need: it is continuous
and nonvanishing on the half-plane `re s > 0` (the two lemmas below),
so along `re s = 1` every zero or pole phenomenon of `őĺ` is carried by
`s(s‚ąí1)` and the continued `ő∂_K` alone. -/
noncomputable def dedekindGammaFactor (K : Type*) [Field K] [NumberField K]
    (s : ‚Ąā) : ‚Ąā :=
  Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ (s / 2) *
    ((Real.pi : ‚Ąā) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
      NumberField.InfinitePlace.nrRealPlaces K *
    ((2 : ‚Ąā) * ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ (-s) * Complex.Gamma s) ^
      NumberField.InfinitePlace.nrComplexPlaces K

/-- **The completed zeta through the elementary factor** (PROVEN
2026-07-24): the field `eq_of_one_lt_re` of `DedekindContinuation`
regrouped as `őĺ_K(s) = s(s‚ąí1)¬∑G_K(s)¬∑ő∂_K(s)` with
