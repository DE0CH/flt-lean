      show ((TensorProduct.congr ŌÜlin (LinearEquiv.refl k V)).trans
          (TensorProduct.lid k V)) (c ‚äó‚āú[k] ((ŌĀ.toLocal v) g y)) =
        ((ŌĀ.toLocal v) g) (((TensorProduct.congr ŌÜlin
