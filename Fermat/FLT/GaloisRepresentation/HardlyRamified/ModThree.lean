/-- **Partition of the ideal count over the class group** (PROVEN
2026-07-24): for `n вү  0` the ideals of norm `n` вҖ” all nonzero вҖ” are
partitioned by their ideal classes:
`ОЈ_C classIdealCount K C n = #{рқ”һ : Nрқ”һ = n}`, the `n`-th coefficient
of the pin's `NumberField.dedekindZeta`.  Proof: the norm-`n` ideals
form a finite type (`Ideal.finite_setOf_absNorm_eq`);
`Equiv.sigmaFiberEquiv` fibers it over `ClassGroup.mk0` and
`Nat.card_sigma` turns the sigma type into the sum over classes. -/
theorem sum_classIdealCount (K : Type*) [Field K] [NumberField K] (n : в„•)
    (hn : n вү  0) :
    вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), classIdealCount K C n =
      Nat.card {I : Ideal (NumberField.RingOfIntegers K) // Ideal.absNorm I = n} := by
  have hfin : Finite {I : Ideal (NumberField.RingOfIntegers K) // Ideal.absNorm I = n} :=
    (Ideal.finite_setOf_absNorm_eq n).to_subtype
  have e0 : {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
      Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} вүғ
      {I : Ideal (NumberField.RingOfIntegers K) // Ideal.absNorm I = n} :=
    { toFun := fun I => вҹЁI.1.1, I.2вҹ©
      invFun := fun I => вҹЁвҹЁI.1, mem_nonZeroDivisors_iff_ne_zero.mpr (by
        intro h0
        exact hn (by rw [вҶҗ I.2, h0]; simp))вҹ©, I.2вҹ©
      left_inv := fun _ => rfl
      right_inv := fun _ => rfl }
  haveI : Finite {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
      Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} := .of_equiv _ e0.symm
  calc вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), classIdealCount K C n
      = вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K),
          Nat.card {I : {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
            Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} //
            ClassGroup.mk0 I.1 = C} :=
        Finset.sum_congr rfl fun C _ =>
          (Nat.card_congr (Equiv.subtypeSubtypeEquivSubtypeInter _ _)).symm
    _ = Nat.card ((C : ClassGroup (NumberField.RingOfIntegers K)) Г—
          {I : {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
            Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} //
            ClassGroup.mk0 I.1 = C}) := Nat.card_sigma.symm
    _ = Nat.card {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
          Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) = n} :=
        Nat.card_congr (Equiv.sigmaFiberEquiv _)
    _ = Nat.card {I : Ideal (NumberField.RingOfIntegers K) // Ideal.absNorm I = n} :=
        Nat.card_congr e0

/-- **The entire completed Dedekind zeta, its functional equation and
its order-one growth** (DECOMPOSED 2026-07-24, assembly PROVEN вҖ” the
class-group summation step, Neukirch VII (5.10), of Hecke's theorem,
on top of the per-class leaf `completedClassZeta_exists`):
`Оҫ_K := ОЈ_C Z C`.  A finite sum of entire functions is entire
(`Differentiable.fun_sum`); on `re s > 1` the common archimedean
factor pulls out of the sum (`Finset.mul_sum`) and the partial
Dirichlet series add up to `О¶_K` (`LSeries_sum` with the bundled
per-class summability, `LSeries_congr`, and the counting partition
`sum_classIdealCount`); the functional equation follows by reindexing
the sum along the involution `C вҶҰ [рқ”Ў]CвҒ»В№` (`Fintype.sum_bijective`
with `dedekindDualClass_involutive`); and the growth bound absorbs the
class number: with `M = max_C B_C` (`Finset.sup'`) and `h = #Cl(K)`,
`hВ·exp(MВ·X) вүӨ exp((M + log h + 1)В·X)` for `X = вҖ–sвҖ–В·log вҖ–sвҖ– вүҘ
2В·log 2 = log 4 вүҘ 1`.  The four conjuncts are verbatim the fields
`differentiable`, `eq_of_one_lt_re`, `funcEq`, `growth` of
`DedekindContinuation`, consumed by the assembly
`dedekindContinuation_exists` below. -/
theorem completedDedekindZeta_exists (K : Type*) [Field K] [NumberField K] :
    вҲғ xi : в„Ӯ вҶ’ в„Ӯ, Differentiable в„Ӯ xi вҲ§
      (вҲҖ s : в„Ӯ, 1 < s.re вҶ’
        xi s = s * (s - 1) * Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) *
          ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
            NumberField.InfinitePlace.nrRealPlaces K *
          ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
            NumberField.InfinitePlace.nrComplexPlaces K *
          NumberField.dedekindZeta K s) вҲ§
      (вҲҖ s : в„Ӯ, xi (1 - s) = xi s) вҲ§
      вҲғ C : в„қ, 0 < C вҲ§ вҲҖ s : в„Ӯ, 2 вүӨ вҖ–sвҖ– вҶ’
        вҖ–xi sвҖ– вүӨ Real.exp (C * вҖ–sвҖ– * Real.log вҖ–sвҖ–) := by
  obtain вҹЁZ, hdiff, hformula, hfe, hgrowthвҹ© := completedClassZeta_exists K
  refine вҹЁfun s => вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), Z C s,
    ?_, ?_, ?_, ?_вҹ©
  В· exact Differentiable.fun_sum fun C _ => hdiff C
  В· intro s hs
    have hsummable : вҲҖ C вҲҲ (Finset.univ : Finset (ClassGroup (NumberField.RingOfIntegers K))),
        LSeriesSummable (fun n => (classIdealCount K C n : в„Ӯ)) s :=
      fun C _ => (hformula C s hs).1
    have hpart : вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K),
        LSeries (fun n => (classIdealCount K C n : в„Ӯ)) s =
        NumberField.dedekindZeta K s := by
      rw [вҶҗ LSeries_sum hsummable]
      unfold NumberField.dedekindZeta
      refine LSeries_congr (fun {n} hn => ?_) s
      simp only [Finset.sum_apply]
      rw [вҶҗ Nat.cast_sum, sum_classIdealCount K n hn]
    calc вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), Z C s
        = вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K),
            s * (s - 1) * Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) *
              ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
                NumberField.InfinitePlace.nrRealPlaces K *
              ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
                NumberField.InfinitePlace.nrComplexPlaces K *
              LSeries (fun n => (classIdealCount K C n : в„Ӯ)) s :=
          Finset.sum_congr rfl fun C _ => (hformula C s hs).2
      _ = s * (s - 1) * Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) *
            ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
              NumberField.InfinitePlace.nrRealPlaces K *
            ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
              NumberField.InfinitePlace.nrComplexPlaces K *
            NumberField.dedekindZeta K s := by
          rw [вҶҗ Finset.mul_sum, hpart]
  В· intro s
    calc вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), Z C (1 - s)
        = вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), Z (dedekindDualClass K C) s :=
          Finset.sum_congr rfl fun C _ => hfe C s
      _ = вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), Z C s :=
          Fintype.sum_bijective (dedekindDualClass K)
            (dedekindDualClass_involutive K).bijective _ _ fun C => rfl
  В· choose B hBpos hB using hgrowth
    have hM1 : (0:в„қ) < B 1 := hBpos 1
    set M := Finset.univ.sup' Finset.univ_nonempty B
    have hMle : B 1 вүӨ M := Finset.le_sup' B (Finset.mem_univ 1)
    have hMpos : 0 < M := lt_of_lt_of_le hM1 hMle
    set h := (Fintype.card (ClassGroup (NumberField.RingOfIntegers K)) : в„қ) with hhdef
    have hh1 : (1:в„қ) вүӨ h := by
      rw [hhdef]
      exact_mod_cast Fintype.card_pos
    have hlogh : 0 вүӨ Real.log h := Real.log_nonneg hh1
    refine вҹЁM + Real.log h + 1, by linarith, ?_вҹ©
    intro s hs
    have hlogs0 : 0 < Real.log вҖ–sвҖ– := Real.log_pos (by linarith)
    have hlog2 : Real.log 2 вүӨ Real.log вҖ–sвҖ– := Real.log_le_log two_pos hs
    have hX1 : 1 вүӨ вҖ–sвҖ– * Real.log вҖ–sвҖ– := by
      have h4 : (1:в„қ) вүӨ Real.log 4 := by
        rw [Real.le_log_iff_exp_le (by norm_num)]
        exact (lt_trans Real.exp_one_lt_d9 (by norm_num)).le
      have h24 : (2:в„қ) * Real.log 2 = Real.log 4 := by
        rw [show (4:в„қ) = 2 ^ 2 by norm_num, Real.log_pow]
        push_cast
        ring
      have h2s : 2 * Real.log 2 вүӨ вҖ–sвҖ– * Real.log вҖ–sвҖ– :=
        mul_le_mul hs hlog2 (Real.log_nonneg (by norm_num)) (by linarith)
      linarith
    calc вҖ–вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), Z C sвҖ–
        вүӨ вҲ‘ C : ClassGroup (NumberField.RingOfIntegers K), вҖ–Z C sвҖ– :=
          norm_sum_le _ _
      _ вүӨ вҲ‘ _C : ClassGroup (NumberField.RingOfIntegers K),
            Real.exp (M * вҖ–sвҖ– * Real.log вҖ–sвҖ–) :=
          Finset.sum_le_sum fun C _ => le_trans (hB C s hs)
            (Real.exp_le_exp.mpr
              (mul_le_mul_of_nonneg_right
                (mul_le_mul_of_nonneg_right (Finset.le_sup' B (Finset.mem_univ C))
                  (by linarith)) hlogs0.le))
      _ = h * Real.exp (M * вҖ–sвҖ– * Real.log вҖ–sвҖ–) := by
          rw [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, hhdef]
      _ вүӨ Real.exp ((M + Real.log h + 1) * вҖ–sвҖ– * Real.log вҖ–sвҖ–) := by
          have hh0 : (0:в„қ) < h := lt_of_lt_of_le one_pos hh1
          have hexp : h * Real.exp (M * вҖ–sвҖ– * Real.log вҖ–sвҖ–) =
              Real.exp (Real.log h + M * вҖ–sвҖ– * Real.log вҖ–sвҖ–) := by
            rw [Real.exp_add, Real.exp_log hh0]
          rw [hexp, Real.exp_le_exp]
          have hkey : (Real.log h + 1) * 1 вүӨ
              (Real.log h + 1) * (вҖ–sвҖ– * Real.log вҖ–sвҖ–) :=
            mul_le_mul_of_nonneg_left hX1 (by linarith)
          nlinarith [hkey]

/-- **Euler-product nonvanishing of the Dedekind zeta Dirichlet series
on the open half-plane of absolute convergence** (PROVEN 2026-07-24 вҖ”
the second, much shallower leaf of the decomposition of
`dedekindContinuation_exists`; unlike `completedDedekindZeta_exists`
it mentions no continued object, only the pin's raw Dirichlet series;
proved by route (a) below, specializing the project's own ideal-monoid
Euler product from `Chebotarev.lean` to the trivial character).
For `re s > 1` the series `О¶_K(s) = ОЈ_рқ”һ Nрқ”һ^{вҲ’s}` factors as the
absolutely convergent Euler product `О _рқ”ӯ (1 вҲ’ Nрқ”ӯ^{вҲ’s})^{вҲ’1}` over the
nonzero prime ideals of `рқ’Ә_K` (Neukirch VII (5.2)): unique
factorization of ideals in the Dedekind domain `рқ’Ә_K` makes the
counting coefficient `n вҶҰ #{рқ”һ : Nрқ”һ = n}` multiplicative, with finitely
many primes above each rational prime.  Intended routes (either
suffices): (a) mathlib's Euler-product machinery
(`Mathlib.NumberTheory.EulerProduct.Basic`,
`ArithmeticFunction.IsMultiplicative.eulerProduct`) applied to the
multiplicative counting function, nonvanishing because a `tprod` of
nonzero factors of a multipliable family is nonzero; (b) the
MГ¶bius-inverse route mathlib uses for
`riemannZeta_ne_zero_of_one_lt_re`
(`Mathlib.NumberTheory.LSeries.Dirichlet`): the ideal MГ¶bius function
`Ој_K(рқ”ҹ) вҲҲ {0, Вұ1}` gives Dirichlet-inverse coefficients
`b(n) = ОЈ_{Nрқ”ҹ = n} Ој_K(рқ”ҹ)` with `|b(n)| вүӨ #{рқ”ҹ : Nрқ”ҹ = n}`, so
`L(b, s)` converges absolutely on `re s > 1` alongside `О¶_K`
(summability from the pin's CesГ ro bound
`Ideal.tendsto_norm_le_div_atTopвӮҖ` via
`LSeriesSummable_of_sum_norm_bigO`), and the convolution identity
`(ОЈ_{рқ”ҹ вҲЈ рқ”һ} Ој_K(рқ”ҹ)) = [рқ”һ = 1]` yields `О¶_K(s)В·L(b, s) = 1`, so
`О¶_K(s) вү  0`. -/
theorem dedekindZeta_ne_zero_of_one_lt_re (K : Type*) [Field K] [NumberField K]
    (s : в„Ӯ) (hs : 1 < s.re) : NumberField.dedekindZeta K s вү  0 := by
  -- Route (a), via the project's own Euler-product machinery
  -- (`Fermat.FLT.GaloisRepresentation.Chebotarev`, already a transitive
  -- public import through `MazurTorsion`): specializing the exp-log form
  -- `exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries`
  -- to the trivial character at level 1 exhibits `О¶_K(s)` as a value of
  -- `Complex.exp`, which never vanishes.
  have h := exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries
    K (1 : DirichletCharacter в„Ӯ 1) hs
  have hcoeff : (fun k : в„• => (1 : DirichletCharacter в„Ӯ 1) (k : ZMod 1) *
      (Nat.card {I : Ideal (NumberField.RingOfIntegers K) //
        Ideal.absNorm I = k} : в„Ӯ)) =
      fun n : в„• => (Nat.card {I : Ideal (NumberField.RingOfIntegers K) //
        Ideal.absNorm I = n} : в„Ӯ) := by
    funext k
    rw [MulChar.one_apply (isUnit_of_subsingleton _), one_mul]
  unfold NumberField.dedekindZeta
  rw [вҶҗ hcoeff, вҶҗ h]
  exact Complex.exp_ne_zero _

/-- **Conjugation of a complex power with nonnegative real base**
(PROVEN 2026-07-24, helper for the Schwarz-reflection glue of
`dedekindContinuation_exists`): `conj (x^w) = x^(conj w)` for
`0 вүӨ x : в„қ` вҖ” the branch cut is avoided since `arg x = 0 вү  ПҖ`. -/
theorem conj_ofReal_cpow (x : в„қ) (hx : 0 вүӨ x) (w : в„Ӯ) :
    (starRingEnd в„Ӯ) ((x : в„Ӯ) ^ w) = (x : в„Ӯ) ^ ((starRingEnd в„Ӯ) w) := by
  rw [Complex.cpow_conj (x : в„Ӯ) w
      (by rw [Complex.arg_ofReal_of_nonneg hx]; exact Real.pi_ne_zero.symm),
    Complex.conj_ofReal]

/-- **Conjugation symmetry of the Dedekind zeta Dirichlet series**
(PROVEN 2026-07-24, glue for the `conj_symm` field of
`DedekindContinuation`): `О¶_K(sМ„) = conj (О¶_K(s))` for EVERY `s : в„Ӯ` вҖ”
the pin's `NumberField.dedekindZeta` is the raw `LSeries` of the
natural-number ideal-counting coefficients, so conjugation commutes
with each term (`n^sМ„ = conj (n^s)` for the nonnegative real base
`n`), and with the `tsum` unconditionally, `starRingEnd в„Ӯ` being a
homeomorphism (divergent junk values are both `0`). -/
theorem dedekindZeta_conj (K : Type*) [Field K] [NumberField K] (s : в„Ӯ) :
    NumberField.dedekindZeta K ((starRingEnd в„Ӯ) s) =
      (starRingEnd в„Ӯ) (NumberField.dedekindZeta K s) := by
  unfold NumberField.dedekindZeta LSeries
  rw [Complex.conj_tsum]
  refine tsum_congr fun n => ?_
  rcases eq_or_ne n 0 with rfl | hn
  В· simp
  В· rw [LSeries.term_of_ne_zero hn, LSeries.term_of_ne_zero hn, map_divвӮҖ,
      Complex.cpow_conj (n : в„Ӯ) s
        (by rw [Complex.natCast_arg]; exact Real.pi_ne_zero.symm)]
    simp

/-- **Hecke's theorem: the continuation package exists** (DECOMPOSED
2026-07-24, assembly PROVEN вҖ” previously the monolithic sorried leaf
of the decomposition of `dedekind_explicit_formula_fejer`, now cut
into the thetaвҖ“Mellin core `completedDedekindZeta_exists` (entire
`Оҫ_K`, the `re s > 1` formula, the functional equation, the order-one
growth bound вҖ” the genuinely deep Poisson-summation material) and the
Euler-product leaf `dedekindZeta_ne_zero_of_one_lt_re`, both sorried
above).  The two remaining fields of `DedekindContinuation` are
DERIVED here: `conj_symm` by Schwarz reflection вҖ” `z вҶҰ conj (Оҫ(zМ„))`
is entire (`differentiableAt_conj_conj_iff`) and agrees with `Оҫ` on
`re s > 1` because every factor of `eq_of_one_lt_re` has real
coefficients (`dedekindZeta_conj`, `Complex.Gamma_conj`,
`conj_ofReal_cpow`), so the identity theorem
(`AnalyticOnNhd.eqOn_of_preconnected_of_eventuallyEq` at the interior
point `2` of the open half-plane, exactly the argument of mathlib's
`riemannZeta_conj`) propagates the agreement to all of `в„Ӯ` вҖ” and
`ne_zero_of_one_lt_re` factorwise from the formula: `s вү  0 вү  s вҲ’ 1`
on `re s > 1`, complex powers of the nonzero bases `|d_K|`, `ПҖ`,
`2ПҖ` never vanish (`Complex.cpow_ne_zero_iff`), `О“` has no zeros on
`re > 0` (`Complex.Gamma_ne_zero_of_re_pos`), and `О¶_K(s) вү  0` is the
Euler-product leaf. -/
theorem dedekindContinuation_exists (K : Type*) [Field K] [NumberField K] :
    Nonempty (DedekindContinuation K) := by
  obtain вҹЁxi, hdiff, heq, hfe, hgrowthвҹ© := completedDedekindZeta_exists K
  -- Schwarz reflection on the half-plane `re s > 1`, factor by factor
  have hhalf : вҲҖ z : в„Ӯ, 1 < z.re вҶ’
      (starRingEnd в„Ӯ) (xi ((starRingEnd в„Ӯ) z)) = xi z := by
    intro z hz
    rw [heq ((starRingEnd в„Ӯ) z) (by rwa [Complex.conj_re])]
    rw [show (starRingEnd в„Ӯ) z / 2 = (starRingEnd в„Ӯ) (z / 2) by
          rw [map_divвӮҖ, map_ofNat],
        show -(starRingEnd в„Ӯ) z / 2 = (starRingEnd в„Ӯ) (-z / 2) by
          rw [map_divвӮҖ, map_ofNat, map_neg],
        show -(starRingEnd в„Ӯ) z = (starRingEnd в„Ӯ) (-z) from (map_neg _ z).symm]
    have hd := conj_ofReal_cpow |(NumberField.discr K : в„қ)| (abs_nonneg _)
    have hpi := conj_ofReal_cpow Real.pi Real.pi_nonneg
    have h2pi := conj_ofReal_cpow (2 * Real.pi) (by positivity)
    simp only [map_mul, map_sub, map_pow, map_one, map_ofNat, Complex.conj_conj,
      Complex.Gamma_conj, hd, hpi, h2pi, dedekindZeta_conj]
    exact (heq z hz).symm
  -- the identity theorem propagates the reflection to all of `в„Ӯ`
  have hg_an : AnalyticOnNhd в„Ӯ
      (fun z => (starRingEnd в„Ӯ) (xi ((starRingEnd в„Ӯ) z))) Set.univ :=
    DifferentiableOn.analyticOnNhd
      (fun z _ =>
        (differentiableAt_conj_conj_iff.mpr (hdiff _)).differentiableWithinAt)
      isOpen_univ
  have hxi_an : AnalyticOnNhd в„Ӯ xi Set.univ :=
    hdiff.differentiableOn.analyticOnNhd isOpen_univ
  have heqOn : Set.EqOn (fun z => (starRingEnd в„Ӯ) (xi ((starRingEnd в„Ӯ) z))) xi
      Set.univ :=
    hg_an.eqOn_of_preconnected_of_eventuallyEq hxi_an isPreconnected_univ
      (Set.mem_univ (2 : в„Ӯ))
      (Filter.eventuallyEq_of_mem
        ((isOpen_lt continuous_const Complex.continuous_re).mem_nhds
          (by norm_num : (2 : в„Ӯ) вҲҲ {z : в„Ӯ | 1 < z.re}))
        fun z hz => hhalf z hz)
  have hconj : вҲҖ s : в„Ӯ, xi ((starRingEnd в„Ӯ) s) = (starRingEnd в„Ӯ) (xi s) := by
    intro s
    have h := heqOn (Set.mem_univ ((starRingEnd в„Ӯ) s))
    simp only [Complex.conj_conj] at h
    exact h.symm
  -- factorwise nonvanishing on `re s > 1`
  have hne : вҲҖ s : в„Ӯ, 1 < s.re вҶ’ xi s вү  0 := by
    intro s hs
    rw [heq s hs]
    have hs0 : s вү  0 := by
      rintro rfl
      norm_num [Complex.zero_re] at hs
    have hs1 : s - 1 вү  0 := by
      rw [sub_ne_zero]
      rintro rfl
      norm_num [Complex.one_re] at hs
    have hdisc : Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) вү  0 := by
      rw [Complex.cpow_ne_zero_iff]
      refine Or.inl ?_
      simp only [ne_eq, Complex.ofReal_eq_zero, abs_eq_zero, Int.cast_eq_zero]
      exact NumberField.discr_ne_zero K
    have hpi1 : ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
        NumberField.InfinitePlace.nrRealPlaces K вү  0 := by
      refine pow_ne_zero _ (mul_ne_zero ?_ ?_)
      В· rw [Complex.cpow_ne_zero_iff]
        exact Or.inl (by simp)
      В· refine Complex.Gamma_ne_zero_of_re_pos ?_
        rw [Complex.div_ofNat_re]
        linarith
    have hpi2 : ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
        NumberField.InfinitePlace.nrComplexPlaces K вү  0 := by
      refine pow_ne_zero _ (mul_ne_zero (mul_ne_zero two_ne_zero ?_) ?_)
      В· rw [Complex.cpow_ne_zero_iff]
        refine Or.inl ?_
        simp only [ne_eq, Complex.ofReal_eq_zero]
        positivity
      В· exact Complex.Gamma_ne_zero_of_re_pos (by linarith)
    exact mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero (mul_ne_zero hs0 hs1)
      hdisc) hpi1) hpi2) (dedekindZeta_ne_zero_of_one_lt_re K s hs)
  exact вҹЁвҹЁxi, hdiff, heq, hfe, hconj, hne, hgrowthвҹ©вҹ©

open scoped Classical in
/-- **Zero multiplicity of the continued Dedekind zeta** (definition,
2026-07-23): the analytic vanishing order `analyticOrderNatAt` of the
entire completed zeta `Оҫ_K` at `ПҒ`, restricted to the open critical
strip `0 < re ПҒ < 1`, and `0` outside it.  On the strip the elementary
factor `s(sвҲ’1)В·|d_K|^{s/2}В·О“-factors` of `Оҫ_K` is finite and
nonvanishing (`О“` has no zeros; its poles lie at `0, вҲ’1, вҲ’2, вҖҰ`, off
the strip), so this is exactly the multiplicity of `ПҒ` as a zero of
the analytically continued `О¶_K` вҖ” the `mult` of the WeilвҖ“Poitou
explicit formula. -/
noncomputable def DedekindContinuation.mult {K : Type*} [Field K] [NumberField K]
    (pkg : DedekindContinuation K) (ПҒ : в„Ӯ) : в„• :=
  if 0 < ПҒ.re вҲ§ ПҒ.re < 1 then analyticOrderNatAt pkg.xi ПҒ else 0

/-- **Support of the multiplicity function** (PROVEN 2026-07-23): by
construction `DedekindContinuation.mult` vanishes off the open
critical strip. -/
theorem DedekindContinuation.mult_mem_strip {K : Type*} [Field K] [NumberField K]
    (pkg : DedekindContinuation K) {ПҒ : в„Ӯ} (h : pkg.mult ПҒ вү  0) :
    0 < ПҒ.re вҲ§ ПҒ.re < 1 := by
  by_contra hcon
  exact h (by simp [DedekindContinuation.mult, hcon])

/-- **A point of positive multiplicity is a zero of `Оҫ_K`** (PROVEN
2026-07-23): `analyticOrderNatAt` vanishes wherever the function does
not. -/
theorem DedekindContinuation.xi_eq_zero_of_mult_ne_zero {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) {ПҒ : в„Ӯ}
    (h : pkg.mult ПҒ вү  0) : pkg.xi ПҒ = 0 := by
  by_contra hne
  refine h ?_
  have h0 : analyticOrderAt pkg.xi ПҒ = 0 := analyticOrderAt_eq_zero.mpr (Or.inr hne)
  simp [DedekindContinuation.mult, analyticOrderNatAt, h0]

/-- **Finiteness of the horizontal truncations of the zero set**
(PROVEN 2026-07-23): the points of positive multiplicity with
`|im ПҒ| вүӨ T` lie in the closed ball of radius `|T| + 2` (the strip
truncation is bounded); were they infinite they would accumulate at
some `zвӮҖ` of that compact ball, and the identity theorem for the
entire `Оҫ_K` would force `Оҫ_K вүЎ 0`, contradicting the Euler-product
nonvanishing at `s = 2`.  No boundary-line information enters:
accumulation at a boundary point of the strip kills an entire function
just as an interior accumulation point does. -/
theorem DedekindContinuation.finite_truncation {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) (T : в„қ) :
    {ПҒ : в„Ӯ | pkg.mult ПҒ вү  0 вҲ§ |ПҒ.im| вүӨ T}.Finite := by
  by_contra hinf
  have hsub : {ПҒ : в„Ӯ | pkg.mult ПҒ вү  0 вҲ§ |ПҒ.im| вүӨ T} вҠҶ
      Metric.closedBall (0 : в„Ӯ) (|T| + 2) := by
    intro ПҒ hПҒ
    obtain вҹЁhre0, hre1вҹ© := pkg.mult_mem_strip hПҒ.1
    rw [Metric.mem_closedBall, dist_zero_right]
    calc вҖ–ПҒвҖ– вүӨ |ПҒ.re| + |ПҒ.im| := Complex.norm_le_abs_re_add_abs_im ПҒ
      _ вүӨ 1 + |T| := add_le_add (by rw [abs_of_pos hre0]; linarith)
          (le_trans hПҒ.2 (le_abs_self T))
      _ вүӨ |T| + 2 := by linarith
  obtain вҹЁzвӮҖ, -, haccвҹ© := Set.Infinite.exists_accPt_of_subset_isCompact hinf
    (isCompact_closedBall (0 : в„Ӯ) (|T| + 2)) hsub
  rw [accPt_iff_frequently_nhdsNE] at hacc
  have hzero : Set.EqOn pkg.xi 0 Set.univ :=
    ((pkg.differentiable.differentiableOn).analyticOnNhd
        isOpen_univ).eqOn_zero_of_preconnected_of_frequently_eq_zero
      isPreconnected_univ (Set.mem_univ zвӮҖ)
      (hacc.mono fun z hz => pkg.xi_eq_zero_of_mult_ne_zero hz.1)
  exact pkg.ne_zero_of_one_lt_re 2 (by norm_num) (hzero (Set.mem_univ 2))

/-- **The Poitou test function `F(x) = f(x)/cosh(x/2)`** (introduced
2026-07-24 in the decomposition of
`DedekindContinuation.fejer_zero_sum_tendsto`): the even function,
compactly supported in `[-6, 6]`, at which Poitou's explicit formula
is actually evaluated вҖ” `poitouPhi` is exactly its two-sided pairing
`ОҰ(s) = вҲ« F(x)В·e^{(sвҲ’1/2)x} dx`, and `F(0) = 1`.  `F` satisfies the
admissibility conditions (i)вҖ“(iii) of Proposition 5 of G. Poitou,
*Sur les petits discriminants*, SГ©m. DelangeвҖ“PisotвҖ“Poitou 18
(1976/77), exp. 6, p. 6-08, because `f = odlyzkoTestFn` does. -/
noncomputable def poitouF (x : в„қ) : в„қ := odlyzkoTestFn x / Real.cosh (x / 2)

/-- **The schoolbook divided-zeros counting inequality** (PROVEN
2026-07-24, the Jensen-free counting core of
`DedekindContinuation.zero_count_window`): if an entire `f : в„Ӯ вҶ’ в„Ӯ`
satisfies `f c вү  0`, is bounded by `M` on the circle `вҖ–z вҲ’ cвҖ– = R`,
and `t` is a finite set of points of the closed disc `вҖ–z вҲ’ cвҖ– вүӨ r`
(`0 < r < R`) whose total `analyticOrderNatAt` is at least `k`, then
`((R вҲ’ r)/r)^k В· вҖ–f cвҖ– вүӨ M` вҖ” so the multiplicity-weighted zero count
of the small disc is at most `log(M/вҖ–f cвҖ–)/log((R вҲ’ r)/r)`.  The
mathlib pin has no analytic Jensen formula and no Hadamard
factorization, so the count is manufactured from the
Cauchy/max-modulus toolkit.  Proof: induction on `k`, dividing off one
zero per step by `dslope`: if `f ПҒ = 0` then
`f = (В· вҲ’ ПҒ) * dslope f ПҒ` EXACTLY (`sub_smul_dslope_of_zero`) with
`dslope f ПҒ` again entire (the removable-singularity lemma
`Complex.differentiableOn_dslope`), the division dropping
`analyticOrderNatAt` at `ПҒ` by one (`analyticOrderAt_mul` against the
order-`1` linear factor) and fixing it elsewhere; each divided linear
factor is `вүҘ R вҲ’ r` on the circle and `вүӨ r` at the centre, and the
base case `k = 0` is the maximum-modulus principle
`Complex.norm_le_of_forall_mem_frontier_norm_le`. -/
theorem sum_analyticOrderNatAt_le_of_frontier_norm_le
    {f : в„Ӯ вҶ’ в„Ӯ} {c : в„Ӯ} {r R M : в„қ} {t : Finset в„Ӯ} {k : в„•}
    (hf : Differentiable в„Ӯ f) (hr : 0 < r) (hrR : r < R) (hfc : f c вү  0)
    (hM : вҲҖ z : в„Ӯ, вҖ–z - cвҖ– = R вҶ’ вҖ–f zвҖ– вүӨ M)
    (ht : вҲҖ ПҒ вҲҲ t, вҖ–ПҒ - cвҖ– вүӨ r)
    (hk : k вүӨ вҲ‘ ПҒ вҲҲ t, analyticOrderNatAt f ПҒ) :
    ((R - r) / r) ^ k * вҖ–f cвҖ– вүӨ M := by
  induction k generalizing f M with
  | zero =>
    have hb : вҲҖ z вҲҲ frontier (Metric.ball c R), вҖ–f zвҖ– вүӨ M := by
      intro z hz
      rw [frontier_ball c (by linarith : (0 : в„қ) < R).ne'] at hz
      exact hM z (by rwa [Metric.mem_sphere, dist_eq_norm] at hz)
    simpa using Complex.norm_le_of_forall_mem_frontier_norm_le
      Metric.isBounded_ball hf.diffContOnCl hb
      (subset_closure (Metric.mem_ball_self (by linarith : (0 : в„қ) < R)))
  | succ k ih =>
    have hRr : (0 : в„қ) < R - r := by linarith
    obtain вҹЁПҒ, hПҒt, hПҒвҹ© : вҲғ ПҒ вҲҲ t, analyticOrderNatAt f ПҒ вү  0 :=
      Finset.exists_ne_zero_of_sum_ne_zero (by omega)
    have hfПҒ : f ПҒ = 0 := apply_eq_zero_of_analyticOrderNatAt_ne_zero hПҒ
    set g : в„Ӯ вҶ’ в„Ӯ := dslope f ПҒ with hg_def
    have hg_diff : Differentiable в„Ӯ g := by
      rw [hg_def, вҶҗ differentiableOn_univ]
      exact (Complex.differentiableOn_dslope Filter.univ_mem).mpr hf.differentiableOn
    have hfactor : вҲҖ z : в„Ӯ, f z = (z - ПҒ) * g z := fun z => by
      rw [hg_def, вҶҗ smul_eq_mul, sub_smul_dslope_of_zero hfПҒ]
    have hgc_ne : g c вү  0 := fun h => hfc (by rw [hfactor c, h, mul_zero])
    have hMg : вҲҖ z : в„Ӯ, вҖ–z - cвҖ– = R вҶ’ вҖ–g zвҖ– вүӨ M / (R - r) := by
      intro z hz
      have hzПҒ : R - r вүӨ вҖ–z - ПҒвҖ– := by
        have h1 : вҖ–z - cвҖ– - вҖ–ПҒ - cвҖ– вүӨ вҖ–z - c - (ПҒ - c)вҖ– := norm_sub_norm_le _ _
        rw [sub_sub_sub_cancel_right, hz] at h1
        have h2 := ht ПҒ hПҒt
        linarith
      rw [le_div_iffвӮҖ hRr]
      calc вҖ–g zвҖ– * (R - r) вүӨ вҖ–g zвҖ– * вҖ–z - ПҒвҖ– :=
            mul_le_mul_of_nonneg_left hzПҒ (norm_nonneg _)
        _ = вҖ–f zвҖ– := by rw [hfactor z, norm_mul, mul_comm]
        _ вүӨ M := hM z hz
    -- order bookkeeping: dividing by the linear factor drops the order
    -- at `ПҒ` by exactly one and leaves all other orders unchanged
    have hfan : вҲҖ z : в„Ӯ, AnalyticAt в„Ӯ f z := fun z => hf.analyticAt z
    have hgan : вҲҖ z : в„Ӯ, AnalyticAt в„Ӯ g z := fun z => hg_diff.analyticAt z
    have hforder : вҲҖ z : в„Ӯ, analyticOrderAt f z вү  вҠӨ := by
      intro z
      have h0 : analyticOrderAt f c вү  вҠӨ := by
        rw [analyticOrderAt_eq_zero.mpr (Or.inr hfc)]
        simp
      exact AnalyticOnNhd.analyticOrderAt_ne_top_of_isPreconnected
        (fun w _ => hfan w) isPreconnected_univ (Set.mem_univ c) (Set.mem_univ z) h0
    have horder_split : вҲҖ Пғ : в„Ӯ, analyticOrderAt f Пғ =
        analyticOrderAt (fun w : в„Ӯ => w - ПҒ) Пғ + analyticOrderAt g Пғ := by
      intro Пғ
      have hfg : f = (fun w : в„Ӯ => w - ПҒ) * g := by
        funext z
        rw [Pi.mul_apply]
        exact hfactor z
      rw [hfg]
      exact analyticOrderAt_mul (by fun_prop) (hgan Пғ)
    have hgorder_ne_top : вҲҖ Пғ : в„Ӯ, analyticOrderAt g Пғ вү  вҠӨ := by
      intro Пғ h
      apply hforder Пғ
      rw [horder_split Пғ, h, add_top]
    have hnat_ne : вҲҖ Пғ : в„Ӯ, Пғ вү  ПҒ вҶ’
        analyticOrderNatAt g Пғ = analyticOrderNatAt f Пғ := by
      intro Пғ hПғ
      have h1 := horder_split Пғ
      rw [(analyticOrderAt_eq_zero (рқ•ң := в„Ӯ) (f := fun w : в„Ӯ => w - ПҒ)
          (zвӮҖ := Пғ)).mpr (Or.inr (sub_ne_zero.mpr hПғ)), zero_add] at h1
      simp [analyticOrderNatAt, h1]
    have hnat_ПҒ : analyticOrderNatAt f ПҒ = analyticOrderNatAt g ПҒ + 1 := by
      have h1 := horder_split ПҒ
      have h2 : analyticOrderAt (fun w : в„Ӯ => w - ПҒ) ПҒ = 1 := by
        simpa using analyticOrderAt_centeredMonomial (рқ•ң := в„Ӯ) (zвӮҖ := ПҒ) (n := 1)
      rw [h2] at h1
      simp only [analyticOrderNatAt, h1]
      rw [add_comm, ENat.toNat_add (hgorder_ne_top ПҒ) (by simp)]
      simp
    have hsum_g : k вүӨ вҲ‘ Пғ вҲҲ t, analyticOrderNatAt g Пғ := by
      have h1 := (Finset.add_sum_erase t (analyticOrderNatAt f) hПҒt).symm
      have h2 := (Finset.add_sum_erase t (analyticOrderNatAt g) hПҒt).symm
      have h3 : вҲ‘ Пғ вҲҲ t.erase ПҒ, analyticOrderNatAt f Пғ
          = вҲ‘ Пғ вҲҲ t.erase ПҒ, analyticOrderNatAt g Пғ :=
        Finset.sum_congr rfl fun Пғ hПғ => (hnat_ne Пғ (Finset.ne_of_mem_erase hПғ)).symm
      omega
    have hIH := ih hg_diff hgc_ne hMg hsum_g
    have hcПҒ : вҖ–c - ПҒвҖ– вүӨ r := by rw [norm_sub_rev]; exact ht ПҒ hПҒt
    have hq_pos : (0 : в„қ) < (R - r) / r := div_pos hRr hr
    have hr0 : r вү  0 := ne_of_gt hr
    calc ((R - r) / r) ^ (k + 1) * вҖ–f cвҖ–
        = ((R - r) / r) ^ (k + 1) * (вҖ–c - ПҒвҖ– * вҖ–g cвҖ–) := by
          rw [hfactor c, norm_mul]
      _ вүӨ ((R - r) / r) ^ (k + 1) * (r * вҖ–g cвҖ–) := by
          have h4 := mul_le_mul_of_nonneg_right hcПҒ (norm_nonneg (g c))
          exact mul_le_mul_of_nonneg_left h4 (pow_nonneg (le_of_lt hq_pos) _)
      _ = (R - r) * (((R - r) / r) ^ k * вҖ–g cвҖ–) := by
          rw [pow_succ]
          have hqr : (R - r) / r * r = R - r := div_mul_cancelвӮҖ _ hr0
          calc ((R - r) / r) ^ k * ((R - r) / r) * (r * вҖ–g cвҖ–)
              = (R - r) / r * r * (((R - r) / r) ^ k * вҖ–g cвҖ–) := by ring
            _ = (R - r) * (((R - r) / r) ^ k * вҖ–g cвҖ–) := by rw [hqr]
      _ вүӨ (R - r) * (M / (R - r)) := mul_le_mul_of_nonneg_left hIH (le_of_lt hRr)
      _ = M := by rw [mul_comm, div_mul_cancelвӮҖ M hRr.ne']

/-- **The elementary factor of the completed Dedekind zeta**
(definition, 2026-07-24 вҖ” introduced for the decomposition of
`DedekindContinuation.xi_window_ratio_bound`): the product
`E(s) = s(sвҲ’1)В·|d_K|^{s/2}В·О“_в„қ(s)^{rвӮҒ}В·О“_в„Ӯ(s)^{rвӮӮ}` of all the
non-Dirichlet factors of `eq_of_one_lt_re`, spelled so that
`Оҫ_K(s) = E(s)В·О¶_K(s)` on `re s > 1` DEFINITIONALLY
(`DedekindContinuation.xi_eq_xiFactor_mul_dedekindZeta`).  Off the
real axis `E` never vanishes (`s вү  0 вү  s вҲ’ 1`, complex powers of
positive real bases are nonzero, and mathlib's `Complex.Gamma`
vanishes only at the nonpositive integers), so on the window circles
at height `T вүҘ 8` вҖ” whose points have `im вүҘ 2` вҖ” the quotient `Оҫ_K/E`
is the honest analytically continued Dedekind zeta, the object whose
polynomial growth PhragmГ©nвҖ“LindelГ¶f controls. -/
noncomputable def dedekindXiFactor (K : Type*) [Field K] [NumberField K]
    (s : в„Ӯ) : в„Ӯ :=
  s * (s - 1) * Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) *
    ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
      NumberField.InfinitePlace.nrRealPlaces K *
    ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
      NumberField.InfinitePlace.nrComplexPlaces K

/-- **The `re s > 1` formula, factored form** (PROVEN 2026-07-24):
`Оҫ_K(s) = E(s)В·О¶_K(s)` on the half-plane of absolute convergence вҖ”
the interface field `eq_of_one_lt_re` with its first five factors
folded into `dedekindXiFactor`. -/
theorem DedekindContinuation.xi_eq_xiFactor_mul_dedekindZeta {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K) (s : в„Ӯ)
    (hs : 1 < s.re) :
    pkg.xi s = dedekindXiFactor K s * NumberField.dedekindZeta K s :=
  pkg.eq_of_one_lt_re s hs

open IsDedekindDomain in
/-- **Uniform Euler-product lower bound for `О¶_K` on the line
`re s = 2`** (PROVEN 2026-07-24 вҖ” leaf (iii) of the decomposition of
`DedekindContinuation.xi_window_ratio_bound`): there is an `m > 0`
with `вҖ–О¶_K(s)вҖ– вүҘ m` for EVERY `s` with `re s = 2`.  Through the
project's exp-log Euler product
`exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries`
(from `Chebotarev.lean`, at the trivial character mod `1`),
`О¶_K(s) = exp(ОЈ_рқ”ӯ вҲ’log(1 вҲ’ Nрқ”ӯ^{вҲ’s}))`, so
`вҖ–О¶_K(s)вҖ– = exp(re ОЈ) вүҘ exp(вҲ’вҖ–ОЈвҖ–)`; each log is bounded in norm by
`(3/2)В·Nрқ”ӯ^{вҲ’2}` (`Complex.norm_log_one_add_half_le_self`, the factors
having norm `вүӨ 2^{вҲ’2} вүӨ 1/2`), and the full-place sum `ОЈ_рқ”ӯ Nрқ”ӯ^{вҲ’2}`
converges (`summable_rpow_neg_natCard_quotient`), giving the uniform
constant `m = exp(вҲ’(3/2)В·ОЈ_рқ”ӯ Nрқ”ӯ^{вҲ’2})` вҖ” the `О¶(2Пғ)/О¶(Пғ)`-style
constant of the classical estimate, uniform in `im s`. -/
theorem dedekindZeta_norm_lower_of_re_eq_two (K : Type*) [Field K]
    [NumberField K] :
    вҲғ m : в„қ, 0 < m вҲ§ вҲҖ s : в„Ӯ, s.re = 2 вҶ’
      m вүӨ вҖ–NumberField.dedekindZeta K sвҖ– := by
  classical
  have hsum2 : Summable
      (fun P : HeightOneSpectrum (NumberField.RingOfIntegers K) =>
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ))) :=
    summable_rpow_neg_natCard_quotient (by norm_num)
  refine вҹЁReal.exp (-(3 / 2 *
      вҲ‘' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ)))), Real.exp_pos _, ?_вҹ©
  intro s hs
  have hs2 : 1 < s.re := by rw [hs]; norm_num
  have h := exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries
    K (1 : DirichletCharacter в„Ӯ 1) hs2
  have hcoeff : (fun k : в„• => (1 : DirichletCharacter в„Ӯ 1) (k : ZMod 1) *
      (Nat.card {I : Ideal (NumberField.RingOfIntegers K) //
        Ideal.absNorm I = k} : в„Ӯ)) =
      fun n : в„• => (Nat.card {I : Ideal (NumberField.RingOfIntegers K) //
        Ideal.absNorm I = n} : в„Ӯ) := by
    funext k
    rw [MulChar.one_apply (isUnit_of_subsingleton _), one_mul]
  -- per-place factor norm bound at `re s = 2`
  have hzb : вҲҖ P : HeightOneSpectrum (NumberField.RingOfIntegers K),
      вҖ–(1 : DirichletCharacter в„Ӯ 1)
          ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
            ZMod 1) *
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s)вҖ– вүӨ
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ)) := by
    intro P
    have hNpos : 0 < Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) := by
      have h2 := two_le_natCard_quotient P
      omega
    rw [norm_mul, Complex.norm_natCast_cpow_of_pos hNpos, Complex.neg_re, hs]
    exact mul_le_of_le_one_left (Real.rpow_nonneg (Nat.cast_nonneg _) _)
      (DirichletCharacter.norm_le_one _ _)
  -- the factors are in the disc of radius `1/2` where `log` is tame
  have hhalf : вҲҖ P : HeightOneSpectrum (NumberField.RingOfIntegers K),
      вҖ–-((1 : DirichletCharacter в„Ӯ 1)
          ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
            ZMod 1) *
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s))вҖ– вүӨ
        1 / 2 := by
    intro P
    rw [norm_neg]
    refine (hzb P).trans ?_
    have h2N : (2 : в„қ) вүӨ
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) := by
      exact_mod_cast two_le_natCard_quotient P
    calc (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ))
        вүӨ (2 : в„қ) ^ (-(2 : в„қ)) :=
          Real.rpow_le_rpow_of_nonpos two_pos h2N (by norm_num)
      _ вүӨ (2 : в„қ) ^ (-1 : в„қ) :=
          (Real.rpow_le_rpow_left_iff one_lt_two).mpr (by norm_num)
      _ = 1 / 2 := by rw [Real.rpow_neg_one]; norm_num
  -- per-place log bound
  have hlogb : вҲҖ P : HeightOneSpectrum (NumberField.RingOfIntegers K),
      вҖ–-Complex.log (1 - (1 : DirichletCharacter в„Ӯ 1)
          ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
            ZMod 1) *
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s))вҖ– вүӨ
        3 / 2 * (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ)) := by
    intro P
    rw [norm_neg, sub_eq_add_neg]
    calc вҖ–Complex.log (1 + -((1 : DirichletCharacter в„Ӯ 1)
            ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
              ZMod 1) *
          (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^
            (-s)))вҖ–
        вүӨ 3 / 2 * вҖ–-((1 : DirichletCharacter в„Ӯ 1)
            ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
              ZMod 1) *
          (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^
            (-s))вҖ– :=
          Complex.norm_log_one_add_half_le_self (hhalf P)
      _ = 3 / 2 * вҖ–(1 : DirichletCharacter в„Ӯ 1)
            ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
              ZMod 1) *
          (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^
            (-s)вҖ– := by rw [norm_neg]
      _ вүӨ 3 / 2 * (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
            (-(2 : в„қ)) :=
          mul_le_mul_of_nonneg_left (hzb P) (by norm_num)
  -- the log sum is absolutely bounded by `(3/2)В·ОЈ_рқ”ӯ Nрқ”ӯ^{вҲ’2}`
  have hnorm_summable : Summable
      (fun P : HeightOneSpectrum (NumberField.RingOfIntegers K) =>
        вҖ–-Complex.log (1 - (1 : DirichletCharacter в„Ӯ 1)
            ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
              ZMod 1) *
          (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^
            (-s))вҖ–) :=
    Summable.of_nonneg_of_le (fun P => norm_nonneg _) hlogb
      (hsum2.mul_left (3 / 2))
  have hS : вҖ–вҲ‘' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
      -Complex.log (1 - (1 : DirichletCharacter в„Ӯ 1)
          ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
            ZMod 1) *
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s))вҖ– вүӨ
      3 / 2 * вҲ‘' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ)) := by
    refine (norm_tsum_le_tsum_norm hnorm_summable).trans ?_
    rw [вҶҗ tsum_mul_left]
    exact Summable.tsum_le_tsum hlogb hnorm_summable (hsum2.mul_left _)
  have hre : -(3 / 2 *
      вҲ‘' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„қ) ^
          (-(2 : в„қ))) вүӨ
      (вҲ‘' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
        -Complex.log (1 - (1 : DirichletCharacter в„Ӯ 1)
            ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) :
              ZMod 1) *
          (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^
            (-s))).re :=
    (abs_le.mp ((Complex.abs_re_le_norm _).trans hS)).1
  unfold NumberField.dedekindZeta
  rw [вҶҗ hcoeff, вҶҗ h, Complex.norm_exp, Real.exp_le_exp]
  exact hre

/-- **PhragmГ©nвҖ“LindelГ¶f window bound: `Оҫ_K` against its elementary
factor on the window circle** (sorry node, stated 2026-07-24 вҖ” leaf
(i) of the decomposition of
`DedekindContinuation.xi_window_ratio_bound`): there are `C > 0` and
`B : в„•` with `вҖ–Оҫ_K(z)вҖ– вүӨ CВ·T^BВ·вҖ–E(z)вҖ–` on the circle
`вҖ–z вҲ’ (2 + iT)вҖ– = 6` for all `T вүҘ 8`, `E = dedekindXiFactor K`.
Since `E` is zero-free on the window (its points have `im вүҘ 2`), this
says the analytically continued Dedekind zeta `Оҫ_K/E` grows
polynomially on the window вҖ” the convexity step of Landau's zero
count (E. Landau, *Algebraische Zahlen*, p. 122; Poitou p. 6-02).

Intended proof: `q := Оҫ_K/E` is differentiable on `im s > 0`
(quotient rule; `E вү  0` off the real axis) and agrees with `О¶_K` on
`re s > 1` (`xi_eq_xiFactor_mul_dedekindZeta`).  Boundary bounds for
the strip `вҲ’4 вүӨ re s вүӨ 8`, `im s вүҘ 1`:

* on `re s = 8`: `|q| = |О¶_K| вүӨ ОЈ_рқ”һ Nрқ”һ^{вҲ’8} = О¶_K(8) < вҲһ` (absolute
  convergence of the Dirichlet series);
* on `re s = вҲ’4`: `q(вҲ’4 + it) = q(5 вҲ’ it)В·E(5 вҲ’ it)/E(вҲ’4 + it)` by
  `funcEq`, `|q(5 вҲ’ it)| вүӨ О¶_K(5)`, and the same-height ratio
  `|E(5 вҲ’ it)/E(вҲ’4 + it)| = O(|t|^B)` by iterating
  `Complex.Gamma_add_one` (shifting `re` into `[1, 2)` costs
  linear factors polynomially bounded above and below at height
  `вүҘ 1`) together with the reflection formula
  `Complex.Gamma_mul_Gamma_one_sub` (trading `О“` at `re вүӨ 0` for
  `1/(О“(1 вҲ’ s)В·sin ПҖs)`, with `sinh(ПҖ|t|) вүӨ |sin ПҖs| вүӨ e^{ПҖ|t|}` and
  `|О“(u + iv)| вүӨ О“(u)` for `u > 0` from the integral
  representation);
* a-priori growth: `|q| вүӨ exp(CвҖ–sвҖ– log вҖ–sвҖ–)В·|E|вҒ»В№` from the `growth`
  field, and `|E(s)|вҒ»В№ вүӨ exp(CвҖІ(1 + |im s|))` on the strip by the
  same reflection/recurrence estimates
  (`|О“(s)| вүҘ ПҖ e^{вҲ’ПҖ|im s|}/О“(1 вҲ’ re s)`-style) вҖ” far below the
  `exp(BвҖІВ·exp(c|im s|))`, `c < ПҖ/12`, tolerance of
  `PhragmenLindelof.vertical_strip`.

For the half-strip (mathlib's PL variants use full vertical lines):
either reflect `q` across `im = 1` by Schwarz symmetry вҖ”
`s вҶҰ conj (q (conj s + 2В·I))` glues with `q` along `im = 1` via
`pkg.conj_symm` and the factorwise conjugation identities
(`Complex.Gamma_conj`, `conj_ofReal_cpow`) вҖ” or run the classical
auxiliary-multiplier proof of half-strip PhragmГ©nвҖ“LindelГ¶f on
rectangles with the maximum principle
(`Complex.norm_le_of_forall_mem_frontier_norm_le`).  Every window
circle point has `im вүҘ 2 > 1`, `re вҲҲ [вҲ’4, 8]`, and `|im| вүӨ T + 6 вүӨ
2T`, so the strip bound `O((1 + |im|)^B)` specializes to `CВ·T^B`. -/
theorem DedekindContinuation.xi_window_le_xiFactor {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    вҲғ C : в„қ, 0 < C вҲ§ вҲғ B : в„•, вҲҖ T : в„қ, 8 вүӨ T вҶ’ вҲҖ z : в„Ӯ,
      вҖ–z - (2 + (T : в„Ӯ) * Complex.I)вҖ– = 6 вҶ’
      вҖ–pkg.xi zвҖ– вүӨ C * T ^ B * вҖ–dedekindXiFactor K zвҖ– := by
  sorry

/-- **О“-ratio bound for the elementary factor across the window
circle** (sorry node, stated 2026-07-24 вҖ” leaf (ii) of the
decomposition of `DedekindContinuation.xi_window_ratio_bound`): on
the circle `вҖ–z вҲ’ cвҖ– = 6`, `c = 2 + iT`, `T вүҘ 8`, the elementary
factor satisfies `вҖ–E(z)вҖ– вүӨ CВ·T^BВ·вҖ–E(c)вҖ–`.  Both sides carry the same
`e^{вҲ’ПҖT/4}`-type О“-decay, so the ratio is polynomial.  Factorwise
(`E = s(sвҲ’1)В·|d|^{s/2}В·О“_в„қ(s)^{rвӮҒ}В·О“_в„Ӯ(s)^{rвӮӮ}`):

* `|z(zвҲ’1)| вүӨ (T + 15)ВІ вүӨ 16TВІ`, while `|c(cвҲ’1)| вүҘ TВІ` (both factors
  of the centre have modulus `вүҘ T`); the power factors have moduli
  `|d|^{re/2}`, `ПҖ^{вҲ’re/2}`, `(2ПҖ)^{вҲ’re}` with `re` confined to
  `[вҲ’4, 8]`, so their window/centre ratios are absolute constants.
* For the О“-ratios `|О“(z/2)/О“(c/2)|` and `|О“(z)/О“(c)|`: shift both
  arguments into `re вҲҲ [1, 2)` by `Complex.Gamma_add_one` (at most
  nine shifts; each linear factor and its inverse is bounded by a
  power of `T` since the heights stay in `[T/2 вҲ’ 3, T + 6]`, all
  `вүҘ 1`).  For the resulting equal-`re` comparison at heights
  `y, yвҖІ` with `|y вҲ’ yвҖІ| вүӨ 6`, use the Euler limit
  `Complex.GammaSeq_tendsto_Gamma`: for equal real parts the
  `n^sВ·n!` parts of the two `GammaSeq`s cancel in modulus, so the
  modulus ratio is the limit of
  `О _{j вүӨ n} (((x+j)ВІ + yвҖІВІ)/((x+j)ВІ + yВІ))^{1/2}`, and
  `|yвҖІВІ вҲ’ yВІ| вүӨ 6(2T + 6)` with
  `ОЈ_j ((x+j)ВІ + yВІ)вҒ»В№ вүӨ yвҒ»ВІ + ПҖ/(2y)` bounds every partial product
  by `exp(6(2T + 6)(yвҒ»ВІ + ПҖ/(2y))/2)`, a constant for
  `y вүҘ T/2 вҲ’ 3 вүҘ 1`; conclude with `le_of_tendsto`.  Horizontal
  (equal-height, `re`-offset `вүӨ 6`) comparisons are recurrence
  shifts again.
* All bounds are uniform over the circle, giving one pair `C`, `B`. -/
theorem dedekindXiFactor_window_ratio (K : Type*) [Field K]
    [NumberField K] :
    вҲғ C : в„қ, 0 < C вҲ§ вҲғ B : в„•, вҲҖ T : в„қ, 8 вүӨ T вҶ’ вҲҖ z : в„Ӯ,
      вҖ–z - (2 + (T : в„Ӯ) * Complex.I)вҖ– = 6 вҶ’
      вҖ–dedekindXiFactor K zвҖ– вүӨ
        C * T ^ B * вҖ–dedekindXiFactor K (2 + (T : в„Ӯ) * Complex.I)вҖ– := by
  sorry

/-- **Window ratio bound at bounded heights `2 вүӨ T вүӨ 8`** (PROVEN
2026-07-24 вҖ” the compactness regime of the decomposition of
`DedekindContinuation.xi_window_ratio_bound`; for `T < 8` the window
circle can cross the real axis, where the elementary factor has its
`О“`-degeneracies, so the analytic leaves start at `T вүҘ 8` and this
regime is handled by pure continuity): every window value is bounded
by the maximum of `вҖ–Оҫ_KвҖ–` on the compact ball `вҖ–zвҖ– вүӨ 16` (extreme
value theorem; every window point at height `T вүӨ 8` lies there), and
the centre values `вҖ–Оҫ_K(2 + iT)вҖ–`, `T вҲҲ [2, 8]`, have a positive
minimum by `ne_zero_of_one_lt_re` at `re = 2` plus continuity on the
compact segment. -/
theorem DedekindContinuation.xi_window_ratio_bound_of_le_eight {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K) :
    вҲғ C : в„қ, 0 < C вҲ§ вҲҖ T : в„қ, 2 вүӨ T вҶ’ T вүӨ 8 вҶ’ вҲҖ z : в„Ӯ,
      вҖ–z - (2 + (T : в„Ӯ) * Complex.I)вҖ– = 6 вҶ’
      вҖ–pkg.xi zвҖ– вүӨ C * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– := by
  have hcont : Continuous pkg.xi := pkg.differentiable.continuous
  -- global bound on a compact ball containing every bounded-height window
  obtain вҹЁw, -, hwmaxвҹ© := (isCompact_closedBall (0 : в„Ӯ) 16).exists_isMaxOn
    вҹЁ0, Metric.mem_closedBall_self (by norm_num)вҹ© hcont.norm.continuousOn
  -- positive minimum of the centre values over `T вҲҲ [2, 8]`
  have hcentre : Continuous fun t : в„қ => (2 : в„Ӯ) + (t : в„Ӯ) * Complex.I :=
    continuous_const.add (Complex.continuous_ofReal.mul continuous_const)
  have hgcont : Continuous
      fun t : в„қ => вҖ–pkg.xi ((2 : в„Ӯ) + (t : в„Ӯ) * Complex.I)вҖ– :=
    (hcont.comp hcentre).norm
  obtain вҹЁTвӮҖ, -, hTвӮҖminвҹ© := (isCompact_Icc (a := (2 : в„қ)) (b := 8)).exists_isMinOn
    вҹЁ2, Set.mem_Icc.mpr вҹЁle_refl _, by norm_numвҹ©вҹ© hgcont.continuousOn
  have hm : 0 < вҖ–pkg.xi (2 + (TвӮҖ : в„Ӯ) * Complex.I)вҖ– := by
    rw [norm_pos_iff]
    refine pkg.ne_zero_of_one_lt_re _ ?_
    have h2 : ((2 : в„Ӯ) + (TвӮҖ : в„Ӯ) * Complex.I).re = 2 := by simp
    rw [h2]
    norm_num
  refine вҹЁ(вҖ–pkg.xi wвҖ– + 1) / вҖ–pkg.xi (2 + (TвӮҖ : в„Ӯ) * Complex.I)вҖ–,
    div_pos (by positivity) hm, ?_вҹ©
  intro T hT2 hT8 z hz
  have hzball : z вҲҲ Metric.closedBall (0 : в„Ӯ) 16 := by
    rw [Metric.mem_closedBall, dist_zero_right]
    have h1 : вҖ–zвҖ– - вҖ–(2 : в„Ӯ) + (T : в„Ӯ) * Complex.IвҖ– вүӨ
        вҖ–z - (2 + (T : в„Ӯ) * Complex.I)вҖ– := norm_sub_norm_le _ _
    have h2 : вҖ–(2 : в„Ӯ) + (T : в„Ӯ) * Complex.IвҖ– вүӨ 2 + T := by
      calc вҖ–(2 : в„Ӯ) + (T : в„Ӯ) * Complex.IвҖ–
          вүӨ вҖ–(2 : в„Ӯ)вҖ– + вҖ–(T : в„Ӯ) * Complex.IвҖ– := norm_add_le _ _
        _ = 2 + T := by
            rw [norm_mul, Complex.norm_I, mul_one, Complex.norm_real,
              Real.norm_eq_abs, abs_of_nonneg (by linarith : (0 : в„қ) вүӨ T)]
            norm_num
    rw [hz] at h1
    linarith
  have hzM : вҖ–pkg.xi zвҖ– вүӨ вҖ–pkg.xi wвҖ– := isMaxOn_iff.mp hwmax z hzball
  have hcM : вҖ–pkg.xi (2 + (TвӮҖ : в„Ӯ) * Complex.I)вҖ– вүӨ
      вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
    isMinOn_iff.mp hTвӮҖmin T (Set.mem_Icc.mpr вҹЁhT2, hT8вҹ©)
  calc вҖ–pkg.xi zвҖ– вүӨ вҖ–pkg.xi wвҖ– + 1 := by linarith
    _ = (вҖ–pkg.xi wвҖ– + 1) / вҖ–pkg.xi (2 + (TвӮҖ : в„Ӯ) * Complex.I)вҖ– *
        вҖ–pkg.xi (2 + (TвӮҖ : в„Ӯ) * Complex.I)вҖ– := by
        rw [div_mul_cancelвӮҖ _ hm.ne']
    _ вүӨ (вҖ–pkg.xi wвҖ– + 1) / вҖ–pkg.xi (2 + (TвӮҖ : в„Ӯ) * Complex.I)вҖ– *
        вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
        mul_le_mul_of_nonneg_left hcM (by positivity)

/-- **Polynomial max/centre ratio for `Оҫ_K` on the window disc at
height `T`** (DECOMPOSED 2026-07-24, assembly PROVEN вҖ” the analytic
leaf of the decomposition of `DedekindContinuation.zero_count_window`,
now cut along Landau's route, E. Landau, *Algebraische Zahlen*,
p. 122, quoted by Poitou p. 6-02, into the PhragmГ©nвҖ“LindelГ¶f window
bound `DedekindContinuation.xi_window_le_xiFactor` (leaf (i),
sorried), the elementary-factor О“-ratio
`dedekindXiFactor_window_ratio` (leaf (ii), sorried), the
Euler-product centre lower bound `dedekindZeta_norm_lower_of_re_eq_two`
(leaf (iii), PROVEN), and the bounded-height compactness bound
`DedekindContinuation.xi_window_ratio_bound_of_le_eight` (PROVEN)):
there is a natural `A вүҘ 1` with `вҖ–Оҫ_K(z)вҖ– вүӨ T^AВ·вҖ–Оҫ_K(2 + iT)вҖ–` for
every `T вүҘ 2` and every `z` on the circle of radius `6` around the
centre `c = 2 + iT`.  This is the convexity estimate that makes
Landau's window count `O(log T)`: numerator and denominator carry the
same exponential О“-decay in `T`, so the RATIO is polynomial even
though `Оҫ_K` itself is exponentially small at height `T`.  (Only the
upper window is stated; the `вҲ’T` window follows by `conj_symm`.)

ASSEMBLY (proven here): for `T вүҘ 8` chain
`вҖ–Оҫ(z)вҖ– вүӨ CвӮҒT^{BвӮҒ}вҖ–E(z)вҖ– вүӨ CвӮҒCвӮӮT^{BвӮҒ+BвӮӮ}вҖ–E(c)вҖ– вүӨ
(CвӮҒCвӮӮ/m)В·T^{BвӮҒ+BвӮӮ}В·вҖ–Оҫ(c)вҖ–`, the last step because
`вҖ–Оҫ(c)вҖ– = вҖ–E(c)вҖ–В·вҖ–О¶_K(c)вҖ– вүҘ mВ·вҖ–E(c)вҖ–` by
`xi_eq_xiFactor_mul_dedekindZeta` at `re c = 2`; for `2 вүӨ T вүӨ 8` use
the compactness constant `CвӮҖ`.  The constants are absorbed into the
exponent: with `max CвӮҖ (CвӮҒCвӮӮ/m) < 2^k вүӨ T^k`, the natural
`A = BвӮҒ + BвӮӮ + k + 1 вүҘ 1` works in both regimes. -/
theorem DedekindContinuation.xi_window_ratio_bound {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    вҲғ A : в„•, 0 < A вҲ§ вҲҖ T : в„қ, 2 вүӨ T вҶ’ вҲҖ z : в„Ӯ,
      вҖ–z - (2 + (T : в„Ӯ) * Complex.I)вҖ– = 6 вҶ’
      вҖ–pkg.xi zвҖ– вүӨ T ^ A * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– := by
  obtain вҹЁCвӮҖ, hCвӮҖ, hвӮҖвҹ© := pkg.xi_window_ratio_bound_of_le_eight
  obtain вҹЁCвӮҒ, hCвӮҒ, BвӮҒ, hвӮҒвҹ© := pkg.xi_window_le_xiFactor
  obtain вҹЁCвӮӮ, hCвӮӮ, BвӮӮ, hвӮӮвҹ© := dedekindXiFactor_window_ratio K
  obtain вҹЁm, hm, hmlowвҹ© := dedekindZeta_norm_lower_of_re_eq_two K
  obtain вҹЁk, hkвҹ© := pow_unbounded_of_one_lt (max CвӮҖ (CвӮҒ * CвӮӮ / m))
    (by norm_num : (1 : в„қ) < 2)
  refine вҹЁBвӮҒ + BвӮӮ + k + 1, by omega, ?_вҹ©
  intro T hT z hz
  have hT1 : (1 : в„қ) вүӨ T := by linarith
  have hT0 : (0 : в„қ) < T := by linarith
  have hxic : (0 : в„қ) вүӨ вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– := norm_nonneg _
  have h2k : (2 : в„қ) ^ k вүӨ T ^ k := pow_le_pow_leftвӮҖ (by norm_num) hT k
  rcases le_or_gt T 8 with hT8 | hT8
  В· -- bounded heights: the compactness constant, absorbed into `T ^ k`
    calc вҖ–pkg.xi zвҖ–
        вүӨ CвӮҖ * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– := hвӮҖ T hT hT8 z hz
      _ вүӨ 2 ^ k * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_right
            (le_trans (le_max_left _ _) hk.le) hxic
      _ вүӨ T ^ k * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_right h2k hxic
      _ вүӨ T ^ (BвӮҒ + BвӮӮ + k + 1) * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_right
            (pow_le_pow_rightвӮҖ hT1 (by omega)) hxic
  В· -- tall windows: PhragmГ©nвҖ“LindelГ¶f Г— О“-ratio Г— Euler lower bound
    have hT8' : (8 : в„қ) вүӨ T := hT8.le
    have hcre : ((2 : в„Ӯ) + (T : в„Ӯ) * Complex.I).re = 2 := by simp
    have hEc : m * вҖ–dedekindXiFactor K (2 + (T : в„Ӯ) * Complex.I)вҖ– вүӨ
        вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– := by
      rw [pkg.xi_eq_xiFactor_mul_dedekindZeta _ (by rw [hcre]; norm_num),
        norm_mul, mul_comm m]
      exact mul_le_mul_of_nonneg_left (hmlow _ hcre) (norm_nonneg _)
    calc вҖ–pkg.xi zвҖ–
        вүӨ CвӮҒ * T ^ BвӮҒ * вҖ–dedekindXiFactor K zвҖ– := hвӮҒ T hT8' z hz
      _ вүӨ CвӮҒ * T ^ BвӮҒ * (CвӮӮ * T ^ BвӮӮ *
            вҖ–dedekindXiFactor K (2 + (T : в„Ӯ) * Complex.I)вҖ–) :=
          mul_le_mul_of_nonneg_left (hвӮӮ T hT8' z hz)
            (mul_nonneg hCвӮҒ.le (pow_nonneg hT0.le _))
      _ = CвӮҒ * CвӮӮ / m * T ^ (BвӮҒ + BвӮӮ) *
            (m * вҖ–dedekindXiFactor K (2 + (T : в„Ӯ) * Complex.I)вҖ–) := by
          rw [pow_add]
          field_simp [hm.ne']
      _ вүӨ CвӮҒ * CвӮӮ / m * T ^ (BвӮҒ + BвӮӮ) *
            вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_left hEc
            (mul_nonneg (div_nonneg (mul_nonneg hCвӮҒ.le hCвӮӮ.le) hm.le)
              (pow_nonneg hT0.le _))
      _ вүӨ 2 ^ k * T ^ (BвӮҒ + BвӮӮ) *
            вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_right
              (le_trans (le_max_right _ _) hk.le)
              (pow_nonneg hT0.le _)) hxic
      _ вүӨ T ^ k * T ^ (BвӮҒ + BвӮӮ) *
            вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_right
            (mul_le_mul_of_nonneg_right h2k (pow_nonneg hT0.le _)) hxic
      _ = T ^ (BвӮҒ + BвӮӮ + k) * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– := by
          rw [вҶҗ pow_add, add_comm k (BвӮҒ + BвӮӮ)]
      _ вүӨ T ^ (BвӮҒ + BвӮӮ + k + 1) * вҖ–pkg.xi (2 + (T : в„Ӯ) * Complex.I)вҖ– :=
          mul_le_mul_of_nonneg_right
            (pow_le_pow_rightвӮҖ hT1 (Nat.le_succ _)) hxic

/-- **Landau's window count: `O(log T)` zeros of `Оҫ_K` at height `T`,
with multiplicity** (DECOMPOSED 2026-07-24, counting core PROVEN вҖ”
leaf (a) of the decomposition of
`DedekindContinuation.fejer_zero_sum_tendsto`): there is a constant
`C > 0` such that for every `T вүҘ 2`, every finite set of points whose
ordinates lie within `1` of `ВұT` carries total `mult` at most
`CВ·log T`.  (Points of `mult = 0` contribute nothing, so no zero-set
membership hypothesis is needed; the set-of-zeros form follows by
summing over `finite_truncation` truncations.)  This is
`N(T+1) вҲ’ N(T) = O(log T)` of E. Landau, *Algebraische Zahlen*,
p. 122, quoted by Poitou p. 6-02; the contour leaf
`DedekindContinuation.weil_explicit_formula_F` consumes it through its
`hcount` hypothesis (horizontal edges through zero-free heights,
BorelвҖ“CarathГ©odory partial fractions for `Оҫ'/Оҫ`).

PROOF (realized here): let `c = 2 + iT`, `r = 5/2`, `R = 6`.  Every
strip point with `|im s вҲ’ T| вүӨ 1` lies in the disc `вҖ–s вҲ’ cвҖ– вүӨ r`
(distance `вүӨ вҲҡ5 < 5/2`), and every strip point with
`|im s + T| вүӨ 1` in the disc around `cМ„ = 2 вҲ’ iT`; `mult` equals
`analyticOrderNatAt` on the strip (`mult_mem_strip`).  The Jensen-free
counting core `sum_analyticOrderNatAt_le_of_frontier_norm_le`
(divided-zeros factorization by `dslope` + maximum modulus) turns the
boundary/centre ratio bound of the remaining analytic leaf
`DedekindContinuation.xi_window_ratio_bound` вҖ” `вҖ–ОҫвҖ– вүӨ T^AВ·вҖ–Оҫ(c)вҖ–` on
`вҖ–z вҲ’ cвҖ– = 6` вҖ” into `(7/5)^kВ·вҖ–Оҫ(c)вҖ– вүӨ T^AВ·вҖ–Оҫ(c)вҖ–` for the window
count `k` at `+T`; `Оҫ(c) вү  0` by `ne_zero_of_one_lt_re`, and taking
`Real.log` gives `k вүӨ AВ·log T/log(7/5)`.  The `вҲ’T` window is
transported to `+T` by `conj_symm` (an isometry on the circle and on
the centre value), so `C = 2A/log(7/5)` works. -/
theorem DedekindContinuation.zero_count_window {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    вҲғ C : в„қ, 0 < C вҲ§ вҲҖ T : в„қ, 2 вүӨ T вҶ’ вҲҖ s : Finset в„Ӯ,
      (вҲҖ ПҒ вҲҲ s, |(|ПҒ.im| - T)| вүӨ 1) вҶ’
      вҲ‘ ПҒ вҲҲ s, (pkg.mult ПҒ : в„қ) вүӨ C * Real.log T := by
  classical
  obtain вҹЁA, hApos, hAвҹ© := pkg.xi_window_ratio_bound
  have hlog75 : (0 : в„қ) < Real.log (7 / 5) := Real.log_pos (by norm_num)
  have hAr : (0 : в„қ) < A := by exact_mod_cast hApos
  refine вҹЁ2 * (A : в„қ) / Real.log (7 / 5), div_pos (by linarith) hlog75, ?_вҹ©
  intro T hT s hs
  have hlogT : (0 : в„қ) < Real.log T := Real.log_pos (by linarith)
  have hAP := hA T hT
  -- the two disc centres at heights `ВұT`
  set cP : в„Ӯ := 2 + (T : в„Ӯ) * Complex.I with hcP_def
  set cM : в„Ӯ := 2 - (T : в„Ӯ) * Complex.I with hcM_def
  have hreP : cP.re = 2 := by simp [hcP_def]
  have himP : cP.im = T := by simp [hcP_def]
  have hreM : cM.re = 2 := by simp [hcM_def]
  have himM : cM.im = -T := by simp [hcM_def]
  have hxiP : pkg.xi cP вү  0 := pkg.ne_zero_of_one_lt_re _ (by rw [hreP]; norm_num)
  have hxiM : pkg.xi cM вү  0 := pkg.ne_zero_of_one_lt_re _ (by rw [hreM]; norm_num)
  have hconj : (starRingEnd в„Ӯ) cP = cM := by
    simp [hcP_def, hcM_def, Complex.ext_iff]
  have hconj' : (starRingEnd в„Ӯ) cM = cP := by
    simp [hcP_def, hcM_def, Complex.ext_iff]
  have hnorm_c : вҖ–pkg.xi cMвҖ– = вҖ–pkg.xi cPвҖ– := by
    rw [вҶҗ hconj, pkg.conj_symm, RCLike.norm_conj]
  -- the ratio bound on the mirror disc, by Schwarz reflection
  have hAM : вҲҖ z : в„Ӯ, вҖ–z - cMвҖ– = 6 вҶ’ вҖ–pkg.xi zвҖ– вүӨ T ^ A * вҖ–pkg.xi cMвҖ– := by
    intro z hz
    have h1 : вҖ–(starRingEnd в„Ӯ) z - cPвҖ– = 6 := by
      rw [вҶҗ hconj', вҶҗ map_sub, RCLike.norm_conj]
      exact hz
    have h2 := hAP _ h1
    rw [pkg.conj_symm z, RCLike.norm_conj] at h2
    rw [hnorm_c]
    exact h2
  -- the per-disc count from the Jensen-free counting core
  have key : вҲҖ c : в„Ӯ, pkg.xi c вү  0 вҶ’
      (вҲҖ z : в„Ӯ, вҖ–z - cвҖ– = 6 вҶ’ вҖ–pkg.xi zвҖ– вүӨ T ^ A * вҖ–pkg.xi cвҖ–) вҶ’
      вҲҖ u : Finset в„Ӯ, (вҲҖ ПҒ вҲҲ u, вҖ–ПҒ - cвҖ– вүӨ 5 / 2) вҶ’
      вҲ‘ ПҒ вҲҲ u, (analyticOrderNatAt pkg.xi ПҒ : в„қ)
        вүӨ (A : в„қ) * Real.log T / Real.log (7 / 5) := by
    intro c hc hMb u hu
    have hcount := sum_analyticOrderNatAt_le_of_frontier_norm_le
      pkg.differentiable (by norm_num : (0 : в„қ) < 5 / 2)
      (by norm_num : (5 : в„қ) / 2 < 6) hc hMb hu le_rfl
    have h75 : ((6 : в„қ) - 5 / 2) / (5 / 2) = 7 / 5 := by norm_num
    rw [h75] at hcount
    have hxin : (0 : в„қ) < вҖ–pkg.xi cвҖ– := norm_pos_iff.mpr hc
    have hk75 : ((7 : в„қ) / 5) ^ (вҲ‘ ПҒ вҲҲ u, analyticOrderNatAt pkg.xi ПҒ) вүӨ T ^ A :=
      le_of_mul_le_mul_right hcount hxin
    have hlogk := Real.log_le_log (by positivity) hk75
    rw [Real.log_pow, Real.log_pow] at hlogk
    rw [le_div_iffвӮҖ hlog75]
    push_cast at hlogk вҠў
    exact hlogk
  -- points within `1` of `ВұT` and of positive multiplicity lie in the discs
  have hdist : вҲҖ c ПҒ : в„Ӯ, c.re = 2 вҶ’ 0 < ПҒ.re вҶ’ ПҒ.re < 1 вҶ’
      |ПҒ.im - c.im| вүӨ 1 вҶ’ вҖ–ПҒ - cвҖ– вүӨ 5 / 2 := by
    intro c ПҒ hcre hre0 hre1 him
    have habs := abs_le.mp him
    have hsq : вҖ–ПҒ - cвҖ– ^ 2 вүӨ (5 / 2 : в„қ) ^ 2 := by
      rw [Complex.sq_norm, Complex.normSq_apply, Complex.sub_re, Complex.sub_im, hcre]
      nlinarith [habs.1, habs.2]
    nlinarith [hsq, norm_nonneg (ПҒ - c)]
  have hmult_eq : вҲҖ ПҒ : в„Ӯ, pkg.mult ПҒ вү  0 вҶ’
      pkg.mult ПҒ = analyticOrderNatAt pkg.xi ПҒ := by
    intro ПҒ h
    have hst := pkg.mult_mem_strip h
    simp only [DedekindContinuation.mult]
    rw [if_pos hst]
  -- restrict to points of nonzero multiplicity and split by hemisphere
  set sf := s.filter (fun ПҒ => pkg.mult ПҒ вү  0) with hsf_def
  have hstep1 : вҲ‘ ПҒ вҲҲ sf, (pkg.mult ПҒ : в„қ) = вҲ‘ ПҒ вҲҲ s, (pkg.mult ПҒ : в„қ) := by
    rw [hsf_def]
    exact Finset.sum_filter_of_ne fun ПҒ _ hПҒ h => hПҒ (by rw [h]; norm_num)
  have hsplit := Finset.sum_filter_add_sum_filter_not sf (fun ПҒ => 0 вүӨ ПҒ.im)
      (fun ПҒ => (pkg.mult ПҒ : в„қ))
  have hup : вҲ‘ ПҒ вҲҲ sf.filter (fun ПҒ => 0 вүӨ ПҒ.im), (pkg.mult ПҒ : в„қ)
      вүӨ (A : в„қ) * Real.log T / Real.log (7 / 5) := by
    have hmem : вҲҖ ПҒ вҲҲ sf.filter (fun ПҒ => 0 вүӨ ПҒ.im), вҖ–ПҒ - cPвҖ– вүӨ 5 / 2 := by
      intro ПҒ hПҒ
      rw [Finset.mem_filter] at hПҒ
      obtain вҹЁhПҒsf, hПҒimвҹ© := hПҒ
      rw [hsf_def, Finset.mem_filter] at hПҒsf
      obtain вҹЁhПҒs, hПҒmвҹ© := hПҒsf
      obtain вҹЁh0, h1вҹ© := pkg.mult_mem_strip hПҒm
      refine hdist cP ПҒ hreP h0 h1 ?_
      rw [himP]
      have h2 := hs ПҒ hПҒs
      rwa [abs_of_nonneg hПҒim] at h2
    calc вҲ‘ ПҒ вҲҲ sf.filter (fun ПҒ => 0 вүӨ ПҒ.im), (pkg.mult ПҒ : в„қ)
        = вҲ‘ ПҒ вҲҲ sf.filter (fun ПҒ => 0 вүӨ ПҒ.im),
            (analyticOrderNatAt pkg.xi ПҒ : в„қ) := by
          refine Finset.sum_congr rfl fun ПҒ hПҒ => ?_
          rw [Finset.mem_filter] at hПҒ
          have hПҒm : pkg.mult ПҒ вү  0 := by
            have h3 := hПҒ.1
            rw [hsf_def, Finset.mem_filter] at h3
            exact h3.2
          rw [hmult_eq ПҒ hПҒm]
      _ вүӨ (A : в„қ) * Real.log T / Real.log (7 / 5) := key cP hxiP hAP _ hmem
  have hlow : вҲ‘ ПҒ вҲҲ sf.filter (fun ПҒ => В¬0 вүӨ ПҒ.im), (pkg.mult ПҒ : в„қ)
      вүӨ (A : в„қ) * Real.log T / Real.log (7 / 5) := by
    have hmem : вҲҖ ПҒ вҲҲ sf.filter (fun ПҒ => В¬0 вүӨ ПҒ.im), вҖ–ПҒ - cMвҖ– вүӨ 5 / 2 := by
      intro ПҒ hПҒ
      rw [Finset.mem_filter] at hПҒ
      obtain вҹЁhПҒsf, hПҒimвҹ© := hПҒ
      rw [hsf_def, Finset.mem_filter] at hПҒsf
      obtain вҹЁhПҒs, hПҒmвҹ© := hПҒsf
      obtain вҹЁh0, h1вҹ© := pkg.mult_mem_strip hПҒm
      refine hdist cM ПҒ hreM h0 h1 ?_
      rw [himM]
      have h2 := hs ПҒ hПҒs
      rw [abs_of_neg (not_le.mp hПҒim)] at h2
      rw [show ПҒ.im - -T = -(-ПҒ.im - T) by ring, abs_neg]
      exact h2
    calc вҲ‘ ПҒ вҲҲ sf.filter (fun ПҒ => В¬0 вүӨ ПҒ.im), (pkg.mult ПҒ : в„қ)
        = вҲ‘ ПҒ вҲҲ sf.filter (fun ПҒ => В¬0 вүӨ ПҒ.im),
            (analyticOrderNatAt pkg.xi ПҒ : в„қ) := by
          refine Finset.sum_congr rfl fun ПҒ hПҒ => ?_
          rw [Finset.mem_filter] at hПҒ
          have hПҒm : pkg.mult ПҒ вү  0 := by
            have h3 := hПҒ.1
            rw [hsf_def, Finset.mem_filter] at h3
            exact h3.2
          rw [hmult_eq ПҒ hПҒm]
      _ вүӨ (A : в„қ) * Real.log T / Real.log (7 / 5) := key cM hxiM hAM _ hmem
  rw [вҶҗ hstep1, вҶҗ hsplit]
  have hlog75' : Real.log (7 / 5) вү  0 := ne_of_gt hlog75
  have hC : 2 * ((A : в„қ) * Real.log T / Real.log (7 / 5))
      = 2 * (A : в„қ) / Real.log (7 / 5) * Real.log T := by
    field_simp
  linarith [hup, hlow, hC]

/-- **The folded vertical-edge functional of Poitou's contour**
(definition, 2026-07-24 вҖ” introduced in the decomposition of
`DedekindContinuation.weil_explicit_formula_F`): the value at
truncation height `T` of BOTH vertical edges of the rectangle
`[вҲ’1/4, 5/4] Г— [вҲ’T, T]`, folded onto the right edge `re s = 5/4`,

`E(T) = ПҖвҒ»В№ В· вҲ«_{вҲ’T}^{T} Re[ОҰ(5/4 + it) В· (Оҫ'/Оҫ)(5/4 + it)] dt`.

Why this is the whole contour up to vanishing edges: the functional
equation `funcEq` gives `(Оҫ'/Оҫ)(1 вҲ’ s) = вҲ’(Оҫ'/Оҫ)(s)` and evenness of
`F` gives `ОҰ(1 вҲ’ s) = ОҰ(s)`, so under `s вҶҰ 1 вҲ’ s` (which maps the
left edge `re s = вҲ’1/4` onto the right edge reversed) the integrand
`ОҰВ·Оҫ'/Оҫ` is odd-symmetric and the left edge contributes exactly the
same as the right; `conj_symm` makes the folded value real, whence
the `Re` inside.  The normalization `ПҖвҒ»В№ = 2В·(2ПҖ)вҒ»В№` carries the
factor `2` of the fold and the `i` of `ds = iВ·dt` against the
`(2ПҖi)вҒ»В№` of the residue theorem.  Consumed by the two limit leaves
`DedekindContinuation.zero_sum_sub_poitouEdge_tendsto_zero` (the
truncated zero sum equals `E(T)` up to vanishing horizontal edges)
and `DedekindContinuation.poitouEdge_tendsto` (the `T вҶ’ вҲһ`
evaluation of `E(T)` by Poitou's Propositions 2вҖ“3). -/
noncomputable def DedekindContinuation.poitouEdge {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) (T : в„қ) : в„қ :=
  Real.piвҒ»В№ * вҲ« t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      (deriv pkg.xi (5 / 4 + t * Complex.I) /
        pkg.xi (5 / 4 + t * Complex.I))).re

/-- **The archimedean elementary factor of the completed Dedekind
zeta** (definition, 2026-07-24 вҖ” shared helper of the two boundary
leaves `DedekindContinuation.xi_one_ne_zero` and
`DedekindContinuation.xi_ne_zero_of_re_eq_one_of_im_ne_zero`):
`G_K(s) = |d_K|^{s/2}В·О“_в„қ(s)^{rвӮҒ}В·О“_в„Ӯ(s)^{rвӮӮ}`, so that the field
`eq_of_one_lt_re` of `DedekindContinuation` reads
`Оҫ_K(s) = s(sвҲ’1)В·G_K(s)В·О¶_K(s)` on `re s > 1`
(`DedekindContinuation.xi_eq_dedekindGammaFactor` below).  Separating
this factor out is what both boundary leaves need: it is continuous
and nonvanishing on the half-plane `re s > 0` (the two lemmas below),
so along `re s = 1` every zero or pole phenomenon of `Оҫ` is carried by
`s(sвҲ’1)` and the continued `О¶_K` alone. -/
noncomputable def dedekindGammaFactor (K : Type*) [Field K] [NumberField K]
    (s : в„Ӯ) : в„Ӯ :=
  Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) *
    ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
      NumberField.InfinitePlace.nrRealPlaces K *
    ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
      NumberField.InfinitePlace.nrComplexPlaces K

/-- **The completed zeta through the elementary factor** (PROVEN
2026-07-24): the field `eq_of_one_lt_re` of `DedekindContinuation`
regrouped as `Оҫ_K(s) = s(sвҲ’1)В·G_K(s)В·О¶_K(s)` with
`G_K = dedekindGammaFactor K` вҖ” pure reassociation. -/
theorem DedekindContinuation.xi_eq_dedekindGammaFactor {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) {s : в„Ӯ} (hs : 1 < s.re) :
    pkg.xi s = s * (s - 1) * dedekindGammaFactor K s *
      NumberField.dedekindZeta K s := by
  rw [pkg.eq_of_one_lt_re s hs]
  simp only [dedekindGammaFactor]
  ring

/-- **Continuity of the elementary factor on `re s > 0`** (PROVEN
2026-07-24): `|d_K|^{s/2}` and the `ПҖ`-powers are continuous as
constant-base complex powers of nonzero bases
(`continuousAt_const_cpow`), and `О“(s/2)`, `О“(s)` are differentiable
away from the nonpositive integers (`Complex.differentiableAt_Gamma`),
which `re s > 0` avoids. -/
theorem dedekindGammaFactor_continuousAt (K : Type*) [Field K] [NumberField K]
    {s : в„Ӯ} (hs : 0 < s.re) : ContinuousAt (dedekindGammaFactor K) s := by
  have hd : (Complex.ofReal |(NumberField.discr K : в„қ)|) вү  0 := by
    simp only [ne_eq, Complex.ofReal_eq_zero, abs_eq_zero, Int.cast_eq_zero]
    exact NumberField.discr_ne_zero K
  have hpi : ((Real.pi : в„қ) : в„Ӯ) вү  0 := by
    simp [Real.pi_ne_zero]
  have h2pi : (((2 : в„қ) * Real.pi : в„қ) : в„Ӯ) вү  0 := by
    simp [Real.pi_ne_zero]
  have hhalf_ne : вҲҖ m : в„•, s / 2 вү  -(m : в„Ӯ) := by
    intro m h
    have hre := congrArg Complex.re h
    rw [Complex.div_ofNat_re] at hre
    simp only [Complex.neg_re, Complex.natCast_re] at hre
    have hm : (0 : в„қ) вүӨ (m : в„қ) := Nat.cast_nonneg m
    linarith
  have hs_ne : вҲҖ m : в„•, s вү  -(m : в„Ӯ) := by
    intro m h
    have hre := congrArg Complex.re h
    simp only [Complex.neg_re, Complex.natCast_re] at hre
    have hm : (0 : в„қ) вүӨ (m : в„қ) := Nat.cast_nonneg m
    linarith
  have hdiv2 : ContinuousAt (fun z : в„Ӯ => z / 2) s :=
    (continuous_id.div_const (2 : в„Ӯ)).continuousAt
  have hc1 : ContinuousAt
      (fun z : в„Ӯ => Complex.ofReal |(NumberField.discr K : в„қ)| ^ (z / 2)) s :=
    ContinuousAt.comp
      (g := fun w : в„Ӯ => Complex.ofReal |(NumberField.discr K : в„қ)| ^ w)
      (f := fun z : в„Ӯ => z / 2) (continuousAt_const_cpow hd) hdiv2
  have hc2a : ContinuousAt (fun z : в„Ӯ => (Real.pi : в„Ӯ) ^ (-z / 2)) s :=
    ContinuousAt.comp (g := fun w : в„Ӯ => (Real.pi : в„Ӯ) ^ w)
      (f := fun z : в„Ӯ => -z / 2) (continuousAt_const_cpow hpi)
      ((continuous_id.neg.div_const (2 : в„Ӯ)).continuousAt)
  have hc2b : ContinuousAt (fun z : в„Ӯ => Complex.Gamma (z / 2)) s :=
    ContinuousAt.comp (g := Complex.Gamma) (f := fun z : в„Ӯ => z / 2)
      (Complex.differentiableAt_Gamma (s / 2) hhalf_ne).continuousAt hdiv2
  have hc3a : ContinuousAt (fun z : в„Ӯ => ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-z)) s :=
    ContinuousAt.comp (g := fun w : в„Ӯ => ((2 * Real.pi : в„қ) : в„Ӯ) ^ w)
      (f := fun z : в„Ӯ => -z) (continuousAt_const_cpow h2pi)
      continuous_neg.continuousAt
  have hО“ : ContinuousAt Complex.Gamma s :=
    (Complex.differentiableAt_Gamma s hs_ne).continuousAt
  show ContinuousAt (fun z : в„Ӯ =>
    Complex.ofReal |(NumberField.discr K : в„қ)| ^ (z / 2) *
      ((Real.pi : в„Ӯ) ^ (-z / 2) * Complex.Gamma (z / 2)) ^
        NumberField.InfinitePlace.nrRealPlaces K *
      ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-z) * Complex.Gamma z) ^
        NumberField.InfinitePlace.nrComplexPlaces K) s
  exact (hc1.mul ((hc2a.mul hc2b).pow _)).mul
    (((continuousAt_const.mul hc3a).mul hО“).pow _)

/-- **Nonvanishing of the elementary factor on `re s > 0`** (PROVEN
2026-07-24): complex powers of the nonzero bases `|d_K|`, `ПҖ`, `2ПҖ`
never vanish (`Complex.cpow_ne_zero_iff`), and `О“` has no zeros on
`re > 0` (`Complex.Gamma_ne_zero_of_re_pos`) вҖ” the same factorwise
argument as the `ne_zero_of_one_lt_re` glue of
`dedekindContinuation_exists`, but valid on the wider half-plane. -/
theorem dedekindGammaFactor_ne_zero (K : Type*) [Field K] [NumberField K]
    {s : в„Ӯ} (hs : 0 < s.re) : dedekindGammaFactor K s вү  0 := by
  simp only [dedekindGammaFactor]
  have hdisc : Complex.ofReal |(NumberField.discr K : в„қ)| ^ (s / 2) вү  0 := by
    rw [Complex.cpow_ne_zero_iff]
    refine Or.inl ?_
    simp only [ne_eq, Complex.ofReal_eq_zero, abs_eq_zero, Int.cast_eq_zero]
    exact NumberField.discr_ne_zero K
  have hpi1 : ((Real.pi : в„Ӯ) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
      NumberField.InfinitePlace.nrRealPlaces K вү  0 := by
    refine pow_ne_zero _ (mul_ne_zero ?_ ?_)
    В· rw [Complex.cpow_ne_zero_iff]
      exact Or.inl (by simp)
    В· refine Complex.Gamma_ne_zero_of_re_pos ?_
      rw [Complex.div_ofNat_re]
      linarith
  have hpi2 : ((2 : в„Ӯ) * ((2 * Real.pi : в„қ) : в„Ӯ) ^ (-s) * Complex.Gamma s) ^
      NumberField.InfinitePlace.nrComplexPlaces K вү  0 := by
    refine pow_ne_zero _ (mul_ne_zero (mul_ne_zero two_ne_zero ?_) ?_)
    В· rw [Complex.cpow_ne_zero_iff]
      refine Or.inl ?_
      simp only [ne_eq, Complex.ofReal_eq_zero]
      positivity
    В· exact Complex.Gamma_ne_zero_of_re_pos hs
  exact mul_ne_zero (mul_ne_zero hdisc hpi1) hpi2

open IsDedekindDomain in
/-- **The Dedekind zeta Dirichlet series as an exponential** (PROVEN
2026-07-24, helper for the de la VallГ©e Poussin leaf): on `re s > 1`,
`О¶_K(s) = exp(ОЈ_P вҲ’log(1 вҲ’ N P^{вҲ’s}))` вҖ” the trivial-character
specialization of the project's Chebotarev Euler product
`exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries`,
the same specialization already used by
`dedekindZeta_ne_zero_of_one_lt_re`.  Exhibiting `О¶_K` as an
exponential is what makes `log|О¶_K|` a prime sum in the 3-4-1
inequality `norm_dedekindZeta_product_ge_one` below. -/
theorem dedekindZeta_eq_exp_tsum (K : Type*) [Field K] [NumberField K]
    {s : в„Ӯ} (hs : 1 < s.re) :
    Complex.exp (вҲ‘' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
        -Complex.log (1 -
          (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s))) =
      NumberField.dedekindZeta K s := by
  have h := exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries
    K (1 : DirichletCharacter в„Ӯ 1) hs
  have hcoeff : (fun k : в„• => (1 : DirichletCharacter в„Ӯ 1) (k : ZMod 1) *
      (Nat.card {I : Ideal (NumberField.RingOfIntegers K) //
        Ideal.absNorm I = k} : в„Ӯ)) =
      fun n : в„• => (Nat.card {I : Ideal (NumberField.RingOfIntegers K) //
        Ideal.absNorm I = n} : в„Ӯ) := by
    funext k
    rw [MulChar.one_apply (isUnit_of_subsingleton _), one_mul]
  have hterm : вҲҖ P : HeightOneSpectrum (NumberField.RingOfIntegers K),
      -Complex.log (1 - (1 : DirichletCharacter в„Ӯ 1)
          ((Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„•) : ZMod 1) *
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s)) =
      -Complex.log (1 -
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s)) := by
    intro P
    rw [MulChar.one_apply (isUnit_of_subsingleton _), one_mul]
  rw [hcoeff] at h
  unfold NumberField.dedekindZeta
  rw [вҶҗ h]
  exact congrArg Complex.exp (tsum_congr fun P => (hterm P).symm)

/-- **Norm bound for the logarithmic Euler factors** (PROVEN
2026-07-24, helper for the summability of the prime log-sums): for
`n вүҘ 2` and `re s > 1`, `вҖ–вҲ’log(1 вҲ’ n^{вҲ’s})вҖ– вүӨ 3/2В·n^{вҲ’re s}` вҖ” the
factor `n^{вҲ’s}` has norm `вүӨ 2^{вҲ’re s} вүӨ 1/2`, so mathlib's
`Complex.norm_log_one_add_half_le_self` applies; the same estimate as
the Chebotarev log bounds, without the character. -/
theorem norm_neg_log_one_sub_natCast_cpow_le {n : в„•} (hn : 2 вүӨ n) {s : в„Ӯ}
    (hs : 1 < s.re) :
    вҖ–-Complex.log (1 - (n : в„Ӯ) ^ (-s))вҖ– вүӨ 3 / 2 * (n : в„қ) ^ (-s.re) := by
  have hnpos : 0 < n := by omega
  have hn2 : (2 : в„қ) вүӨ (n : в„қ) := by exact_mod_cast hn
  have hnorm : вҖ–(n : в„Ӯ) ^ (-s)вҖ– = (n : в„қ) ^ (-s.re) := by
    rw [Complex.norm_natCast_cpow_of_pos hnpos, Complex.neg_re]
  have hhalf : вҖ–(n : в„Ӯ) ^ (-s)вҖ– вүӨ 1 / 2 := by
    rw [hnorm]
    calc (n : в„қ) ^ (-s.re) вүӨ (2 : в„қ) ^ (-s.re) :=
          Real.rpow_le_rpow_of_nonpos two_pos hn2 (by linarith)
      _ вүӨ (2 : в„қ) ^ (-1 : в„қ) :=
          (Real.rpow_le_rpow_left_iff one_lt_two).mpr (by linarith)
      _ = 1 / 2 := by rw [Real.rpow_neg_one]; norm_num
  rw [norm_neg, sub_eq_add_neg]
  calc вҖ–Complex.log (1 + -((n : в„Ӯ) ^ (-s)))вҖ–
      вүӨ 3 / 2 * вҖ–-((n : в„Ӯ) ^ (-s))вҖ– :=
        Complex.norm_log_one_add_half_le_self (by rwa [norm_neg])
    _ = 3 / 2 * (n : в„қ) ^ (-s.re) := by rw [norm_neg, hnorm]

open IsDedekindDomain in
/-- **Summability of the prime log-sum of `О¶_K`** (PROVEN 2026-07-24):
the family `P вҶҰ вҲ’log(1 вҲ’ N P^{вҲ’s})` is summable for `re s > 1`, by the
`3/2В·N P^{вҲ’re s}` bound above against the place-sum summability leaf
`summable_rpow_neg_natCard_quotient` from the Chebotarev development.
Feeds the `Re`-and-`tsum` exchanges of the 3-4-1 inequality. -/
theorem summable_neg_log_one_sub_natCard_cpow (K : Type*) [Field K]
    [NumberField K] {s : в„Ӯ} (hs : 1 < s.re) :
    Summable (fun P : HeightOneSpectrum (NumberField.RingOfIntegers K) =>
      -Complex.log (1 -
        (Nat.card (NumberField.RingOfIntegers K в§ё P.asIdeal) : в„Ӯ) ^ (-s))) :=
  Summable.of_norm (Summable.of_nonneg_of_le (fun _ => norm_nonneg _)
    (fun P => norm_neg_log_one_sub_natCast_cpow_le (two_le_natCard_quotient P) hs)
    ((summable_rpow_neg_natCard_quotient hs).mul_left (3 / 2)))

/-- **Mertens' `3-4-1` positivity for a single Euler factor** (PROVEN
2026-07-24; the statement and proof are mathlib's private
`DirichletCharacter.re_log_comb_nonneg'` from
`Mathlib.NumberTheory.LSeries.Nonvanishing`, reproved here because
mathlib keeps it `private`): for `0 вүӨ a < 1` and `вҖ–zвҖ– = 1`,
`0 вүӨ 3В·Re(вҲ’log(1вҲ’a)) + 4В·Re(вҲ’log(1вҲ’az)) + Re(вҲ’log(1вҲ’azВІ))` вҖ” expand
each logarithm by its Taylor series (`hasSum_taylorSeries_neg_log`)
and observe `3 + 4В·Re(zвҒҝ) + Re(zВІвҒҝ) = 2(1 + Re zвҒҝ)ВІ + (вҖ–zвҒҝвҖ–ВІ вҲ’
(Re zвҒҝ)ВІ)В·вҖҰ вүҘ 0` termwise, the trigonometric inequality
`3 + 4cos Оё + cos 2Оё = 2(1 + cos Оё)ВІ вүҘ 0`. -/
theorem re_log_comb_nonneg_aux {a : в„қ} (haвӮҖ : 0 вүӨ a) (haвӮҒ : a < 1) {z : в„Ӯ}
    (hz : вҖ–zвҖ– = 1) :
    0 вүӨ 3 * (-Complex.log (1 - a)).re + 4 * (-Complex.log (1 - a * z)).re +
      (-Complex.log (1 - a * z ^ 2)).re := by
  have hacвӮҖ : вҖ–(a : в„Ӯ)вҖ– < 1 := by
    simp only [Complex.norm_of_nonneg haвӮҖ, haвӮҒ]
  have hacвӮҒ : вҖ–(a : в„Ӯ) * zвҖ– < 1 := by rwa [norm_mul, hz, mul_one]
  have hacвӮӮ : вҖ–(a : в„Ӯ) * z ^ 2вҖ– < 1 := by
    rwa [norm_mul, norm_pow, hz, one_pow, mul_one]
  rw [вҶҗ ((Complex.hasSum_re <|
      Complex.hasSum_taylorSeries_neg_log hacвӮҖ).mul_left 3).add
    ((Complex.hasSum_re <|
      Complex.hasSum_taylorSeries_neg_log hacвӮҒ).mul_left 4) |>.add
    (Complex.hasSum_re <|
      Complex.hasSum_taylorSeries_neg_log hacвӮӮ) |>.tsum_eq]
  refine tsum_nonneg fun n => ?_
  simp only [вҶҗ Complex.ofReal_pow, Complex.div_natCast_re, Complex.ofReal_re,
    mul_pow, Complex.mul_re, Complex.ofReal_im, zero_mul, sub_zero]
  rcases n.eq_zero_or_pos with rfl | hn
  В· simp
  В· simp only [вҶҗ mul_div_assoc, вҶҗ add_div]
    refine div_nonneg ?_ n.cast_nonneg
    rw [вҶҗ pow_mul, pow_mul', sq, Complex.mul_re, вҶҗ sq, вҶҗ sq,
      вҶҗ Complex.sq_norm_sub_sq_re, norm_pow, hz]
    convert! (show 0 вүӨ 2 * a ^ n * ((z ^ n).re + 1) ^ 2 by positivity) using 1
    ring

/-- **The `3-4-1` positivity at one prime power base** (PROVEN
2026-07-24; the analog of mathlib's private
`DirichletCharacter.re_log_comb_nonneg` at the trivial character): for
`n вүҘ 2`, `x > 0`, `t : в„қ`, the three Euler factors of `О¶_K` at
`1+x`, `1+x+it`, `1+x+2it` split as `a`, `az`, `azВІ` with
`a = n^{вҲ’(1+x)} вҲҲ [0,1)` and `z = n^{вҲ’it}` of norm one, so
`re_log_comb_nonneg_aux` applies. -/
theorem re_log_comb_nonneg_natCast {n : в„•} (hn : 2 вүӨ n) {x : в„қ} (hx : 0 < x)
    (t : в„қ) :
    0 вүӨ 3 * (-Complex.log (1 - (n : в„Ӯ) ^ (-(1 + x : в„Ӯ)))).re +
      4 * (-Complex.log (1 - (n : в„Ӯ) ^ (-(1 + x + t * Complex.I : в„Ӯ)))).re +
      (-Complex.log (1 - (n : в„Ӯ) ^ (-(1 + x + 2 * t * Complex.I : в„Ӯ)))).re := by
  have hn0 : (n : в„Ӯ) вү  0 := Nat.cast_ne_zero.mpr (by omega)
  have hnR : (1 : в„қ) < (n : в„қ) := by exact_mod_cast (by omega : 1 < n)
  have haвӮҖ : (0 : в„қ) вүӨ (n : в„қ) ^ (-(1 + x)) :=
    Real.rpow_nonneg (Nat.cast_nonneg n) _
  have haвӮҒ : (n : в„қ) ^ (-(1 + x)) < 1 :=
    Real.rpow_lt_one_of_one_lt_of_neg hnR (by linarith)
  have hz : вҖ–(n : в„Ӯ) ^ (-((t : в„Ӯ) * Complex.I))вҖ– = 1 := by
    rw [Complex.norm_natCast_cpow_of_pos (by omega)]
    simp
  have eвӮҖ : (n : в„Ӯ) ^ (-(1 + x : в„Ӯ)) = (((n : в„қ) ^ (-(1 + x)) : в„қ) : в„Ӯ) := by
    rw [Complex.ofReal_cpow (Nat.cast_nonneg n)]
    push_cast
    rfl
  have eвӮҒ : (n : в„Ӯ) ^ (-(1 + x + t * Complex.I : в„Ӯ)) =
      (((n : в„қ) ^ (-(1 + x)) : в„қ) : в„Ӯ) * (n : в„Ӯ) ^ (-((t : в„Ӯ) * Complex.I)) := by
    rw [show -(1 + x + t * Complex.I : в„Ӯ) =
        -(1 + x : в„Ӯ) + -((t : в„Ӯ) * Complex.I) by ring,
      Complex.cpow_add _ _ hn0, eвӮҖ]
  have eвӮӮ : (n : в„Ӯ) ^ (-(1 + x + 2 * t * Complex.I : в„Ӯ)) =
      (((n : в„қ) ^ (-(1 + x)) : в„қ) : в„Ӯ) *
        ((n : в„Ӯ) ^ (-((t : в„Ӯ) * Complex.I))) ^ 2 := by
    rw [show -(1 + x + 2 * t * Complex.I : в„Ӯ) =
        -(1 + x : в„Ӯ) + ((2 : в„•) : в„Ӯ) * -((t : в„Ӯ) * Complex.I) by push_cast; ring,
      Complex.cpow_add _ _ hn0, Complex.cpow_nat_mul, eвӮҖ]
  rw [eвӮҖ, eвӮҒ, eвӮӮ]
  exact re_log_comb_nonneg_aux haвӮҖ haвӮҒ hz

open IsDedekindDomain in
/-- **Mertens' `3-4-1` inequality for the Dedekind zeta function**
(PROVEN 2026-07-24; the transplant of mathlib's
`DirichletCharacter.norm_LSeries_product_ge_one` onto the Dedekind
Euler product): for `x > 0` and `t : в„қ`,
`1 вүӨ |О¶_K(1+x)Ві В· О¶_K(1+x+it)вҒҙ В· О¶_K(1+x+2it)|`.  Through
`dedekindZeta_eq_exp_tsum` the norm of the product is
`exp(ОЈ_P Re(3(вҲ’log вҖҰ) + 4(вҲ’log вҖҰ) + (вҲ’log вҖҰ)))`, and the per-place
summand is nonnegative by `re_log_comb_nonneg_natCast`.  This is the
inequality that forbids a zero of `О¶_K` on `re s = 1`: a zero at
`1 + it` would make the `4`-th power vanish to order `4` as `x вҶ’ 0вҒә`,
beating the order-`3` pole of `О¶_K(1+x)Ві`. -/
theorem norm_dedekindZeta_product_ge_one (K : Type*) [Field K] [NumberField K]
    {x : в„қ} (hx : 0 < x) (t : в„қ) :
    1 вүӨ вҖ–NumberField.dedekindZeta K (1 + x) ^ 3 *
      NumberField.dedekindZeta K (1 + x + t * Complex.I) ^ 4 *
      NumberField.dedekindZeta K (1 + x + 2 * t * Complex.I)вҖ– := by
  have hвӮҖ : 1 < (1 + x : в„Ӯ).re := by
    simp only [Complex.add_re, Complex.one_re, Complex.ofReal_re]
    linarith
  have hвӮҒ : 1 < (1 + x + t * Complex.I : в„Ӯ).re := by
    simp only [Complex.add_re, Complex.one_re, Complex.ofReal_re,
      Complex.mul_re, Complex.ofReal_im, Complex.I_re, Complex.I_im,
      mul_zero, mul_one, sub_zero, add_zero]
    linarith
  have hвӮӮ : 1 < (1 + x + 2 * t * Complex.I : в„Ӯ).re := by
    simp only [Complex.add_re, Complex.one_re, Complex.ofReal_re,
      Complex.mul_re, Complex.mul_im, Complex.ofReal_im, Complex.I_re,
      Complex.I_im, Complex.re_ofNat, Complex.im_ofNat, mul_zero, mul_one,
      zero_mul, sub_zero, add_zero]
    linarith
  have HвӮҖ := summable_neg_log_one_sub_natCard_cpow K hвӮҖ
  have HвӮҒ := summable_neg_log_one_sub_natCard_cpow K hвӮҒ
  have HвӮӮ := summable_neg_log_one_sub_natCard_cpow K hвӮӮ
  have hsumвӮҖ := (Complex.hasSum_re HвӮҖ.hasSum).summable.mul_left 3
  have hsumвӮҒ := (Complex.hasSum_re HвӮҒ.hasSum).summable.mul_left 4
  have hsumвӮӮ := (Complex.hasSum_re HвӮӮ.hasSum).summable
  rw [вҶҗ dedekindZeta_eq_exp_tsum K hвӮҖ, вҶҗ dedekindZeta_eq_exp_tsum K hвӮҒ,
    вҶҗ dedekindZeta_eq_exp_tsum K hвӮӮ, вҶҗ Complex.exp_nat_mul,
    вҶҗ Complex.exp_nat_mul, вҶҗ Complex.exp_add, вҶҗ Complex.exp_add,
    Complex.norm_exp, Real.one_le_exp_iff]
  simp only [Nat.cast_ofNat, Complex.add_re, Complex.mul_re, Complex.re_ofNat,
    Complex.im_ofNat, zero_mul, sub_zero]
  rw [Complex.re_tsum HвӮҖ, Complex.re_tsum HвӮҒ, Complex.re_tsum HвӮӮ,
    вҶҗ tsum_mul_left, вҶҗ tsum_mul_left, вҶҗ hsumвӮҖ.tsum_add hsumвӮҒ,
    вҶҗ (hsumвӮҖ.add hsumвӮҒ).tsum_add hsumвӮӮ]
  exact tsum_nonneg fun P =>
    re_log_comb_nonneg_natCast (two_le_natCard_quotient P) hx t

/-- **`Оҫ_K(1) вү  0`: the class-number-formula residue** (PROVEN
2026-07-24 вҖ” preliminary leaf (bвӮҖбөў) of the decomposition of
`DedekindContinuation.weil_explicit_formula_F`; Poitou p. 6-01
"PrГ©liminaires", the `t = 0` boundary case).  Proof:
`Оҫ(1) = lim_{ПғвҶ’1вҒә} Пғ(ПғвҲ’1)В·|d|^{Пғ/2}В·О“_в„қ(Пғ)^{rвӮҒ}В·О“_в„Ӯ(Пғ)^{rвӮӮ}В·О¶_K(Пғ)`
along real `Пғ вҶ“ 1`, by continuity of `xi` (from `differentiable`)
and `eq_of_one_lt_re`; the pin's Dirichlet class number formula
`NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT` with
`NumberField.dedekindZeta_residue_pos` makes
`(ПғвҲ’1)В·О¶_K(Пғ) вҶ’ residue вү  0` while the remaining factor
`ПғВ·G_K(Пғ)` tends to the nonzero `G_K(1)`
(`dedekindGammaFactor_continuousAt`/`_ne_zero`), so `Оҫ(1)` is a
product of nonzero numbers by uniqueness of limits.  Note `funcEq` at
`s = 1` gives `Оҫ(0) = Оҫ(1)`, so this leaf also rules out a zero at
`0`. -/
theorem DedekindContinuation.xi_one_ne_zero {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) :
    pkg.xi 1 вү  0 := by
  have hcoe : Filter.Tendsto (fun Пғ : в„қ => (Пғ : в„Ӯ))
      (nhdsWithin 1 (Set.Ioi 1)) (nhds (1 : в„Ӯ)) := by
    have h := Complex.continuous_ofReal.tendsto (1 : в„қ)
    rw [Complex.ofReal_one] at h
    exact h.mono_left nhdsWithin_le_nhds
  have hG : Filter.Tendsto (fun Пғ : в„қ => (Пғ : в„Ӯ) * dedekindGammaFactor K (Пғ : в„Ӯ))
      (nhdsWithin 1 (Set.Ioi 1)) (nhds (dedekindGammaFactor K 1)) := by
    have h := ((continuousAt_id.mul (dedekindGammaFactor_continuousAt K
      (by simp : (0 : в„қ) < (1 : в„Ӯ).re))).tendsto).comp hcoe
    simpa only [Function.comp_def, Pi.mul_apply, id_eq, one_mul] using h
  have hres := NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT K
  have hxi : Filter.Tendsto (fun Пғ : в„қ => pkg.xi (Пғ : в„Ӯ))
      (nhdsWithin 1 (Set.Ioi 1))
      (nhds (dedekindGammaFactor K 1 *
        (NumberField.dedekindZeta_residue K : в„Ӯ))) := by
    refine (hG.mul hres).congr' ?_
    filter_upwards [self_mem_nhdsWithin] with Пғ hПғ
    rw [pkg.xi_eq_dedekindGammaFactor
      (by rw [Complex.ofReal_re]; exact hПғ : 1 < ((Пғ : в„Ӯ)).re)]
    ring
  have hxc : Filter.Tendsto (fun Пғ : в„қ => pkg.xi (Пғ : в„Ӯ))
      (nhdsWithin 1 (Set.Ioi 1)) (nhds (pkg.xi 1)) := by
    have h := (pkg.differentiable 1).continuousAt.tendsto.comp hcoe
    simpa only [Function.comp_def] using h
  rw [tendsto_nhds_unique hxc hxi]
  exact mul_ne_zero (dedekindGammaFactor_ne_zero K (by simp))
    (by exact_mod_cast NumberField.dedekindZeta_residue_ne_zero K)

/-- **`Оҫ_K(1 + it) вү  0` for `t вү  0`: de la VallГ©e Poussin** (PROVEN
2026-07-24 вҖ” preliminary leaf (bвӮҖбөўбөў) of the decomposition of
`DedekindContinuation.weil_explicit_formula_F`; Poitou p. 6-01
"PrГ©liminaires", the `t вү  0` boundary case).  Proof: suppose
`Оҫ(1+it) = 0` and let `x вҶ“ 0`.  The Mertens `3-4-1` inequality
`norm_dedekindZeta_product_ge_one` (the transplant of mathlib's
`riemannZeta_ne_zero_of_one_le_re` skeleton from
`Mathlib.NumberTheory.LSeries.Nonvanishing` onto the Dedekind Euler
product of the Chebotarev development) gives
`1 вүӨ |О¶_K(1+x)|ВіВ·|О¶_K(1+x+it)|вҒҙВ·|О¶_K(1+x+2it)|`.  Rewrite the right
side as `|xВ·О¶_K(1+x)|Ві В· |О¶_K(1+x+it)/x|вҒҙ В· |О¶_K(1+x+2it)| В· x`:
through `Оҫ = s(sвҲ’1)В·G_KВ·О¶_K` with the elementary factor continuous
and nonzero near the boundary points (`dedekindGammaFactor_*`), the
first factor tends to the class-number-formula residue cubed
(`NumberField.tendsto_sub_one_mul_dedekindZeta_nhdsGT`), the second
to `|Оҫ'(1+it)/E(1+it)|вҒҙ` by the slope characterization of the
derivative at the putative zero (`hasDerivAt_iff_tendsto_slope`), the
third to a finite value, and the trailing `x` to `0` вҖ” so the whole
product tends to `0`, contradicting `вүҘ 1`: a zero of order `вүҘ 1` at
`1 + it` makes the `4`-th power vanish to order `4`, beating the
order-`3` pole of `О¶_K(Пғ)Ві`. -/
theorem DedekindContinuation.xi_ne_zero_of_re_eq_one_of_im_ne_zero {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K)
    (t : в„қ) (ht : t вү  0) :
    pkg.xi (1 + t * Complex.I) вү  0 := by
  intro hzero
  -- continuity and nonvanishing of the full elementary factor
  have hE_cont : вҲҖ w : в„Ӯ, 0 < w.re вҶ’
      ContinuousAt (fun z : в„Ӯ => z * (z - 1) * dedekindGammaFactor K z) w :=
    fun w hw => (continuousAt_id.mul (continuousAt_id.sub continuousAt_const)).mul
      (dedekindGammaFactor_continuousAt K hw)
  have hE_ne : вҲҖ w : в„Ӯ, 0 < w.re вҶ’ w вү  0 вҶ’ w вү  1 вҶ’
      w * (w - 1) * dedekindGammaFactor K w вү  0 := fun w hw h0 h1 =>
    mul_ne_zero (mul_ne_zero h0 (sub_ne_zero.mpr h1))
      (dedekindGammaFactor_ne_zero K hw)
  -- real parts along the two shifted vertical lines
  have hreвӮҒ : вҲҖ x : в„қ, (1 + (x : в„Ӯ) + t * Complex.I).re = 1 + x := by
    intro x
    simp [Complex.add_re, Complex.mul_re]
  have hreвӮӮ : вҲҖ x : в„қ, (1 + (x : в„Ӯ) + 2 * t * Complex.I).re = 1 + x := by
    intro x
    simp [Complex.add_re, Complex.mul_re, Complex.mul_im]
  -- the two boundary points avoid `0` and `1`
  have hzвӮҒre : (0 : в„қ) < (1 + (t : в„Ӯ) * Complex.I).re := by
    norm_num [Complex.add_re, Complex.mul_re]
  have hzвӮӮre : (0 : в„қ) < (1 + 2 * (t : в„Ӯ) * Complex.I).re := by
    norm_num [Complex.add_re, Complex.mul_re, Complex.mul_im]
  have hzвӮҒ0 : (1 + (t : в„Ӯ) * Complex.I) вү  0 := by
    intro h
    have h0 := congrArg Complex.re h
    norm_num [Complex.add_re, Complex.mul_re] at h0
  have hzвӮҒ1 : (1 + (t : в„Ӯ) * Complex.I) вү  1 := by
    intro h
    have h1 := congrArg Complex.im h
    norm_num [Complex.add_im, Complex.mul_im] at h1
    exact ht h1
  have hzвӮӮ0 : (1 + 2 * (t : в„Ӯ) * Complex.I) вү  0 := by
    intro h
    have h0 := congrArg Complex.re h
    norm_num [Complex.add_re, Complex.mul_re, Complex.mul_im] at h0
  have hzвӮӮ1 : (1 + 2 * (t : в„Ӯ) * Complex.I) вү  1 := by
    intro h
    have h1 := congrArg Complex.im h
    norm_num [Complex.add_im, Complex.mul_im, Complex.mul_re] at h1
    exact ht h1
  -- filter maps as `x вҶ“ 0`
  have hcoe0 : Filter.Tendsto (fun x : в„қ => (x : в„Ӯ))
      (nhdsWithin 0 (Set.Ioi 0)) (nhds (0 : в„Ӯ)) := by
    have h := Complex.continuous_ofReal.tendsto (0 : в„қ)
    rw [Complex.ofReal_zero] at h
    exact h.mono_left nhdsWithin_le_nhds
  have hmвӮҒ : Filter.Tendsto (fun x : в„қ => 1 + (x : в„Ӯ) + t * Complex.I)
