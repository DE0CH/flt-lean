    intro g hg
    rw [map_mul, map_mul, hg, mul_one, map_inv, inv_mul_cancel]
  -- the second eigenvector `w = u ПғвӮҖ В·бөҘ v` and its eigen-equation on `H`
  set w : Fin 2 вҶ’ Dickson.K 3 :=
    Matrix.mulVec ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) v with hwdef
  have hgw : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’
      Matrix.mulVec ((u g : GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) w =
        ПҮвӮҖ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) вҖў w := by
    intro g hg
    have hcomm : u g * u ПғвӮҖ = u ПғвӮҖ * u (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) := by
      rw [вҶҗ map_mul, вҶҗ map_mul]
      congr 1
      group
    have hmat : ((u g : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) *
        ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
        ((u ПғвӮҖ : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) *
        ((u (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) := by
      rw [вҶҗ Units.val_mul, вҶҗ Units.val_mul, hcomm]
    rw [hwdef, Matrix.mulVec_mulVec, hmat, вҶҗ Matrix.mulVec_mulVec,
      hПҮвӮҖ _ (hHconj g hg), Matrix.mulVec_smul]
  -- entrywise eigen-equations
  have hAv : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ вҲҖ i : Fin 2,
      ((u g : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) i 0 * v 0 +
        ((u g : GL (Fin 2) (Dickson.K 3)) :
          Matrix (Fin 2) (Fin 2) (Dickson.K 3)) i 1 * v 1 = ПҮвӮҖ g * v i := by
    intro g hg i
