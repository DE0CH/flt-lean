    (continuous_const.sub (continuous_abs.div_const 6)).mul
      (Real.continuous_cos.comp (continuous_const.mul continuous_id))
  have hsplit : (вҲ« y in (-6 : в„қ)..6, (1 - |y| / 6) * Real.cos (t * y)) =
