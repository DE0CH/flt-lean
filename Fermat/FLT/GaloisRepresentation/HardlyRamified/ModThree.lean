    (Or.inr (Or.inr (Or.inr (Or.inr hcase))))

/-- **The Serre ¬ß5.4/Tate elimination, arithmetic cases** (DECOMPOSED
2026-07-22 into the six per-case sorry nodes above ‚ÄĒ `dihedral`,
`alt4`, `sym4`, `alt5`, `psl`, `pgl`): with the notation of
`serre_elimination` below, the dihedral, `A‚āĄ`, `S‚āĄ`, `A‚āÖ`,
`PSL‚āā(ūĚĒĹ_{3^m})`, `PGL‚āā(ūĚĒĹ_{3^m})` cases contradict the hardly-ramified
ramification constraints (cyclotomic determinant, unramified outside
`{2, 3}`, flat at `3`, tame quadratic quotient at `2`) via Serre's
discriminant/conductor bounds over `‚Ąö` (Serre, Duke 1987, ¬ß5.4: no
extension of `‚Ąö` with these Galois groups and local conditions
exists). -/
theorem serre_elimination_arith {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (habs : Slop.OddRep.IsAbsolutelyIrreducible
      (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V))
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (ŌÄ : őď ‚Ąö ‚Üí* Dickson.PGL 3)
    (hŌÄ : ‚ąÄ g, ŌÄ g = QuotientGroup.mk (u g))
    (hcase :
      (‚ąÉ n : ‚Ąē, n ‚Č• 2 ‚ąß Nonempty (ŌÄ.range ‚ČÉ* DihedralGroup n)) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* alternatingGroup (Fin 4))) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* Equiv.Perm (Fin 4))) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* alternatingGroup (Fin 5))) ‚ą®
      (‚ąÉ m : ‚Ąē, m ‚Č• 1 ‚ąß Nonempty (ŌÄ.range ‚ČÉ*
        Matrix.ProjectiveSpecialLinearGroup (Fin 2) (GaloisField 3 m))) ‚ą®
      (‚ąÉ m : ‚Ąē, m ‚Č• 1 ‚ąß Nonempty (ŌÄ.range ‚ČÉ*
        (GL (Fin 2) (GaloisField 3 m) ‚ßł
          Subgroup.center (GL (Fin 2) (GaloisField 3 m)))))) :
    False := by
  rcases hcase with h | h | h | h | h | h
  ¬∑ exact serre_elimination_dihedral V hV hŌĀ habs b e u hu ŌÄ hŌÄ h
  ¬∑ exact serre_elimination_alt4 V hV hŌĀ habs b e u hu ŌÄ hŌÄ h
  ¬∑ exact serre_elimination_sym4 V hV hŌĀ habs b e u hu ŌÄ hŌÄ h
  ¬∑ exact serre_elimination_alt5 V hV hŌĀ habs b e u hu ŌÄ hŌÄ h
  ¬∑ exact serre_elimination_psl V hV hŌĀ habs b e u hu ŌÄ hŌÄ h
  ¬∑ exact serre_elimination_pgl V hV hŌĀ habs b e u hu ŌÄ hŌÄ h

