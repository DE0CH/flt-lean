    {E : Type*} [NormedAddCommGroup E] [InnerProductSpace ‚ĄĚ E]
    [FiniteDimensional ‚ĄĚ E] [MeasurableSpace E] [BorelSpace E]
    (L : Submodule ‚Ą§ E) [DiscreteTopology L] [IsZLattice ‚ĄĚ L]
    (t : ‚ĄĚ) (ht : 0 < t) :
    ‚ąĎ' v : L, Real.exp (-Real.pi * t‚ĀĽ¬Ļ * ‚ÄĖ(v : E)‚ÄĖ ^ 2) =
      (ZLattice.covolume L)‚ĀĽ¬Ļ * t ^ ((Module.finrank ‚ĄĚ E : ‚ĄĚ) / 2) *
        ‚ąĎ' w : LinearMap.BilinForm.dualSubmodule (inner‚āó E) L,
