theorem heckeFEPair_exists (K : Type*) [Field K] [NumberField K]
    (hОё : вҲҖ (E : Type) [NormedAddCommGroup E] [InnerProductSpace в„қ E]
      [FiniteDimensional в„қ E] [MeasurableSpace E] [BorelSpace E]
      (L : Submodule в„Ө E) [DiscreteTopology L] [IsZLattice в„қ L]
      (t : в„қ), 0 < t вҶ’
      вҲ‘' v : L, Real.exp (-Real.pi * tвҒ»В№ * вҖ–(v : E)вҖ– ^ 2) =
        (ZLattice.covolume L)вҒ»В№ * t ^ ((Module.finrank в„қ E : в„қ) / 2) *
          вҲ‘' w : LinearMap.BilinForm.dualSubmodule (innerвӮ— E) L,
            Real.exp (-Real.pi * t * вҖ–(w : E)вҖ– ^ 2)) :
    вҲғ (P : ClassGroup (NumberField.RingOfIntegers K) вҶ’ WeakFEPair в„Ӯ) (ПҒ : в„Ӯ),
      (вҲҖ C, (P C).k = 1 / 2) вҲ§
      (вҲҖ C, (P C).Оө = 1) вҲ§
      (вҲҖ C, (P C).fвӮҖ = ПҒ) вҲ§
      (вҲҖ C, (P C).gвӮҖ = ПҒ) вҲ§
