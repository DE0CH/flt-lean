      Subgroup.center (GL (Fin 2) (Dickson.K 3)) := by
    intro hc
    apply hŌąne
    apply Subtype.ext
    show QuotientGroup.mk' (Subgroup.center (GL (Fin 2) (Dickson.K 3)))
      (s : GL (Fin 2) (Dickson.K 3)) = 1
