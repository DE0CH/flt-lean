        rw [hОҪ1] at hanti'
        exact inv_eq_one.mp hanti'.symm
      have h := hОҪHconj (ПғвӮҖ * gПғ * ПғвӮҖвҒ»В№) (c * ПғвӮҖвҒ»В№)вҒ»В№ hj (hHinv _ hh)
      rw [inv_inv, show c * ПғвӮҖвҒ»В№ * (ПғвӮҖ * gПғ * ПғвӮҖвҒ»В№) * (c * ПғвӮҖвҒ»В№)вҒ»В№ =
        c * gПғ * cвҒ»В№ by group] at h
      rw [h]
      exact hОҪ2
  -- (3) a UNIFORM exponent for `ОҪ` on `H`, prime to `3`: push `ПҒ`
  -- into the finite unit group of `End k V` (`pow_card_eq_one'`) and
  -- strip the `3`-part against the pointwise prime-to-`3` orders
  haveI hfinV : Finite V := Module.finite_of_finite k
  haveI : Finite (Module.End k V) :=
    Finite.of_injective (fun f => (f : V вҶ’ V)) DFunLike.coe_injective
  haveI : Finite (Module.End k V)ЛЈ :=
    Finite.of_injective (fun u => (u : Module.End k V))
      (fun _ _ h => Units.ext h)
  set cвӮҖ : в„• := Nat.card (Module.End k V)ЛЈ
  have hcвӮҖ0 : cвӮҖ вү  0 := Nat.card_pos.ne'
  have hПҒpow : вҲҖ g : О“ в„ҡ, ПҒ (g ^ cвӮҖ) = 1 := by
    intro g
    have h1 : (MonoidHomClass.toMonoidHom ПҒ).toHomUnits (g ^ cвӮҖ) = 1 := by
      rw [map_pow]
      exact pow_card_eq_one'
    have h2 := congrArg Units.val h1
    simpa using h2
  have hexpc : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g ^ cвӮҖ = 1 := by
    intro g hg
    rw [вҶҗ hОҪpow g hg cвӮҖ]
    exact hОҪker _ (hПҒpow g)
  have hNexp : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g ^ (ordCompl[3] cвӮҖ) = 1 := by
    intro g hg
    obtain вҹЁn, _hn0, hn3, hgnвҹ© := hОҪord g hg
