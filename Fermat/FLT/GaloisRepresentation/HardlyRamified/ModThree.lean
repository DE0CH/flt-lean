      have hpi : (3.14 : ‚ĄĚ) < Real.pi := Real.pi_gt_d2
      linarith
    linarith [hexp]
  -- the logarithmic form of the goal
  have key : (n : ‚ĄĚ) * Real.log (33 / 4) ‚Č§
      Real.log |(NumberField.discr K : ‚ĄĚ)| := by
    have hn48 : (48 : ‚ĄĚ) ‚Č§ (n : ‚ĄĚ) := by exact_mod_cast hdeg
    have hn0 : (0 : ‚ĄĚ) ‚Č§ (n : ‚ĄĚ) := by linarith
    have hJ' : (0 : ‚ĄĚ) ‚Č§ (n : ‚ĄĚ) *
