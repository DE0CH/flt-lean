      В· rw [Set.indicator_of_mem (Set.mem_Ioc.mpr вҹЁhx6, le_of_abs_le hxвҹ©),
          odlyzkoTestFn, max_eq_left (by linarith)]
    В· rw [Set.indicator_of_notMem (by
        simp only [Set.mem_Ioc, not_and_or, not_lt, not_le]
        rcases lt_abs.mp hx with h | h
        В· exact Or.inr h
        В· exact Or.inl (by linarith)),
        odlyzkoTestFn, max_eq_right (by linarith)]
      exact zero_mul _
