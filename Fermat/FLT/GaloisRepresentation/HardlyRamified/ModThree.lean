    have hx0 : (Submodule.span k {x}).mkQ x = 0 := by
      rw [Submodule.mkQ_apply, Submodule.Quotient.mk_eq_zero]
      exact Submodule.mem_span_singleton_self x
    have hL : ŌĀ g (a ‚ÄĘ x + bb ‚ÄĘ w‚āÄ) =
        a ‚ÄĘ ((Ōá g : k) ‚ÄĘ x) + bb ‚ÄĘ ((Ōą g : k) ‚ÄĘ w‚āÄ) := by
      rw [map_add, map_smul, map_smul, hgen g, hŌą g w‚āÄ hw‚āÄ]
    rw [hL]
    simp only [map_add, map_smul, hx0, smul_zero, zero_add]
    rw [smul_comm]

/-- **The stable line with unramified-at-`3` quotient character**
(DECOMPOSED 2026-07-22 into the two sorry nodes above ‚ÄĒ the Raynaud
dichotomy `subCharacter_unramified_at_three_of_quot_ramified` and the
Serre swap `exists_line_with_quotCharacter_eq_subCharacter`): a
reducible mod-3 hardly ramified representation has a stable LINE whose
quotient character is unramified at `3`. Assembly: the given stable
submodule is a line with sub-character `Ōą` and quotient character `Ōá`;
either `Ōá` is already unramified at `3` (take `W‚āÄ`), or the Raynaud
dichotomy makes `Ōą` unramified at `3` and the Serre swap provides a
second stable line whose quotient character is `Ōą`. -/
theorem exists_line_with_unramified_quotCharacter_at_three
    {k : Type u} [Finite k] [Field k] [Algebra ‚Ą§_[3] k]
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (W‚āÄ : Submodule k V) (hW‚āÄ0 : W‚āÄ ‚Č† ‚ä•) (hW‚āÄtop : W‚āÄ ‚Č† ‚ä§)
    (hW‚āÄstable : ‚ąÄ g : őď ‚Ąö, W‚āÄ.map (ŌĀ g) ‚Č§ W‚āÄ) :
    ‚ąÉ (W : Submodule k V) (Ōá‚āā : őď ‚Ąö ‚Üí* kň£),
      Module.finrank k W = 1 ‚ąß
      (‚ąÄ g v, v ‚ąą W ‚Üí ŌĀ g v ‚ąą W) ‚ąß
      (‚ąÄ g v, W.mkQ (ŌĀ g v) = (Ōá‚āā g : k) ‚ÄĘ W.mkQ v) ‚ąß
      (localInertiaGroup
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat ‚Č§
        (Ōá‚āā.comp (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom).ker) := by
  classical
  -- the given stable submodule is a line with a line quotient
  have hfr : Module.finrank k V = 2 :=
    Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
  have hstable : ‚ąÄ g v, v ‚ąą W‚āÄ ‚Üí ŌĀ g v ‚ąą W‚āÄ := fun g v hv =>
    hW‚āÄstable g ‚ü®v, hv, rfl‚ü©
  have hW‚āÄfr : Module.finrank k W‚āÄ = 1 := by
    have hle : Module.finrank k W‚āÄ ‚Č§ 2 := hfr ‚Ėł Submodule.finrank_le W‚āÄ
    have h0 : Module.finrank k W‚āÄ ‚Č† 0 := fun h0 =>
      hW‚āÄ0 (Submodule.finrank_eq_zero.mp h0)
    have h2 : Module.finrank k W‚āÄ ‚Č† 2 := fun h2 =>
      hW‚āÄtop (Submodule.eq_top_of_finrank_eq (h2.trans hfr.symm))
    omega
  have hQ1 : Module.finrank k (V ‚ßł W‚āÄ) = 1 := by
    have hsum := Submodule.finrank_quotient_add_finrank W‚āÄ
    omega
  obtain ‚ü®Ōá, hŌá‚ü© := exists_quotCharacter ŌĀ W‚āÄ hQ1 hstable
  by_cases h3 : localInertiaGroup
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat ‚Č§
    (Ōá.comp (Field.absoluteGaloisGroup.map (algebraMap ‚Ąö
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat))).toMonoidHom).ker
  ¬∑ -- the quotient character of `W‚āÄ` is already unramified at `3`
    exact ‚ü®W‚āÄ, Ōá, hW‚āÄfr, hstable, hŌá, h3‚ü©
  ¬∑ -- the Serre swap: the second line, whose quotient character is the
    -- sub-character of `W‚āÄ`, unramified at `3` by the Raynaud dichotomy
    obtain ‚ü®Ōą, hŌą‚ü© := exists_subCharacter ŌĀ W‚āÄ hW‚āÄfr hstable
    obtain ‚ü®W‚āĀ, hW‚āĀfr, hW‚āĀstable, hW‚āĀŌá‚ü© :=
      exists_line_with_quotCharacter_eq_subCharacter V hV hŌĀ W‚āÄ hW‚āÄfr
        hstable Ōą hŌą Ōá hŌá h3
    exact ‚ü®W‚āĀ, Ōą, hW‚āĀfr, hW‚āĀstable, hW‚āĀŌá,
      subCharacter_unramified_at_three_of_quot_ramified V hV hŌĀ W‚āÄ hW‚āÄfr
        hstable Ōą hŌą Ōá hŌá h3‚ü©


