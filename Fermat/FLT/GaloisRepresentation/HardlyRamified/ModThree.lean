theorem completedDedekindZeta_exists (K : Type*) [Field K] [NumberField K] :
    ‚ąÉ xi : ‚Ąā ‚Üí ‚Ąā, Differentiable ‚Ąā xi ‚ąß
      (‚ąÄ s : ‚Ąā, 1 < s.re ‚Üí
        xi s = s * (s - 1) * Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ (s / 2) *
          ((Real.pi : ‚Ąā) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
            NumberField.InfinitePlace.nrRealPlaces K *
          ((2 : ‚Ąā) * ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ (-s) * Complex.Gamma s) ^
            NumberField.InfinitePlace.nrComplexPlaces K *
          NumberField.dedekindZeta K s) ‚ąß
      (‚ąÄ s : ‚Ąā, xi (1 - s) = xi s) ‚ąß
      ‚ąÉ C : ‚ĄĚ, 0 < C ‚ąß ‚ąÄ s : ‚Ąā, 2 ‚Č§ ‚ÄĖs‚ÄĖ ‚Üí
        ‚ÄĖxi s‚ÄĖ ‚Č§ Real.exp (C * ‚ÄĖs‚ÄĖ * Real.log ‚ÄĖs‚ÄĖ) := by
  obtain ‚ü®Z, hdiff, hformula, hfe, hgrowth‚ü© := completedClassZeta_exists K
  refine ‚ü®fun s => ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), Z C s,
    ?_, ?_, ?_, ?_‚ü©
  ¬∑ exact Differentiable.fun_sum fun C _ => hdiff C
  ¬∑ intro s hs
    have hsummable : ‚ąÄ C ‚ąą (Finset.univ : Finset (ClassGroup (NumberField.RingOfIntegers K))),
        LSeriesSummable (fun n => (classIdealCount K C n : ‚Ąā)) s :=
      fun C _ => (hformula C s hs).1
    have hpart : ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K),
        LSeries (fun n => (classIdealCount K C n : ‚Ąā)) s =
        NumberField.dedekindZeta K s := by
      rw [‚Üź LSeries_sum hsummable]
      unfold NumberField.dedekindZeta
      refine LSeries_congr (fun {n} hn => ?_) s
      simp only [Finset.sum_apply]
      rw [‚Üź Nat.cast_sum, sum_classIdealCount K n hn]
    calc ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), Z C s
        = ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K),
            s * (s - 1) * Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ (s / 2) *
              ((Real.pi : ‚Ąā) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
                NumberField.InfinitePlace.nrRealPlaces K *
              ((2 : ‚Ąā) * ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ (-s) * Complex.Gamma s) ^
                NumberField.InfinitePlace.nrComplexPlaces K *
              LSeries (fun n => (classIdealCount K C n : ‚Ąā)) s :=
          Finset.sum_congr rfl fun C _ => (hformula C s hs).2
      _ = s * (s - 1) * Complex.ofReal |(NumberField.discr K : ‚ĄĚ)| ^ (s / 2) *
            ((Real.pi : ‚Ąā) ^ (-s / 2) * Complex.Gamma (s / 2)) ^
              NumberField.InfinitePlace.nrRealPlaces K *
            ((2 : ‚Ąā) * ((2 * Real.pi : ‚ĄĚ) : ‚Ąā) ^ (-s) * Complex.Gamma s) ^
              NumberField.InfinitePlace.nrComplexPlaces K *
            NumberField.dedekindZeta K s := by
          rw [‚Üź Finset.mul_sum, hpart]
  ¬∑ intro s
    calc ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), Z C (1 - s)
        = ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), Z (dedekindDualClass K C) s :=
          Finset.sum_congr rfl fun C _ => hfe C s
      _ = ‚ąĎ C : ClassGroup (NumberField.RingOfIntegers K), Z C s :=
          Fintype.sum_bijective (dedekindDualClass K)
            (dedekindDualClass_involutive K).bijective _ _ fun C => rfl
  ¬∑ choose B hBpos hB using hgrowth
    have hM1 : (0:‚ĄĚ) < B 1 := hBpos 1
    set M := Finset.univ.sup' Finset.univ_nonempty B
    have hMle : B 1 ‚Č§ M := Finset.le_sup' B (Finset.mem_univ 1)
    have hMpos : 0 < M := lt_of_lt_of_le hM1 hMle
    set h := (Fintype.card (ClassGroup (NumberField.RingOfIntegers K)) : ‚ĄĚ) with hhdef
    have hh1 : (1:‚ĄĚ) ‚Č§ h := by
      rw [hhdef]
      exact_mod_cast Fintype.card_pos
    have hlogh : 0 ‚Č§ Real.log h := Real.log_nonneg hh1
    refine ‚ü®M + Real.log h + 1, by linarith, ?_‚ü©
    intro s hs
