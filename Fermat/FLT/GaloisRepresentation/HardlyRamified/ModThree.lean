    rw [show (starRingEnd ‚Ąā) z / 2 = (starRingEnd ‚Ąā) (z / 2) by
          rw [map_div‚āÄ, map_ofNat],
        show -(starRingEnd ‚Ąā) z / 2 = (starRingEnd ‚Ąā) (-z / 2) by
          rw [map_div‚āÄ, map_ofNat, map_neg],
        show -(starRingEnd ‚Ąā) z = (starRingEnd ‚Ąā) (-z) from (map_neg _ z).symm]
