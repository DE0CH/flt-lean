/-- **Complex conjugation and the 3-adic cyclotomic character** (DERIVED
2026-07-18 ‚ÄĒ the oddness input): the absolute Galois group of `‚Ąö`
contains an involution on which the 3-adic cyclotomic character takes
the value `-1`. Construction: `‚ĄĚŠĶÉň°ŠĶć ‚ČÉ‚āź[‚ĄĚ] ‚Ąā`, so `őď ‚ĄĚ` has exactly two
elements (Galois, degree `2`); the image `c` of the nontrivial one
under `őď ‚ĄĚ ‚Üí őď ‚Ąö` is an involution, so `Ōá‚āÉ(c)¬≤ = 1`, i.e. `Ōá‚āÉ(c) = ¬Ī1`
in the domain `‚Ą§_[3]`; and `Ōá‚āÉ(c) = 1` would force `c` to fix a
primitive cube root of unity `ő∂`, hence the nontrivial element of `őď ‚ĄĚ`
to fix `őĻ ő∂ ‚ąČ ‚ĄĚ` ‚ÄĒ but `‚ĄĚ(őĻ ő∂) = ‚ĄĚŠĶÉň°ŠĶć` in degree `2`, so that element
would be the identity. -/
theorem exists_conj_cyclotomicCharacter_three :
    ‚ąÉ c : őď ‚Ąö, c * c = 1 ‚ąß
      ((cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 c.toRingEquiv :
        ‚Ą§_[3]ň£) : ‚Ą§_[3]) = -1 := by
  haveI h3 : Fact (Nat.Prime 3) := ‚ü®Nat.prime_three‚ü©
  classical
  -- `‚ĄĚŠĶÉň°ŠĶć ‚ČÉ‚āź[‚ĄĚ] ‚Ąā`, hence `őď ‚ĄĚ` has exactly two elements
  haveI : IsAlgClosed ‚Ąā := Complex.isAlgClosed
  haveI : IsAlgClosure ‚ĄĚ ‚Ąā := ‚ü®inferInstance, Algebra.IsAlgebraic.of_finite ‚ĄĚ ‚Ąā‚ü©
  let e : AlgebraicClosure ‚ĄĚ ‚ČÉ‚āź[‚ĄĚ] ‚Ąā :=
    IsAlgClosure.equiv ‚ĄĚ (AlgebraicClosure ‚ĄĚ) ‚Ąā
  haveI : FiniteDimensional ‚ĄĚ (AlgebraicClosure ‚ĄĚ) :=
    Module.Finite.equiv e.symm.toLinearEquiv
  have hfr : Module.finrank ‚ĄĚ (AlgebraicClosure ‚ĄĚ) = 2 := by
    rw [e.toLinearEquiv.finrank_eq]
    exact Complex.finrank_real_complex
  haveI : IsGalois ‚ĄĚ (AlgebraicClosure ‚ĄĚ) := ‚ü®‚ü©
  have hcard : Nat.card (őď ‚ĄĚ) = 2 :=
    (IsGalois.card_aut_eq_finrank ‚ĄĚ (AlgebraicClosure ‚ĄĚ)).trans hfr
  -- the nontrivial element of `őď ‚ĄĚ`
  haveI : Finite (őď ‚ĄĚ) := Nat.finite_of_card_ne_zero (by omega)
  haveI : Nontrivial (őď ‚ĄĚ) := Finite.one_lt_card_iff_nontrivial.mp (by omega)
  obtain ‚ü®ŌÉ, hŌÉ‚ü© := exists_ne (1 : őď ‚ĄĚ)
  have hŌÉ2 : ŌÉ * ŌÉ = 1 := by
    have h : ŌÉ ^ Nat.card (őď ‚ĄĚ) = 1 := pow_card_eq_one'
    rwa [hcard, pow_two] at h
  -- its image in `őď ‚Ąö` is the sought involution
  refine ‚ü®absoluteGaloisGroup.map (algebraMap ‚Ąö ‚ĄĚ) ŌÉ, ?_, ?_‚ü©
  ¬∑ rw [‚Üź map_mul, hŌÉ2, map_one]
  ¬∑ set c : őď ‚Ąö := absoluteGaloisGroup.map (algebraMap ‚Ąö ‚ĄĚ) ŌÉ
    set x : ‚Ą§_[3] :=
      ((cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 c.toRingEquiv :
        ‚Ą§_[3]ň£) : ‚Ą§_[3])
    -- `x¬≤ = 1`, so `x = ¬Ī1` in the domain `‚Ą§_[3]`
    have hsq : x * x = 1 := by
      have hmul : (c * c).toRingEquiv = c.toRingEquiv * c.toRingEquiv := rfl
      have hone : ((1 : őď ‚Ąö).toRingEquiv) = 1 := rfl
      have h := congrArg (fun g => ((cyclotomicCharacter
        (AlgebraicClosure ‚Ąö) 3 g : ‚Ą§_[3]ň£) : ‚Ą§_[3]))
        (hmul.symm.trans (by rw [‚Üź map_mul, hŌÉ2, map_one, hone] : _ = _))
      simpa [map_mul] using h
    rcases mul_self_eq_one_iff.mp hsq with hx1 | hxm1
    swap
    ¬∑ exact hxm1
    -- rule out `x = 1`: `c` would fix a primitive cube root of unity
    exfalso
    obtain ‚ü®ő∂, hő∂‚ü© := HasEnoughRootsOfUnity.exists_primitiveRoot
      (AlgebraicClosure ‚Ąö) 3
    -- `c ő∂ = ő∂ ^ (x mod 3) = ő∂`
    have hfix : c.toRingEquiv ő∂ = ő∂ := by
      have hspec := cyclotomicCharacter.spec 3 (n := 1) c.toRingEquiv ő∂
        (by rw [pow_one]; exact hő∂.pow_eq_one)
      rw [hspec, show (cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3
        c.toRingEquiv).val = x from rfl, hx1, map_one]
      rw [show ((1 : ZMod (3 ^ 1)).val) = 1 from rfl, pow_one]
    -- transport along the embedding `őĻ : ‚ĄöŠĶÉň°ŠĶć ‚Üí ‚ĄĚŠĶÉň°ŠĶć`
    have hŌÉz : ŌÉ (AlgebraicClosure.map (algebraMap ‚Ąö ‚ĄĚ) ő∂) =
        AlgebraicClosure.map (algebraMap ‚Ąö ‚ĄĚ) ő∂ := by
      rw [‚Üź absoluteGaloisGroup.lift_map (algebraMap ‚Ąö ‚ĄĚ) ŌÉ ő∂]
      exact congrArg _ hfix
    set z : AlgebraicClosure ‚ĄĚ := AlgebraicClosure.map (algebraMap ‚Ąö ‚ĄĚ) ő∂
    -- `z` is a primitive cube root of unity, hence not real
    have hzprim : IsPrimitiveRoot z 3 :=
      hő∂.map_of_injective (AlgebraicClosure.map (algebraMap ‚Ąö ‚ĄĚ)).injective
    have hznotbot : z ‚ąČ (‚ä• : IntermediateField ‚ĄĚ (AlgebraicClosure ‚ĄĚ)) := by
      intro hmem
      obtain ‚ü®r, hr‚ü© := IntermediateField.mem_bot.mp hmem
      -- `r¬≥ = 1` in `‚ĄĚ` forces `r = 1`, forcing `z = 1`
      have hr3 : r ^ 3 = 1 := by
        have h := hzprim.pow_eq_one
        rw [‚Üź hr] at h
        exact (algebraMap ‚ĄĚ (AlgebraicClosure ‚ĄĚ)).injective
          (by rw [map_pow, map_one]; exact h)
      have hr1 : r = 1 := by nlinarith [sq_nonneg (r - 1), sq_nonneg (r + 1)]
      exact hzprim.ne_one (by norm_num) (by rw [‚Üź hr, hr1, map_one])
    -- `‚ĄĚ(z) = ‚ĄĚŠĶÉň°ŠĶć` in degree `2`
    have htop : IntermediateField.adjoin ‚ĄĚ {z} = ‚ä§ := by
      rw [‚Üź IntermediateField.finrank_eq_one_iff_eq_top]
      have hmul : Module.finrank ‚ĄĚ (IntermediateField.adjoin ‚ĄĚ {z}) *
          Module.finrank (IntermediateField.adjoin ‚ĄĚ {z})
            (AlgebraicClosure ‚ĄĚ) = 2 := by
        rw [Module.finrank_mul_finrank]
        exact hfr
      have hne1 : Module.finrank ‚ĄĚ (IntermediateField.adjoin ‚ĄĚ {z}) ‚Č† 1 := by
        rw [Ne, IntermediateField.finrank_eq_one_iff]
        intro hbot
        exact hznotbot (hbot ‚Ėł IntermediateField.mem_adjoin_simple_self ‚ĄĚ z)
      have hdvd : Module.finrank ‚ĄĚ (IntermediateField.adjoin ‚ĄĚ {z}) ‚ą£ 2 :=
        ‚ü®_, hmul.symm‚ü©
      rcases (Nat.dvd_prime Nat.prime_two).mp hdvd with h1 | h2
      ¬∑ exact absurd h1 hne1
      ¬∑ rw [h2] at hmul
        omega
    -- `ŌÉ` fixes `‚ĄĚ` and `z`, hence everything ‚ÄĒ contradicting `ŌÉ ‚Č† 1`
    refine hŌÉ (AlgEquiv.ext fun w => ?_)
    have hw : w ‚ąą IntermediateField.adjoin ‚ĄĚ {z} :=
      htop ‚Ėł IntermediateField.mem_top
    show ŌÉ w = w
    induction hw using IntermediateField.adjoin_induction with
    | mem u hu =>
      rw [Set.mem_singleton_iff] at hu
      rw [hu]
      exact hŌÉz
    | algebraMap r => exact ŌÉ.commutes r
    | add a b _ _ ha hb => rw [map_add, ha, hb]
    | mul a b _ _ ha hb => rw [map_mul, ha, hb]
    | inv a _ ha => rw [map_inv‚āÄ, ha]

/-- A finite field admitting a `‚Ą§_[3]`-algebra structure has `3 = 0`:
the image of `3` under `‚Ą§_[3] ‚Üí k` is not a unit (else the composite
would embed a characteristic-`p ‚Č† 3` situation into `‚Ą§_[3]ň£`), and in a
field every nonzero element is a unit. Precisely: `k` has prime
characteristic `p`; if `p ‚Č† 3` then `(p : ‚Ą§_[3])` is a unit (its
residue mod `3` is nonzero), yet it maps to `(p : k) = 0`, which is not
a unit ‚ÄĒ contradiction. -/
theorem charP_three_of_finite_padicIntThree_algebra
    {k : Type u} [Finite k] [Field k] [Algebra ‚Ą§_[3] k] : CharP k 3 := by
  cases nonempty_fintype k
  obtain ‚ü®p, hchar‚ü© := CharP.exists k
  haveI := hchar
  haveI hp : Fact p.Prime := ‚ü®CharP.char_is_prime k p‚ü©
  rcases eq_or_ne p 3 with rfl | hp3
  ¬∑ exact hchar
  ¬∑ exfalso
    -- `(p : ‚Ą§_[3])` is a unit: its norm is not `< 1` since `3 ‚ą§ p`
    have hunit : IsUnit ((p : ‚Ąē) : ‚Ą§_[3]) := by
      by_contra hnu
      have hlt : ‚ÄĖ((p : ‚Ąē) : ‚Ą§_[3])‚ÄĖ < 1 := PadicInt.not_isUnit_iff.mp hnu
      rw [show ‚ÄĖ((p : ‚Ąē) : ‚Ą§_[3])‚ÄĖ = ‚ÄĖ((p : ‚Ąē) : ‚Ąö_[3])‚ÄĖ from by
        rw [PadicInt.norm_def]; norm_cast] at hlt
      have hdvd : (3 : ‚Ąē) ‚ą£ p := Padic.norm_natCast_lt_one_iff.mp hlt
      exact hp3 ((Nat.prime_dvd_prime_iff_eq Nat.prime_three hp.out).mp hdvd).symm
    -- but it maps to `(p : k) = 0` under the algebra map
    have hzero : algebraMap ‚Ą§_[3] k ((p : ‚Ąē) : ‚Ą§_[3]) = 0 := by
      rw [map_natCast]
      exact CharP.cast_eq_zero k p
    exact (hunit.map (algebraMap ‚Ą§_[3] k)).ne_zero hzero

/-- A finite field admitting a `‚Ą§_[3]`-algebra structure has `3 = 0`
(the cast form of `charP_three_of_finite_padicIntThree_algebra`). -/
theorem three_eq_zero_of_finite_padicIntThree_algebra
    {k : Type u} [Finite k] [Field k] [Algebra ‚Ą§_[3] k] : (3 : k) = 0 :=
  haveI := charP_three_of_finite_padicIntThree_algebra (k := k)
  CharP.cast_eq_zero k 3

/-- **The `1`-eigenspace of an odd involution is a line**: on a
`2`-dimensional space over a field where `2 ‚Č† 0`, a linear involution
of determinant `-1` has a `1`-dimensional fixed space. The involution
splits the space as `E‚āĀ ‚äē E‚āč‚āĀ` (via `v = 2‚ĀĽ¬Ļ(v + fv) + 2‚ĀĽ¬Ļ(v - fv)`);
`E‚āĀ = ‚ä§` forces `f = 1` of determinant `1`, `E‚āč‚āĀ = ‚ä§` forces `f = -1`
of determinant `(-1)¬≤ = 1`, so determinant `-1` leaves only the split
`1 + 1`. -/
theorem finrank_eigenspace_one_of_involution {k : Type u} [Field k]
    {V : Type*} [AddCommGroup V] [Module k V] [Module.Finite k V]
    (hrank : Module.rank k V = 2) {f : V ‚Üí‚āó[k] V}
    (hsq : f * f = 1) (hdet : LinearMap.det f = -1) (h2 : (2 : k) ‚Č† 0) :
    Module.finrank k (Module.End.eigenspace f 1) = 1 := by
  have hfr : Module.finrank k V = 2 :=
    Module.finrank_eq_of_rank_eq (by exact_mod_cast hrank)
  have hff : ‚ąÄ v, f (f v) = v := fun v =>
    congrFun (congrArg DFunLike.coe hsq) v
  -- the sum of the eigenspaces is everything:
  -- `v = 2‚ĀĽ¬Ļ ‚ÄĘ (v + f v) + 2‚ĀĽ¬Ļ ‚ÄĘ (v - f v)`
  have hsup : Module.End.eigenspace f 1 ‚äĒ Module.End.eigenspace f (-1) = ‚ä§ := by
    rw [eq_top_iff]
    intro v _
    have h1 : v + f v ‚ąą Module.End.eigenspace f 1 := by
      rw [Module.End.mem_eigenspace_iff, one_smul, map_add, hff]
      abel
    have h2' : v - f v ‚ąą Module.End.eigenspace f (-1) := by
      rw [Module.End.mem_eigenspace_iff, map_sub, hff, neg_smul, one_smul,
        neg_sub]
    have hv : v = (2 : k)‚ĀĽ¬Ļ ‚ÄĘ (v + f v) + (2 : k)‚ĀĽ¬Ļ ‚ÄĘ (v - f v) := by
      rw [‚Üź smul_add]
      have hvv : (v + f v) + (v - f v) = (2 : k) ‚ÄĘ v := by
        rw [two_smul]; abel
      rw [hvv, smul_smul, inv_mul_cancel‚āÄ h2, one_smul]
    rw [hv]
    exact Submodule.add_mem _
      (Submodule.mem_sup_left (Submodule.smul_mem _ _ h1))
      (Submodule.mem_sup_right (Submodule.smul_mem _ _ h2'))
  -- the intersection is trivial: `v = f v = -v` forces `2v = 0`
  have hinf : Module.End.eigenspace f 1 ‚äď Module.End.eigenspace f (-1) = ‚ä• := by
    rw [eq_bot_iff]
    intro v hv
    obtain ‚ü®hv1, hv2‚ü© := Submodule.mem_inf.mp hv
    rw [Module.End.mem_eigenspace_iff, one_smul] at hv1
    rw [Module.End.mem_eigenspace_iff] at hv2
    have h2v : (2 : k) ‚ÄĘ v = 0 := by
      rw [two_smul]
      nth_rw 1 [‚Üź hv1]
      rw [hv2, neg_smul, one_smul]
      abel
    rw [smul_eq_zero] at h2v
    exact Submodule.mem_bot _ |>.mpr (h2v.resolve_left h2)
  -- dimension bookkeeping
  have hdim : Module.finrank k (Module.End.eigenspace f 1) +
      Module.finrank k (Module.End.eigenspace f (-1)) = 2 := by
    have h := Submodule.finrank_sup_add_finrank_inf_eq
      (Module.End.eigenspace f 1) (Module.End.eigenspace f (-1))
    rw [hsup, hinf, finrank_top, hfr, finrank_bot, add_zero] at h
    exact h.symm
  -- eliminate `E‚āĀ = ‚ä§` (then `f = 1`, determinant `1`)
  have hone_ne : (-1 : k) ‚Č† 1 := fun h => h2 (by linear_combination -h)
  have hcase2 : Module.finrank k (Module.End.eigenspace f 1) ‚Č† 2 := by
    intro htwo
    have htop : Module.End.eigenspace f 1 = ‚ä§ :=
      Submodule.eq_top_of_finrank_eq (htwo.trans hfr.symm)
    have hfone : f = 1 := by
      ext v
      have hv : v ‚ąą Module.End.eigenspace f 1 := htop ‚Ėł Submodule.mem_top
      rw [Module.End.mem_eigenspace_iff, one_smul] at hv
      simpa using hv
    rw [hfone] at hdet
    rw [show LinearMap.det (1 : V ‚Üí‚āó[k] V) = 1 from LinearMap.det_id] at hdet
    exact hone_ne hdet.symm
  -- eliminate `E‚āĀ = ‚ä•` (then `E‚āč‚āĀ = ‚ä§`, `f = -1`, determinant `(-1)¬≤ = 1`)
  have hcase0 : Module.finrank k (Module.End.eigenspace f 1) ‚Č† 0 := by
    intro hzero
    have htwo2 : Module.finrank k (Module.End.eigenspace f (-1)) = 2 := by
      omega
    have htop : Module.End.eigenspace f (-1) = ‚ä§ :=
      Submodule.eq_top_of_finrank_eq (htwo2.trans hfr.symm)
    have hfneg : f = (-1 : k) ‚ÄĘ (1 : V ‚Üí‚āó[k] V) := by
      ext v
      have hv : v ‚ąą Module.End.eigenspace f (-1) := htop ‚Ėł Submodule.mem_top
      rw [Module.End.mem_eigenspace_iff] at hv
      simpa using hv
    rw [hfneg, LinearMap.det_smul] at hdet
    rw [show LinearMap.det (1 : V ‚Üí‚āó[k] V) = 1 from LinearMap.det_id,
      hfr] at hdet
    simp only [neg_one_sq, mul_one] at hdet
    exact hone_ne hdet.symm
  omega

