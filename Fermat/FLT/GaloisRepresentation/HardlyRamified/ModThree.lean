        (Real.exp (1 / 2 * x) * Real.cos (c * x))) =
      2 * вҲ« x : в„қ, odlyzkoTestFn x * Real.cos (c * x) := by
    rw [вҶҗ MeasureTheory.integral_add (hIint (-(1 / 2))) (hIint (1 / 2)),
      вҶҗ MeasureTheory.integral_const_mul]
    refine MeasureTheory.integral_congr_ae
      (Filter.Eventually.of_forall fun x => ?_)
    have hch : Real.cosh (x / 2) вү  0 := (Real.cosh_pos _).ne'
    have hcosh2 : Real.exp (-(1 / 2) * x) + Real.exp (1 / 2 * x) =
