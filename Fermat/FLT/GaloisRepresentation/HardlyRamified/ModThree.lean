        ClassGroup.mk0 I = C}) вүғ
      {I : (Ideal (NumberField.RingOfIntegers K))вҒ° //
        Ideal.absNorm (I : Ideal (NumberField.RingOfIntegers K)) вүӨ n вҲ§
        ClassGroup.mk0 I = C} :=
    { toFun := fun p => вҹЁp.2.1,
        le_trans (le_of_eq p.2.2.1) (Finset.mem_Icc.mp p.1.2).2, p.2.2.2вҹ©
      invFun := fun I =>
        вҹЁвҹЁIdeal.absNorm (I.1 : Ideal (NumberField.RingOfIntegers K)),
