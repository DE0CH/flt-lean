theorem kernel_field_discr_two_exponent {k : Type u} [Finite k] [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
