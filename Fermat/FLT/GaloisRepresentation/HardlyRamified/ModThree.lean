        have h3invle : (Valued.v (3 : AlgebraicClosure ‚Ąö_[2]))‚ĀĽ¬Ļ ‚Č§ 1 := by
          have hmem : (3 : AlgebraicClosure ‚Ąö_[2])‚ĀĽ¬Ļ ‚ąą Z2bar := by
