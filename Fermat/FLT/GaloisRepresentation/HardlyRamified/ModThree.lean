  let ŌÜq : (k ‚ßł (‚ä• : Ideal k)) ‚ČÉ+* k := RingEquiv.quotientBot k
  have hŌÜalg : ‚ąÄ r : k, ŌÜq (algebraMap k (k ‚ßł (‚ä• : Ideal k)) r) = r :=
    fun _ => rfl
