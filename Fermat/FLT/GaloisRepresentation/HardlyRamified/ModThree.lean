/-- **The Serre ¬ß5.4/Tate elimination over the Dickson list** (cyclic
case PROVEN 2026-07-18; the noncyclic cases delegate to the leaf
above): given a mod-3 hardly ramified representation `ŌĀ`, a group
homomorphism `ŌÄ` from `őď ‚Ąö` to `PGL‚āā(ūĚĒĹŐĄ‚āÉ)` which is the
projectivization of the base change of `ŌĀ` to `ūĚĒĹŐĄ‚āÉ` (witnessed
explicitly: `u` is the matrix form of the base-changed action in the
basis `b`, transported along the field identification `e`, and `ŌÄ` is
its class modulo the centre), and the Dickson classification of the
finite image `ŌÄ.range`, every case is eliminated. -/
theorem serre_elimination {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (habs : Slop.OddRep.IsAbsolutelyIrreducible
      (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V))
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (ŌÄ : őď ‚Ąö ‚Üí* Dickson.PGL 3)
    (hŌÄ : ‚ąÄ g, ŌÄ g = QuotientGroup.mk (u g))
    (hcase :
      (IsCyclic ŌÄ.range) ‚ą®
      (‚ąÉ n : ‚Ąē, n ‚Č• 2 ‚ąß Nonempty (ŌÄ.range ‚ČÉ* DihedralGroup n)) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* alternatingGroup (Fin 4))) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* Equiv.Perm (Fin 4))) ‚ą®
      (Nonempty (ŌÄ.range ‚ČÉ* alternatingGroup (Fin 5))) ‚ą®
      (‚ąÉ (m t : ‚Ąē) (_ : m ‚Č• 1) (_ : Nat.Coprime t 3) (_ : t ‚ą£ 3 ^ m - 1)
        (ŌÜ : Multiplicative (ZMod t) ‚Üí*
          MulAut (Multiplicative (Fin m ‚Üí ZMod 3))),
        Nonempty (ŌÄ.range ‚ČÉ*
          (Multiplicative (Fin m ‚Üí ZMod 3)) ‚čä[ŌÜ] Multiplicative (ZMod t))) ‚ą®
      (‚ąÉ m : ‚Ąē, m ‚Č• 1 ‚ąß Nonempty (ŌÄ.range ‚ČÉ*
        Matrix.ProjectiveSpecialLinearGroup (Fin 2) (GaloisField 3 m))) ‚ą®
      (‚ąÉ m : ‚Ąē, m ‚Č• 1 ‚ąß Nonempty (ŌÄ.range ‚ČÉ*
        (GL (Fin 2) (GaloisField 3 m) ‚ßł
          Subgroup.center (GL (Fin 2) (GaloisField 3 m)))))) :
    False := by
  rcases hcase with hcyc | hrest
  ¬∑ -- **cyclic case, PROVEN**: a cyclic projective image makes the matrix
    -- image abelian (a group with cyclic central quotient is abelian), so
    -- the base-changed action is by commuting operators; over the
    -- algebraically closed field each operator then acts as a scalar (its
    -- eigenspace is invariant, hence everything), and a scalar action on a
    -- `2`-dimensional space has a stable line ‚ÄĒ contradicting absolute
    -- irreducibility.
    classical
    set L := AlgebraicClosure k
    set ŌÉŌĀ : Representation L (őď ‚Ąö) (L ‚äó[k] V) :=
      Slop.OddRep.baseChange L (MonoidHomClass.toMonoidHom ŌĀ)
    have hirr : ŌÉŌĀ.IsIrreducible := habs
    -- the image of `ŌÄ` is the image of `u.range` in the quotient
    have hrange : Subgroup.map
        (QuotientGroup.mk' (Subgroup.center (GL (Fin 2) (Dickson.K 3))))
        u.range = ŌÄ.range := by
      ext x
      simp only [Subgroup.mem_map, MonoidHom.mem_range]
      constructor
      ¬∑ rintro ‚ü®_, ‚ü®g, rfl‚ü©, rfl‚ü©
        exact ‚ü®g, (hŌÄ g).trans rfl‚ü©
      ¬∑ rintro ‚ü®g, rfl‚ü©
        exact ‚ü®u g, ‚ü®g, rfl‚ü©, ((hŌÄ g).trans rfl).symm‚ü©
    -- the matrix image is abelian
    have hcomm_u : ‚ąÄ g‚āĀ g‚āā : őď ‚Ąö, u g‚āĀ * u g‚āā = u g‚āā * u g‚āĀ := by
      haveI hcyc' : IsCyclic (Subgroup.map
          (QuotientGroup.mk' (Subgroup.center (GL (Fin 2) (Dickson.K 3))))
          u.range) := hrange ‚Ėł hcyc
      have hker : ((QuotientGroup.mk'
          (Subgroup.center (GL (Fin 2) (Dickson.K 3)))).subgroupMap
            u.range).ker ‚Č§ Subgroup.center u.range := by
        rintro ‚ü®x, hx‚ü© hmem
        have hx1 : QuotientGroup.mk' (Subgroup.center
            (GL (Fin 2) (Dickson.K 3))) x = 1 := congrArg Subtype.val hmem
        have hxc : x ‚ąą Subgroup.center (GL (Fin 2) (Dickson.K 3)) := by
          rwa [‚Üź QuotientGroup.ker_mk' (Subgroup.center
            (GL (Fin 2) (Dickson.K 3))), MonoidHom.mem_ker]
        exact Subgroup.mem_center_iff.mpr fun y => Subtype.ext
          ((Subgroup.mem_center_iff.mp hxc) y.1)
      haveI h := MonoidHom.isMulCommutative_of_isCyclic_of_ker_le_center
        ((QuotientGroup.mk' (Subgroup.center
          (GL (Fin 2) (Dickson.K 3)))).subgroupMap u.range) hker
      intro g‚āĀ g‚āā
      exact congrArg Subtype.val
        (h.is_comm.comm ‚ü®u g‚āĀ, MonoidHom.mem_range.mpr ‚ü®g‚āĀ, rfl‚ü©‚ü©
          ‚ü®u g‚āā, MonoidHom.mem_range.mpr ‚ü®g‚āā, rfl‚ü©‚ü©)
    -- the base-changed operators commute
    have hcomm : ‚ąÄ g‚āĀ g‚āā : őď ‚Ąö, ŌÉŌĀ g‚āĀ * ŌÉŌĀ g‚āā = ŌÉŌĀ g‚āā * ŌÉŌĀ g‚āĀ := by
      intro g‚āĀ g‚āā
      have hmap : ‚ąÄ M N : Matrix (Fin 2) (Fin 2) (AlgebraicClosure k),
          M.map e = N.map e ‚Üí M = N := by
        intro M N h
        ext i j
        exact e.injective (by
          have := congrFun (congrFun (congrArg Matrix.of.symm h) i) j
          exact this)
      have hval := congrArg (Units.val) (hcomm_u g‚āĀ g‚āā)
      rw [Units.val_mul, Units.val_mul, hu, hu, ‚Üź Matrix.map_mul,
        ‚Üź Matrix.map_mul] at hval
      have hmat := hmap _ _ hval
      have hmul : ‚ąÄ gg‚āĀ gg‚āā : őď ‚Ąö, LinearMap.toMatrix b b (ŌÉŌĀ gg‚āĀ) *
          LinearMap.toMatrix b b (ŌÉŌĀ gg‚āā) =
          LinearMap.toMatrix b b (ŌÉŌĀ gg‚āĀ * ŌÉŌĀ gg‚āā) :=
        fun gg‚āĀ gg‚āā => (LinearMap.toMatrix_comp b b b _ _).symm
      rw [hmul, hmul] at hmat
      exact (LinearMap.toMatrix b b).injective hmat
    -- each operator is a scalar
    haveI : Module.Finite L (L ‚äó[k] V) := Module.Finite.base_change k L V
    have hfr2 : Module.finrank L (L ‚äó[k] V) = 2 := by
      rw [Module.finrank_baseChange]
      exact Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
    haveI : Nontrivial (L ‚äó[k] V) :=
      Module.nontrivial_of_finrank_pos (R := L) (by omega)
    obtain ‚ü®hnt, hsub‚ü© := (Slop.OddRep.isIrreducible_iff_forall ŌÉŌĀ).mp hirr
    have hscalar : ‚ąÄ g : őď ‚Ąö, ‚ąÉ őľ : L, ‚ąÄ v : L ‚äó[k] V, ŌÉŌĀ g v = őľ ‚ÄĘ v := by
      intro g
      obtain ‚ü®őľ, hőľ‚ü© := Module.End.exists_eigenvalue (ŌÉŌĀ g)
      have hEne : Module.End.eigenspace (ŌÉŌĀ g) őľ ‚Č† ‚ä• := hőľ
      have hEinv : ‚ąÄ h : őď ‚Ąö, ‚ąÄ w ‚ąą Module.End.eigenspace (ŌÉŌĀ g) őľ,
          ŌÉŌĀ h w ‚ąą Module.End.eigenspace (ŌÉŌĀ g) őľ := by
        intro h w hw
        rw [Module.End.mem_eigenspace_iff] at hw ‚äĘ
        have hc := congrFun (congrArg DFunLike.coe (hcomm g h)) w
        simp only [Module.End.mul_apply] at hc
        rw [hc, hw, map_smul]
      rcases hsub (Module.End.eigenspace (ŌÉŌĀ g) őľ) hEinv with hE | hE
      ¬∑ exact absurd hE hEne
      ¬∑ refine ‚ü®őľ, fun v => ?_‚ü©
        have hv : v ‚ąą Module.End.eigenspace (ŌÉŌĀ g) őľ :=
          hE ‚Ėł Submodule.mem_top
        rwa [Module.End.mem_eigenspace_iff] at hv
    -- a scalar action on a `2`-dimensional space has a stable line
    obtain ‚ü®v, hv‚ü© := exists_ne (0 : L ‚äó[k] V)
    have hWinv : ‚ąÄ g : őď ‚Ąö, ‚ąÄ w ‚ąą Submodule.span L {v},
        ŌÉŌĀ g w ‚ąą Submodule.span L {v} := by
      intro g w hw
      obtain ‚ü®őľ, hőľ‚ü© := hscalar g
      rw [hőľ w]
      exact Submodule.smul_mem _ _ hw
    rcases hsub (Submodule.span L {v}) hWinv with hW | hW
    ¬∑ exact hv ((Submodule.mem_bot L).mp
        (hW ‚Ėł Submodule.mem_span_singleton_self v))
    ¬∑ have h1 : Module.finrank L (Submodule.span L {v}) = 1 :=
        finrank_span_singleton hv
      rw [hW, finrank_top, hfr2] at h1
      omega
  ¬∑ exact serre_elimination_noncyclic V hV hŌĀ habs b e u hu ŌÄ hŌÄ hrest

