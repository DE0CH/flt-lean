theorem two_mul_local_differentIdeal_exponent_add_two_le_of_flat_at_three
    {k : Type u} [Finite k] [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ПҒ : GaloisRep в„ҡ k V}
    (hПҒ : IsHardlyRamified (show Odd 3 by decide) hV ПҒ)
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) вҠ—[k] V))
    (e : AlgebraicClosure k вүғ+* Dickson.K 3)
    (u : О“ в„ҡ вҶ’* GL (Fin 2) (Dickson.K 3))
    (hu : вҲҖ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ)) g)).map e)
    (M : IntermediateField
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
      (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)))
    [FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) M]
    (hM : вҲҖ Пғ : О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat),
      u (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 вҶ’
      вҲҖ x вҲҲ M, Пғ x = x)
    (d : в„•)
    (hd : IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) M) ^ d вҲЈ
      differentIdeal
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat)
        (IntegralClosure
          (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
            Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) M)) :
    2 * d + 2 вүӨ 3 * Ideal.ramificationIdx'
      (IsLocalRing.maximalIdeal
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat))
      (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) M)) := by
  classical
  -- (1) unpack flatness into the explicit finite flat Hopf package
  obtain вҹЁG, i1, i2, i3, i4, i5, f, hbijвҹ© :=
    hasFlatProlongationAt_three_of_isFlatAt V hПҒ.isFlat
  letI := i1
  letI := i2
  letI := i3
  letI := i4
  letI := i5
  let g := Equiv.ofBijective f hbij
  have hfs : вҲҖ x : V, f (g.symm x) = x := fun x => g.apply_symm_apply x
  -- the coefficient field has characteristic `3`
  have h3V : вҲҖ w : V, w + w + w = 0 := by
    intro w
    have h3k : (3 : k) = 0 := three_eq_zero_of_finite_padicIntThree_algebra
    have h1 : ((3 : в„•) : k) вҖў w = (3 : в„•) вҖў w := Nat.cast_smul_eq_nsmul k 3 w
    rw [show ((3 : в„•) : k) = (3 : k) from by norm_cast, h3k, zero_smul] at h1
    have h2 : (3 : в„•) вҖў w = w + w + w := by
      rw [show (3 : в„•) = 2 + 1 from rfl, add_nsmul, two_nsmul, one_nsmul]
    rw [вҶҗ h2]
    exact h1.symm
  -- (2) the geometric points of the package are killed by `3`
  have hkill : вҲҖ ПҮ : в„ҡвӮғбөҘ вҠ—[рқ’ӘвӮғбөҘ] G вҶ’вӮҗ[в„ҡвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ, ПҮ * ПҮ * ПҮ = 1 := by
    intro ПҮ
    have h0 : Additive.ofMul ПҮ + Additive.ofMul ПҮ + Additive.ofMul ПҮ =
        (0 : Additive (в„ҡвӮғбөҘ вҠ—[рқ’ӘвӮғбөҘ] G вҶ’вӮҗ[в„ҡвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ)) := by
      apply g.injective
      show f (Additive.ofMul ПҮ + Additive.ofMul ПҮ + Additive.ofMul ПҮ) = f 0
      rw [map_add f, map_add f, map_zero f]
      exact h3V (f (Additive.ofMul ПҮ))
    have h1 := congrArg Additive.toMul h0
    rwa [toMul_add, toMul_add, toMul_zero, toMul_ofMul] at h1
  -- (3) the two spellings of the local action agree: ring homs out of
  -- `в„ҡ` are unique
  have hbridge : вҲҖ (П„ : О“ (в„ҡвӮғбөҘ)) (w : V),
      (ПҒ.toLocal Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) П„ w =
      ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) П„) w := by
    intro П„ w
    rw [GaloisRep.toLocal_apply]
    exact congrArg (fun (h : в„ҡ вҶ’+* (в„ҡвӮғбөҘ)) =>
      ПҒ (Field.absoluteGaloisGroup.map h П„) w) (Subsingleton.elim _ _)
  -- (4) the kernel-field glue: a substitution fixing every point acts
  -- trivially on `V`, hence is killed by `u`, hence fixes `M` by `hM`
  have hMpkg : вҲҖ Пғ : О“ (в„ҡвӮғбөҘ),
      (вҲҖ ПҮ : в„ҡвӮғбөҘ вҠ—[рқ’ӘвӮғбөҘ] G вҶ’вӮҗ[в„ҡвӮғбөҘ] в„ҡвӮғбөҘбөғЛЎбөҚ, Пғ вҖў ПҮ = ПҮ) вҶ’
      вҲҖ x вҲҲ M, Пғ x = x := by
    intro Пғ hПғ
    refine hM Пғ ?_
    -- the local substitution acts trivially on `V`
    have hfixV : вҲҖ w : V,
        ПҒ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) Пғ) w = w := by
      intro w
      have h2 : Additive.toMul (Пғ вҖў g.symm w) =
          Пғ вҖў Additive.toMul (g.symm w) := rfl
      have h3 : Additive.toMul (Пғ вҖў g.symm w) = Additive.toMul (g.symm w) := by
        rw [h2]
        exact hПғ _
      have h1 : Пғ вҖў g.symm w = g.symm w := Additive.toMul.injective h3
      have h4 : f (Пғ вҖў g.symm w) = f (g.symm w) := by rw [h1]
      rw [map_smul f, hfs] at h4
      have h5 : (ПҒ.toLocal
          Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) Пғ w = w := h4
      exact (hbridge Пғ w).symm.trans h5
    -- hence the matrix realization kills the global lift: the matrix
    -- transport of the identity is the identity
    have hend : (MonoidHomClass.toMonoidHom ПҒ :
        Representation k (О“ в„ҡ) V)
        (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) Пғ) = 1 := by
      refine LinearMap.ext fun w => ?_
      rw [Module.End.one_apply]
      exact hfixV w
    apply Units.ext
    rw [Units.val_one,
      hu (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) Пғ)]
    have hbc : (Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ПҒ))
        (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) Пғ) =
        ((MonoidHomClass.toMonoidHom ПҒ :
          Representation k (О“ в„ҡ) V)
          (Field.absoluteGaloisGroup.map (algebraMap в„ҡ (в„ҡвӮғбөҘ)) Пғ)).baseChange
          (AlgebraicClosure k) := rfl
    rw [hbc, hend, Module.End.one_eq_id, LinearMap.baseChange_id,
      вҶҗ Module.End.one_eq_id, LinearMap.toMatrix_one,
      Matrix.map_one _ (map_zero e) (map_one e)]
  -- (5) the scheme-theoretic Fontaine bound closes the estimate
  exact two_mul_local_differentIdeal_exponent_add_two_le_of_hopf_package
    G hkill M hMpkg d hd

end FontaineHopfBound

