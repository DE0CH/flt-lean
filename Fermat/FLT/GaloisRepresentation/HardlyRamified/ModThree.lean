      Filter.atTop (nhds 0) := by
  obtain ‚ü®c, hc, hgap‚ü© := pkg.exists_goodHeight_gap hcount
  have hsel : ‚ąÄ T : ‚ĄĚ, ‚ąÉ T' : ‚ĄĚ, 2 ‚Č§ T ‚Üí T ‚Č§ T' ‚ąß T' ‚Č§ T + 1 ‚ąß
      ‚ąÄ ŌĀ : ‚Ąā, pkg.mult ŌĀ ‚Č† 0 ‚Üí c / Real.log T ‚Č§ |(|ŌĀ.im| - T')| := by
    intro T
    by_cases hT : 2 ‚Č§ T
    ¬∑ obtain ‚ü®T', hT'‚ü© := hgap T hT
      exact ‚ü®T', fun _ => hT'‚ü©
    ¬∑ exact ‚ü®T, fun h => absurd h hT‚ü©
  choose ŌĄ hŌĄ using hsel
  have hŌĄ' : ‚ąÄ T : ‚ĄĚ, 2 ‚Č§ T ‚Üí T ‚Č§ ŌĄ T ‚ąß ŌĄ T ‚Č§ T + 1 :=
    fun T hT => ‚ü®(hŌĄ T hT).1, (hŌĄ T hT).2.1‚ü©
  have hident : ‚ąÄ T : ‚ĄĚ, 2 ‚Č§ T ‚Üí
      (‚ąĎ' ŌĀ : {ŌĀ : ‚Ąā // pkg.mult ŌĀ ‚Č† 0 ‚ąß |ŌĀ.im| ‚Č§ ŌĄ T},
        (pkg.mult ŌĀ.1 : ‚ĄĚ) * (poitouPhi ŌĀ.1).re) =
      pkg.poitouEdge (ŌĄ T) + pkg.poitouHorizontal (ŌĄ T) := by
    intro T hT
    obtain ‚ü®h1, -, h3‚ü© := hŌĄ T hT
    refine pkg.zero_sum_eq_poitouEdge_add_poitouHorizontal hbnd
      (lt_of_lt_of_le (by linarith) h1) ?_
    intro ŌĀ hŌĀ heq
    have hg := h3 ŌĀ hŌĀ
    rw [heq, sub_self, abs_zero] at hg
    have hpos : 0 < c / Real.log T := div_pos hc (Real.log_pos (by linarith))
    linarith
  have hH := pkg.poitouHorizontal_gap_tendsto_zero hcount hbnd hc ŌĄ hŌĄ
  have hS := pkg.zero_sum_bridge_tendsto_zero hcount ŌĄ hŌĄ'
  have hE := pkg.poitouEdge_bridge_tendsto_zero ŌĄ hŌĄ'
  have hcomb := (hS.neg.add hH).add hE
  rw [neg_zero, zero_add, add_zero] at hcomb
  refine Filter.Tendsto.congr' ?_ hcomb
  filter_upwards [Filter.eventually_ge_atTop (2 : ‚ĄĚ)] with T hT
  simp only [hident T hT]
  ring

/-- **The pole-pair edge functional** (definition, 2026-07-24 ‚ÄĒ
introduced in the decomposition of
`DedekindContinuation.poitouEdge_tendsto`): the analogue of
`DedekindContinuation.poitouEdge` with the elementary pole pair
`h(s) = 1/s + 1/(s‚ąí1)` ‚ÄĒ the log-derivative of the normalizing
factor `s(s‚ąí1)` of `őĺ` ‚ÄĒ in place of `őĺ'/őĺ`.  `h` has the same odd
symmetry `h(1 ‚ąí s) = ‚ąíh(s)` under the functional-equation
substitution as `őĺ'/őĺ` itself, which is why the same folded
right-edge form captures its whole rectangle contour.  Note
`(5/4 + it).re = 5/4`, so neither denominator vanishes on the
line. -/
noncomputable def poitouPoleEdge (T : ‚ĄĚ) : ‚ĄĚ :=
  Real.pi‚ĀĽ¬Ļ * ‚ąę t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      (1 / (5 / 4 + t * Complex.I) + 1 / (5 / 4 + t * Complex.I - 1))).re

section PoitouPoleEdgeFourier

open MeasureTheory Filter Set Complex
open scoped FourierTransform Convolution

/-- **The time-side profile of `ő¶` on the line `Re s = 5/4`**
(introduced 2026-07-24 for the proof of `poitouPoleEdge_tendsto`):
`G(x) = F(x)¬∑e^{3x/4}` with `F = poitouF`, so that
`ő¶(5/4 + it) = ‚ąę G(x)¬∑e^{itx} dx` (`poitouPhi_line_eq`) ‚ÄĒ i.e. `G` is
the inverse Fourier profile of the edge restriction of `ő¶`.  It is
continuous with support in `[-6, 6]`. -/
noncomputable def poitouG (x : ‚ĄĚ) : ‚Ąā := ((poitouF x * Real.exp (3 / 4 * x) : ‚ĄĚ) : ‚Ąā)

/-- **Continuity of `poitouF`** (PROVEN 2026-07-24): quotient of the
continuous Fej√©r kernel by the positive `cosh`. -/
theorem continuous_poitouF : Continuous poitouF := by
  apply Continuous.div
  ¬∑ unfold odlyzkoTestFn; fun_prop
  ¬∑ fun_prop
  ¬∑ exact fun x => (Real.cosh_pos _).ne'

/-- **Continuity of `poitouG`** (PROVEN 2026-07-24). -/
theorem continuous_poitouG : Continuous poitouG := by
  refine Complex.continuous_ofReal.comp (continuous_poitouF.mul ?_)
  fun_prop

/-- **`poitouG` vanishes beyond the Fej√©r support `[-6, 6]`**
(PROVEN 2026-07-24). -/
theorem poitouG_eq_zero {x : ‚ĄĚ} (hx : 6 ‚Č§ |x|) : poitouG x = 0 := by
  have h : odlyzkoTestFn x = 0 := by
    rw [odlyzkoTestFn, max_eq_right]
    have : (6:‚ĄĚ) ‚Č§ |x| := hx
    nlinarith [this]
  rw [poitouG, poitouF, h, zero_div, zero_mul, Complex.ofReal_zero]

/-- **`poitouG` has compact support** (PROVEN 2026-07-24). -/
theorem poitouG_hasCompactSupport : HasCompactSupport poitouG := by
  apply HasCompactSupport.intro (isCompact_Icc (a := (-6:‚ĄĚ)) (b := 6))
  intro x hx
  apply poitouG_eq_zero
  simp only [Set.mem_Icc, not_and_or, not_le] at hx
  rcases hx with h | h
  ¬∑ exact le_abs.2 (Or.inr (by linarith))
  ¬∑ exact le_abs.2 (Or.inl h.le)

/-- **`poitouG` is integrable** (PROVEN 2026-07-24): continuous with
compact support. -/
theorem poitouG_integrable : Integrable poitouG :=
  continuous_poitouG.integrable_of_hasCompactSupport poitouG_hasCompactSupport

/-- **`ő¶` on the line `Re s = 5/4` as a Fourier-type integral of
`poitouG`** (PROVEN 2026-07-24): splitting
`e^{(3/4 + it)x} = e^{3x/4}¬∑e^{itx}` in the defining integral of
`poitouPhi`. -/
theorem poitouPhi_line_eq (t : ‚ĄĚ) :
    poitouPhi (5 / 4 + t * Complex.I) =
      ‚ąę x : ‚ĄĚ, poitouG x * Complex.exp (((t * x : ‚ĄĚ) : ‚Ąā) * Complex.I) := by
  rw [poitouPhi]
  have h : ‚ąÄ x : ‚ĄĚ, ((odlyzkoTestFn x / Real.cosh (x / 2) : ‚ĄĚ) : ‚Ąā) *
      Complex.exp ((5 / 4 + t * Complex.I - 1 / 2) * (x : ‚Ąā)) =
      poitouG x * Complex.exp (((t * x : ‚ĄĚ) : ‚Ąā) * Complex.I) := by
    intro x
    rw [show ((5 / 4 + t * Complex.I - 1 / 2) * (x : ‚Ąā)) =
        ((3 / 4 * x : ‚ĄĚ) : ‚Ąā) + ((t * x : ‚ĄĚ) : ‚Ąā) * Complex.I by push_cast; ring,
      Complex.exp_add, poitouG, poitouF, ‚Üź Complex.ofReal_exp]
    push_cast
    ring
  simp_rw [h]

/-- **The Fourier transform of `poitouG` is `ő¶` on the line**
(PROVEN 2026-07-24): with mathlib's `2ŌÄ`-in-the-exponent convention,
`ūĚďē poitouG őĺ = ő¶(5/4 - 2ŌÄőĺ¬∑i)`. -/
theorem fourier_poitouG (őĺ : ‚ĄĚ) :
    ūĚďē poitouG őĺ = poitouPhi (5 / 4 + ((-(2 * Real.pi * őĺ) : ‚ĄĚ) : ‚Ąā) * Complex.I) := by
  rw [Real.fourier_real_eq_integral_exp_smul, poitouPhi_line_eq]
  have h : ‚ąÄ v : ‚ĄĚ, Complex.exp (((-2 * Real.pi * v * őĺ : ‚ĄĚ) : ‚Ąā) * Complex.I) ‚ÄĘ poitouG v
      = poitouG v * Complex.exp (((-(2 * Real.pi * őĺ) * v : ‚ĄĚ) : ‚Ąā) * Complex.I) := by
    intro v
    rw [smul_eq_mul, mul_comm]
    congr 2
    push_cast
    ring
  simp_rw [h]

/-- **The one-sided exponential kernel `e^{ay}¬∑1_{y<0}`**
(introduced 2026-07-24 for the proof of `poitouPoleEdge_tendsto`): the
time-side profile of the pole factor `1/(a + it)` ‚ÄĒ its Fourier
transform is `1/(a - 2ŌÄőĺ¬∑i)` (`fourier_expKernel`). -/
noncomputable def expKernel (a : ‚ĄĚ) : ‚ĄĚ ‚Üí ‚Ąā :=
  Set.indicator (Set.Iio (0 : ‚ĄĚ)) fun y => Complex.exp (((a * y : ‚ĄĚ) : ‚Ąā))

/-- **Integrability of `e^{zy}` on `(-‚ąě, 0]` for `Re z > 0`**
(PROVEN 2026-07-24; generic helper, reusable for one-sided Laplace
kernels). -/
theorem integrableOn_cexp_mul_Iic {z : ‚Ąā} (hz : 0 < z.re) :
    IntegrableOn (fun y : ‚ĄĚ => Complex.exp (z * y)) (Set.Iic (0 : ‚ĄĚ)) := by
  have h1 : IntegrableOn (fun u : ‚ĄĚ => Real.exp (-z.re * u)) (Set.Ici (-(0:‚ĄĚ))) := by
    rw [neg_zero, integrableOn_Ici_iff_integrableOn_Ioi]
    exact exp_neg_integrableOn_Ioi 0 hz
  have h2 : IntegrableOn (fun y : ‚ĄĚ => Real.exp (z.re * y)) (Set.Iic (0:‚ĄĚ)) := by
    refine h1.comp_neg_Iic.congr_fun (fun y _ => ?_) measurableSet_Iic
    simp
  refine h2.mono' ?_ ?_
  ¬∑ exact (Complex.continuous_exp.comp (by fun_prop)).aestronglyMeasurable
  ¬∑ refine Filter.Eventually.of_forall fun y => ?_
    rw [Complex.norm_exp]
    simp [Complex.mul_re]

/-- **Integrability of the one-sided exponential kernel**
(PROVEN 2026-07-24). -/
theorem expKernel_integrable {a : ‚ĄĚ} (ha : 0 < a) : Integrable (expKernel a) := by
  rw [expKernel, integrable_indicator_iff measurableSet_Iio]
  have h := integrableOn_cexp_mul_Iic (z := (a : ‚Ąā)) (by simpa using ha)
  refine (h.mono_set Iio_subset_Iic_self).congr_fun (fun y _ => ?_) measurableSet_Iio
  push_cast
  ring_nf

/-- **`‚ąę_{-‚ąě}^0 e^{zy} dy = 1/z` for `Re z > 0`** (PROVEN 2026-07-24;
generic helper, reusable for one-sided Laplace kernels): improper
fundamental theorem of calculus on `Iic` with antiderivative
`e^{zy}/z` vanishing at `-‚ąě`. -/
theorem integral_cexp_mul_Iic {z : ‚Ąā} (hz : 0 < z.re) :
    ‚ąę y in Set.Iic (0:‚ĄĚ), Complex.exp (z * y) = 1 / z := by
  have hz0 : z ‚Č† 0 := fun h => by simp [h] at hz
  have hder : ‚ąÄ y ‚ąą Set.Iio (0:‚ĄĚ),
      HasDerivAt (fun y : ‚ĄĚ => Complex.exp (z * y) / z) (Complex.exp (z * y)) y := by
    intro y _
    have h1 : HasDerivAt (fun y : ‚ĄĚ => z * (y : ‚Ąā)) z y := by
      simpa using (Complex.ofRealCLM.hasDerivAt (x := y)).const_mul z
    have h2 := h1.cexp.div_const z
    simpa [mul_div_cancel_right‚āÄ _ hz0] using h2
  have htends : Tendsto (fun y : ‚ĄĚ => Complex.exp (z * y) / z) atBot (nhds 0) := by
    rw [tendsto_zero_iff_norm_tendsto_zero]
    have hn : ‚ąÄ y : ‚ĄĚ, ‚ÄĖComplex.exp (z * y) / z‚ÄĖ = Real.exp (z.re * y) / ‚ÄĖz‚ÄĖ := by
      intro y
      rw [norm_div, Complex.norm_exp]
      congr 2
      simp [Complex.mul_re]
    simp_rw [hn]
    have h3 : Tendsto (fun y : ‚ĄĚ => z.re * y) atBot atBot :=
      Tendsto.const_mul_atBot hz tendsto_id
    simpa using (Real.tendsto_exp_atBot.comp h3).div_const ‚ÄĖz‚ÄĖ
  have hcont : ContinuousWithinAt (fun y : ‚ĄĚ => Complex.exp (z * y) / z)
      (Set.Iic (0:‚ĄĚ)) 0 := by
    refine Continuous.continuousWithinAt ?_
    fun_prop
  have h := integral_Iic_of_hasDerivAt_of_tendsto hcont hder
    (integrableOn_cexp_mul_Iic hz) htends
  simpa using h

/-- **The Fourier transform of the one-sided exponential kernel is the
pole factor** (PROVEN 2026-07-24): `ūĚďē (expKernel a) őĺ = 1/(a - 2ŌÄőĺ¬∑i)`,
written in the `a + ti` shape at `t = -2ŌÄőĺ` to match
`fourier_poitouG`. -/
theorem fourier_expKernel {a : ‚ĄĚ} (ha : 0 < a) (őĺ : ‚ĄĚ) :
    ūĚďē (expKernel a) őĺ = 1 / ((a : ‚Ąā) + ((-(2 * Real.pi * őĺ) : ‚ĄĚ) : ‚Ąā) * Complex.I) := by
  set z : ‚Ąā := (a : ‚Ąā) + ((-(2 * Real.pi * őĺ) : ‚ĄĚ) : ‚Ąā) * Complex.I with hzdef
  have hzre : 0 < z.re := by
    rw [hzdef]
    simpa using ha
  rw [Real.fourier_real_eq_integral_exp_smul]
  have h : ‚ąÄ v : ‚ĄĚ, Complex.exp (((-2 * Real.pi * v * őĺ : ‚ĄĚ) : ‚Ąā) * Complex.I) ‚ÄĘ expKernel a v
      = Set.indicator (Set.Iio (0:‚ĄĚ)) (fun y => Complex.exp (z * y)) v := by
    intro v
    rw [smul_eq_mul, expKernel]
    by_cases hv : v ‚ąą Set.Iio (0:‚ĄĚ)
    ¬∑ rw [Set.indicator_of_mem hv, Set.indicator_of_mem hv, ‚Üź Complex.exp_add]
      congr 1
      rw [hzdef]
      push_cast
      ring
    ¬∑ rw [Set.indicator_of_notMem hv, Set.indicator_of_notMem hv, mul_zero]
  simp_rw [h]
  rw [integral_indicator measurableSet_Iio, setIntegral_congr_set Iio_ae_eq_Iic,
    integral_cexp_mul_Iic hzre]

/-- **The single-pole line integral by Fourier inversion**
(PROVEN 2026-07-24; the crux of `poitouPoleEdge_tendsto`): for `a > 0`,
`‚ąę_‚ĄĚ ő¶(5/4 + it)/(a + it) dt = 2ŌÄ ‚ąę_0^‚ąě e^{-au}¬∑G(u) du`.  Proof: the
convolution `w = expKernel a ‚čÜ poitouG` is integrable and continuous,
its Fourier transform is the pointwise product
`őĺ ‚Ü¶ ő¶(5/4 - 2ŌÄőĺi)/(a - 2ŌÄőĺi)` (`Real.fourier_mul_convolution_eq` with
`fourier_expKernel` and `fourier_poitouG`), which is integrable by the
hypothesis after the linear change of variables `t = -2ŌÄőĺ`; Fourier
inversion (`Integrable.fourierInv_fourier_eq`) at `0` then evaluates
`‚ąę ūĚďē w = w 0`, and `w 0 = ‚ąę_0^‚ąě e^{-au}¬∑G(u) du` by unfolding the
convolution over the negative half-line. -/
theorem integral_poitouPhi_line_div {a : ‚ĄĚ} (ha : 0 < a)
    (hInt : Integrable fun t : ‚ĄĚ =>
      poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I)) :
    (‚ąę t : ‚ĄĚ, poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I))
      = (2 * Real.pi) ‚ÄĘ ‚ąę u in Set.Ioi (0:‚ĄĚ),
          Complex.exp (((-(a * u) : ‚ĄĚ) : ‚Ąā)) * poitouG u := by
  classical
  set w : ‚ĄĚ ‚Üí ‚Ąā := expKernel a ‚čÜ[ContinuousLinearMap.mul ‚Ąā ‚Ąā] poitouG with hw
  have hőļ : Integrable (expKernel a) := expKernel_integrable ha
  have hwInt : Integrable w := hőļ.integrable_convolution (ContinuousLinearMap.mul ‚Ąā ‚Ąā)
    poitouG_integrable
  have hwCont : Continuous w := poitouG_hasCompactSupport.continuous_convolution_right
    (ContinuousLinearMap.mul ‚Ąā ‚Ąā) hőļ.locallyIntegrable continuous_poitouG
  have hFw : ‚ąÄ őĺ : ‚ĄĚ, ūĚďē w őĺ =
      poitouPhi (5 / 4 + ((-(2 * Real.pi * őĺ) : ‚ĄĚ) : ‚Ąā) * Complex.I) /
        ((a : ‚Ąā) + ((-(2 * Real.pi * őĺ) : ‚ĄĚ) : ‚Ąā) * Complex.I) := by
    intro őĺ
    rw [hw, Real.fourier_mul_convolution_eq hőļ poitouG_integrable, fourier_expKernel ha,
      fourier_poitouG, one_div_mul_eq_div]
  have hFwInt : Integrable (ūĚďē w) := by
    have hne : (-(2 * Real.pi)) ‚Č† (0:‚ĄĚ) := by
      simp [Real.pi_ne_zero]
    have h1 : Integrable fun őĺ : ‚ĄĚ =>
        poitouPhi (5 / 4 + (((-(2 * Real.pi)) * őĺ : ‚ĄĚ) : ‚Ąā) * Complex.I) /
          ((a : ‚Ąā) + (((-(2 * Real.pi)) * őĺ : ‚ĄĚ) : ‚Ąā) * Complex.I) :=
      hInt.comp_mul_left' hne
    refine h1.congr (Filter.Eventually.of_forall fun őĺ => ?_)
    rw [hFw őĺ]
    simp only [neg_mul]
  have hinv : ūĚďē‚ĀĽ (ūĚďē w) 0 = w 0 := hwInt.fourierInv_fourier_eq hFwInt hwCont.continuousAt
  have hL : ūĚďē‚ĀĽ (ūĚďē w) 0 = ‚ąę őĺ : ‚ĄĚ, ūĚďē w őĺ := by
    rw [Real.fourierInv_eq_fourier_neg, neg_zero, Real.fourier_real_eq]
    simp
  have hchange : (‚ąę őĺ : ‚ĄĚ, ūĚďē w őĺ) = |((-(2 * Real.pi))‚ĀĽ¬Ļ)| ‚ÄĘ
      ‚ąę t : ‚ĄĚ, poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I) := by
    rw [show (fun őĺ : ‚ĄĚ => ūĚďē w őĺ) = fun őĺ : ‚ĄĚ =>
        (fun t : ‚ĄĚ => poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I))
          ((-(2 * Real.pi)) * őĺ) from funext fun őĺ => by
        rw [hFw őĺ]; push_cast; simp only [neg_mul]]
    exact MeasureTheory.Measure.integral_comp_mul_left
      (fun t : ‚ĄĚ => poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I))
      (-(2 * Real.pi))
  have habs : |((-(2 * Real.pi))‚ĀĽ¬Ļ)| = (2 * Real.pi)‚ĀĽ¬Ļ := by
    rw [abs_inv, abs_neg, abs_of_pos (by positivity)]
  have hw0 : w 0 = ‚ąę u in Set.Ioi (0:‚ĄĚ),
      Complex.exp (((-(a * u) : ‚ĄĚ) : ‚Ąā)) * poitouG u := by
    rw [hw, convolution_def]
    simp only [ContinuousLinearMap.mul_apply', zero_sub]
    rw [show (fun t : ‚ĄĚ => expKernel a t * poitouG (-t)) =
        Set.indicator (Set.Iio (0:‚ĄĚ))
          (fun t => Complex.exp (((a * t : ‚ĄĚ) : ‚Ąā)) * poitouG (-t)) from funext fun t => by
        rw [expKernel]
        by_cases h : t ‚ąą Set.Iio (0:‚ĄĚ) <;> simp [h]]
    rw [integral_indicator measurableSet_Iio]
    have hni := integral_comp_neg_Ioi (0:‚ĄĚ)
      (fun t => Complex.exp (((a * t : ‚ĄĚ) : ‚Ąā)) * poitouG (-t))
    rw [neg_zero] at hni
    rw [setIntegral_congr_set Iio_ae_eq_Iic, ‚Üź hni]
    refine setIntegral_congr_fun measurableSet_Ioi fun u _ => ?_
    rw [neg_neg]
    congr 2
    push_cast
    ring
  have hkey : (2 * Real.pi)‚ĀĽ¬Ļ ‚ÄĘ
      (‚ąę t : ‚ĄĚ, poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I)) = w 0 := by
    rw [‚Üź habs, ‚Üź hchange, ‚Üź hL, hinv]
  have h2ŌÄ : (0:‚ĄĚ) < 2 * Real.pi := by positivity
  calc (‚ąę t : ‚ĄĚ, poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I))
      = ((2 * Real.pi) * (2 * Real.pi)‚ĀĽ¬Ļ) ‚ÄĘ
        (‚ąę t : ‚ĄĚ, poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I)) := by
        rw [mul_inv_cancel‚āÄ h2ŌÄ.ne', one_smul]
    _ = (2 * Real.pi) ‚ÄĘ ((2 * Real.pi)‚ĀĽ¬Ļ ‚ÄĘ
        (‚ąę t : ‚ĄĚ, poitouPhi (5 / 4 + t * Complex.I) / ((a : ‚Ąā) + t * Complex.I))) := by
        rw [mul_smul]
    _ = (2 * Real.pi) ‚ÄĘ w 0 := by rw [hkey]
    _ = (2 * Real.pi) ‚ÄĘ ‚ąę u in Set.Ioi (0:‚ĄĚ),
          Complex.exp (((-(a * u) : ‚ĄĚ) : ‚Ąā)) * poitouG u := by rw [hw0]

/-- **The trivial `L¬Ļ` bound of `ő¶` on the line** (PROVEN 2026-07-24):
`‚ÄĖő¶(5/4 + it)‚ÄĖ ‚Č§ ‚ÄĖG‚ÄĖ‚āĀ` uniformly in `t`. -/
theorem poitouPhi_line_norm_le_const (t : ‚ĄĚ) :
    ‚ÄĖpoitouPhi (5 / 4 + t * Complex.I)‚ÄĖ ‚Č§ ‚ąę x : ‚ĄĚ, ‚ÄĖpoitouG x‚ÄĖ := by
  rw [poitouPhi_line_eq]
  refine (norm_integral_le_integral_norm _).trans (le_of_eq ?_)
  refine integral_congr_ae (Filter.Eventually.of_forall fun x => ?_)
  show ‚ÄĖpoitouG x * Complex.exp (((t * x : ‚ĄĚ) : ‚Ąā) * Complex.I)‚ÄĖ = ‚ÄĖpoitouG x‚ÄĖ
  rw [norm_mul, Complex.norm_exp_ofReal_mul_I, mul_one]

