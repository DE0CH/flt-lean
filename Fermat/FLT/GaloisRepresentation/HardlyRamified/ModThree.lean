      (by exact_mod_cast hval_lt) (by rw [pow_one]; exact hО¶spec)
    have h2 : ((PadicInt.toZModPow 1)
        ((cyclotomicCharacter (AlgebraicClosure в„ҡ) 3
          (g'.toRingEquiv) : в„Ө_[3]ЛЈ) : в„Ө_[3])).val = 1 := h1.symm
