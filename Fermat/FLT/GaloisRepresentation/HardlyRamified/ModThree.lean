    have hkey : c‚āÄ ^ 2 * r = (d : ‚Ąö) := by
      have hnum : (r.num : ‚Ąö) = r * ((r.den : ‚Ąē) : ‚Ąö) :=
        (div_eq_iff hdenq).mp (Rat.num_div_den r)
      have hbdq : ((b : ‚Ąē) : ‚Ąö) ^ 2 * (d : ‚Ąö) =
