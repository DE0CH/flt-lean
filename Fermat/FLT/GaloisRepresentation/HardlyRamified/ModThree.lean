narrow class groups `hвҒә = 1, 1, 1, 2, 1, 2, 2` are elementary
`2`-groups, killing odd characters) вҖ” with the assembly PROVEN here:
at `q = 3` the eighth-power kill of leaf (a) combines with the odd
pointwise order through `orderOf вҲЈ gcd(8, n) = 1`, extending `hОҪunr`
to every prime, and leaf (b) concludes): a function
`ОҪ : О“ в„ҡ вҶ’ рқ”ҪМ„вӮғ` that is a nonvanishing multiplicative character on
`H = ker Оё' = О“_{в„ҡ(вҲҡd)}` (`hОҪmul`, `hОҪne0`), trivial on an OPEN
subgroup `U вүӨ H` (`hUopen`, `hUker` вҖ” so `ОҪ` factors through a finite
abelian extension of `в„ҡ(вҲҡd)`), of ODD pointwise order coprime to `3`
(`hОҪodd`), and trivial on EVERY `О“ в„ҡ`-conjugate of the local inertia
image at every prime `q вү  3` that lies in `H` (`hОҪunr` вҖ” i.e. `ОҪ` is
unramified at every place of `в„ҡ(вҲҡd)` not above `3`), is identically
`1` on `H`. No Galois representation appears: this node is pure
class field theory over the seven quadratic fields, and NO
anti-equivariance is needed for the odd part. -/
theorem odd_order_character_eq_one_ray_class
    (Оё' : О“ в„ҡ вҶ’* Multiplicative (ZMod 2))
    (d : в„Ө)
    (hd : d = -1 вҲЁ d = 2 вҲЁ d = -2 вҲЁ d = 3 вҲЁ d = -3 вҲЁ d = 6 вҲЁ d = -6)
    (x : AlgebraicClosure в„ҡ) (hx : x ^ 2 = (d : AlgebraicClosure в„ҡ))
    (hОё'x : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ” g x = x)
    (ОҪ : О“ в„ҡ вҶ’ Dickson.K 3)
    (hОҪmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ОҪ (g * h) = ОҪ g * ОҪ h)
    (hОҪne0 : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g вү  0)
    (U : Subgroup (О“ в„ҡ)) (hUopen : IsOpen (U : Set (О“ в„ҡ)))
    (hUker : вҲҖ g вҲҲ U, Оё' g = 1 вҲ§ ОҪ g = 1)
    (hОҪodd : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’
      вҲғ n : в„•, 0 < n вҲ§ Odd n вҲ§ В¬ (3 вҲЈ n) вҲ§ ОҪ g ^ n = 1)
    (hОҪunr : вҲҖ (q : в„•) (hq : q.Prime), q вү  3 вҶ’ вҲҖ c : О“ в„ҡ,
      вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        Оё' (c * Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ * cвҒ»В№) = 1 вҶ’
        ОҪ (c * Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ * cвҒ»В№) = 1) :
    вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g = 1 := by
  refine odd_character_eq_one_of_unramified_everywhere_ray_class Оё' d hd
    x hx hОё'x ОҪ hОҪmul hОҪne0 U hUopen hUker hОҪodd ?_
  intro q hq c Пғ hПғ hОё
  by_cases hq3 : q = 3
  В· subst hq3
    have h8 := character_pow_eight_localInertia_three_eq_one_ray_class Оё'
      ОҪ hОҪmul hОҪne0 U hUopen hUker hОҪodd c Пғ hПғ hОё
    obtain вҹЁn, hn0, hnodd, hn3, hgnвҹ© := hОҪodd _ hОё
    have hdgcd := Nat.dvd_gcd (orderOf_dvd_of_pow_eq_one h8)
      (orderOf_dvd_of_pow_eq_one hgn)
    have hco : Nat.gcd 8 n = 1 := by
      have h2n : Nat.Coprime 2 n :=
        (Nat.prime_two.coprime_iff_not_dvd).mpr (by
          rw [Nat.odd_iff] at hnodd
          omega)
      exact Nat.Coprime.pow_left 3 h2n
    rw [hco, Nat.dvd_one] at hdgcd
    exact orderOf_eq_one_iff.mp hdgcd
  В· exact hОҪunr q hq hq3 c Пғ hПғ hОё

/-- **A quadratic character of `О“_{в„ҡ(вҲҡ-3)}` unramified outside `3` is
