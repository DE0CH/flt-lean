open scoped Classical in
/-- **The derivative of the minimal polynomial as a product of conjugate
differences** (Serre, *Corps Locaux* III ¬ß6 Cor. 2 input, global form): for
a primitive algebraic integer `őł` of the Galois number field `K/‚Ąö`,
`f'(őł) = ‚ąŹ_{ŌÉ ‚Č† 1} (őł ‚ąí ŌÉőł)` in `ūĚďě K`, where `f = minpoly ‚Ą§ őł`.  Indeed
`minpoly ‚Ąö őł` splits in `K` with simple roots exactly the `#Gal(K/‚Ąö)`
distinct conjugates `ŌÉőł` (primitivity makes `ŌÉ ‚Ü¶ ŌÉőł` injective), so its
image in `K[X]` is the Lagrange nodal polynomial of the conjugates, whose
derivative at the node `őł` is the product of the differences
(`Lagrange.eval_nodal_derivative_eval_node_eq`). -/
theorem aeval_derivative_minpoly_eq_prod_sub_smul
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    [IsGalois ‚Ąö K]
    (őł : NumberField.RingOfIntegers K)
    (hőł : Algebra.adjoin ‚Ąö
      {(algebraMap (NumberField.RingOfIntegers K) K őł : K)} = ‚ä§) :
    Polynomial.aeval őł (Polynomial.derivative (minpoly ‚Ą§ őł)) =
      ‚ąŹ ŌÉ ‚ąą Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K), (őł - ŌÉ ‚ÄĘ őł) := by
  have hint : IsIntegral ‚Ą§ őł := Algebra.IsIntegral.isIntegral őł
  have hintK : IsIntegral ‚Ąö
      (algebraMap (NumberField.RingOfIntegers K) K őł : K) :=
    IsIntegral.of_finite ‚Ąö _
  set őłK : K := algebraMap (NumberField.RingOfIntegers K) K őł with hőłKdef
  set v : (K ‚ČÉ‚āź[‚Ąö] K) ‚Üí K := fun ŌÉ => ŌÉ őłK with hvdef
  -- injectivity of the conjugate map
  have hvinj : Function.Injective v := by
    intro ŌÉ ŌĄ hŌÉŌĄ
    have h1 : (ŌĄ‚ĀĽ¬Ļ * ŌÉ) őłK = őłK := by
      have h2 : ŌĄ‚ĀĽ¬Ļ (ŌÉ őłK) = ŌĄ‚ĀĽ¬Ļ (ŌĄ őłK) := congrArg _ hŌÉŌĄ
      rwa [‚Üź AlgEquiv.mul_apply, ‚Üź AlgEquiv.mul_apply, inv_mul_cancel,
        AlgEquiv.one_apply] at h2
    have h3 : ŌĄ‚ĀĽ¬Ļ * ŌÉ = 1 := algEquiv_eq_one_of_algebraMap_fixed K hőł h1
    rw [‚Üź one_mul ŌÉ, ‚Üź mul_inv_cancel ŌĄ, mul_assoc, h3, mul_one]
  -- the mapped minimal polynomial
  set P : Polynomial K :=
    (minpoly ‚Ąö őłK).map (algebraMap ‚Ąö K) with hPdef
  have hPmonic : P.Monic := (minpoly.monic hintK).map _
  have hPsplits : P.Splits := by
    rw [hPdef]
    exact Normal.splits inferInstance őłK
  have hPdeg : P.natDegree = Fintype.card (K ‚ČÉ‚āź[‚Ąö] K) := by
    have hadj : IntermediateField.adjoin ‚Ąö {őłK} = ‚ä§ := by
      refine IntermediateField.toSubalgebra_injective ?_
      rw [IntermediateField.adjoin_simple_toSubalgebra_of_isAlgebraic
        hintK.isAlgebraic, IntermediateField.top_toSubalgebra]
      exact hőł
    have hdeg : (minpoly ‚Ąö őłK).natDegree = Module.finrank ‚Ąö K := by
      rw [‚Üź IntermediateField.adjoin.finrank hintK, hadj]
      exact IntermediateField.finrank_top'
    have h2 : P.natDegree = (minpoly ‚Ąö őłK).natDegree := by
      rw [hPdef]
      exact Polynomial.natDegree_map_eq_of_injective
        (algebraMap ‚Ąö K).injective _
    rw [h2, hdeg, ‚Üź Nat.card_eq_fintype_card]
    exact (IsGalois.card_aut_eq_finrank ‚Ąö K).symm
  -- the roots of `P` are exactly the conjugates
  have hroots : P.roots = Finset.univ.val.map v := by
    symm
    refine Multiset.eq_of_le_of_card_le ?_ ?_
    ¬∑ rw [Multiset.le_iff_count]
      intro a
      by_cases ha : a ‚ąą Finset.univ.val.map v
      ¬∑ rw [Multiset.count_eq_one_of_mem
          (Finset.univ.nodup.map hvinj) ha]
        rw [Nat.one_le_iff_ne_zero, Ne, Multiset.count_eq_zero,
          not_not]
        obtain ‚ü®ŌÉ, -, rfl‚ü© := Multiset.mem_map.mp ha
        rw [Polynomial.mem_roots (hPmonic.ne_zero)]
        rw [Polynomial.IsRoot, hPdef, Polynomial.eval_map,
          ‚Üź Polynomial.aeval_def, hvdef]
        have h2 : Polynomial.aeval (ŌÉ őłK) (minpoly ‚Ąö őłK) =
            ŌÉ (Polynomial.aeval őłK (minpoly ‚Ąö őłK)) :=
          Polynomial.aeval_algHom_apply ŌÉ.toAlgHom őłK (minpoly ‚Ąö őłK)
        rw [h2, minpoly.aeval, map_zero]
      ¬∑ rw [Multiset.count_eq_zero_of_notMem ha]
        exact Nat.zero_le _
    ¬∑ rw [Multiset.card_map, ‚Üź Finset.card_def, Finset.card_univ,
        Polynomial.splits_iff_card_roots.mp hPsplits, hPdeg]
  -- `P` is the nodal polynomial of the conjugates
  have hnodal : P = Lagrange.nodal Finset.univ v := by
    rw [hPsplits.eq_prod_roots_of_monic hPmonic,
      hroots, Lagrange.nodal, Finset.prod_eq_multiset_prod,
      Multiset.map_map]
    rfl
  -- evaluate the derivative at the node `1`
  have hKeval : Polynomial.eval őłK (Polynomial.derivative P) =
      ‚ąŹ ŌÉ ‚ąą Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K), (őłK - v ŌÉ) := by
    have h1 : őłK = v 1 := by rw [hvdef]; rfl
    rw [hnodal, h1, Lagrange.eval_nodal_derivative_eval_node_eq
      (Finset.mem_univ 1), Lagrange.eval_nodal]
  -- pull everything back to `ūĚďě K`
  apply FaithfulSMul.algebraMap_injective (NumberField.RingOfIntegers K) K
  have hLHS : algebraMap (NumberField.RingOfIntegers K) K
      (Polynomial.aeval őł (Polynomial.derivative (minpoly ‚Ą§ őł))) =
      Polynomial.eval őłK (Polynomial.derivative P) := by
    have h1 : algebraMap (NumberField.RingOfIntegers K) K
        (Polynomial.aeval őł (Polynomial.derivative (minpoly ‚Ą§ őł))) =
        Polynomial.aeval őłK (Polynomial.derivative (minpoly ‚Ą§ őł)) := by
      rw [hőłKdef]
      exact (Polynomial.aeval_algebraMap_apply K őł _).symm
    rw [h1, hPdef, minpoly.isIntegrallyClosed_eq_field_fractions ‚Ąö K hint,
      Polynomial.derivative_map, Polynomial.derivative_map,
      Polynomial.eval_map, Polynomial.eval‚āā_map, Polynomial.aeval_def]
    congr 1
  rw [hLHS, hKeval, map_prod]
  refine Finset.prod_congr rfl fun ŌÉ _ => ?_
  rw [map_sub, hvdef, hőłKdef]
  congr 1

open scoped Classical in
/-- **The double count of the ramification filtration** (Serre, *Corps
Locaux* IV ¬ß1, proof of Prop. 4): summing over the nontrivial `ŌÉ` the number
of levels `i < n` at which `ŌÉ ‚ąą G_i = inertia(Q^(i+1))` equals
`ő£_{i<n} (#G_i ‚ąí 1)` ‚ÄĒ count the pairs `(ŌÉ, i)` with `ŌÉ ‚ąą G_i \ {1}` both
ways. -/
theorem sum_card_filter_inertia_eq
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (n : ‚Ąē) :
    ‚ąĎ ŌÉ ‚ąą Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K),
      ((Finset.range n).filter
        (fun i => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).card =
    ‚ąĎ i ‚ąą Finset.range n,
      (Nat.card ((Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K)) - 1) := by
  simp only [Finset.card_filter]
  rw [Finset.sum_comm]
  refine Finset.sum_congr rfl fun i _ => ?_
  rw [show (‚ąĎ ŌÉ ‚ąą Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K),
      if ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K) then 1 else 0) =
      ((Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K)).filter
        (fun ŌÉ => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).card from
    (Finset.card_filter
      (fun ŌÉ => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))
      (Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K))).symm]
  have h2 : (Finset.univ.erase (1 : K ‚ČÉ‚āź[‚Ąö] K)).filter
      (fun ŌÉ => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K)) =
      (Finset.univ.filter
        (fun ŌÉ => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).erase 1 :=
    Finset.filter_erase _ _ _
  rw [h2, Finset.card_erase_of_mem
    (Finset.mem_filter.mpr ‚ü®Finset.mem_univ _, Subgroup.one_mem _‚ü©)]
  congr 1
  rw [Nat.card_eq_fintype_card]
  exact (Fintype.card_subtype
    (fun ŌÉ => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).symm

/-- **The different-exponent bound through the lower ramification
filtration** (PROVEN 2026-07-24 ‚ÄĒ leaf (a) of the decomposition of the
wild Fontaine bound below; Serre, *Corps Locaux* IV ¬ß1 Prop. 4, `‚Č§`
direction, proven GLOBALLY, avoiding the completion entirely): if `Q^d`
divides the different ideal `ūĚĒ°_{K/‚Ąö}` at a nonzero prime `Q` of the
Galois number field `K/‚Ąö`, then `d ‚Č§ ő£_{i<n} (#G_i ‚ąí 1)`, where
`G_i = inertia(Q^(i+1)) = {ŌÉ ‚ąą Gal(K/‚Ąö) | ‚ąÄ x ‚ąą ūĚďě K, ŌÉx ‚ąí x ‚ąą Q^(i+1)}`
is the `i`-th lower-numbering ramification group at `Q` and the level
`n` already has `G_n = ‚ä•` (so the truncated sum is the full one).
Proof: choose the master generator `őł` of
`exists_dense_primitive_generator` ‚ÄĒ a primitive algebraic integer with
`‚Ą§[őł]` dense modulo `Q^(n+2)` and `ŌÉőł ‚ČĘ őł (mod Q)` for every `ŌÉ` moving
`Q` (Serre's III ¬ß6 Prop. 12 residue-generator-plus-uniformizer
construction, CRT against the conjugate primes, and a pigeonhole over
the finitely many intermediate fields for primitivity).  The different
divides `(f'(őł))` (mathlib's `conductor_mul_differentIdeal`), and
`f'(őł) = ‚ąŹ_{ŌÉ‚Č†1} (őł ‚ąí ŌÉőł)` since the minimal polynomial is the Lagrange
nodal polynomial of the conjugates
(`aeval_derivative_minpoly_eq_prod_sub_smul`).  Each factor lies in `Q`
to order at most `#{i < n : ŌÉ ‚ąą G_i}`: a congruence `ŌÉőł ‚Č° őł (mod
Q^(i+1))` propagates to all of `ūĚďě K` by density
(`mem_inertia_pow_of_smul_sub_mem_of_dense`), so an exponent beyond the
count would either put `ŌÉ` into `G_n = ‚ä•` or overfill the count.
Unique factorization collects the factor bounds into
`d ‚Č§ ő£_{ŌÉ‚Č†1} #{i<n : ŌÉ ‚ąą G_i}`, and the double count
`sum_card_filter_inertia_eq` converts the total to
`ő£_{i<n} (#G_i ‚ąí 1)`. -/
theorem le_sum_card_inertia_pow_of_pow_dvd_differentIdeal
    (K : IntermediateField ‚Ąö (AlgebraicClosure ‚Ąö)) [NumberField K]
    [IsGalois ‚Ąö K]
    (Q : Ideal (NumberField.RingOfIntegers K)) (hQ : Q.IsPrime)
    (hQbot : Q ‚Č† ‚ä•)
    (n : ‚Ąē) (hn : (Q ^ (n + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K) = ‚ä•)
    (d : ‚Ąē) (hd : Q ^ d ‚ą£ differentIdeal ‚Ą§ (NumberField.RingOfIntegers K)) :
    d ‚Č§ ‚ąĎ i ‚ąą Finset.range n,
      (Nat.card ((Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K)) - 1) := by
  classical
  haveI := hQ
  haveI : Q.IsMaximal := hQ.isMaximal hQbot
  -- the master generator at level `n + 2`
  obtain ‚ü®őł, hőłtop, hőłdens, hőłconj‚ü© :=
    exists_dense_primitive_generator K Q hQ hQbot (n + 2) (by omega)
  -- the product formula
  have hprod := aeval_derivative_minpoly_eq_prod_sub_smul K őł hőłtop
  -- the different divides the span of `f'(őł)`
  have hdiv : differentIdeal ‚Ą§ (NumberField.RingOfIntegers K) ‚ą£
      Ideal.span
        {Polynomial.aeval őł (Polynomial.derivative (minpoly ‚Ą§ őł))} :=
    ‚ü®conductor ‚Ą§ őł, by
      rw [mul_comm]
      exact (conductor_mul_differentIdeal ‚Ą§ ‚Ąö K őł hőłtop).symm‚ü©
  -- the per-`ŌÉ` bound: `őł ‚ąí ŌÉőł ‚ąČ Q^{#{i<n : ŌÉ ‚ąą G_i} + 1}`
  have hnotmem : ‚ąÄ ŌÉ : K ‚ČÉ‚āź[‚Ąö] K, ŌÉ ‚Č† 1 ‚Üí
      őł - ŌÉ ‚ÄĘ őł ‚ąČ Q ^ (((Finset.range n).filter
        (fun i => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).card + 1) := by
    intro ŌÉ hŌÉ1 hmem
    have hmQ : ŌÉ ‚ÄĘ őł - őł ‚ąą Q := by
      have h1 : őł - ŌÉ ‚ÄĘ őł ‚ąą Q := Ideal.pow_le_self (Nat.succ_ne_zero _) hmem
      have h2 : ŌÉ ‚ÄĘ őł - őł = -(őł - ŌÉ ‚ÄĘ őł) := by ring
      rw [h2]
      exact Submodule.neg_mem _ h1
    have hŌÉQ : ŌÉ ‚ÄĘ Q = Q := by
      by_contra hne
      exact hőłconj ŌÉ hne hmQ
    have hmle : ((Finset.range n).filter
        (fun i => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).card ‚Č§ n :=
      le_trans (Finset.card_filter_le _ _) (le_of_eq (Finset.card_range n))
    have hGi : ‚ąÄ i, i ‚Č§ ((Finset.range n).filter
        (fun i => ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K))).card ‚Üí
        ŌÉ ‚ąą (Q ^ (i + 1)).inertia (K ‚ČÉ‚āź[‚Ąö] K) := by
      intro i hi
      refine mem_inertia_pow_of_smul_sub_mem_of_dense K Q (i + 1)
        (őł := őł) ?_ hŌÉQ ?_
      ¬∑ intro y
        obtain ‚ü®h, hh‚ü© := hőłdens y
