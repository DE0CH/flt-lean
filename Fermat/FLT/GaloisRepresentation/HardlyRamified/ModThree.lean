/-- **The flatness-to-package collapse at `3`** (PROVEN 2026-07-24 вҖ”
the same `вҠҘ`-ideal collapse as in the proof of
`exists_connectedEtale_subgroup_at_three` further down the file,
factored out so the Fontaine different-bound assembly below can
consume the EXPLICIT Hopf package): a representation flat at `3` over
a finite discrete char-3 coefficient field has a flat prolongation at
`3` in the sense of `GaloisRep.HasFlatProlongationAt`.  Proof:
`IsFlatAt` at the open ideal `вҠҘ` of the discrete field `k` gives the
package for the base change `ПҒ вҠ— (k в§ё вҠҘ)`; the coefficient collapse
`k в§ё вҠҘ вүғ+* k` (`RingEquiv.quotientBot`) induces a `О“ в„ҡвӮғбөҘ`-equivariant
additive isomorphism `(k в§ё вҠҘ) вҠ—[k] V вүғ+ V` (tensor `congr` + `lid`),
along which `HasFlatProlongationAt.of_equiv` transports the package
to `ПҒ` itself. -/
theorem hasFlatProlongationAt_three_of_isFlatAt
    {k : Type u} [Finite k] [Field k] [Algebra в„Ө_[3] k]
    [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    {ПҒ : GaloisRep в„ҡ k V}
    (hflat : ПҒ.IsFlatAt Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat) :
    ПҒ.HasFlatProlongationAt
      Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat := by
  classical
  set v := Nat.prime_three.toHeightOneSpectrumRingOfIntegersRat
  -- flatness at the open ideal `вҠҘ` of the discrete field `k`
  have h0 := hflat.cond вҠҘ (isOpen_discrete _)
  -- the coefficient collapse `k в§ё вҠҘ вүғвӮ—[k] k`
  let ПҶq : (k в§ё (вҠҘ : Ideal k)) вүғ+* k := RingEquiv.quotientBot k
  have hПҶalg : вҲҖ r : k, ПҶq (algebraMap k (k в§ё (вҠҘ : Ideal k)) r) = r :=
    fun _ => rfl
  let ПҶlin : (k в§ё (вҠҘ : Ideal k)) вүғвӮ—[k] k :=
    { ПҶq.toAddEquiv with
      map_smul' := fun r x => by
        show ПҶq (r вҖў x) = r вҖў ПҶq x
        rw [Algebra.smul_def, Algebra.smul_def, map_mul, hПҶalg,
          Algebra.algebraMap_self_apply] }
  -- the equivariant space identification `(k в§ё вҠҘ) вҠ—[k] V вүғ+ V`
  let e : (((ПҒ.baseChange (k в§ё (вҠҘ : Ideal k))).toLocal v).Space вүғ+
      ((ПҒ.toLocal v).Space)) :=
    ((TensorProduct.congr ПҶlin (LinearEquiv.refl k V)).trans
      (TensorProduct.lid k V)).toAddEquiv
  have he : вҲҖ (g : О“ (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ v))
      (x : ((ПҒ.baseChange (k в§ё (вҠҘ : Ideal k))).toLocal v).Space),
      e (g вҖў x) = g вҖў e x := by
    intro g x
    show e (((ПҒ.baseChange (k в§ё (вҠҘ : Ideal k))).toLocal v) g x) =
      ((ПҒ.toLocal v) g) (e x)
    induction x using TensorProduct.induction_on with
    | zero => simp
    | add a b ha hb => simp only [map_add, ha, hb]
    | tmul c y =>
      show ((TensorProduct.congr ПҶlin (LinearEquiv.refl k V)).trans
          (TensorProduct.lid k V)) (c вҠ—вӮң[k] ((ПҒ.toLocal v) g y)) =
        ((ПҒ.toLocal v) g) (((TensorProduct.congr ПҶlin
          (LinearEquiv.refl k V)).trans (TensorProduct.lid k V)) (c вҠ—вӮң[k] y))
      simp only [LinearEquiv.trans_apply, TensorProduct.congr_tmul,
        LinearEquiv.refl_apply, TensorProduct.lid_tmul, map_smul]
  exact h0.of_equiv _ e he

