    В· rcases eq_or_lt_of_le (neg_le_of_abs_le hx) with hx6 | hx6
      В· rw [Set.indicator_of_notMem (by simp [вҶҗ hx6])]
        rw [odlyzkoTestFn, вҶҗ hx6]
