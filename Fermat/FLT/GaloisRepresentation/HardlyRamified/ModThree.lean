        map_mul, map_mul, map_inv,
        mul_comm (cyclotomicCharacter (AlgebraicClosure ‚Ąö) 3 c.toRingEquiv),
        mul_assoc, mul_inv_cancel, mul_one]
    rw [h, hconj]
    exact cyclotomicCharacter_algebraMap_eq_one_of_inertia_two (k := k) hŌĄ
  -- (2) the tame structure at `2`: the functional `ŌÄ‚āā` is `ŌĀ m`-invariant,
  -- so its conjugate `ŌÄ'` is `ŌĀ g'`-invariant and surjective
