      simpa using h1.symm
    have hőłP : őł ‚ąą ŌÉ‚ĀĽ¬Ļ ‚ÄĘ Q := by
      have h1 : őł‚āā ‚ąą ŌÉ‚ĀĽ¬Ļ ‚ÄĘ Q := hőł‚āāS _ hin
      have h2 : (c‚āĀ : ‚Ą§) ‚ÄĘ w ‚ąą ŌÉ‚ĀĽ¬Ļ ‚ÄĘ Q := zsmul_mem (hJS _ hin hwJ) _
      rw [hőłdef]
      exact Submodule.add_mem _ h1 h2
