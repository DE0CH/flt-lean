  have hОҙП„ : Оҙ П„ = 1 := by
    have h := (hОҙ П„ 0).2.1 hП„
    rwa [GaloisRep.ker, MonoidHom.mem_ker] at h
  have hПҖm : вҲҖ x : V, ПҖвӮӮ (ПҒ m x) = ПҖвӮӮ x := by
    intro x
    have h := (hОҙ П„ x).1
    rw [GaloisRep.map_apply, вҶҗ hm] at h
    rw [h, hОҙП„, Module.End.one_apply]
  set ПҖ' : V вҶ’вӮ—[k] k := ПҖвӮӮ.comp (ПҒ cвҒ»В№ : Module.End k V) with hПҖ'
  have hПҖ'surj : Function.Surjective ПҖ' := by
    intro r
    obtain вҹЁx, hxвҹ© := hПҖsurj r
    refine вҹЁПҒ c x, ?_вҹ©
    rw [hПҖ', LinearMap.comp_apply]
    have hcc : (ПҒ cвҒ»В№) ((ПҒ c) x) = x := by
      rw [вҶҗ Module.End.mul_apply, вҶҗ map_mul, inv_mul_cancel, map_one,
        Module.End.one_apply]
    rw [hcc, hx]
  have hПҖ'inv : вҲҖ x : V, ПҖ' (ПҒ g' x) = ПҖ' x := by
    intro x
    rw [hПҖ', LinearMap.comp_apply, LinearMap.comp_apply]
    have h1 : (ПҒ cвҒ»В№ : Module.End k V) * ПҒ g' =
        ПҒ m * (ПҒ cвҒ»В№ : Module.End k V) := by
      rw [вҶҗ map_mul, вҶҗ map_mul, heq]
      congr 1
      group
    have h2 := congrArg (fun F : Module.End k V => F x) h1
    simp only [Module.End.mul_apply] at h2
    rw [h2, hПҖm]
  -- (3) hence `det (ПҒ g' - 1) = 0`: the row of `ПҖ'`-values is a nonzero
  -- kernel covector of its matrix
  have hfr : Module.finrank k V = 2 :=
    Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
  have hdet0 : LinearMap.det ((ПҒ g' : Module.End k V) - 1) = 0 := by
    set bk : Module.Basis (Fin 2) k V := Module.finBasisOfFinrankEq k V hfr
    rw [вҶҗ LinearMap.det_toMatrix bk, вҶҗ Matrix.exists_vecMul_eq_zero_iff]
    refine вҹЁfun i => ПҖ' (bk i), ?_, ?_вҹ©
    В· intro h0
      obtain вҹЁx, hxвҹ© := hПҖ'surj 1
      have hzero : вҲҖ i, ПҖ' (bk i) = 0 := fun i => congrFun h0 i
      have hpx : ПҖ' x = 0 := by
        rw [вҶҗ bk.sum_repr x, map_sum]
        simp [map_smul, hzero]
      rw [hx] at hpx
      exact one_ne_zero hpx
    В· funext j
      simp only [Matrix.vecMul, dotProduct, LinearMap.toMatrix_apply,
        Pi.zero_apply]
      have hterm : вҲҖ i : Fin 2,
          ПҖ' (bk i) * (bk.repr (((ПҒ g' : Module.End k V) - 1) (bk j))) i =
          ПҖ' ((bk.repr (((ПҒ g' : Module.End k V) - 1) (bk j))) i вҖў bk i) := by
        intro i
        rw [map_smul, smul_eq_mul, mul_comm]
      rw [Finset.sum_congr rfl fun i _ => hterm i, вҶҗ map_sum, bk.sum_repr]
      simp only [LinearMap.sub_apply, Module.End.one_apply, map_sub, hПҖ'inv,
        sub_self]
  -- (4) transport both determinants to the matrix `N = u g'` over `K 3`
  set N : Matrix (Fin 2) (Fin 2) (Dickson.K 3) :=
    ((u g' : GL (Fin 2) (Dickson.K 3)) : Matrix (Fin 2) (Fin 2) (Dickson.K 3))
    with hN
  have hПғПҒ : вҲҖ g : О“ в„ҡ, (Slop.OddRep.baseChange (AlgebraicClosure k)
      (MonoidHomClass.toMonoidHom ПҒ)) g =
      LinearMap.baseChange (AlgebraicClosure k) (ПҒ g) := fun g => rfl
  have hNval : N = (LinearMap.toMatrix b b
      (LinearMap.baseChange (AlgebraicClosure k) (ПҒ g'))).map e := by
    rw [hN, hu g', hПғПҒ]
  have hdet_transport : вҲҖ f : Module.End k V,
      ((LinearMap.toMatrix b b
        (LinearMap.baseChange (AlgebraicClosure k) f)).map e).det =
      e (algebraMap k (AlgebraicClosure k) (LinearMap.det f)) := by
    intro f
    rw [show (LinearMap.toMatrix b b
        (LinearMap.baseChange (AlgebraicClosure k) f)).map вҮ‘e =
      (e : AlgebraicClosure k вҶ’+* Dickson.K 3).mapMatrix
        (LinearMap.toMatrix b b (LinearMap.baseChange (AlgebraicClosure k) f))
      from rfl]
    rw [вҶҗ RingHom.map_det]
    rw [LinearMap.det_toMatrix, LinearMap.det_baseChange]
    rfl
  have hNdet : N.det = 1 := by
    rw [hNval, hdet_transport, hdetk, map_one, map_one]
  have hNsub : N - 1 = (LinearMap.toMatrix b b (LinearMap.baseChange
      (AlgebraicClosure k) ((ПҒ g' : Module.End k V) - 1))).map e := by
    rw [hNval]
    have h1 : LinearMap.baseChange (AlgebraicClosure k)
        (1 : Module.End k V) =
        (LinearMap.id : (AlgebraicClosure k) вҠ—[k] V
          вҶ’вӮ—[AlgebraicClosure k] (AlgebraicClosure k) вҠ—[k] V) := by
      rw [show ((1 : Module.End k V) : V вҶ’вӮ—[k] V) = LinearMap.id from rfl,
        LinearMap.baseChange_id]
    have hpt : вҲҖ j : Fin 2, (LinearMap.baseChange (AlgebraicClosure k)
        ((ПҒ g' : Module.End k V) - 1)) (b j) =
        (LinearMap.baseChange (AlgebraicClosure k) (ПҒ g')) (b j) - b j := by
      intro j
      rw [LinearMap.baseChange_sub, LinearMap.sub_apply, h1,
        LinearMap.id_apply]
    ext i j
    simp only [Matrix.sub_apply, Matrix.map_apply, Matrix.one_apply,
      LinearMap.toMatrix_apply, hpt, map_sub, Finsupp.sub_apply,
      Module.Basis.repr_self, Finsupp.single_apply]
    split
    В· rename_i hij
      simp [hij]
    В· rename_i hij
      rw [if_neg (fun h => hij h.symm)]
      simp
  have hNone : (N - 1).det = 0 := by
    rw [hNsub, hdet_transport, hdet0, map_zero, map_zero]
  -- (5) the two determinants force `tr N = 2`
