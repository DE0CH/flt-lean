      rw [h1, hCH, ‚Üź hs2, sq, sub_self]
    have hdet0 : Matrix.det (f - s ‚ÄĘ 1) = 0 ‚ą® Matrix.det (f + s ‚ÄĘ 1) = 0 := by
      have h1 : Matrix.det (f - s ‚ÄĘ 1) * Matrix.det (f + s ‚ÄĘ 1) = 0 := by
        rw [‚Üź Matrix.det_mul, hfact]
        exact Matrix.det_zero
      exact mul_eq_zero.mp h1
    obtain ‚ü®t, htdet‚ü© : ‚ąÉ t : Dickson.K 3, Matrix.det (f - t ‚ÄĘ 1) = 0 := by
      rcases hdet0 with h1 | h1
      ¬∑ exact ‚ü®s, h1‚ü©
      ¬∑ refine ‚ü®-s, ?_‚ü©
        rw [neg_smul, sub_neg_eq_add]
        exact h1
    obtain ‚ü®v, hv0, hvker‚ü© := Matrix.exists_mulVec_eq_zero_iff.mpr htdet
    -- `f` is nonscalar (it has an anticommuting partner)
    have hfns : f - t ‚ÄĘ 1 ‚Č† 0 := by
      intro h0
      have hf : f = t ‚ÄĘ 1 := by rwa [sub_eq_zero] at h0
      apply hexcl p ?_ hp
      rw [hf, mul_smul_comm, mul_one, smul_mul_assoc, one_mul]
    -- multiplicativity data for the sign of conjugation on `f`
    have hmulval : ‚ąÄ g h' : őď ‚Ąö, (u (g * h')).val = (u g).val * (u h').val := by
      intro g h'
      rw [map_mul]
      rfl
    have hcc : ‚ąÄ g h' : őď ‚Ąö, (u g).val * f = f * (u g).val ‚Üí
        (u h').val * f = f * (u h').val ‚Üí
        (u (g * h')).val * f = f * (u (g * h')).val := by
      intro g h' hg hh'
      rw [hmulval, mul_assoc, hh', ‚Üź mul_assoc, hg, mul_assoc]
    have hca : ‚ąÄ g h' : őď ‚Ąö, (u g).val * f = f * (u g).val ‚Üí
        (u h').val * f = -(f * (u h').val) ‚Üí
        (u (g * h')).val * f = -(f * (u (g * h')).val) := by
      intro g h' hg hh'
      rw [hmulval, mul_assoc, hh', mul_neg, neg_inj, ‚Üź mul_assoc, hg, mul_assoc]
    have hac : ‚ąÄ g h' : őď ‚Ąö, (u g).val * f = -(f * (u g).val) ‚Üí
        (u h').val * f = f * (u h').val ‚Üí
        (u (g * h')).val * f = -(f * (u (g * h')).val) := by
      intro g h' hg hh'
      rw [hmulval, mul_assoc, hh', ‚Üź mul_assoc, hg, neg_mul, mul_assoc]
    have haa : ‚ąÄ g h' : őď ‚Ąö, (u g).val * f = -(f * (u g).val) ‚Üí
        (u h').val * f = -(f * (u h').val) ‚Üí
        (u (g * h')).val * f = f * (u (g * h')).val := by
      intro g h' hg hh'
      rw [hmulval, mul_assoc, hh', mul_neg, ‚Üź mul_assoc, hg, neg_mul, neg_neg,
        mul_assoc]
    -- the switched character: the sign of conjugation on `f`
    let őł' : őď ‚Ąö ‚Üí* Multiplicative (ZMod 2) :=
      { toFun := fun g => if (u g).val * f = f * (u g).val then 1
          else Multiplicative.ofAdd (1 : ZMod 2)
        map_one' := by
          have h1 : (u 1).val = 1 := by rw [map_one]; rfl
          rw [h1, one_mul, mul_one]
          exact if_pos rfl
        map_mul' := by
          intro g h'
          rcases hdich g with hg | hg <;> rcases hdich h' with hh' | hh'
          ¬∑ rw [if_pos hg, if_pos hh', if_pos (hcc g h' hg hh'), one_mul]
          ¬∑ rw [if_pos hg, if_neg fun hc => hexcl h' hc hh',
              if_neg fun hc => hexcl (g * h') hc (hca g h' hg hh'), one_mul]
          ¬∑ rw [if_neg fun hc => hexcl g hc hg, if_pos hh',
              if_neg fun hc => hexcl (g * h') hc (hac g h' hg hh'), mul_one]
          ¬∑ rw [if_neg fun hc => hexcl g hc hg,
              if_neg fun hc => hexcl h' hc hh',
              if_pos (haa g h' hg hh')]
            decide }
    have hőł'apply : ‚ąÄ g : őď ‚Ąö, őł' g =
        if (u g).val * f = f * (u g).val then 1
        else Multiplicative.ofAdd (1 : ZMod 2) := fun g => rfl
    have hŌČ : Multiplicative.ofAdd (1 : ZMod 2) ‚Č† 1 := by decide
    have hy2 : ‚ąÄ y : Multiplicative (ZMod 2),
        y = 1 ‚ą® y = Multiplicative.ofAdd (1 : ZMod 2) := by decide
    have hsurj' : Function.Surjective őł' := by
      intro y
      rcases hy2 y with rfl | rfl
      ¬∑ exact ‚ü®1, map_one őł'‚ü©
      ¬∑ refine ‚ü®p, ?_‚ü©
        rw [hőł'apply p, if_neg fun hc => hexcl p hc hp]
    have htriv'' : ‚ąÄ g : őď ‚Ąö, ŌĀ g = 1 ‚Üí őł' g = 1 := by
      intro g hg
      rw [hőł'apply g, if_pos (by rw [huone g hg, one_mul, mul_one])]
    refine ‚ü®őł', hsurj', htriv'', v, hv0, ?_‚ü©
    intro g hg
    have hcg : (u g).val * f = f * (u g).val := by
      by_contra hc
      rw [hőł'apply g, if_neg hc] at hg
      exact hŌČ hg
    have hswap : (f - t ‚ÄĘ 1) * (u g).val = (u g).val * (f - t ‚ÄĘ 1) := by
      rw [sub_mul, mul_sub, smul_mul_assoc, one_mul, mul_smul_comm, mul_one, hcg]
    have hwker : Matrix.mulVec (f - t ‚ÄĘ 1) (Matrix.mulVec (u g).val v) = 0 := by
      rw [Matrix.mulVec_mulVec, hswap, ‚Üź Matrix.mulVec_mulVec, hvker,
        Matrix.mulVec_zero]
    exact exists_smul_eq_of_mulVec_eq_zero hfns hvker hwker hv0

/-- **Coordinates from a non-proportional pair** (PROVEN 2026-07-23 ‚ÄĒ
elementary 2√ó2 linear algebra for the induced-structure glue of the
dihedral ray-class decomposition): if `v ‚Č† 0` and `w` is not a scalar
multiple of `v`, then every vector of `Fin 2 ‚Üí F` is a linear
combination of `v` and `w`. Cramer-style explicit coefficients over
the nonzero cross-determinant `v 0 * w 1 - v 1 * w 0`. -/
theorem exists_smul_add_smul_of_not_proportional {F : Type*} [Field F]
    {v w : Fin 2 ‚Üí F} (hv : v ‚Č† 0)
    (hnp : ¬¨ ‚ąÉ c : F, w = c ‚ÄĘ v) (x : Fin 2 ‚Üí F) :
    ‚ąÉ őĪ ő≤ : F, x = őĪ ‚ÄĘ v + ő≤ ‚ÄĘ w := by
  classical
  have hcross : v 0 * w 1 - v 1 * w 0 ‚Č† 0 := by
    intro h
    apply hnp
    have hvi : v 0 ‚Č† 0 ‚ą® v 1 ‚Č† 0 := by
      by_contra hcon
      push Not at hcon
      refine hv (funext fun i => ?_)
      fin_cases i
      ¬∑ exact hcon.1
      ¬∑ exact hcon.2
    rcases hvi with h0 | h1
    ¬∑ refine ‚ü®w 0 / v 0, funext fun i => ?_‚ü©
      fin_cases i
      ¬∑ exact (div_mul_cancel‚āÄ (w 0) h0).symm
      ¬∑ show w 1 = w 0 / v 0 * v 1
        field_simp
        linear_combination h
    ¬∑ refine ‚ü®w 1 / v 1, funext fun i => ?_‚ü©
      fin_cases i
      ¬∑ show w 0 = w 1 / v 1 * v 0
        field_simp
        linear_combination -h
      ¬∑ exact (div_mul_cancel‚āÄ (w 1) h1).symm
  refine ‚ü®(x 0 * w 1 - x 1 * w 0) / (v 0 * w 1 - v 1 * w 0),
    (v 0 * x 1 - v 1 * x 0) / (v 0 * w 1 - v 1 * w 0),
    funext fun i => ?_‚ü©
  fin_cases i
  ¬∑ show x 0 = (x 0 * w 1 - x 1 * w 0) / (v 0 * w 1 - v 1 * w 0) * v 0 +
      (v 0 * x 1 - v 1 * x 0) / (v 0 * w 1 - v 1 * w 0) * w 0
    rw [div_mul_eq_mul_div, div_mul_eq_mul_div, ‚Üź add_div,
      eq_div_iff hcross]
    ring
  ¬∑ show x 1 = (x 0 * w 1 - x 1 * w 0) / (v 0 * w 1 - v 1 * w 0) * v 1 +
      (v 0 * x 1 - v 1 * x 0) / (v 0 * w 1 - v 1 * w 0) * w 1
    rw [div_mul_eq_mul_div, div_mul_eq_mul_div, ‚Üź add_div,
      eq_div_iff hcross]
    ring

