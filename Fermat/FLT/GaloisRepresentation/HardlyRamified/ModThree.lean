/-- **Restriction of the local inertia at `2` to a finite Galois
level** (PROVEN 2026-07-24 вҖ” the at-`2` twin of the at-`3` restriction
lemma `restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_three`
below, same prime-independent argument): the restriction to a finite
Galois subextension `N` of an element of the full local inertia group
at `2` lies in the finite-level inertia subgroup. If a displacement
`П„ вҖў x вҲ’ x` were NOT in `рқ”Ә(IC-N)`, it would be a unit of the local
ring `IC-N`; its image under `integralClosureInclusion` вҖ” which equals
`Пғ вҖў xМӮ вҲ’ xМӮ` by `AlgEquiv.restrictNormal_commutes` вҖ” would then be a
unit of the big integral closure lying in `рқ”Ә(IC-big)` (the defining
property of `localInertiaGroup`), forcing `рқ”Ә(IC-big) = вҠӨ`. -/
theorem restrictNormalHom_mem_inertia_of_mem_localInertiaGroup_two
    (N : IntermediateField
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)
        (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)))
    [FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N]
    [IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N]
    (Пғ : AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)
      вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat]
      AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat))
    (hПғ : Пғ вҲҲ localInertiaGroup
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) :
    AlgEquiv.restrictNormalHom N Пғ вҲҲ
      (IsLocalRing.maximalIdeal (IntegralClosure
        (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
        (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N) := by
  rw [show (IsLocalRing.maximalIdeal (IntegralClosure
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).inertia
      (N вүғвӮҗ[IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat] N) =
    (IsLocalRing.maximalIdeal (IntegralClosure
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers в„ҡ
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N)).toAddSubgroup.inertia _
    from rfl, AddSubgroup.mem_inertia]
  intro x
  rw [Submodule.mem_toAddSubgroup]
  by_contra hnot
  -- the displacement would be a unit of the local ring `IC-N`
  have hunit : IsUnit ((AlgEquiv.restrictNormalHom N Пғ) вҖў x - x) := by
    by_contra hnu
    exact hnot ((IsLocalRing.mem_maximalIdeal _).mpr (mem_nonunits_iff.mpr hnu))
  -- push the displacement into the big integral closure
  have hkey : integralClosureInclusion
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat N
      ((AlgEquiv.restrictNormalHom N Пғ) вҖў x - x) =
      Пғ вҖў (integralClosureInclusion
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat N x) -
      integralClosureInclusion
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat N x := by
    rw [map_sub]
    congr 1
    exact Subtype.ext (AlgEquiv.restrictNormal_commutes Пғ N x.1)
  -- the defining property of the full local inertia group
  have hbig := AddSubgroup.mem_inertia.mp hПғ
    (integralClosureInclusion
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat N x)
  rw [Submodule.mem_toAddSubgroup] at hbig
  -- a unit inside the big maximal ideal: absurd
  have hmap := hunit.map (integralClosureInclusion
    Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat N)
  rw [hkey] at hmap
  exact (IsLocalRing.maximalIdeal.isMaximal _).ne_top
    (Ideal.eq_top_of_isUnit_mem _ hbig hmap)

section TameGeneratorGeneric

open scoped Pointwise

/-- **Ring automorphisms preserve the maximal ideal of a local ring**:
the action of a group element under a `MulSemiringAction` maps the
maximal ideal into itself (a unit image would pull back to a unit along
the inverse automorphism). -/
theorem smul_mem_maximalIdeal_of_mem
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (g : G) {x : R} (hx : x вҲҲ IsLocalRing.maximalIdeal R) :
    g вҖў x вҲҲ IsLocalRing.maximalIdeal R := by
  rw [IsLocalRing.mem_maximalIdeal, mem_nonunits_iff] at hx вҠў
  intro hu
  have h1 := hu.map (MulSemiringAction.toRingEquiv G R gвҒ»В№)
  rw [show (MulSemiringAction.toRingEquiv G R gвҒ»В№) (g вҖў x) = gвҒ»В№ вҖў (g вҖў x) from rfl,
    inv_smul_smul] at h1
  exact hx h1

/-- Powers of the maximal ideal are likewise preserved by ring
automorphisms (induction over the ideal product). -/
theorem smul_mem_maximalIdeal_pow_of_mem
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (g : G) : вҲҖ (k : в„•) {x : R}, x вҲҲ (IsLocalRing.maximalIdeal R) ^ k вҶ’
      g вҖў x вҲҲ (IsLocalRing.maximalIdeal R) ^ k := by
  intro k
  induction k with
  | zero =>
      intro x _
      rw [pow_zero, Ideal.one_eq_top]
      exact Submodule.mem_top
  | succ n ih =>
      intro x hx
      rw [pow_succ] at hx вҠў
      refine Submodule.mul_induction_on hx (fun a ha b hb => ?_) (fun a b ha hb => ?_)
      В· rw [smul_mul']
        exact Ideal.mul_mem_mul (ih ha) (smul_mem_maximalIdeal_of_mem g hb)
      В· rw [smul_add]
        exact add_mem ha hb

/-- **The derivative bound at level `вүҘ 2`** (Serre, *Corps Locaux* IV):
an automorphism displacing every ring element into `рқ”Ә^(j+2)` displaces
every element OF `рқ”Ә^(j+2)` into `рқ”Ә^(j+3)` вҖ” split `c = aВ·b` with
`a вҲҲ рқ”Ә^(j+1)`, `b вҲҲ рқ”Ә` and use `g(ab) вҲ’ ab = g(a)(g(b) вҲ’ b) +
(g(a) вҲ’ a)b`, whose terms live in `рқ”Ә^(2j+3)` and `рқ”Ә^(j+3)`. -/
theorem smul_sub_mem_maximalIdeal_pow_succ
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (g : G) (j : в„•)
    (hg : вҲҖ a : R, g вҖў a - a вҲҲ (IsLocalRing.maximalIdeal R) ^ (j + 2)) :
    вҲҖ c вҲҲ (IsLocalRing.maximalIdeal R) ^ (j + 2),
      g вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ (j + 3) := by
  intro c hc
  rw [show j + 2 = (j + 1) + 1 from rfl, pow_succ] at hc
  refine Submodule.mul_induction_on hc (fun a ha b hb => ?_) (fun a b ha hb => ?_)
  В· have hkey : g вҖў (a * b) - a * b = (g вҖў a) * (g вҖў b - b) + (g вҖў a - a) * b := by
      rw [smul_mul']
      ring
    rw [hkey]
    refine add_mem ?_ ?_
    В· have h1 : (g вҖў a) * (g вҖў b - b) вҲҲ
          (IsLocalRing.maximalIdeal R) ^ (j + 1) * (IsLocalRing.maximalIdeal R) ^ (j + 2) :=
        Ideal.mul_mem_mul (smul_mem_maximalIdeal_pow_of_mem g (j + 1) ha) (hg b)
      have hle : (IsLocalRing.maximalIdeal R) ^ (j + 1 + (j + 2)) вүӨ
          (IsLocalRing.maximalIdeal R) ^ (j + 3) := Ideal.pow_le_pow_right (by omega)
      rw [вҶҗ pow_add] at h1
      exact hle h1
    В· have h1 : (g вҖў a - a) * b вҲҲ
          (IsLocalRing.maximalIdeal R) ^ (j + 2) * IsLocalRing.maximalIdeal R :=
        Ideal.mul_mem_mul (hg a) hb
      rwa [вҶҗ pow_succ] at h1
  В· have hkey : g вҖў (a + b) - (a + b) = (g вҖў a - a) + (g вҖў b - b) := by
      rw [smul_add]
      ring
    rw [hkey]
    exact add_mem ha hb

/-- **The `n`-th-power step** (uniform in the residue characteristic;
Serre, *Corps Locaux* IV): if `g` displaces `R` into `рқ”Ә^(i+1)` and
displaces `рқ”Ә^(i+1)` into `рқ”Ә^(i+2)`, and `n вҲҲ рқ”Ә`, then `gвҒҝ` displaces
`R` into `рқ”Ә^(i+2)`. Telescoping: `gбөҸa вҲ’ a вүЎ kВ·(ga вҲ’ a) mod рқ”Ә^(i+2)`
by induction on `k` (the increment `gбөҸ(ga вҲ’ a) вҲ’ (ga вҲ’ a)` lies in
`рқ”Ә^(i+2)` because `ga вҲ’ a вҲҲ рқ”Ә^(i+1)` and every power of `g` displaces
`рқ”Ә^(i+1)` into `рқ”Ә^(i+2)`), and at `k = n` the main term
`nВ·(ga вҲ’ a) вҲҲ рқ”ӘВ·рқ”Ә^(i+1)` dies too. -/
theorem pow_smul_sub_mem_maximalIdeal_pow_succ
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (n : в„•) (hn : (n : R) вҲҲ IsLocalRing.maximalIdeal R)
    (g : G) (i : в„•)
    (hg : вҲҖ a : R, g вҖў a - a вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 1))
    (hg2 : вҲҖ c вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 1),
      g вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 2)) :
    вҲҖ a : R, (g ^ n) вҖў a - a вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
  -- every power of `g` also displaces `рқ”Ә^(i+1)` into `рқ”Ә^(i+2)`
  have hpow : вҲҖ (k : в„•), вҲҖ c вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 1),
      (g ^ k) вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
    intro k
    induction k with
    | zero => intro c _; simp
    | succ m ih =>
        intro c hc
        have hkey : (g ^ (m + 1)) вҖў c - c =
            (g ^ m) вҖў (g вҖў c - c) + ((g ^ m) вҖў c - c) := by
          rw [pow_succ, mul_smul, smul_sub]
          ring
        rw [hkey]
        exact add_mem (smul_mem_maximalIdeal_pow_of_mem _ (i + 2) (hg2 c hc)) (ih c hc)
  -- telescoping: `gбөҸa вҲ’ a вүЎ kВ·(ga вҲ’ a)` modulo `рқ”Ә^(i+2)`
  have htel : вҲҖ (k : в„•) (a : R),
      (g ^ k) вҖў a - a - (k : R) * (g вҖў a - a) вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
    intro k
    induction k with
    | zero => intro a; simp
    | succ m ih =>
        intro a
        have hkey : (g ^ (m + 1)) вҖў a - a - ((m + 1 : в„•) : R) * (g вҖў a - a) =
            ((g ^ m) вҖў (g вҖў a - a) - (g вҖў a - a)) +
              ((g ^ m) вҖў a - a - (m : R) * (g вҖў a - a)) := by
          rw [pow_succ, mul_smul, smul_sub]
          push_cast
          ring
        rw [hkey]
        exact add_mem (hpow m _ (hg a)) (ih a)
  intro a
  have h1 := htel n a
  have h2 : (n : R) * (g вҖў a - a) вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
    rw [pow_succ']
    exact Ideal.mul_mem_mul hn (hg a)
  have h3 := add_mem h1 h2
  simpa using h3

/-- **Wild elements have `p`-power order** (Serre, *Corps Locaux* IV
В§2, made monogenicity-free, uniform in the residue characteristic
`p`): in a Noetherian local domain of residue characteristic `p` with
a finite faithfully acting automorphism group, an automorphism `Пғ`
displacing `R` into `рқ”Ә` and `рқ”Ә` into `рқ”ӘВІ` has `p`-power order. The
coprime-to-`p` part `П„ = Пғ^(p^jвӮҖ)` climbs the filtration
`H_i = {g | (g вҲ’ 1)R вҠҶ рқ”Ә^(i+1)}` forever: `П„ вҲҲ H_i вҹ№ П„^p вҲҲ H_(i+1)`
(the `p`-th-power step) and `П„ вҲҲ вҹЁП„^pвҹ©` (BГ©zout, order coprime to
`p`), so `П„` displaces into `вӢӮ рқ”Ә^n = 0` (Krull) and is trivial. -/
theorem exists_pow_prime_pow_eq_one_of_wild
    {R : Type*} [CommRing R] [IsDomain R] [IsNoetherianRing R] [IsLocalRing R]
    {G : Type*} [Group G] [Finite G] [MulSemiringAction G R]
    (hfaith : вҲҖ g : G, (вҲҖ a : R, g вҖў a = a) вҶ’ g = 1)
    {p : в„•} (hp : p.Prime) (hpm : (p : R) вҲҲ IsLocalRing.maximalIdeal R)
    (Пғ : G)
    (hПғ : вҲҖ a : R, Пғ вҖў a - a вҲҲ IsLocalRing.maximalIdeal R)
    (hker : вҲҖ c вҲҲ IsLocalRing.maximalIdeal R,
      Пғ вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ 2) :
    вҲғ j : в„•, Пғ ^ p ^ j = 1 := by
  classical
  refine вҹЁ(orderOf Пғ).factorization p, ?_вҹ©
  set П„ := Пғ ^ p ^ (orderOf Пғ).factorization p with hП„def
  -- the order of `П„` is coprime to `p`
  have hn0 : orderOf Пғ вү  0 := (orderOf_pos Пғ).ne'
  have hП„ord : Nat.Coprime p (orderOf П„) := by
    have hdvd : p ^ (orderOf Пғ).factorization p вҲЈ orderOf Пғ := Nat.ordProj_dvd (orderOf Пғ) p
    have horder : orderOf П„ = orderOf Пғ / p ^ (orderOf Пғ).factorization p := by
      rw [hП„def, orderOf_pow, Nat.gcd_eq_right hdvd]
    rw [horder]
    exact Nat.coprime_ordCompl hp hn0
  -- BГ©zout: `П„` lies in every subgroup containing `П„^p`
  have hbez : вҲҖ H : Subgroup G, П„ ^ p вҲҲ H вҶ’ П„ вҲҲ H := by
    intro H hH
    have hab := Nat.gcd_eq_gcd_ab p (orderOf П„)
    rw [Nat.Coprime.gcd_eq_one hП„ord] at hab
    have hzp : ((П„ ^ p) ^ Nat.gcdA p (orderOf П„) : G) = П„ := by
      have hexp : (p : в„Ө) * Nat.gcdA p (orderOf П„) =
          1 - (orderOf П„ : в„Ө) * Nat.gcdB p (orderOf П„) := by
        push_cast at hab
        linarith
      rw [вҶҗ zpow_natCast П„ p, вҶҗ zpow_mul]
      rw [hexp, zpow_sub, zpow_one, zpow_mul, zpow_natCast, pow_orderOf_eq_one, one_zpow,
        inv_one, mul_one]
    exact hzp в–ё Subgroup.zpow_mem H hH _
  -- powers of `Пғ` keep the level-one displacement bounds
  have hpow1 : вҲҖ (k : в„•) (a : R), Пғ ^ k вҖў a - a вҲҲ IsLocalRing.maximalIdeal R := by
    intro k
    induction k with
    | zero => intro a; simp
    | succ m ih =>
        intro a
        have hkey : Пғ ^ (m + 1) вҖў a - a = Пғ ^ m вҖў (Пғ вҖў a - a) + (Пғ ^ m вҖў a - a) := by
          rw [pow_succ, mul_smul, smul_sub]
          ring
        rw [hkey]
        exact add_mem (smul_mem_maximalIdeal_of_mem _ (hПғ a)) (ih a)
  have hpow2 : вҲҖ (k : в„•), вҲҖ c вҲҲ IsLocalRing.maximalIdeal R,
      Пғ ^ k вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ 2 := by
    intro k
    induction k with
    | zero => intro c _; simp
    | succ m ih =>
        intro c hc
        have hkey : Пғ ^ (m + 1) вҖў c - c = Пғ ^ m вҖў (Пғ вҖў c - c) + (Пғ ^ m вҖў c - c) := by
          rw [pow_succ, mul_smul, smul_sub]
          ring
        rw [hkey]
        exact add_mem (smul_mem_maximalIdeal_pow_of_mem _ 2 (hker c hc)) (ih c hc)
  -- the main climb: `П„` lies in every level of the filtration
  have hclaim : вҲҖ i : в„•, П„ вҲҲ ((IsLocalRing.maximalIdeal R) ^ (i + 1)).inertia G := by
    intro i
    induction i with
    | zero =>
        refine AddSubgroup.mem_inertia.mpr fun a => ?_
        rw [zero_add, pow_one]
        exact hpow1 _ a
    | succ i ih =>
        have hlev : вҲҖ a : R, П„ вҖў a - a вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 1) :=
          fun a => AddSubgroup.mem_inertia.mp ih a
        have h2 : вҲҖ c вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 1),
            П„ вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
          rcases i with _ | j
          В· intro c hc
            rw [pow_one] at hc
            exact hpow2 _ c hc
          В· exact smul_sub_mem_maximalIdeal_pow_succ П„ j hlev
        have hstep := pow_smul_sub_mem_maximalIdeal_pow_succ p hpm П„ i hlev h2
        exact hbez _ (AddSubgroup.mem_inertia.mpr hstep)
  -- Krull intersection: `П„` acts trivially
  have htriv : вҲҖ a : R, П„ вҖў a = a := by
    intro a
    have hall : П„ вҖў a - a вҲҲ вЁ… m : в„•, (IsLocalRing.maximalIdeal R) ^ m := by
      rw [Submodule.mem_iInf]
      intro m
      rcases m with _ | m
      В· rw [pow_zero, Ideal.one_eq_top]
        exact Submodule.mem_top
      В· exact AddSubgroup.mem_inertia.mp (hclaim m) a
    rw [Ideal.iInf_pow_eq_bot_of_isLocalRing (IsLocalRing.maximalIdeal R)
      (IsLocalRing.maximalIdeal.isMaximal R).ne_top] at hall
    rw [вҶҗ sub_eq_zero]
    exact (Ideal.mem_bot).mp hall
  exact hfaith П„ htriv

/-- **The generic finite-level tame-generator theorem** (Serre, *Corps
Locaux* IV В§1вҖ“2, over an abstract DVR, uniform in the residue
characteristic `p`): given a finite group acting faithfully by ring
automorphisms on a DVR `R` with `p вҲҲ рқ”Ә` for a prime `p`, and an
element `ПҶ` acting as the `p`-th-power map on the residue field, there
is an inertia element `t` such that (a) every inertia element is a
power of `t` times a `p`-power-order element, and (b) `ПҶtПҶвҒ»В№(t^p)вҒ»В№`
has `p`-power order. The tame character `Оё(Пғ) = Пғ(ПҖ)/ПҖ mod рқ”Ә` (a
cocycle made multiplicative on inertia by residue triviality) embeds
inertia-mod-wild into the cyclic group `ОәЛЈ`; its kernel is
`p`-power-order by `exists_pow_prime_pow_eq_one_of_wild`, and `Оё` is
`ПҶ`-semilinear: `Оё(ПҶПғПҶвҒ»В№) = Оё(Пғ)^p`. -/
theorem exists_finite_level_tame_generator_of_frobenius
    {R : Type*} [CommRing R] [IsDomain R] [IsDiscreteValuationRing R]
    {G : Type*} [Group G] [Finite G] [MulSemiringAction G R]
    (hfaith : вҲҖ g : G, (вҲҖ a : R, g вҖў a = a) вҶ’ g = 1)
    {p : в„•} (hp : p.Prime) (hpm : (p : R) вҲҲ IsLocalRing.maximalIdeal R)
    (ПҶ : G) (hПҶ : вҲҖ x : R, ПҶ вҖў x - x ^ p вҲҲ IsLocalRing.maximalIdeal R) :
    вҲғ t вҲҲ (IsLocalRing.maximalIdeal R).inertia G,
      (вҲҖ Пғ вҲҲ (IsLocalRing.maximalIdeal R).inertia G,
        вҲғ m j : в„•, ((t ^ m)вҒ»В№ * Пғ) ^ p ^ j = 1) вҲ§
      вҲғ j : в„•, (ПҶ * t * ПҶвҒ»В№ * (t ^ p)вҒ»В№) ^ p ^ j = 1 := by
  classical
  -- a uniformizer and the unit cocycle `g вҖў ПҖ = ПҖ * U g`
  obtain вҹЁПҖ, hПҖвҹ© := IsDiscreteValuationRing.exists_irreducible R
  have hПҖ0 : ПҖ вү  0 := hПҖ.ne_zero
  have hspan : IsLocalRing.maximalIdeal R = Ideal.span {ПҖ} := hПҖ.maximalIdeal_eq
  have hUex : вҲҖ g : G, вҲғ u : RЛЈ, ПҖ * u = g вҖў ПҖ := by
    intro g
    have hgПҖ : Irreducible (g вҖў ПҖ) :=
      (MulEquiv.irreducible_iff (MulSemiringAction.toRingEquiv G R g)).mpr hПҖ
    exact IsDiscreteValuationRing.associated_of_irreducible R hПҖ hgПҖ
  choose U hU using hUex
  -- the cocycle relation and normalization
  have hUmul : вҲҖ g h : G, (U (g * h) : R) = U g * (g вҖў (U h : R)) := by
    intro g h
    refine mul_left_cancelвӮҖ hПҖ0 ?_
    calc ПҖ * (U (g * h) : R) = (g * h) вҖў ПҖ := hU (g * h)
      _ = g вҖў (h вҖў ПҖ) := mul_smul g h ПҖ
      _ = g вҖў (ПҖ * (U h : R)) := by rw [hU h]
      _ = (g вҖў ПҖ) * (g вҖў (U h : R)) := smul_mul' g ПҖ (U h : R)
      _ = (ПҖ * (U g : R)) * (g вҖў (U h : R)) := by rw [hU g]
      _ = ПҖ * ((U g : R) * (g вҖў (U h : R))) := by ring
  have hU1 : (U 1 : R) = 1 := by
    refine mul_left_cancelвӮҖ hПҖ0 ?_
    rw [hU 1, one_smul, mul_one]
  -- the tame character on the inertia subgroup
  have hmul : вҲҖ Пғ П„ : вҶҘ((IsLocalRing.maximalIdeal R).inertia G),
      Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U ((Пғ * П„ : _) : G)) =
        Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U (Пғ : G)) *
          Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U (П„ : G)) := by
    intro Пғ П„
    refine Units.ext ?_
    show Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ((Пғ : G) * (П„ : G)) : R) =
      Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (Пғ : G) : R) *
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (П„ : G) : R)
    rw [hUmul (Пғ : G) (П„ : G), map_mul]
    congr 1
    exact Ideal.Quotient.eq.mpr (AddSubgroup.mem_inertia.mp Пғ.2 (U (П„ : G) : R))
  set Оё : вҶҘ((IsLocalRing.maximalIdeal R).inertia G) вҶ’*
      (R в§ё IsLocalRing.maximalIdeal R)ЛЈ :=
    MonoidHom.mk' (fun Пғ =>
      Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U (Пғ : G))) hmul
    with hОёdef
  have hОёval : вҲҖ Пғ : вҶҘ((IsLocalRing.maximalIdeal R).inertia G),
      (Оё Пғ : R в§ё IsLocalRing.maximalIdeal R) =
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (Пғ : G) : R) := fun Пғ => rfl
  -- the kernel of the tame character has p-power order
  have hker_of_Оё : вҲҖ x : вҶҘ((IsLocalRing.maximalIdeal R).inertia G), Оё x = 1 вҶ’
      вҲҖ c вҲҲ IsLocalRing.maximalIdeal R,
        (x : G) вҖў c - c вҲҲ (IsLocalRing.maximalIdeal R) ^ 2 := by
    intro x hx c hc
    have hu1 : (U (x : G) : R) - 1 вҲҲ IsLocalRing.maximalIdeal R := by
      refine Ideal.Quotient.eq.mp ?_
      have hval := congrArg Units.val hx
      rw [hОёval] at hval
      simpa using hval
    obtain вҹЁr, hrвҹ© := Ideal.mem_span_singleton'.mp (hspan в–ё hc)
    have hxc : (x : G) вҖў c - c = (((x : G) вҖў r) * (U (x : G) : R) - r) * ПҖ := by
      calc (x : G) вҖў c - c = (x : G) вҖў (r * ПҖ) - r * ПҖ := by rw [hr]
        _ = ((x : G) вҖў r) * ((x : G) вҖў ПҖ) - r * ПҖ := by rw [smul_mul']
        _ = ((x : G) вҖў r) * (ПҖ * (U (x : G) : R)) - r * ПҖ := by rw [hU (x : G)]
        _ = (((x : G) вҖў r) * (U (x : G) : R) - r) * ПҖ := by ring
    rw [hxc, pow_two]
    refine Ideal.mul_mem_mul ?_ (hspan в–ё Ideal.mem_span_singleton_self ПҖ)
    have hsplit : ((x : G) вҖў r) * (U (x : G) : R) - r =
        ((x : G) вҖў r) * ((U (x : G) : R) - 1) + ((x : G) вҖў r - r) := by ring
    rw [hsplit]
    exact add_mem (Ideal.mul_mem_left _ _ hu1) (AddSubgroup.mem_inertia.mp x.2 r)
  have hwild : вҲҖ x : вҶҘ((IsLocalRing.maximalIdeal R).inertia G), Оё x = 1 вҶ’
      вҲғ j : в„•, (x : G) ^ p ^ j = 1 := fun x hx =>
    exists_pow_prime_pow_eq_one_of_wild hfaith hp hpm (x : G)
      (AddSubgroup.mem_inertia.mp x.2) (hker_of_Оё x hx)
  -- the image of the tame character is cyclic; pick a generator
  have hfr : ((Оё.range : Set (R в§ё IsLocalRing.maximalIdeal R)ЛЈ)).Finite := by
    rw [MonoidHom.coe_range]
    exact Set.finite_range Оё
  haveI : Finite вҶҘОё.range := hfr.to_subtype
  haveI : IsCyclic вҶҘОё.range := isCyclic_subgroup_units Оё.range
  obtain вҹЁgen, hgenвҹ© := IsCyclic.exists_generator (Оұ := вҶҘОё.range)
  obtain вҹЁtвӮҖ, htвӮҖвҹ© : вҲғ tвӮҖ : вҶҘ((IsLocalRing.maximalIdeal R).inertia G),
      Оё tвӮҖ = (gen : (R в§ё IsLocalRing.maximalIdeal R)ЛЈ) := gen.2
  refine вҹЁ(tвӮҖ : G), tвӮҖ.2, ?_, ?_вҹ©
  В· -- clause (a): powers of `tвӮҖ` exhaust inertia mod wild
    intro Пғ hПғ
    have hmemrange : (вҹЁОё вҹЁПғ, hПғвҹ©, вҹЁвҹЁПғ, hПғвҹ©, rflвҹ©вҹ© : вҶҘОё.range) вҲҲ Submonoid.powers gen :=
      (isOfFinOrder_of_finite gen).mem_powers_iff_mem_zpowers.mpr (hgen _)
    obtain вҹЁm, hmвҹ© := hmemrange
    refine вҹЁm, ?_вҹ©
    have hval := congrArg (Subtype.val) hm
    push_cast at hval
    have hОё1 : Оё ((tвӮҖ ^ m)вҒ»В№ * вҹЁПғ, hПғвҹ©) = 1 := by
      rw [map_mul, map_inv, map_pow, htвӮҖ, hval, inv_mul_cancel]
    obtain вҹЁj, hjвҹ© := hwild _ hОё1
    refine вҹЁj, ?_вҹ©
    simpa using hj
  В· -- clause (b): Frobenius conjugation raises the tame character to `p`
    have hПҶres : вҲҖ x : R,
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (ПҶ вҖў x) =
          (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) x) ^ p := by
      intro x
      rw [вҶҗ map_pow]
      exact Ideal.Quotient.eq.mpr (hПҶ x)
    have hconjmem : ПҶ * (tвӮҖ : G) * ПҶвҒ»В№ вҲҲ (IsLocalRing.maximalIdeal R).inertia G := by
      refine AddSubgroup.mem_inertia.mpr fun x => ?_
      have hrw : (ПҶ * (tвӮҖ : G) * ПҶвҒ»В№) вҖў x - x =
          ПҶ вҖў ((tвӮҖ : G) вҖў (ПҶвҒ»В№ вҖў x) - ПҶвҒ»В№ вҖў x) := by
        rw [smul_sub, mul_smul, mul_smul, smul_inv_smul]
      rw [hrw]
      exact smul_mem_maximalIdeal_of_mem ПҶ (AddSubgroup.mem_inertia.mp tвӮҖ.2 _)
    -- the semilinearity computation
    have hsemi : Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)
        (U (ПҶ * (tвӮҖ : G) * ПҶвҒ»В№) : R) =
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (tвӮҖ : G) : R) ^ p := by
      have e3 : Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶ : R) *
          Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶвҒ»В№ : R) ^ p = 1 := by
        have e0 : (1 : R) = (U ПҶ : R) * (ПҶ вҖў (U ПҶвҒ»В№ : R)) := by
          rw [вҶҗ hU1, вҶҗ hUmul ПҶ ПҶвҒ»В№, mul_inv_cancel]
        have e1 := congrArg (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)) e0
        rw [map_one, map_mul, hПҶres] at e1
        exact e1.symm
      have e1 : (U (ПҶ * (tвӮҖ : G) * ПҶвҒ»В№) : R) =
          (U ПҶ : R) * (ПҶ вҖў ((U (tвӮҖ : G) : R) * ((tвӮҖ : G) вҖў (U ПҶвҒ»В№ : R)))) := by
        rw [mul_assoc, hUmul ПҶ ((tвӮҖ : G) * ПҶвҒ»В№), hUmul (tвӮҖ : G) ПҶвҒ»В№]
      have e2 := congrArg (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)) e1
      rw [map_mul, smul_mul', map_mul, hПҶres, hПҶres] at e2
      have et : Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) ((tвӮҖ : G) вҖў (U ПҶвҒ»В№ : R)) =
          Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶвҒ»В№ : R) :=
        Ideal.Quotient.eq.mpr (AddSubgroup.mem_inertia.mp tвӮҖ.2 _)
      rw [et] at e2
      calc Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (ПҶ * (tвӮҖ : G) * ПҶвҒ»В№) : R)
          = Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶ : R) *
            (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (tвӮҖ : G) : R) ^ p *
              Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶвҒ»В№ : R) ^ p) := e2
        _ = Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (tвӮҖ : G) : R) ^ p *
            (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶ : R) *
              Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ПҶвҒ»В№ : R) ^ p) := by ring
        _ = Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (tвӮҖ : G) : R) ^ p := by
            rw [e3, mul_one]
    have hОё1 : Оё ((вҹЁПҶ * (tвӮҖ : G) * ПҶвҒ»В№, hconjmemвҹ© :
        вҶҘ((IsLocalRing.maximalIdeal R).inertia G)) * (tвӮҖ ^ p)вҒ»В№) = 1 := by
      have hc : Оё (вҹЁПҶ * (tвӮҖ : G) * ПҶвҒ»В№, hconjmemвҹ© :
          вҶҘ((IsLocalRing.maximalIdeal R).inertia G)) = Оё tвӮҖ ^ p := by
        refine Units.ext ?_
        rw [hОёval, Units.val_pow_eq_pow_val, hОёval]
        exact hsemi
      rw [map_mul, map_inv, map_pow, hc, mul_inv_cancel]
    obtain вҹЁj, hjвҹ© := hwild _ hОё1
    refine вҹЁj, ?_вҹ©
    simpa using hj

