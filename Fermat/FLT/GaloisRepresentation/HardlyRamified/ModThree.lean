open scoped Classical in
/-- **Zero multiplicity of the continued Dedekind zeta** (definition,
2026-07-23): the analytic vanishing order `analyticOrderNatAt` of the
entire completed zeta `őĺ_K` at `ŌĀ`, restricted to the open critical
strip `0 < re ŌĀ < 1`, and `0` outside it.  On the strip the elementary
factor `s(s‚ąí1)¬∑|d_K|^{s/2}¬∑őď-factors` of `őĺ_K` is finite and
nonvanishing (`őď` has no zeros; its poles lie at `0, ‚ąí1, ‚ąí2, ‚Ä¶`, off
the strip), so this is exactly the multiplicity of `ŌĀ` as a zero of
the analytically continued `ő∂_K` ‚ÄĒ the `mult` of the Weil‚ÄďPoitou
explicit formula. -/
noncomputable def DedekindContinuation.mult {K : Type*} [Field K] [NumberField K]
    (pkg : DedekindContinuation K) (ŌĀ : ‚Ąā) : ‚Ąē :=
  if 0 < ŌĀ.re ‚ąß ŌĀ.re < 1 then analyticOrderNatAt pkg.xi ŌĀ else 0

/-- **Support of the multiplicity function** (PROVEN 2026-07-23): by
construction `DedekindContinuation.mult` vanishes off the open
critical strip. -/
theorem DedekindContinuation.mult_mem_strip {K : Type*} [Field K] [NumberField K]
    (pkg : DedekindContinuation K) {ŌĀ : ‚Ąā} (h : pkg.mult ŌĀ ‚Č† 0) :
    0 < ŌĀ.re ‚ąß ŌĀ.re < 1 := by
  by_contra hcon
  exact h (by simp [DedekindContinuation.mult, hcon])

/-- **A point of positive multiplicity is a zero of `őĺ_K`** (PROVEN
2026-07-23): `analyticOrderNatAt` vanishes wherever the function does
not. -/
theorem DedekindContinuation.xi_eq_zero_of_mult_ne_zero {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) {ŌĀ : ‚Ąā}
    (h : pkg.mult ŌĀ ‚Č† 0) : pkg.xi ŌĀ = 0 := by
  by_contra hne
  refine h ?_
  have h0 : analyticOrderAt pkg.xi ŌĀ = 0 := analyticOrderAt_eq_zero.mpr (Or.inr hne)
  simp [DedekindContinuation.mult, analyticOrderNatAt, h0]

/-- **Finiteness of the horizontal truncations of the zero set**
(PROVEN 2026-07-23): the points of positive multiplicity with
`|im ŌĀ| ‚Č§ T` lie in the closed ball of radius `|T| + 2` (the strip
truncation is bounded); were they infinite they would accumulate at
some `z‚āÄ` of that compact ball, and the identity theorem for the
entire `őĺ_K` would force `őĺ_K ‚Č° 0`, contradicting the Euler-product
nonvanishing at `s = 2`.  No boundary-line information enters:
accumulation at a boundary point of the strip kills an entire function
just as an interior accumulation point does. -/
theorem DedekindContinuation.finite_truncation {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) (T : ‚ĄĚ) :
    {ŌĀ : ‚Ąā | pkg.mult ŌĀ ‚Č† 0 ‚ąß |ŌĀ.im| ‚Č§ T}.Finite := by
  by_contra hinf
  have hsub : {ŌĀ : ‚Ąā | pkg.mult ŌĀ ‚Č† 0 ‚ąß |ŌĀ.im| ‚Č§ T} ‚äÜ
      Metric.closedBall (0 : ‚Ąā) (|T| + 2) := by
    intro ŌĀ hŌĀ
    obtain ‚ü®hre0, hre1‚ü© := pkg.mult_mem_strip hŌĀ.1
    rw [Metric.mem_closedBall, dist_zero_right]
    calc ‚ÄĖŌĀ‚ÄĖ ‚Č§ |ŌĀ.re| + |ŌĀ.im| := Complex.norm_le_abs_re_add_abs_im ŌĀ
      _ ‚Č§ 1 + |T| := add_le_add (by rw [abs_of_pos hre0]; linarith)
          (le_trans hŌĀ.2 (le_abs_self T))
      _ ‚Č§ |T| + 2 := by linarith
  obtain ‚ü®z‚āÄ, -, hacc‚ü© := Set.Infinite.exists_accPt_of_subset_isCompact hinf
    (isCompact_closedBall (0 : ‚Ąā) (|T| + 2)) hsub
