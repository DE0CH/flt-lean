    intro h0
    apply hindep
    by_cases hv0 : v 0 = 0
    В· have hv1 : v 1 вү  0 := by
        intro hv1
        apply hv
        funext i
        fin_cases i
        В· exact hv0
        В· exact hv1
      have hw0 : w 0 = 0 := by
