would-be induced representation is NOT genuinely dihedral. The whole
matrix layer is condensed into the single arithmetic hypothesis
`hПҮprod`: on `H` the product `ПҮвӮҖ В· ПҮвӮҖ^{ПғвӮҖ}` is the mod-3 cyclotomic
character (the determinant of the induced representation on the
eigenbasis).

Intended content (Serre's mod-3 analogue, Duke 1987 В§5, of Tate's
2-adic letter argument, per fixed `d`). The ratio `ОҪ := ПҮвӮҖ/ПҮвӮҖ^{ПғвӮҖ}`
is multiplicative on `H` (`hПҮmul`), trivial on the open normal
subgroup `ker ПҒ` (`hПҮker` + normality + `htriv'`), of finite order
prime to `3` (its values are units of `рқ”ҪМ„вӮғ = вӢғвӮҷ рқ”Ҫ_{3вҒҝ}`, so of finite
multiplicative order with no `3`-part), and ANTI-equivariant:
`ОҪ(ПғвӮҖвҒ»В№gПғвӮҖ) = ОҪ(g)вҒ»В№`, from `hПҮmul` alone via `ПғвӮҖВІ вҲҲ H` and
`H`-conjugation-invariance of the abelian-valued `ПҮвӮҖ`. It is
unramified at `2` (`h2unr` for the `ПҮвӮҖ` factor; `hПҮprod` plus
triviality of the cyclotomic character on the inertia at `2` вҖ” the
PROVEN `cyclotomicCharacter_algebraMap_eq_one_of_inertia_two`, stated
LATER in this file, so move or re-derive it when resolving this
node вҖ” for the conjugate factor) and at every prime `q вҲү {2, 3}`
(`hПҮunr`, same transport), and at the conjugate copies of those
inertia subgroups (conjugation by `h вҲҲ H` fixes `ОҪ`; conjugation by
`ПғвӮҖ` inverts it). At `3`: `ПҒ` is flat (`hПҒ.isFlat`); Raynaud's
classification over the at-worst-quadratically-ramified completions
of `в„ҡ(вҲҡd)` above `3` (`e вүӨ 2 = 3 - 1`) bounds the ramification at `3`
of the splitting field of `ПҒ` вҖ” through which `ОҪ` factors, by
`hПҮker` вҖ” so `ОҪ` has bounded conductor above `3` (tameness is
automatic: `ОҪ` has order prime to `3`, killing the pro-`3` wild
inertia). Ray class, per field: `ОҪ` is then a character of the ray
class group of `в„ҡ(вҲҡd)` with conductor supported in the tame primes
above `3`; the class numbers of the seven fields
`в„ҡ(вҲҡ-1), в„ҡ(вҲҡВұ2), в„ҡ(вҲҡВұ3), в„ҡ(вҲҡВұ6)` are `1, 1, 1, 1, 1, 1, 2`, and the
ray class groups modulo the allowed conductor above `3` are generated
by ramified classes on which the anti-equivariant `ОҪ` is forced to
vanish; so `ОҪ = 1`, i.e. `ПҮвӮҖ = ПҮвӮҖ^{ПғвӮҖ}` on `H`. References: Serre,
Duke Math. J. 54 (1987) В§5; Tate's 1974 letter to Serre (Е’uvres III);
Neukirch, ANT VI В§6 (ray class groups). -/
theorem dihedral_eigenvalue_character_symmetric_ray_class {k : Type u}
    [Finite k] [Field k]
    [Algebra в„Ө_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ПҒ : GaloisRep в„ҡ k V}
    (hПҒ : IsHardlyRamified (show Odd 3 by decide) hV ПҒ)
    (e : AlgebraicClosure k вүғ+* Dickson.K 3)
    (Оё' : О“ в„ҡ вҶ’* Multiplicative (ZMod 2))
    (htriv' : вҲҖ g : О“ в„ҡ, ПҒ g = 1 вҶ’ Оё' g = 1)
    (d : в„Ө)
    (hd : d = -1 вҲЁ d = 2 вҲЁ d = -2 вҲЁ d = 3 вҲЁ d = -3 вҲЁ d = 6 вҲЁ d = -6)
    (x : AlgebraicClosure в„ҡ) (hx : x ^ 2 = (d : AlgebraicClosure в„ҡ))
    (hОё'x : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ” g x = x)
    (ПғвӮҖ : О“ в„ҡ) (hПғвӮҖ : Оё' ПғвӮҖ вү  1)
    (ПҮвӮҖ : О“ в„ҡ вҶ’ Dickson.K 3)
    (hПҮne0 : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ПҮвӮҖ g вү  0)
    (hПҮmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ПҮвӮҖ (g * h) = ПҮвӮҖ g * ПҮвӮҖ h)
    (hПҮker : вҲҖ g : О“ в„ҡ, ПҒ g = 1 вҶ’ ПҮвӮҖ g = 1)
    (hПҮprod : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’
      ПҮвӮҖ g * ПҮвӮҖ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) =
        ((e : AlgebraicClosure k вҶ’+* Dickson.K 3).comp
          ((algebraMap k (AlgebraicClosure k)).comp (algebraMap в„Ө_[3] k)))
          ((cyclotomicCharacter (AlgebraicClosure в„ҡ) 3 g.toRingEquiv : в„Ө_[3]ЛЈ) : в„Ө_[3]))
    (hПҮunr : вҲҖ (q : в„•) (hq : q.Prime), q вү  2 вҶ’ q вү  3 вҶ’
      вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        ПҮвӮҖ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1)
    (h2unr : вҲҖ Пғ вҲҲ localInertiaGroup
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat,
      Оё' (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 вҲ§
      ПҮвӮҖ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
        (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1) :
    вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ПҮвӮҖ g = ПҮвӮҖ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) := by
  classical
  -- (0) `H = ker Оё'` is stable under products, inverses and
  -- `ПғвӮҖ`-conjugation (the target `Multiplicative (ZMod 2)` is abelian)
  have hHconj : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) = 1 := by
    intro g hg
    rw [map_mul, map_mul, hg, mul_one, map_inv, inv_mul_cancel]
  have hHinv : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' gвҒ»В№ = 1 := by
    intro g hg
    rw [map_inv, hg, inv_one]
  have hHmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’ Оё' (g * h) = 1 := by
    intro g h hg hh
    rw [map_mul, hg, hh, mul_one]
  -- (1) `ПҮвӮҖ` is a character of `H`: unit value at `1`, inverses, and
  -- `H`-conjugation invariance (the values commute in the field)
  have hПҮone : ПҮвӮҖ 1 = 1 := by
    have h := hПҮmul 1 1 (map_one Оё') (map_one Оё')
    rw [mul_one] at h
    have hne := hПҮne0 1 (map_one Оё')
    field_simp at h
    exact h.symm
  have hПҮinv : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ПҮвӮҖ gвҒ»В№ = (ПҮвӮҖ g)вҒ»В№ := by
    intro g hg
    have h := hПҮmul gвҒ»В№ g (hHinv g hg) hg
    rw [inv_mul_cancel, hПҮone] at h
    exact eq_inv_of_mul_eq_one_left h.symm
  have hПҮHconj : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ПҮвӮҖ (hвҒ»В№ * g * h) = ПҮвӮҖ g := by
    intro g h hg hh
    rw [hПҮmul (hвҒ»В№ * g) h (hHmul _ _ (hHinv h hh) hg) hh,
      hПҮmul hвҒ»В№ g (hHinv h hh) hg, hПҮinv h hh]
    field_simp [hПҮne0 h hh]
  -- `ПғвӮҖВІ вҲҲ H`: squares are trivial in `Multiplicative (ZMod 2)`
  have hПғвӮҖsq : Оё' (ПғвӮҖ * ПғвӮҖ) = 1 := by
    rw [map_mul]
    exact (by decide : вҲҖ a : Multiplicative (ZMod 2), a * a = 1) _
  -- (2) the ratio character `ОҪ = ПҮвӮҖ / ПҮвӮҖ^{ПғвӮҖ}`: multiplicative,
  -- nonvanishing, and ANTI-equivariant under `ПғвӮҖ`-conjugation
  set ОҪ : О“ в„ҡ вҶ’ Dickson.K 3 :=
    fun g => ПҮвӮҖ g * (ПҮвӮҖ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ))вҒ»В№ with hОҪdef
  have hОҪmul : вҲҖ g h : О“ в„ҡ, Оё' g = 1 вҶ’ Оё' h = 1 вҶ’
      ОҪ (g * h) = ОҪ g * ОҪ h := by
    intro g h hg hh
    have hexp : ПғвӮҖвҒ»В№ * (g * h) * ПғвӮҖ =
        (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) * (ПғвӮҖвҒ»В№ * h * ПғвӮҖ) := by group
    rw [hОҪdef]
    simp only
    rw [hПҮmul g h hg hh, hexp,
      hПҮmul _ _ (hHconj g hg) (hHconj h hh), mul_inv]
    ring
  have hОҪne0 : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ g вү  0 := by
    intro g hg
    exact mul_ne_zero (hПҮne0 g hg) (inv_ne_zero (hПҮne0 _ (hHconj g hg)))
  have hОҪanti : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’ ОҪ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) = (ОҪ g)вҒ»В№ := by
    intro g hg
    have hexp : ПғвӮҖвҒ»В№ * (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) * ПғвӮҖ =
        (ПғвӮҖ * ПғвӮҖ)вҒ»В№ * g * (ПғвӮҖ * ПғвӮҖ) := by group
    rw [hОҪdef]
    simp only
    rw [hexp, hПҮHconj g (ПғвӮҖ * ПғвӮҖ) hg hПғвӮҖsq, mul_inv, inv_inv]
    ring
  -- (3) `ОҪ` is trivial on the normal subgroup `ker ПҒ`
  have hОҪker : вҲҖ g : О“ в„ҡ, ПҒ g = 1 вҶ’ ОҪ g = 1 := by
    intro g hg
    have hconjker : ПҒ (ПғвӮҖвҒ»В№ * g * ПғвӮҖ) = 1 := by
      rw [map_mul, map_mul, hg, mul_one, вҶҗ map_mul, inv_mul_cancel, map_one]
    rw [hОҪdef]
    simp only
    rw [hПҮker g hg, hПҮker _ hconjker, inv_one, mul_one]
  -- (4) the values of `ОҪ` lie in `рқ”ҪМ„вӮғЛЈ`, hence have order prime to `3`
  have hОҪord : вҲҖ g : О“ в„ҡ, Оё' g = 1 вҶ’
      вҲғ n : в„•, 0 < n вҲ§ В¬ (3 вҲЈ n) вҲ§ ОҪ g ^ n = 1 := fun g hg =>
    exists_pow_eq_one_not_three_dvd_of_ne_zero _ (hОҪne0 g hg)
  -- (5) `ОҪ` is unramified at every prime `q вү  3`: `Оё'` and `ПҮвӮҖ` vanish
  -- on the inertia image (`h2unr` at `2`; the local leaves away from
  -- `2`), and the conjugate factor `ПҮвӮҖ^{ПғвӮҖ}` is handled by the product
  -- formula `hПҮprod` plus triviality of the mod-3 cyclotomic character
  -- on the inertia at `q вү  3`
  have hОҪunr : вҲҖ (q : в„•) (hq : q.Prime), q вү  3 вҶ’
      вҲҖ Пғ вҲҲ localInertiaGroup hq.toHeightOneSpectrumRingOfIntegersRat,
        ОҪ (Field.absoluteGaloisGroup.map (algebraMap в„ҡ
          (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
            hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ) = 1 := by
    intro q hq hq3 Пғ hПғ
    set gПғ : О“ в„ҡ := Field.absoluteGaloisGroup.map (algebraMap в„ҡ
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion в„ҡ
        hq.toHeightOneSpectrumRingOfIntegersRat)) Пғ
    have hОё1 : Оё' gПғ = 1 := by
      by_cases hq2 : q = 2
      В· subst hq2
        exact (h2unr Пғ hПғ).1
      В· exact theta'_eq_one_of_mem_localInertiaGroup_of_ne_two_three Оё' d hd
          x hx hОё'x q hq hq2 hq3 Пғ hПғ
    have hПҮ1 : ПҮвӮҖ gПғ = 1 := by
      by_cases hq2 : q = 2
      В· subst hq2
        exact (h2unr Пғ hПғ).2
      В· exact hПҮunr q hq hq2 hq3 Пғ hПғ
    have hcyc : algebraMap в„Ө_[3] k
        ((cyclotomicCharacter (AlgebraicClosure в„ҡ) 3 gПғ.toRingEquiv :
          в„Ө_[3]ЛЈ) : в„Ө_[3]) = 1 := by
      by_cases hq2 : q = 2
      В· subst hq2
        obtain вҹЁП„, hП„, c, heqвҹ© := localInertia_two_eq_map_padic hПғ
        set m : О“ в„ҡ := Field.absoluteGaloisGroup.map (algebraMap в„ҡ в„ҡ_[2]) П„
        have heq' : gПғ = c * m * cвҒ»В№ := heq
        have hconj : cyclotomicCharacter (AlgebraicClosure в„ҡ) 3
            gПғ.toRingEquiv =
            cyclotomicCharacter (AlgebraicClosure в„ҡ) 3 m.toRingEquiv := by
