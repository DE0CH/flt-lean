      (TensorProduct.lid k V)).toAddEquiv
  have he : ‚ąÄ (g : őď (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö v))
      (x : ((ŌĀ.baseChange (k ‚ßł (‚ä• : Ideal k))).toLocal v).Space),
      e (g ‚ÄĘ x) = g ‚ÄĘ e x := by
    intro g x
