  have hőīŌĄ : őī ŌĄ = 1 := by
    have h := (hőī ŌĄ 0).2.1 hŌĄ
    rwa [GaloisRep.ker, MonoidHom.mem_ker] at h
  have hŌÄm : ‚ąÄ x : V, ŌÄ‚āā (ŌĀ m x) = ŌÄ‚āā x := by
    intro x
    have h := (hőī ŌĄ x).1
    rw [GaloisRep.map_apply, ‚Üź hm] at h
    rw [h, hőīŌĄ, Module.End.one_apply]
  set ŌÄ' : V ‚Üí‚āó[k] k := ŌÄ‚āā.comp (ŌĀ c‚ĀĽ¬Ļ : Module.End k V) with hŌÄ'
  have hŌÄ'surj : Function.Surjective ŌÄ' := by
    intro r
    obtain ‚ü®x, hx‚ü© := hŌÄsurj r
    refine ‚ü®ŌĀ c x, ?_‚ü©
    rw [hŌÄ', LinearMap.comp_apply]
    have hcc : (ŌĀ c‚ĀĽ¬Ļ) ((ŌĀ c) x) = x := by
      rw [‚Üź Module.End.mul_apply, ‚Üź map_mul, inv_mul_cancel, map_one,
        Module.End.one_apply]
