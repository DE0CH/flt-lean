noncomputable def DedekindContinuation.poitouHorizontal {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K) (T : ‚ĄĚ) : ‚ĄĚ :=
  ((2 * (Real.pi : ‚Ąā) * Complex.I)‚ĀĽ¬Ļ *
    ((‚ąę ŌÉ in (-(1 / 4) : ‚ĄĚ)..(5 / 4),
        poitouPhi (ŌÉ - T * Complex.I) *
          (deriv pkg.xi (ŌÉ - T * Complex.I) / pkg.xi (ŌÉ - T * Complex.I))) -
