          (-(2 : ‚ĄĚ))) :=
    summable_rpow_neg_natCard_quotient (by norm_num)
  refine ‚ü®Real.exp (-(3 / 2 *
      ‚ąĎ' P : HeightOneSpectrum (NumberField.RingOfIntegers K),
        (Nat.card (NumberField.RingOfIntegers K ‚ßł P.asIdeal) : ‚ĄĚ) ^
          (-(2 : ‚ĄĚ)))), Real.exp_pos _, ?_‚ü©
  intro s hs
