            algebraMap ‚Ąö_[2] (AlgebraicClosure ‚Ąö_[2]) 3 := by
          rw [map_ofNat]
        have h3ne : (3 : AlgebraicClosure ‚Ąö_[2]) ‚Č† 0 := by
