open scoped Pointwise

/-- **Ring automorphisms preserve the maximal ideal of a local ring**:
the action of a group element under a `MulSemiringAction` maps the
maximal ideal into itself (a unit image would pull back to a unit along
the inverse automorphism). -/
theorem smul_mem_maximalIdeal_of_mem
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (g : G) {x : R} (hx : x ‚ąą IsLocalRing.maximalIdeal R) :
    g ‚ÄĘ x ‚ąą IsLocalRing.maximalIdeal R := by
  rw [IsLocalRing.mem_maximalIdeal, mem_nonunits_iff] at hx ‚äĘ
  intro hu
  have h1 := hu.map (MulSemiringAction.toRingEquiv G R g‚ĀĽ¬Ļ)
  rw [show (MulSemiringAction.toRingEquiv G R g‚ĀĽ¬Ļ) (g ‚ÄĘ x) = g‚ĀĽ¬Ļ ‚ÄĘ (g ‚ÄĘ x) from rfl,
    inv_smul_smul] at h1
  exact hx h1

/-- Powers of the maximal ideal are likewise preserved by ring
automorphisms (induction over the ideal product). -/
theorem smul_mem_maximalIdeal_pow_of_mem
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (g : G) : ‚ąÄ (k : ‚Ąē) {x : R}, x ‚ąą (IsLocalRing.maximalIdeal R) ^ k ‚Üí
      g ‚ÄĘ x ‚ąą (IsLocalRing.maximalIdeal R) ^ k := by
  intro k
  induction k with
  | zero =>
      intro x _
      rw [pow_zero, Ideal.one_eq_top]
      exact Submodule.mem_top
  | succ n ih =>
      intro x hx
      rw [pow_succ] at hx ‚äĘ
      refine Submodule.mul_induction_on hx (fun a ha b hb => ?_) (fun a b ha hb => ?_)
      ¬∑ rw [smul_mul']
        exact Ideal.mul_mem_mul (ih ha) (smul_mem_maximalIdeal_of_mem g hb)
      ¬∑ rw [smul_add]
        exact add_mem ha hb

/-- **The derivative bound at level `‚Č• 2`** (Serre, *Corps Locaux* IV):
an automorphism displacing every ring element into `ūĚĒ™^(j+2)` displaces
every element OF `ūĚĒ™^(j+2)` into `ūĚĒ™^(j+3)` ‚ÄĒ split `c = a¬∑b` with
`a ‚ąą ūĚĒ™^(j+1)`, `b ‚ąą ūĚĒ™` and use `g(ab) ‚ąí ab = g(a)(g(b) ‚ąí b) +
(g(a) ‚ąí a)b`, whose terms live in `ūĚĒ™^(2j+3)` and `ūĚĒ™^(j+3)`. -/
theorem smul_sub_mem_maximalIdeal_pow_succ
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (g : G) (j : ‚Ąē)
    (hg : ‚ąÄ a : R, g ‚ÄĘ a - a ‚ąą (IsLocalRing.maximalIdeal R) ^ (j + 2)) :
    ‚ąÄ c ‚ąą (IsLocalRing.maximalIdeal R) ^ (j + 2),
      g ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ (j + 3) := by
  intro c hc
  rw [show j + 2 = (j + 1) + 1 from rfl, pow_succ] at hc
  refine Submodule.mul_induction_on hc (fun a ha b hb => ?_) (fun a b ha hb => ?_)
  ¬∑ have hkey : g ‚ÄĘ (a * b) - a * b = (g ‚ÄĘ a) * (g ‚ÄĘ b - b) + (g ‚ÄĘ a - a) * b := by
      rw [smul_mul']
      ring
    rw [hkey]
    refine add_mem ?_ ?_
    ¬∑ have h1 : (g ‚ÄĘ a) * (g ‚ÄĘ b - b) ‚ąą
          (IsLocalRing.maximalIdeal R) ^ (j + 1) * (IsLocalRing.maximalIdeal R) ^ (j + 2) :=
        Ideal.mul_mem_mul (smul_mem_maximalIdeal_pow_of_mem g (j + 1) ha) (hg b)
      have hle : (IsLocalRing.maximalIdeal R) ^ (j + 1 + (j + 2)) ‚Č§
          (IsLocalRing.maximalIdeal R) ^ (j + 3) := Ideal.pow_le_pow_right (by omega)
      rw [‚Üź pow_add] at h1
      exact hle h1
    ¬∑ have h1 : (g ‚ÄĘ a - a) * b ‚ąą
          (IsLocalRing.maximalIdeal R) ^ (j + 2) * IsLocalRing.maximalIdeal R :=
        Ideal.mul_mem_mul (hg a) hb
      rwa [‚Üź pow_succ] at h1
  ¬∑ have hkey : g ‚ÄĘ (a + b) - (a + b) = (g ‚ÄĘ a - a) + (g ‚ÄĘ b - b) := by
      rw [smul_add]
      ring
    rw [hkey]
    exact add_mem ha hb

/-- **The `n`-th-power step** (uniform in the residue characteristic;
Serre, *Corps Locaux* IV): if `g` displaces `R` into `ūĚĒ™^(i+1)` and
displaces `ūĚĒ™^(i+1)` into `ūĚĒ™^(i+2)`, and `n ‚ąą ūĚĒ™`, then `g‚ĀŅ` displaces
`R` into `ūĚĒ™^(i+2)`. Telescoping: `gŠĶŹa ‚ąí a ‚Č° k¬∑(ga ‚ąí a) mod ūĚĒ™^(i+2)`
by induction on `k` (the increment `gŠĶŹ(ga ‚ąí a) ‚ąí (ga ‚ąí a)` lies in
`ūĚĒ™^(i+2)` because `ga ‚ąí a ‚ąą ūĚĒ™^(i+1)` and every power of `g` displaces
`ūĚĒ™^(i+1)` into `ūĚĒ™^(i+2)`), and at `k = n` the main term
`n¬∑(ga ‚ąí a) ‚ąą ūĚĒ™¬∑ūĚĒ™^(i+1)` dies too. -/
theorem pow_smul_sub_mem_maximalIdeal_pow_succ
    {R : Type*} [CommRing R] [IsLocalRing R]
    {G : Type*} [Group G] [MulSemiringAction G R]
    (n : ‚Ąē) (hn : (n : R) ‚ąą IsLocalRing.maximalIdeal R)
    (g : G) (i : ‚Ąē)
    (hg : ‚ąÄ a : R, g ‚ÄĘ a - a ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 1))
    (hg2 : ‚ąÄ c ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 1),
      g ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 2)) :
    ‚ąÄ a : R, (g ^ n) ‚ÄĘ a - a ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
  -- every power of `g` also displaces `ūĚĒ™^(i+1)` into `ūĚĒ™^(i+2)`
  have hpow : ‚ąÄ (k : ‚Ąē), ‚ąÄ c ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 1),
      (g ^ k) ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
    intro k
    induction k with
    | zero => intro c _; simp
    | succ m ih =>
        intro c hc
        have hkey : (g ^ (m + 1)) ‚ÄĘ c - c =
            (g ^ m) ‚ÄĘ (g ‚ÄĘ c - c) + ((g ^ m) ‚ÄĘ c - c) := by
          rw [pow_succ, mul_smul, smul_sub]
          ring
        rw [hkey]
        exact add_mem (smul_mem_maximalIdeal_pow_of_mem _ (i + 2) (hg2 c hc)) (ih c hc)
  -- telescoping: `gŠĶŹa ‚ąí a ‚Č° k¬∑(ga ‚ąí a)` modulo `ūĚĒ™^(i+2)`
  have htel : ‚ąÄ (k : ‚Ąē) (a : R),
      (g ^ k) ‚ÄĘ a - a - (k : R) * (g ‚ÄĘ a - a) ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
    intro k
    induction k with
    | zero => intro a; simp
    | succ m ih =>
        intro a
        have hkey : (g ^ (m + 1)) ‚ÄĘ a - a - ((m + 1 : ‚Ąē) : R) * (g ‚ÄĘ a - a) =
            ((g ^ m) ‚ÄĘ (g ‚ÄĘ a - a) - (g ‚ÄĘ a - a)) +
              ((g ^ m) ‚ÄĘ a - a - (m : R) * (g ‚ÄĘ a - a)) := by
          rw [pow_succ, mul_smul, smul_sub]
          push_cast
          ring
        rw [hkey]
        exact add_mem (hpow m _ (hg a)) (ih a)
  intro a
  have h1 := htel n a
  have h2 : (n : R) * (g ‚ÄĘ a - a) ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
    rw [pow_succ']
    exact Ideal.mul_mem_mul hn (hg a)
  have h3 := add_mem h1 h2
  simpa using h3

/-- **Wild elements have `p`-power order** (Serre, *Corps Locaux* IV
¬ß2, made monogenicity-free, uniform in the residue characteristic
`p`): in a Noetherian local domain of residue characteristic `p` with
a finite faithfully acting automorphism group, an automorphism `ŌÉ`
displacing `R` into `ūĚĒ™` and `ūĚĒ™` into `ūĚĒ™¬≤` has `p`-power order. The
coprime-to-`p` part `ŌĄ = ŌÉ^(p^j‚āÄ)` climbs the filtration
`H_i = {g | (g ‚ąí 1)R ‚äÜ ūĚĒ™^(i+1)}` forever: `ŌĄ ‚ąą H_i ‚üĻ ŌĄ^p ‚ąą H_(i+1)`
(the `p`-th-power step) and `ŌĄ ‚ąą ‚ü®ŌĄ^p‚ü©` (B√©zout, order coprime to
`p`), so `ŌĄ` displaces into `‚čā ūĚĒ™^n = 0` (Krull) and is trivial. -/
theorem exists_pow_prime_pow_eq_one_of_wild
    {R : Type*} [CommRing R] [IsDomain R] [IsNoetherianRing R] [IsLocalRing R]
    {G : Type*} [Group G] [Finite G] [MulSemiringAction G R]
    (hfaith : ‚ąÄ g : G, (‚ąÄ a : R, g ‚ÄĘ a = a) ‚Üí g = 1)
    {p : ‚Ąē} (hp : p.Prime) (hpm : (p : R) ‚ąą IsLocalRing.maximalIdeal R)
    (ŌÉ : G)
    (hŌÉ : ‚ąÄ a : R, ŌÉ ‚ÄĘ a - a ‚ąą IsLocalRing.maximalIdeal R)
    (hker : ‚ąÄ c ‚ąą IsLocalRing.maximalIdeal R,
      ŌÉ ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ 2) :
    ‚ąÉ j : ‚Ąē, ŌÉ ^ p ^ j = 1 := by
  classical
  refine ‚ü®(orderOf ŌÉ).factorization p, ?_‚ü©
  set ŌĄ := ŌÉ ^ p ^ (orderOf ŌÉ).factorization p with hŌĄdef
  -- the order of `ŌĄ` is coprime to `p`
  have hn0 : orderOf ŌÉ ‚Č† 0 := (orderOf_pos ŌÉ).ne'
  have hŌĄord : Nat.Coprime p (orderOf ŌĄ) := by
    have hdvd : p ^ (orderOf ŌÉ).factorization p ‚ą£ orderOf ŌÉ := Nat.ordProj_dvd (orderOf ŌÉ) p
    have horder : orderOf ŌĄ = orderOf ŌÉ / p ^ (orderOf ŌÉ).factorization p := by
      rw [hŌĄdef, orderOf_pow, Nat.gcd_eq_right hdvd]
    rw [horder]
    exact Nat.coprime_ordCompl hp hn0
  -- B√©zout: `ŌĄ` lies in every subgroup containing `ŌĄ^p`
  have hbez : ‚ąÄ H : Subgroup G, ŌĄ ^ p ‚ąą H ‚Üí ŌĄ ‚ąą H := by
    intro H hH
    have hab := Nat.gcd_eq_gcd_ab p (orderOf ŌĄ)
    rw [Nat.Coprime.gcd_eq_one hŌĄord] at hab
    have hzp : ((ŌĄ ^ p) ^ Nat.gcdA p (orderOf ŌĄ) : G) = ŌĄ := by
      have hexp : (p : ‚Ą§) * Nat.gcdA p (orderOf ŌĄ) =
          1 - (orderOf ŌĄ : ‚Ą§) * Nat.gcdB p (orderOf ŌĄ) := by
        push_cast at hab
        linarith
      rw [‚Üź zpow_natCast ŌĄ p, ‚Üź zpow_mul]
      rw [hexp, zpow_sub, zpow_one, zpow_mul, zpow_natCast, pow_orderOf_eq_one, one_zpow,
        inv_one, mul_one]
    exact hzp ‚Ėł Subgroup.zpow_mem H hH _
  -- powers of `ŌÉ` keep the level-one displacement bounds
  have hpow1 : ‚ąÄ (k : ‚Ąē) (a : R), ŌÉ ^ k ‚ÄĘ a - a ‚ąą IsLocalRing.maximalIdeal R := by
    intro k
    induction k with
    | zero => intro a; simp
    | succ m ih =>
        intro a
        have hkey : ŌÉ ^ (m + 1) ‚ÄĘ a - a = ŌÉ ^ m ‚ÄĘ (ŌÉ ‚ÄĘ a - a) + (ŌÉ ^ m ‚ÄĘ a - a) := by
          rw [pow_succ, mul_smul, smul_sub]
          ring
        rw [hkey]
        exact add_mem (smul_mem_maximalIdeal_of_mem _ (hŌÉ a)) (ih a)
  have hpow2 : ‚ąÄ (k : ‚Ąē), ‚ąÄ c ‚ąą IsLocalRing.maximalIdeal R,
      ŌÉ ^ k ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ 2 := by
    intro k
    induction k with
    | zero => intro c _; simp
    | succ m ih =>
        intro c hc
        have hkey : ŌÉ ^ (m + 1) ‚ÄĘ c - c = ŌÉ ^ m ‚ÄĘ (ŌÉ ‚ÄĘ c - c) + (ŌÉ ^ m ‚ÄĘ c - c) := by
          rw [pow_succ, mul_smul, smul_sub]
          ring
        rw [hkey]
        exact add_mem (smul_mem_maximalIdeal_pow_of_mem _ 2 (hker c hc)) (ih c hc)
  -- the main climb: `ŌĄ` lies in every level of the filtration
  have hclaim : ‚ąÄ i : ‚Ąē, ŌĄ ‚ąą ((IsLocalRing.maximalIdeal R) ^ (i + 1)).inertia G := by
    intro i
    induction i with
    | zero =>
        refine AddSubgroup.mem_inertia.mpr fun a => ?_
        rw [zero_add, pow_one]
        exact hpow1 _ a
    | succ i ih =>
        have hlev : ‚ąÄ a : R, ŌĄ ‚ÄĘ a - a ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 1) :=
          fun a => AddSubgroup.mem_inertia.mp ih a
        have h2 : ‚ąÄ c ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 1),
            ŌĄ ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ (i + 2) := by
          rcases i with _ | j
          ¬∑ intro c hc
            rw [pow_one] at hc
            exact hpow2 _ c hc
          ¬∑ exact smul_sub_mem_maximalIdeal_pow_succ ŌĄ j hlev
        have hstep := pow_smul_sub_mem_maximalIdeal_pow_succ p hpm ŌĄ i hlev h2
        exact hbez _ (AddSubgroup.mem_inertia.mpr hstep)
  -- Krull intersection: `ŌĄ` acts trivially
  have htriv : ‚ąÄ a : R, ŌĄ ‚ÄĘ a = a := by
    intro a
    have hall : ŌĄ ‚ÄĘ a - a ‚ąą ‚®Ö m : ‚Ąē, (IsLocalRing.maximalIdeal R) ^ m := by
      rw [Submodule.mem_iInf]
      intro m
      rcases m with _ | m
      ¬∑ rw [pow_zero, Ideal.one_eq_top]
        exact Submodule.mem_top
      ¬∑ exact AddSubgroup.mem_inertia.mp (hclaim m) a
    rw [Ideal.iInf_pow_eq_bot_of_isLocalRing (IsLocalRing.maximalIdeal R)
      (IsLocalRing.maximalIdeal.isMaximal R).ne_top] at hall
    rw [‚Üź sub_eq_zero]
    exact (Ideal.mem_bot).mp hall
  exact hfaith ŌĄ htriv

/-- **The generic finite-level tame-generator theorem** (Serre, *Corps
Locaux* IV ¬ß1‚Äď2, over an abstract DVR, uniform in the residue
characteristic `p`): given a finite group acting faithfully by ring
automorphisms on a DVR `R` with `p ‚ąą ūĚĒ™` for a prime `p`, and an
element `ŌÜ` acting as the `p`-th-power map on the residue field, there
is an inertia element `t` such that (a) every inertia element is a
power of `t` times a `p`-power-order element, and (b) `ŌÜtŌÜ‚ĀĽ¬Ļ(t^p)‚ĀĽ¬Ļ`
has `p`-power order. The tame character `őł(ŌÉ) = ŌÉ(ŌÄ)/ŌÄ mod ūĚĒ™` (a
cocycle made multiplicative on inertia by residue triviality) embeds
inertia-mod-wild into the cyclic group `őļň£`; its kernel is
`p`-power-order by `exists_pow_prime_pow_eq_one_of_wild`, and `őł` is
`ŌÜ`-semilinear: `őł(ŌÜŌÉŌÜ‚ĀĽ¬Ļ) = őł(ŌÉ)^p`. -/
theorem exists_finite_level_tame_generator_of_frobenius
    {R : Type*} [CommRing R] [IsDomain R] [IsDiscreteValuationRing R]
    {G : Type*} [Group G] [Finite G] [MulSemiringAction G R]
    (hfaith : ‚ąÄ g : G, (‚ąÄ a : R, g ‚ÄĘ a = a) ‚Üí g = 1)
    {p : ‚Ąē} (hp : p.Prime) (hpm : (p : R) ‚ąą IsLocalRing.maximalIdeal R)
    (ŌÜ : G) (hŌÜ : ‚ąÄ x : R, ŌÜ ‚ÄĘ x - x ^ p ‚ąą IsLocalRing.maximalIdeal R) :
    ‚ąÉ t ‚ąą (IsLocalRing.maximalIdeal R).inertia G,
      (‚ąÄ ŌÉ ‚ąą (IsLocalRing.maximalIdeal R).inertia G,
        ‚ąÉ m j : ‚Ąē, ((t ^ m)‚ĀĽ¬Ļ * ŌÉ) ^ p ^ j = 1) ‚ąß
      ‚ąÉ j : ‚Ąē, (ŌÜ * t * ŌÜ‚ĀĽ¬Ļ * (t ^ p)‚ĀĽ¬Ļ) ^ p ^ j = 1 := by
  classical
  -- a uniformizer and the unit cocycle `g ‚ÄĘ ŌÄ = ŌÄ * U g`
  obtain ‚ü®ŌÄ, hŌÄ‚ü© := IsDiscreteValuationRing.exists_irreducible R
  have hŌÄ0 : ŌÄ ‚Č† 0 := hŌÄ.ne_zero
  have hspan : IsLocalRing.maximalIdeal R = Ideal.span {ŌÄ} := hŌÄ.maximalIdeal_eq
  have hUex : ‚ąÄ g : G, ‚ąÉ u : Rň£, ŌÄ * u = g ‚ÄĘ ŌÄ := by
    intro g
    have hgŌÄ : Irreducible (g ‚ÄĘ ŌÄ) :=
      (MulEquiv.irreducible_iff (MulSemiringAction.toRingEquiv G R g)).mpr hŌÄ
    exact IsDiscreteValuationRing.associated_of_irreducible R hŌÄ hgŌÄ
  choose U hU using hUex
  -- the cocycle relation and normalization
  have hUmul : ‚ąÄ g h : G, (U (g * h) : R) = U g * (g ‚ÄĘ (U h : R)) := by
    intro g h
    refine mul_left_cancel‚āÄ hŌÄ0 ?_
    calc ŌÄ * (U (g * h) : R) = (g * h) ‚ÄĘ ŌÄ := hU (g * h)
      _ = g ‚ÄĘ (h ‚ÄĘ ŌÄ) := mul_smul g h ŌÄ
      _ = g ‚ÄĘ (ŌÄ * (U h : R)) := by rw [hU h]
      _ = (g ‚ÄĘ ŌÄ) * (g ‚ÄĘ (U h : R)) := smul_mul' g ŌÄ (U h : R)
      _ = (ŌÄ * (U g : R)) * (g ‚ÄĘ (U h : R)) := by rw [hU g]
      _ = ŌÄ * ((U g : R) * (g ‚ÄĘ (U h : R))) := by ring
  have hU1 : (U 1 : R) = 1 := by
    refine mul_left_cancel‚āÄ hŌÄ0 ?_
    rw [hU 1, one_smul, mul_one]
  -- the tame character on the inertia subgroup
  have hmul : ‚ąÄ ŌÉ ŌĄ : ‚Ü•((IsLocalRing.maximalIdeal R).inertia G),
      Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U ((ŌÉ * ŌĄ : _) : G)) =
        Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U (ŌÉ : G)) *
          Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U (ŌĄ : G)) := by
    intro ŌÉ ŌĄ
    refine Units.ext ?_
    show Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ((ŌÉ : G) * (ŌĄ : G)) : R) =
      Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (ŌÉ : G) : R) *
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (ŌĄ : G) : R)
    rw [hUmul (ŌÉ : G) (ŌĄ : G), map_mul]
    congr 1
    exact Ideal.Quotient.eq.mpr (AddSubgroup.mem_inertia.mp ŌÉ.2 (U (ŌĄ : G) : R))
  set őł : ‚Ü•((IsLocalRing.maximalIdeal R).inertia G) ‚Üí*
      (R ‚ßł IsLocalRing.maximalIdeal R)ň£ :=
    MonoidHom.mk' (fun ŌÉ =>
      Units.map (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)).toMonoidHom (U (ŌÉ : G))) hmul
    with hőłdef
  have hőłval : ‚ąÄ ŌÉ : ‚Ü•((IsLocalRing.maximalIdeal R).inertia G),
      (őł ŌÉ : R ‚ßł IsLocalRing.maximalIdeal R) =
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (ŌÉ : G) : R) := fun ŌÉ => rfl
  -- the kernel of the tame character has p-power order
  have hker_of_őł : ‚ąÄ x : ‚Ü•((IsLocalRing.maximalIdeal R).inertia G), őł x = 1 ‚Üí
      ‚ąÄ c ‚ąą IsLocalRing.maximalIdeal R,
        (x : G) ‚ÄĘ c - c ‚ąą (IsLocalRing.maximalIdeal R) ^ 2 := by
    intro x hx c hc
    have hu1 : (U (x : G) : R) - 1 ‚ąą IsLocalRing.maximalIdeal R := by
      refine Ideal.Quotient.eq.mp ?_
      have hval := congrArg Units.val hx
      rw [hőłval] at hval
      simpa using hval
    obtain ‚ü®r, hr‚ü© := Ideal.mem_span_singleton'.mp (hspan ‚Ėł hc)
    have hxc : (x : G) ‚ÄĘ c - c = (((x : G) ‚ÄĘ r) * (U (x : G) : R) - r) * ŌÄ := by
      calc (x : G) ‚ÄĘ c - c = (x : G) ‚ÄĘ (r * ŌÄ) - r * ŌÄ := by rw [hr]
        _ = ((x : G) ‚ÄĘ r) * ((x : G) ‚ÄĘ ŌÄ) - r * ŌÄ := by rw [smul_mul']
        _ = ((x : G) ‚ÄĘ r) * (ŌÄ * (U (x : G) : R)) - r * ŌÄ := by rw [hU (x : G)]
        _ = (((x : G) ‚ÄĘ r) * (U (x : G) : R) - r) * ŌÄ := by ring
    rw [hxc, pow_two]
    refine Ideal.mul_mem_mul ?_ (hspan ‚Ėł Ideal.mem_span_singleton_self ŌÄ)
    have hsplit : ((x : G) ‚ÄĘ r) * (U (x : G) : R) - r =
        ((x : G) ‚ÄĘ r) * ((U (x : G) : R) - 1) + ((x : G) ‚ÄĘ r - r) := by ring
    rw [hsplit]
    exact add_mem (Ideal.mul_mem_left _ _ hu1) (AddSubgroup.mem_inertia.mp x.2 r)
  have hwild : ‚ąÄ x : ‚Ü•((IsLocalRing.maximalIdeal R).inertia G), őł x = 1 ‚Üí
      ‚ąÉ j : ‚Ąē, (x : G) ^ p ^ j = 1 := fun x hx =>
    exists_pow_prime_pow_eq_one_of_wild hfaith hp hpm (x : G)
      (AddSubgroup.mem_inertia.mp x.2) (hker_of_őł x hx)
  -- the image of the tame character is cyclic; pick a generator
  have hfr : ((őł.range : Set (R ‚ßł IsLocalRing.maximalIdeal R)ň£)).Finite := by
    rw [MonoidHom.coe_range]
    exact Set.finite_range őł
  haveI : Finite ‚Ü•őł.range := hfr.to_subtype
  haveI : IsCyclic ‚Ü•őł.range := isCyclic_subgroup_units őł.range
  obtain ‚ü®gen, hgen‚ü© := IsCyclic.exists_generator (őĪ := ‚Ü•őł.range)
  obtain ‚ü®t‚āÄ, ht‚āÄ‚ü© : ‚ąÉ t‚āÄ : ‚Ü•((IsLocalRing.maximalIdeal R).inertia G),
      őł t‚āÄ = (gen : (R ‚ßł IsLocalRing.maximalIdeal R)ň£) := gen.2
  refine ‚ü®(t‚āÄ : G), t‚āÄ.2, ?_, ?_‚ü©
  ¬∑ -- clause (a): powers of `t‚āÄ` exhaust inertia mod wild
    intro ŌÉ hŌÉ
    have hmemrange : (‚ü®őł ‚ü®ŌÉ, hŌÉ‚ü©, ‚ü®‚ü®ŌÉ, hŌÉ‚ü©, rfl‚ü©‚ü© : ‚Ü•őł.range) ‚ąą Submonoid.powers gen :=
      (isOfFinOrder_of_finite gen).mem_powers_iff_mem_zpowers.mpr (hgen _)
    obtain ‚ü®m, hm‚ü© := hmemrange
    refine ‚ü®m, ?_‚ü©
    have hval := congrArg (Subtype.val) hm
    push_cast at hval
    have hőł1 : őł ((t‚āÄ ^ m)‚ĀĽ¬Ļ * ‚ü®ŌÉ, hŌÉ‚ü©) = 1 := by
      rw [map_mul, map_inv, map_pow, ht‚āÄ, hval, inv_mul_cancel]
    obtain ‚ü®j, hj‚ü© := hwild _ hőł1
    refine ‚ü®j, ?_‚ü©
    simpa using hj
  ¬∑ -- clause (b): Frobenius conjugation raises the tame character to `p`
    have hŌÜres : ‚ąÄ x : R,
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (ŌÜ ‚ÄĘ x) =
          (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) x) ^ p := by
      intro x
      rw [‚Üź map_pow]
      exact Ideal.Quotient.eq.mpr (hŌÜ x)
    have hconjmem : ŌÜ * (t‚āÄ : G) * ŌÜ‚ĀĽ¬Ļ ‚ąą (IsLocalRing.maximalIdeal R).inertia G := by
      refine AddSubgroup.mem_inertia.mpr fun x => ?_
      have hrw : (ŌÜ * (t‚āÄ : G) * ŌÜ‚ĀĽ¬Ļ) ‚ÄĘ x - x =
          ŌÜ ‚ÄĘ ((t‚āÄ : G) ‚ÄĘ (ŌÜ‚ĀĽ¬Ļ ‚ÄĘ x) - ŌÜ‚ĀĽ¬Ļ ‚ÄĘ x) := by
        rw [smul_sub, mul_smul, mul_smul, smul_inv_smul]
      rw [hrw]
      exact smul_mem_maximalIdeal_of_mem ŌÜ (AddSubgroup.mem_inertia.mp t‚āÄ.2 _)
    -- the semilinearity computation
    have hsemi : Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)
        (U (ŌÜ * (t‚āÄ : G) * ŌÜ‚ĀĽ¬Ļ) : R) =
        Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U (t‚āÄ : G) : R) ^ p := by
      have e3 : Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ŌÜ : R) *
          Ideal.Quotient.mk (IsLocalRing.maximalIdeal R) (U ŌÜ‚ĀĽ¬Ļ : R) ^ p = 1 := by
        have e0 : (1 : R) = (U ŌÜ : R) * (ŌÜ ‚ÄĘ (U ŌÜ‚ĀĽ¬Ļ : R)) := by
          rw [‚Üź hU1, ‚Üź hUmul ŌÜ ŌÜ‚ĀĽ¬Ļ, mul_inv_cancel]
        have e1 := congrArg (Ideal.Quotient.mk (IsLocalRing.maximalIdeal R)) e0
        rw [map_one, map_mul, hŌÜres] at e1
        exact e1.symm
      have e1 : (U (ŌÜ * (t‚āÄ : G) * ŌÜ‚ĀĽ¬Ļ) : R) =
