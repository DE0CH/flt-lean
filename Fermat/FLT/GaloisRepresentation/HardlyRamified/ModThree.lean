set_option maxHeartbeats 1000000 in
/-- **The Serre elimination, semidirect case** (PROVEN 2026-07-18 ‚ÄĒ
purely representation-theoretic): the left factor gives a nontrivial
normal exponent-3 subgroup of `ŌÄ.range`; its `őď ‚Ąö`-preimage (the kernel
of the right-component character `r`) acts by scalar-times-unipotent
operators (the cube is central hence scalar by irreducibility, a cube
root and the char-3 Frobenius give `(ŌÉŌĀ g ‚ąí őľ)¬≤ = 0`, with `őľ ‚Č† 0` by
invertibility); either every kernel element is scalar (then the left
factor is trivial in `PGL‚āā`, contradicting `m ‚Č• 1`) or some nonscalar
`g‚āÄ` has a `1`-dimensional eigenline `W` (rank‚Äďnullity) shared by every
nonscalar kernel element (the unipotent parameter is unique, central
commutator scalars are `¬Ī1` by determinants, and `‚ąí1` is impossible in
characteristic `3` by expanding the two nilpotency relations), so
normality of the kernel makes `W` a `őď ‚Ąö`-stable line ‚ÄĒ contradicting
absolute irreducibility. -/
theorem serre_elimination_semidirect {k : Type u} [Finite k] [Field k]
    [Algebra ‚Ą§_[3] k] [TopologicalSpace k] [DiscreteTopology k]
    (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
    [Module.Free k V]
    (hV : Module.rank k V = 2) {ŌĀ : GaloisRep ‚Ąö k V}
    (_hŌĀ : IsHardlyRamified (show Odd 3 by decide) hV ŌĀ)
    (habs : Slop.OddRep.IsAbsolutelyIrreducible
      (MonoidHomClass.toMonoidHom ŌĀ : Representation k (őď ‚Ąö) V))
    (b : Module.Basis (Fin 2) (AlgebraicClosure k)
      ((AlgebraicClosure k) ‚äó[k] V))
    (e : AlgebraicClosure k ‚ČÉ+* Dickson.K 3)
    (u : őď ‚Ąö ‚Üí* GL (Fin 2) (Dickson.K 3))
    (hu : ‚ąÄ g, ((u g : GL (Fin 2) (Dickson.K 3)) :
      Matrix (Fin 2) (Fin 2) (Dickson.K 3)) =
      (LinearMap.toMatrix b b ((Slop.OddRep.baseChange (AlgebraicClosure k)
        (MonoidHomClass.toMonoidHom ŌĀ)) g)).map e)
    (ŌÄ : őď ‚Ąö ‚Üí* Dickson.PGL 3)
    (hŌÄ : ‚ąÄ g, ŌÄ g = QuotientGroup.mk (u g))
    {m t : ‚Ąē} (hm : m ‚Č• 1)
    (ŌÜ : Multiplicative (ZMod t) ‚Üí* MulAut (Multiplicative (Fin m ‚Üí ZMod 3)))
    (hiso : Nonempty (ŌÄ.range ‚ČÉ*
      (Multiplicative (Fin m ‚Üí ZMod 3)) ‚čä[ŌÜ] Multiplicative (ZMod t))) :
    False := by
  classical
  obtain ‚ü®eiso‚ü© := hiso
  haveI h3 : Fact (Nat.Prime 3) := ‚ü®Nat.prime_three‚ü©
  set L := AlgebraicClosure k
  set ŌÉŌĀ : Representation L (őď ‚Ąö) (L ‚äó[k] V) :=
    Slop.OddRep.baseChange L (MonoidHomClass.toMonoidHom ŌĀ)
  have hirr : ŌÉŌĀ.IsIrreducible := habs
  haveI : Module.Finite L (L ‚äó[k] V) := Module.Finite.base_change k L V
  have hfr2 : Module.finrank L (L ‚äó[k] V) = 2 := by
    rw [Module.finrank_baseChange]
    exact Module.finrank_eq_of_rank_eq (by exact_mod_cast hV)
  haveI : Nontrivial (L ‚äó[k] V) :=
    Module.nontrivial_of_finrank_pos (R := L) (by omega)
  obtain ‚ü®hnt, hsub‚ü© := (Slop.OddRep.isIrreducible_iff_forall ŌÉŌĀ).mp hirr
  -- characteristic `3` in `L` and in the endomorphism ring
  haveI hchark : CharP k 3 := charP_three_of_finite_padicIntThree_algebra
  haveI hcharL : CharP L 3 :=
    charP_of_injective_algebraMap (algebraMap k L).injective 3
  have hEnd_ne : (1 : Module.End L (L ‚äó[k] V)) ‚Č† 0 := by
    obtain ‚ü®v, hv‚ü© := exists_ne (0 : L ‚äó[k] V)
    intro h1
    exact hv (by simpa using congrFun (congrArg DFunLike.coe h1) v)
  haveI hcharEnd : CharP (Module.End L (L ‚äó[k] V)) 3 := by
    refine charP_of_injective_algebraMap (R := L) ?_ 3
    intro a c hac
    obtain ‚ü®v, hv‚ü© := exists_ne (0 : L ‚äó[k] V)
    have h := congrFun (congrArg DFunLike.coe hac) v
    simp only [Module.algebraMap_end_apply] at h
    have h2 : (a - c) ‚ÄĘ v = 0 := by
      have h3 := sub_smul a c v
      rw [h, sub_self] at h3
      exact h3
    rcases smul_eq_zero.mp h2 with h' | h'
    ¬∑ exact sub_eq_zero.mp h'
    ¬∑ exact absurd h' hv
  -- transport toolkit
  have hmap_inj : ‚ąÄ M N : Matrix (Fin 2) (Fin 2) (AlgebraicClosure k),
      M.map e = N.map e ‚Üí M = N := by
    intro M N h
    ext i j
    exact e.injective (congrFun (congrFun (congrArg Matrix.of.symm h) i) j)
  have hmulM : ‚ąÄ gg‚āĀ gg‚āā : őď ‚Ąö, LinearMap.toMatrix b b (ŌÉŌĀ gg‚āĀ) *
      LinearMap.toMatrix b b (ŌÉŌĀ gg‚āā) =
      LinearMap.toMatrix b b (ŌÉŌĀ gg‚āĀ * ŌÉŌĀ gg‚āā) :=
    fun gg‚āĀ gg‚āā => (LinearMap.toMatrix_comp b b b _ _).symm
  -- ŌÉŌĀ takes values in units
  have hunit : ‚ąÄ g : őď ‚Ąö, ŌÉŌĀ g * ŌÉŌĀ g‚ĀĽ¬Ļ = 1 := by
    intro g
    rw [‚Üź map_mul, mul_inv_cancel, map_one]
  -- commuting with the whole action forces a scalar
  have hscalar_of_comm : ‚ąÄ T : Module.End L (L ‚äó[k] V),
      (‚ąÄ h : őď ‚Ąö, T * ŌÉŌĀ h = ŌÉŌĀ h * T) ‚Üí ‚ąÉ őĹ : L, T = őĹ ‚ÄĘ 1 := by
    intro T hT
    obtain ‚ü®őĹ, hőĹ‚ü© := Module.End.exists_eigenvalue T
    have hEinv : ‚ąÄ h : őď ‚Ąö, ‚ąÄ w ‚ąą Module.End.eigenspace T őĹ,
        ŌÉŌĀ h w ‚ąą Module.End.eigenspace T őĹ := by
      intro h w hw
      rw [Module.End.mem_eigenspace_iff] at hw ‚äĘ
      have hc := congrFun (congrArg DFunLike.coe (hT h)) w
      simp only [Module.End.mul_apply] at hc
      rw [hc, hw, map_smul]
    rcases hsub (Module.End.eigenspace T őĹ) hEinv with hE | hE
    ¬∑ exact absurd hE hőĹ
    ¬∑ refine ‚ü®őĹ, LinearMap.ext fun v => ?_‚ü©
      have hv : v ‚ąą Module.End.eigenspace T őĹ := hE ‚Ėł Submodule.mem_top
      rw [Module.End.mem_eigenspace_iff] at hv
      simpa using hv
  -- a `g` whose projective class is trivial acts by a scalar
  have hscalar_of_pi_one : ‚ąÄ g : őď ‚Ąö, ŌÄ g = 1 ‚Üí ‚ąÉ őĹ : L, ŌÉŌĀ g = őĹ ‚ÄĘ 1 := by
    intro g hg
    refine hscalar_of_comm (ŌÉŌĀ g) fun h => ?_
    -- the matrix of `g` is central, so it commutes with the matrix of `h`
    have hcen : (u g : GL (Fin 2) (Dickson.K 3)) ‚ąą
        Subgroup.center (GL (Fin 2) (Dickson.K 3)) := by
      rw [‚Üź QuotientGroup.ker_mk' (Subgroup.center
        (GL (Fin 2) (Dickson.K 3))), MonoidHom.mem_ker]
      exact ((hŌÄ g).symm.trans hg : _)
    have hcommGL : u g * u h = u h * u g :=
      (Subgroup.mem_center_iff.mp hcen (u h)).symm
    have hval := congrArg Units.val hcommGL
    rw [Units.val_mul, Units.val_mul, hu, hu, ‚Üź Matrix.map_mul,
      ‚Üź Matrix.map_mul] at hval
    have hmat := hmap_inj _ _ hval
    rw [hmulM, hmulM] at hmat
    exact (LinearMap.toMatrix b b).injective hmat
  -- conversely: a scalar action has trivial projective class
  have hpi_one_of_scalar : ‚ąÄ g : őď ‚Ąö, (‚ąÉ őĹ : L, ŌÉŌĀ g = őĹ ‚ÄĘ 1) ‚Üí ŌÄ g = 1 := by
    rintro g ‚ü®őĹ, hőĹ‚ü©
    have hval : ((u g : GL (Fin 2) (Dickson.K 3)) :
        Matrix (Fin 2) (Fin 2) (Dickson.K 3)) = e őĹ ‚ÄĘ 1 := by
      rw [hu, hőĹ, map_smul, LinearMap.toMatrix_one]
      ext i j
      by_cases hij : i = j <;>
        simp [Matrix.map_apply, Matrix.smul_apply, hij]
    have hcen : (u g : GL (Fin 2) (Dickson.K 3)) ‚ąą
        Subgroup.center (GL (Fin 2) (Dickson.K 3)) := by
      refine Subgroup.mem_center_iff.mpr fun y => ?_
      apply Units.ext
      rw [Units.val_mul, Units.val_mul, hval]
      rw [smul_mul_assoc, one_mul, mul_smul_comm, mul_one]
    rw [hŌÄ g]
    have : QuotientGroup.mk' (Subgroup.center
        (GL (Fin 2) (Dickson.K 3))) (u g) = 1 := by
      rw [‚Üź MonoidHom.mem_ker, QuotientGroup.ker_mk']
      exact hcen
    exact this
  -- the kernel of the right component: the `őď ‚Ąö`-preimage of the
  -- normal elementary abelian `3`-subgroup
  set r : őď ‚Ąö ‚Üí* Multiplicative (ZMod t) :=
    (SemidirectProduct.rightHom.comp eiso.toMonoidHom).comp
      ŌÄ.rangeRestrict
  -- elements of the kernel cube to a central class
  have hcube : ‚ąÄ g : őď ‚Ąö, g ‚ąą r.ker ‚Üí (ŌÄ g) ^ 3 = 1 := by
    intro g hg
    have hy : SemidirectProduct.rightHom (eiso (ŌÄ.rangeRestrict g)) = 1 := hg
    have hy3 : (eiso (ŌÄ.rangeRestrict g)) ^ 3 = 1 := by
      have hmem : eiso (ŌÄ.rangeRestrict g) ‚ąą
          (SemidirectProduct.inl (ŌÜ := ŌÜ)).range := by
        rw [SemidirectProduct.range_inl_eq_ker_rightHom]
        exact hy
      obtain ‚ü®n, hn‚ü© := hmem
      rw [‚Üź hn, ‚Üź map_pow]
      have hn3 : n ^ 3 = 1 := by
        apply Multiplicative.toAdd.injective
        rw [toAdd_pow, toAdd_one]
        funext i
        show (3 : ‚Ąē) ‚ÄĘ Multiplicative.toAdd n i = 0
        rw [nsmul_eq_mul,
          show ((3 : ‚Ąē) : ZMod 3) = 0 from ZMod.natCast_self 3, zero_mul]
      rw [hn3, map_one]
    have hx3 : (ŌÄ.rangeRestrict g) ^ 3 = 1 := by
      apply eiso.injective
      rw [map_pow, hy3, map_one]
    have := congrArg Subtype.val hx3
    simpa using this
  -- kernel elements act by scalar-times-unipotent operators
  have hcube_scalar : ‚ąÄ g : őď ‚Ąö, g ‚ąą r.ker ‚Üí
      ‚ąÉ őĹ : L, (ŌÉŌĀ g) ^ 3 = őĹ ‚ÄĘ 1 := by
    intro g hg
    have hpi3 : ŌÄ (g ^ 3) = 1 := by rw [map_pow]; exact hcube g hg
    obtain ‚ü®őĹ, hőĹ‚ü© := hscalar_of_pi_one (g ^ 3) hpi3
    exact ‚ü®őĹ, by rw [‚Üź map_pow]; exact hőĹ‚ü©
  -- the unipotent structure: `(ŌÉŌĀ g ‚ąí őľ)¬≤ = 0` with `őľ¬≥ = őĹ`, `őľ ‚Č† 0`
  have hunip : ‚ąÄ g : őď ‚Ąö, g ‚ąą r.ker ‚Üí
      ‚ąÉ őľ : L, őľ ‚Č† 0 ‚ąß (ŌÉŌĀ g - őľ ‚ÄĘ 1) ^ 2 = 0 := by
    intro g hg
    obtain ‚ü®őĹ, hőĹ‚ü© := hcube_scalar g hg
    obtain ‚ü®őľ, hőľ‚ü© := IsAlgClosed.exists_pow_nat_eq (k := L) őĹ
      (n := 3) (by norm_num)
    have hcomm : Commute (ŌÉŌĀ g) (őľ ‚ÄĘ (1 : Module.End L (L ‚äó[k] V))) := by
      unfold Commute SemiconjBy
      rw [mul_smul_comm, smul_mul_assoc, mul_one, one_mul]
    have hnil3 : (ŌÉŌĀ g - őľ ‚ÄĘ 1) ^ 3 = 0 := by
      have hfrob := sub_pow_char_of_commute (p := 3)
        (x := ŌÉŌĀ g) (y := őľ ‚ÄĘ (1 : Module.End L (L ‚äó[k] V))) hcomm
      rw [hfrob, hőĹ, smul_pow, one_pow, hőľ, sub_self]
    have hnil2 : (ŌÉŌĀ g - őľ ‚ÄĘ 1) ^ 2 = 0 := by
      have hnil : IsNilpotent (ŌÉŌĀ g - őľ ‚ÄĘ 1) := ‚ü®3, hnil3‚ü©
      have hchar := IsNilpotent.charpoly_eq_X_pow_finrank hnil
      have haev := LinearMap.aeval_self_charpoly (ŌÉŌĀ g - őľ ‚ÄĘ 1)
      rw [hchar, hfr2] at haev
      simpa using haev
    refine ‚ü®őľ, ?_, hnil2‚ü©
    -- `őľ ‚Č† 0`: otherwise `ŌÉŌĀ g` is nilpotent yet invertible
    intro hőľ0
    rw [hőľ0] at hőľ
    have hőĹ0 : őĹ = 0 := by rw [‚Üź hőľ]; ring
    rw [hőĹ0, zero_smul] at hőĹ
    have hcomm' : Commute (ŌÉŌĀ g) (ŌÉŌĀ g‚ĀĽ¬Ļ) := by
      show ŌÉŌĀ g * ŌÉŌĀ g‚ĀĽ¬Ļ = ŌÉŌĀ g‚ĀĽ¬Ļ * ŌÉŌĀ g
      rw [‚Üź map_mul, ‚Üź map_mul, mul_inv_cancel, inv_mul_cancel]
    have h1 : (1 : Module.End L (L ‚äó[k] V)) = 0 := by
      have h2 : (ŌÉŌĀ g) ^ 3 * (ŌÉŌĀ g‚ĀĽ¬Ļ) ^ 3 = 1 := by
        rw [‚Üź hcomm'.mul_pow, hunit, one_pow]
      rw [‚Üź h2, hőĹ, zero_mul]
    exact hEnd_ne h1
  -- Case split: either every kernel element is scalar, or some is not
  by_cases hallscalar : ‚ąÄ g : őď ‚Ąö, g ‚ąą r.ker ‚Üí ‚ąÉ őĹ : L, ŌÉŌĀ g = őĹ ‚ÄĘ 1
  ¬∑ -- then the elementary abelian subgroup is trivial in `PGL‚āā`
    -- pick a nontrivial element of the left factor
    haveI : Nonempty (Fin m) := Fin.pos_iff_nonempty.mp (by omega)
    haveI : Nontrivial (Fin m ‚Üí ZMod 3) := inferInstance
    obtain ‚ü®n‚āÄ, hn‚āÄ‚ü© := exists_ne (1 : Multiplicative (Fin m ‚Üí ZMod 3))
    obtain ‚ü®g‚āÄ, hg‚āÄ‚ü© := ŌÄ.rangeRestrict_surjective
      (eiso.symm (SemidirectProduct.inl n‚āÄ))
    have hg‚āÄker : g‚āÄ ‚ąą r.ker := by
      show SemidirectProduct.rightHom (eiso (ŌÄ.rangeRestrict g‚āÄ)) = 1
      rw [hg‚āÄ, MulEquiv.apply_symm_apply]
      exact SemidirectProduct.rightHom_inl n‚āÄ
    have hŌÄg‚āÄ : ŌÄ g‚āÄ ‚Č† 1 := by
      intro hone
      have hx1 : ŌÄ.rangeRestrict g‚āÄ = 1 := by
        apply Subtype.ext
        simpa using hone
      rw [hx1] at hg‚āÄ
      have hinl1 : SemidirectProduct.inl (ŌÜ := ŌÜ) n‚āÄ = 1 := by
        have := congrArg eiso hg‚āÄ
        rw [MulEquiv.apply_symm_apply, map_one] at this
        exact this.symm
      exact hn‚āÄ (SemidirectProduct.inl_injective (by rw [hinl1, map_one]))
    exact hŌÄg‚āÄ (hpi_one_of_scalar g‚āÄ (hallscalar g‚āÄ hg‚āÄker))
  ¬∑ -- some kernel element is nonscalar: its eigenline is stable
    push Not at hallscalar
    obtain ‚ü®g‚āÄ, hg‚āÄker, hg‚āÄns'‚ü© := hallscalar
    have hg‚āÄns : ¬¨ ‚ąÉ őĹ : L, ŌÉŌĀ g‚āÄ = őĹ ‚ÄĘ 1 := by
      rintro ‚ü®őĹ, hőĹ‚ü©
      exact hg‚āÄns' őĹ hőĹ
    obtain ‚ü®őľ‚āÄ, hőľ‚āÄne, hőľ‚āÄnil‚ü© := hunip g‚āÄ hg‚āÄker
