      have h1 : ŌÉ ‚ÄĘ őł ‚ąą ŌÉ ‚ÄĘ ŌÉ‚ĀĽ¬Ļ ‚ÄĘ Q :=
        Ideal.smul_mem_pointwise_smul _ _ _ hőłP
      rwa [smul_inv_smul] at h1
