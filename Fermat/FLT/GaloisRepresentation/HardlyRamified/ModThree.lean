          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)
        (AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
          Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)))
    [FiniteDimensional (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N]
    [IsGalois (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
      Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat) N]
    (ŌÉ : AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat)
      ‚ČÉ‚āź[IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat]
      AlgebraicClosure (IsDedekindDomain.HeightOneSpectrum.adicCompletion ‚Ąö
        Nat.prime_two.toHeightOneSpectrumRingOfIntegersRat))
