/-- **Integrability of the single-pole line integrand**
(PROVEN 2026-07-24): continuity on the line plus the global majorant
`KВ·(1+tВІ)вҒ»В№` manufactured from the trivial bound
(`poitouPhi_line_norm_le_const`, for `|t| вүӨ 1`, against `вҖ–a+tiвҖ– вүҘ a`)
and the decay `M/|t|` (`poitouPhi_line_decay`, for `|t| вүҘ 1`, against
`вҖ–a+tiвҖ– вүҘ |t|`). -/
theorem poitouPoleTerm_integrable {a : в„қ} (ha : 0 < a) :
    Integrable fun t : в„қ => poitouPhi (5 / 4 + t * Complex.I) / ((a : в„Ӯ) + t * Complex.I) := by
  obtain вҹЁM, hM0, hMвҹ© := poitouPhi_line_decay
  set C : в„қ := вҲ« x : в„қ, вҖ–poitouG xвҖ– with hC
  have hC0 : 0 вүӨ C := by
    rw [hC]
    exact integral_nonneg fun x => norm_nonneg _
  set K : в„қ := max (2 * C / a) (2 * M) with hK
  have hcont : Continuous fun t : в„қ =>
      poitouPhi (5 / 4 + t * Complex.I) / ((a : в„Ӯ) + t * Complex.I) := by
    refine poitouPhi_line_continuous.div (by fun_prop) fun t => ?_
    intro hzero
    have hre := congrArg Complex.re hzero
    simp at hre
    exact ha.ne' hre
  refine (integrable_inv_one_add_sq.const_mul K).mono' hcont.aestronglyMeasurable ?_
  refine Filter.Eventually.of_forall fun t => ?_
  have hdenвӮҒ : a вүӨ вҖ–(a : в„Ӯ) + t * Complex.IвҖ– := by
    have h := Complex.abs_re_le_norm ((a : в„Ӯ) + t * Complex.I)
    have hre : ((a : в„Ӯ) + t * Complex.I).re = a := by simp
    rw [hre] at h
    exact (le_abs_self a).trans h
  have hdenвӮӮ : |t| вүӨ вҖ–(a : в„Ӯ) + t * Complex.IвҖ– := by
    have h := Complex.abs_im_le_norm ((a : в„Ӯ) + t * Complex.I)
    have him : ((a : в„Ӯ) + t * Complex.I).im = t := by simp
    rwa [him] at h
  rw [norm_div]
  have hmain : вҖ–poitouPhi (5 / 4 + t * Complex.I)вҖ– / вҖ–(a : в„Ӯ) + t * Complex.IвҖ– *
      (1 + t ^ 2) вүӨ K := by
    rcases le_total |t| 1 with hcase | hcase
    В· have h1 : вҖ–poitouPhi (5 / 4 + t * Complex.I)вҖ– / вҖ–(a : в„Ӯ) + t * Complex.IвҖ– вүӨ C / a := by
        refine div_le_divвӮҖ hC0 ?_ ha hdenвӮҒ
        rw [hC]
        exact poitouPhi_line_norm_le_const t
      have h2 : (1 : в„қ) + t ^ 2 вүӨ 2 := by
        nlinarith [abs_nonneg t, abs_mul_abs_self t, sq_abs t]
      calc вҖ–poitouPhi (5 / 4 + t * Complex.I)вҖ– / вҖ–(a : в„Ӯ) + t * Complex.IвҖ– * (1 + t ^ 2)
          вүӨ C / a * 2 := by
            refine mul_le_mul h1 h2 (by positivity) (by positivity)
        _ = 2 * C / a := by ring
        _ вүӨ K := le_max_left _ _
    В· have htpos : (0:в„қ) < |t| := lt_of_lt_of_le zero_lt_one hcase
      have ht0 : t вү  0 := abs_pos.mp htpos
      have h1 : вҖ–poitouPhi (5 / 4 + t * Complex.I)вҖ– / вҖ–(a : в„Ӯ) + t * Complex.IвҖ– вүӨ
          M / t ^ 2 := by
        have hstep : вҖ–poitouPhi (5 / 4 + t * Complex.I)вҖ– / вҖ–(a : в„Ӯ) + t * Complex.IвҖ– вүӨ
            (M / |t|) / |t| := by
          refine div_le_divвӮҖ (by positivity) (hM t ht0) htpos hdenвӮӮ
        refine hstep.trans (le_of_eq ?_)
        rw [div_div, abs_mul_abs_self, вҶҗ sq]
      have h2 : (1:в„қ) + t ^ 2 вүӨ 2 * t ^ 2 := by
        nlinarith [abs_nonneg t, abs_mul_abs_self t, sq_abs t]
      calc вҖ–poitouPhi (5 / 4 + t * Complex.I)вҖ– / вҖ–(a : в„Ӯ) + t * Complex.IвҖ– * (1 + t ^ 2)
          вүӨ M / t ^ 2 * (2 * t ^ 2) := by
            refine mul_le_mul h1 h2 (by positivity) (by positivity)
        _ = 2 * M := by
            have ht2 : t ^ 2 вү  0 := pow_ne_zero _ ht0
            field_simp [ht2]
        _ вүӨ K := le_max_right _ _
  rw [вҶҗ div_eq_mul_inv, le_div_iffвӮҖ (by positivity : (0:в„қ) < 1 + t ^ 2)]
  exact hmain

/-- **Integrability of `FВ·e^{cx}` complexified** (PROVEN 2026-07-24):
continuous with compact support in `[-6, 6]`. -/
theorem integrable_ofReal_poitouF_mul_exp (c : в„қ) :
    Integrable fun x : в„қ => ((poitouF x * Real.exp (c * x) : в„қ) : в„Ӯ) := by
  refine Continuous.integrable_of_hasCompactSupport ?_ ?_
  В· exact Complex.continuous_ofReal.comp (continuous_poitouF.mul (by fun_prop))
  В· apply HasCompactSupport.intro (isCompact_Icc (a := (-6:в„қ)) (b := 6))
    intro x hx
    have h6 : (6:в„қ) вүӨ |x| := by
      simp only [Set.mem_Icc, not_and_or, not_le] at hx
      rcases hx with h | h
      В· exact le_abs.2 (Or.inr (by linarith))
      В· exact le_abs.2 (Or.inl h.le)
    have h0 : odlyzkoTestFn x = 0 := by
      rw [odlyzkoTestFn, max_eq_right]
      nlinarith [h6]
    rw [poitouF, h0, zero_div, zero_mul, Complex.ofReal_zero]

/-- **`ОҰ` at a real point as a real-profile integral**
(PROVEN 2026-07-24): `ОҰ(r) = вҲ« F(x)В·e^{(r-1/2)x} dx` coerced. -/
theorem poitouPhi_ofReal (r : в„қ) :
    poitouPhi (r : в„Ӯ) = вҲ« x : в„қ, ((poitouF x * Real.exp ((r - 1 / 2) * x) : в„қ) : в„Ӯ) := by
  rw [poitouPhi]
  have h : вҲҖ x : в„қ, ((odlyzkoTestFn x / Real.cosh (x / 2) : в„қ) : в„Ӯ) *
      Complex.exp (((r : в„Ӯ) - 1 / 2) * (x : в„Ӯ)) =
      ((poitouF x * Real.exp ((r - 1 / 2) * x) : в„қ) : в„Ӯ) := by
    intro x
    rw [show ((r : в„Ӯ) - 1 / 2) * (x : в„Ӯ) = (((r - 1 / 2) * x : в„қ) : в„Ӯ) by push_cast; ring,
      вҶҗ Complex.ofReal_exp, poitouF]
    push_cast
    ring
  simp_rw [h]

/-- **`ОҰ(0) + ОҰ(1)` as a one-sided FejГ©r integral**
(PROVEN 2026-07-24, complex-level twin of the later
`poitouPhi_zero_add_one_re`, needed at this earlier point of the
file): `e^{-x/2} + e^{x/2} = 2В·cosh(x/2)` cancels the `cosh` in
`poitouF`, and evenness folds `вҲ«_в„қ = 2вҲ«_0^вҲһ`. -/
theorem poitouPhi_zero_add_one :
    poitouPhi 0 + poitouPhi 1 =
      ((4 * вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x : в„қ) : в„Ӯ) := by
  have h0 : poitouPhi 0 = вҲ« x : в„қ, ((poitouF x * Real.exp ((0 - 1 / 2) * x) : в„қ) : в„Ӯ) := by
    rw [show (0:в„Ӯ) = ((0:в„қ) : в„Ӯ) by norm_num, poitouPhi_ofReal]
  have h1 : poitouPhi 1 = вҲ« x : в„қ, ((poitouF x * Real.exp ((1 - 1 / 2) * x) : в„қ) : в„Ӯ) := by
    rw [show (1:в„Ӯ) = ((1:в„қ) : в„Ӯ) by norm_num, poitouPhi_ofReal]
  rw [h0, h1, вҶҗ integral_add (integrable_ofReal_poitouF_mul_exp _)
    (integrable_ofReal_poitouF_mul_exp _)]
  have hsum : вҲҖ x : в„қ, ((poitouF x * Real.exp ((0 - 1 / 2) * x) : в„қ) : в„Ӯ) +
      ((poitouF x * Real.exp ((1 - 1 / 2) * x) : в„қ) : в„Ӯ) =
      ((2 * odlyzkoTestFn x : в„қ) : в„Ӯ) := by
    intro x
    rw [вҶҗ Complex.ofReal_add]
    congr 1
    have e0 : (0 - 1 / 2 : в„қ) * x = -(x / 2) := by ring
    have e1 : (1 - 1 / 2 : в„қ) * x = x / 2 := by ring
    rw [e0, e1]
    have hcosh : Real.cosh (x / 2) вү  0 := (Real.cosh_pos _).ne'
    rw [Real.cosh_eq] at hcosh
    rw [poitouF, Real.cosh_eq]
    field_simp [hcosh]
    ring
  simp_rw [hsum]
  rw [integral_complex_ofReal]
  congr 1
  rw [integral_const_mul]
  have heven : (вҲ« x : в„қ, odlyzkoTestFn x) =
      2 * вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x := by
    have habs := integral_comp_abs (f := fun y : в„қ => max (1 - y / 6) 0)
    have hL : (вҲ« x : в„қ, odlyzkoTestFn x) = вҲ« x : в„қ, max (1 - |x| / 6) 0 := by
      simp only [odlyzkoTestFn]
    have hR : (вҲ« x in Set.Ioi (0:в„қ), max (1 - x / 6) 0) =
        вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x := by
      refine setIntegral_congr_fun measurableSet_Ioi fun x hx => ?_
      rw [odlyzkoTestFn, abs_of_pos hx]
    rw [hL, habs, hR]
  rw [heven]
  ring

/-- **The pole part of the vertical edge gives `ОҰ(0) + ОҰ(1)`**
(PROVEN 2026-07-24 вҖ” leaf (bвӮӮбөў) of the decomposition of
`DedekindContinuation.poitouEdge_tendsto`; the mirrored residue
computation, no `pkg` involved).  Instead of the rectangle contour,
the proof evaluates the whole line integral by FOURIER INVERSION:
the integrand splits as `ОҰ/(5/4+ti) + ОҰ/(1/4+ti)`
(since `sвҲ’1 = 1/4+ti` on the line), each pole term is integrable on
`в„қ` (`poitouPoleTerm_integrable`, from the trivial bound and the
integration-by-parts decay `вҖ–ОҰ(5/4+ti)вҖ– вүӨ M/|t|`), and
`integral_poitouPhi_line_div` вҖ” Fourier inversion applied at `0` to
the convolution of `poitouG` with a one-sided exponential kernel вҖ”
evaluates `вҲ«_в„қ ОҰ(5/4+ti)/(a+ti) dt = 2ПҖ вҲ«_0^вҲһ e^{-au} G(u) du` for
`a вҲҲ {5/4, 1/4}`.  The two one-sided integrals recombine by
`e^{-u/2} + e^{u/2} = 2 cosh(u/2)` into `4ПҖ вҲ«_0^вҲһ F`, which equals
`ПҖВ·(ОҰ(0)+ОҰ(1)).re` by `poitouPhi_zero_add_one`; the truncation limit
`вҲ«_{-T}^T вҶ’ вҲ«_в„қ` is `MeasureTheory.intervalIntegral_tendsto_integral`
on the real parts, and the `ПҖвҒ»В№` prefactor cancels. -/
theorem poitouPoleEdge_tendsto :
    Filter.Tendsto poitouPoleEdge Filter.atTop
      (nhds ((poitouPhi 0).re + (poitouPhi 1).re)) := by
  have h54 := poitouPoleTerm_integrable (a := 5/4) (by norm_num)
  have h14 := poitouPoleTerm_integrable (a := 1/4) (by norm_num)
  have hv54 := integral_poitouPhi_line_div (a := 5/4) (by norm_num) h54
  have hv14 := integral_poitouPhi_line_div (a := 1/4) (by norm_num) h14
  set Fc : в„қ вҶ’ в„Ӯ := fun t => poitouPhi (5 / 4 + t * Complex.I) *
    (1 / (5 / 4 + t * Complex.I) + 1 / (5 / 4 + t * Complex.I - 1)) with hFc
  have hsplit : вҲҖ t : в„қ, Fc t =
      poitouPhi (5 / 4 + t * Complex.I) / (((5/4 : в„қ) : в„Ӯ) + t * Complex.I) +
      poitouPhi (5 / 4 + t * Complex.I) / (((1/4 : в„қ) : в„Ӯ) + t * Complex.I) := by
    intro t
    rw [hFc]
    push_cast
    ring
  have hIntF : Integrable Fc := by
    refine (h54.add h14).congr (Filter.Eventually.of_forall fun t => ?_)
    exact (hsplit t).symm
  have hint : вҲҖ c : в„қ, 0 вүӨ c вҶ’ IntegrableOn
      (fun u : в„қ => Complex.exp (((-(c * u) : в„қ) : в„Ӯ)) * poitouG u) (Set.Ioi (0:в„қ)) := by
    intro c hc
    refine Integrable.mono' poitouG_integrable.norm.integrableOn
      ((Complex.continuous_exp.comp (by fun_prop)).mul continuous_poitouG).aestronglyMeasurable ?_
    refine (ae_restrict_iff' measurableSet_Ioi).2 (Filter.Eventually.of_forall fun u hu => ?_)
    rw [norm_mul, вҶҗ Complex.ofReal_exp, Complex.norm_real, Real.norm_eq_abs,
      abs_of_pos (Real.exp_pos _)]
    have hle : Real.exp (-(c * u)) вүӨ 1 :=
      Real.exp_le_one_iff.2 (neg_nonpos.2 (mul_nonneg hc hu.le))
    calc Real.exp (-(c * u)) * вҖ–poitouG uвҖ– вүӨ 1 * вҖ–poitouG uвҖ– :=
          mul_le_mul_of_nonneg_right hle (norm_nonneg _)
      _ = вҖ–poitouG uвҖ– := one_mul _
  have hpt : вҲҖ u : в„қ, Complex.exp (((-(5/4 * u : в„қ) : в„қ) : в„Ӯ)) * poitouG u +
      Complex.exp (((-(1/4 * u : в„қ) : в„қ) : в„Ӯ)) * poitouG u =
      ((2 * odlyzkoTestFn u : в„қ) : в„Ӯ) := by
    intro u
    rw [poitouG, вҶҗ Complex.ofReal_exp, вҶҗ Complex.ofReal_exp, вҶҗ Complex.ofReal_mul,
      вҶҗ Complex.ofReal_mul, вҶҗ Complex.ofReal_add]
    congr 1
    have e1 : Real.exp (-(5/4 * u)) * Real.exp (3 / 4 * u) = Real.exp (-(u / 2)) := by
      rw [вҶҗ Real.exp_add]
      congr 1
      ring
    have e2 : Real.exp (-(1/4 * u)) * Real.exp (3 / 4 * u) = Real.exp (u / 2) := by
      rw [вҶҗ Real.exp_add]
      congr 1
      ring
    have hcosh : Real.cosh (u / 2) вү  0 := (Real.cosh_pos _).ne'
    calc Real.exp (-(5/4 * u)) * (poitouF u * Real.exp (3 / 4 * u)) +
        Real.exp (-(1/4 * u)) * (poitouF u * Real.exp (3 / 4 * u))
        = poitouF u * (Real.exp (-(5/4 * u)) * Real.exp (3 / 4 * u) +
            Real.exp (-(1/4 * u)) * Real.exp (3 / 4 * u)) := by ring
      _ = poitouF u * (Real.exp (-(u / 2)) + Real.exp (u / 2)) := by rw [e1, e2]
      _ = poitouF u * (2 * Real.cosh (u / 2)) := by
          rw [Real.cosh_eq]
          ring
      _ = 2 * odlyzkoTestFn u := by
          rw [poitouF]
          field_simp [hcosh]
  have hkey : (вҲ« t : в„қ, Fc t) =
      ((4 * Real.pi * вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x : в„қ) : в„Ӯ) := by
    rw [integral_congr_ae (Filter.Eventually.of_forall hsplit), integral_add h54 h14,
      hv54, hv14, вҶҗ smul_add, вҶҗ integral_add (hint (5/4) (by norm_num)) (hint (1/4) (by norm_num))]
    rw [setIntegral_congr_fun measurableSet_Ioi (fun u _ => hpt u)]
    rw [integral_complex_ofReal, Complex.real_smul, вҶҗ Complex.ofReal_mul]
    congr 1
    rw [integral_const_mul]
    ring
  have hIntRe : Integrable fun t : в„қ => (Fc t).re := by
    have h := Complex.reCLM.integrable_comp hIntF
    simpa using h
  have hre_val : (вҲ« t : в„қ, (Fc t).re) =
      4 * Real.pi * вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x := by
    have h := Complex.reCLM.integral_comp_comm hIntF
    rw [hkey] at h
    simpa using h
  have hlim : Filter.Tendsto (fun T : в„қ => вҲ« t in (-T)..T, (Fc t).re) Filter.atTop
      (nhds (вҲ« t : в„қ, (Fc t).re)) :=
    intervalIntegral_tendsto_integral hIntRe tendsto_neg_atTop_atBot tendsto_id
  have hfin := hlim.const_mul Real.piвҒ»В№
  rw [hre_val] at hfin
  have hzo : (poitouPhi 0).re + (poitouPhi 1).re =
      4 * вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x := by
    have h := congrArg Complex.re poitouPhi_zero_add_one
    simpa using h
  have hval : Real.piвҒ»В№ * (4 * Real.pi * вҲ« x in Set.Ioi (0:в„қ), odlyzkoTestFn x) =
      (poitouPhi 0).re + (poitouPhi 1).re := by
    rw [hzo]
    have hpi : Real.pi вү  0 := Real.pi_ne_zero
    field_simp [hpi]
  rw [hval] at hfin
  have hEq : poitouPoleEdge = fun T : в„қ => Real.piвҒ»В№ * вҲ« t in (-T)..T, (Fc t).re := by
    funext T
    rw [poitouPoleEdge]
  rw [hEq]
  exact hfin

end PoitouPoleEdgeFourier

/-- **The discriminant part of the folded vertical edge** (definition,
2026-07-24 вҖ” introduced in the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`): the analogue
of `DedekindContinuation.poitouEdge` with the CONSTANT `(log|d_K|)/2`
вҖ” the log-derivative of the discriminant factor `|d_K|^{s/2}` of the
completed zeta `Z_K` вҖ” in place of `Оҫ'/Оҫ`. -/
noncomputable def poitouConstEdge (K : Type*) [Field K] [NumberField K]
    (T : в„қ) : в„қ :=
  Real.piвҒ»В№ * вҲ« t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      Complex.ofReal (Real.log |(NumberField.discr K : в„қ)| / 2)).re

/-- **The archimedean part of the folded vertical edge** (definition,
2026-07-24 вҖ” introduced in the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`): the analogue
of `DedekindContinuation.poitouEdge` with
`rвӮӮВ·(ПҲ(s) вҲ’ log 2ПҖ)` вҖ” the log-derivative of the archimedean factor
`О“_в„Ӯ(s)^{rвӮӮ} = (2В·(2ПҖ)^{вҲ’s}В·О“(s))^{rвӮӮ}` of the completed zeta, where
`ПҲ = Complex.digamma` is the pin's logarithmic derivative of `О“` вҖ”
in place of `Оҫ'/Оҫ`.  (For the totally complex fields of the consuming
decomposition the real factor `О“_в„қ^{rвӮҒ}` is absent, `rвӮҒ = 0`, so this
is the WHOLE archimedean log-derivative.) -/
noncomputable def poitouGammaEdge (K : Type*) [Field K] [NumberField K]
    (T : в„қ) : в„қ :=
  Real.piвҒ»В№ * вҲ« t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      ((NumberField.InfinitePlace.nrComplexPlaces K : в„Ӯ) *
        (Complex.digamma (5 / 4 + t * Complex.I) -
          Complex.ofReal (Real.log (2 * Real.pi))))).re

/-- **The prime part of the folded vertical edge** (definition,
2026-07-24 вҖ” introduced in the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`): the analogue
of `DedekindContinuation.poitouEdge` with the log-derivative
`О¶_K'/О¶_K` of the pin's raw Dedekind zeta Dirichlet series in place
of `Оҫ'/Оҫ`.  On the edge line `re s = 5/4 > 1` the series converges
absolutely and `О¶_K(s) вү  0` (`dedekindZeta_ne_zero_of_one_lt_re`), so
the integrand is the honest logarithmic derivative there. -/
noncomputable def poitouPrimeEdge (K : Type*) [Field K] [NumberField K]
    (T : в„қ) : в„қ :=
  Real.piвҒ»В№ * вҲ« t in (-T)..T,
    (poitouPhi (5 / 4 + t * Complex.I) *
      (deriv (NumberField.dedekindZeta K) (5 / 4 + t * Complex.I) /
        NumberField.dedekindZeta K (5 / 4 + t * Complex.I))).re

/-- **The integrand split: edge minus pole edge = discriminant +
archimedean + prime edges** (sorry node, stated 2026-07-24 вҖ” leaf
(bвӮӮбөўбөўВ·0), the log-derivative bookkeeping stage of the decomposition
of `DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`; an exact
identity for EVERY `T`, no limits).  Intended proof, pointwise on the
edge `s = 5/4 + it` where `re s = 5/4 > 1`:

1. `eq_of_one_lt_re` writes `Оҫ` on the OPEN half-plane `re > 1` as
   the product `s(sвҲ’1)В·|d|^{s/2}В·О“_в„қ-factor^{rвӮҒ}В·О“_в„Ӯ-factor^{rвӮӮ}В·О¶_K`,
   and `htc` kills the real factor
   (`NumberField.IsTotallyComplex.nrRealPlaces_eq_zero`, `pow_zero`).
2. Openness (`isOpen_lt continuous_const Complex.continuous_re`) lets
   `Filter.EventuallyEq.deriv_eq` transport `deriv pkg.xi` to the
   derivative of the product; each factor is differentiable at `s` вҖ”
   polynomials, the `cpow`s with nonzero constant base
   (`|d| вү  0` by `NumberField.discr_ne_zero`, `2ПҖ вү  0`), `О“(s)` for
   `re s > 0`, and `О¶_K` by the pin's `LSeries_hasDerivAt` above the
   abscissa of absolute convergence (`вүӨ 1` for the ideal-counting
   coefficients via `summable_natCard_absNorm_mul_rpow_neg` from
   `Chebotarev.lean`) вҖ” and nonvanishing at `s`: `s, sвҲ’1 вү  0`
   (`re = 5/4`), `Complex.Gamma_ne_zero`, nonzero-base `cpow`s, and
   `dedekindZeta_ne_zero_of_one_lt_re` (PROVEN above).  Iterated
   `logDeriv_mul`/`logDeriv_pow` then split the logarithmic
   derivative: `(Оҫ'/Оҫ)(s) = 1/s + 1/(sвҲ’1) + (log|d|)/2 +
   rвӮӮВ·(ПҲ(s) вҲ’ log 2ПҖ) + (О¶_K'/О¶_K)(s)`, with `ПҲ = Complex.digamma`
   (`Complex.digamma_def`, `logDeriv_apply`) and the elementary
   log-derivatives `(c^s)'/c^s = log c` of constant-base `cpow`.
3. Multiply by `ОҰ(s)`, take `Re`: pointwise in `t`, the
   `DedekindContinuation.poitouEdge` integrand minus the
   `poitouPoleEdge` integrand equals the sum of the three edge
   integrands (`mul_add`, `Complex.add_re`).
4. Integrate over `[вҲ’T, T]`: `intervalIntegral.integral_sub` and
   `integral_add` need integrability of each piece, which follows
   from continuity in `t` (`Continuous.intervalIntegrable`): `ОҰ`
   along the edge by dominated parameter-continuity of `poitouPhi`
   (compactly supported integrand вҖ” the same continuity brick the
   sibling leaf `poitouPoleEdge_tendsto` needs; manufacture a shared
   forward helper), `ПҲ` at zero-free points of the differentiable
   `О“`, `О¶_K'/О¶_K` since `deriv О¶_K` is again an `LSeries`
   (`LSeries_deriv`) differentiable above the abscissa and the
   denominator is nonvanishing and continuous; finally distribute
   `ПҖвҒ»В№` over the sum (`mul_add`). -/
theorem DedekindContinuation.poitouEdge_sub_poleEdge_eq {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K)
    (htc : NumberField.IsTotallyComplex K) (T : в„қ) :
    pkg.poitouEdge T - poitouPoleEdge T =
      poitouConstEdge K T + poitouGammaEdge K T + poitouPrimeEdge K T := by
  sorry

/-- **Fourier inversion at the origin: the discriminant edge converges
to `log |d_K|`** (sorry node, stated 2026-07-24 вҖ” leaf (bвӮӮбөўбөўВ·1), the
Fourier/test-function bookkeeping stage of the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`; Poitou
p. 6-03, the constant term of Proposition 2).  Intended proof: with
`G(x) = poitouF x В· e^{3x/4}` вҖ” continuous, piecewise-`CВ№`, supported
in `[вҲ’6, 6]` вҖ” the edge value of `ОҰ` is a Fourier integral:
`ОҰ(5/4 + it) = вҲ« G(x)В·e^{itx} dx` (unfold `poitouPhi`;
`e^{(sвҲ’1/2)x} = e^{3x/4}В·e^{itx}` at `s = 5/4 + it`), i.e. up to the
`2ПҖ`-rescaling of the pin's normalization `e^{вҲ’2ПҖiВ·xВ·Оҫ}` the inverse
Fourier transform of `G`.  `G` is integrable (continuous with compact
support) and its transform is `O(1/tВІ)` (two integrations by parts
against the piecewise-affine `odlyzkoTestFn`, whose derivative has
bounded variation), hence integrable, so
`Continuous.fourierInv_fourier_eq` (the pin's
`Mathlib.Analysis.Fourier.Inversion`) evaluated at `0` gives
`(2ПҖ)вҒ»В№ вҲ«_в„қ ОҰ(5/4 + it) dt = G(0) = poitouF 0 = 1` (`cosh 0 = 1`,
`odlyzkoTestFn 0 = 1`).  The symmetric truncations converge to the
full integral (`MeasureTheory.intervalIntegral_tendsto_integral`
with the integrability of `t вҶҰ (ОҰ(5/4+it)В·c).re` from the same
`O(1/tВІ)` decay), and the real constant `c = (log|d|)/2` commutes
with `Re` and the integral, so
`poitouConstEdge K T вҶ’ ПҖвҒ»В№В·2ПҖВ·1В·(log|d|)/2 = log |d_K|`. -/
theorem poitouConstEdge_tendsto (K : Type*) [Field K] [NumberField K] :
    Filter.Tendsto (poitouConstEdge K) Filter.atTop
      (nhds (Real.log |(NumberField.discr K : в„қ)|)) := by
  sorry

/-- **Poitou's Lemmes 1вҖ“2: the archimedean edge converges to the
digamma terms** (sorry node, stated 2026-07-24 вҖ” leaf (bвӮӮбөўбөўВ·2), the
О“-factor/digamma stage of the decomposition of
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`; Poitou
pp. 6-04вҖ“6-06, Lemme 1, Lemme 2 and formula (5)).  The pin's digamma
material (`Mathlib.Analysis.SpecialFunctions.Gamma.Digamma`) is thin
вҖ” `digamma = logDeriv Gamma`, the recurrence
`Complex.digamma_apply_add_one`, and the anchor
`Complex.digamma_one = вҲ’Оі` (from `hasDerivAt_Gamma_one` of the pin's
`Mathlib.NumberTheory.Harmonic.GammaDeriv`) вҖ” so this leaf must
manufacture Gauss' integral representation itself.  Intended proof:

1. *Partial fractions.*  From the Euler-limit
   `Complex.GammaSeq_tendsto_Gamma` (differentiate the logarithm of
   `GammaSeq`, locally uniform convergence), or by telescoping the
   recurrence against `digamma_one` with the tail asymptotics
   `ПҲ(s + N) вҲ’ log N вҶ’ 0`, derive
   `ПҲ(s) = вҲ’Оі + ОЈ_{kвүҘ0} (1/(k+1) вҲ’ 1/(s+k))` for `re s > 0`.
2. *Lemme 1 (Gauss).*  `1/(k+1) вҲ’ 1/(s+k) =
   вҲ«вӮҖ^вҲһ (e^{вҲ’(k+1)x} вҲ’ e^{вҲ’(s+k)x}) dx`; summing the geometric series
   `ОЈ_k e^{вҲ’kx} = (1 вҲ’ e^{вҲ’x})вҒ»В№` under the integral (Tonelli plus
   dominated convergence; integrands `O(xВ·e^{вҲ’x})` near `0`) gives
   `ПҲ(s) = вҲ’Оі + вҲ«вӮҖ^вҲһ (e^{вҲ’x} вҲ’ e^{вҲ’sx})/(1 вҲ’ e^{вҲ’x}) dx` on
   `re s > 0`.
3. *Lemme 2 (pairing).*  Insert into the edge; Fubini swaps the
   `t`- and `x`-integrals (absolute convergence from the `O(1/tВІ)`
   strip decay of `ОҰ` against the `O(log|t|)` growth of `ПҲ` along
   the line вҖ” the same decay brick as `poitouConstEdge_tendsto`,
   which also supplies `ПҖвҒ»В№ вҲ«_в„қ ОҰ(5/4+it) dt = 2`), and the Fourier
   inversion at the shifted point evaluates
   `ПҖвҒ»В№ вҲ«_в„қ ОҰ(5/4+it)В·e^{вҲ’(5/4+it)x} dt = 2В·e^{вҲ’5x/4}В·G(x)
   = 2В·F(x)В·e^{вҲ’x/2}` for `x > 0`, `G(x) = F(x)e^{3x/4}`.  With
   `1 вҲ’ e^{вҲ’x} = e^{вҲ’x/2}В·2 sinh(x/2)` the edge tends to
   `nВ·(вҲ’Оі вҲ’ log 2ПҖ) + nВ·вҲ«вӮҖ^вҲһ (e^{вҲ’x/2} вҲ’ F(x))/(2 sinh(x/2)) dx`,
   where `n = 2rвӮӮ` by `NumberField.IsTotallyComplex.finrank`.
4. *Constant extraction.*  `вҲ«вӮҖ^вҲһ (1 вҲ’ e^{вҲ’x/2})/(2 sinh(x/2)) dx
   = log 4` (substitute `u = e^{вҲ’x/2}`: the integrand becomes
   `u/(1+u)В·(2/u)`, and `2вҲ«вӮҖ^1 du/(1+u) = 2 log 2`), so the limit is
   `вҲ’n(Оі + log 2ПҖ + log 4) + nвҲ«вӮҖ^вҲһ (1вҲ’F)/(2 sinh(x/2))
   = вҲ’n(Оі + log 8ПҖ) + nвҲ«вӮҖ^вҲһ (1вҲ’F)/(2 sinh(x/2))`, as stated. -/
theorem poitouGammaEdge_tendsto (K : Type*) [Field K] [NumberField K]
    (htc : NumberField.IsTotallyComplex K) :
    Filter.Tendsto (poitouGammaEdge K) Filter.atTop
      (nhds (-((Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi))) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ),
            (1 - poitouF x) / (2 * Real.sinh (x / 2))))) := by
  sorry

/-- **The prime edge converges to the prime sum** (sorry node, stated
2026-07-24 вҖ” leaf (bвӮӮбөўбөўВ·3), the Euler-product stage of the
decomposition of `DedekindContinuation.poitouEdge_sub_poleEdge_tendsto`;
Poitou pp. 6-03вҖ“6-04, the ultrametric term of Proposition 2).
Intended proof: on `re s = 5/4` the log-derivative of the Euler
product is the absolutely convergent double Dirichlet series
`вҲ’(О¶_K'/О¶_K)(s) = ОЈ_рқ”ӯ ОЈ_{mвүҘ1} (log Nрқ”ӯ)В·Nрқ”ӯ^{вҲ’ms}` over the nonzero
primes of `рқ’Ә_K`: the project's own ideal Euler product
(`exp_tsum_neg_log_one_sub_dirichletCharacter_mul_cpow_neg_eq_LSeries`
from `Chebotarev.lean` at the trivial character of level `1` вҖ” the
same PROVEN input that closed `dedekindZeta_ne_zero_of_one_lt_re`
above) writes `О¶_K = exp(ОЈ_рқ”ӯ вҲ’log(1 вҲ’ Nрқ”ӯ^{вҲ’s}))` on the half-plane;
differentiating the locally uniformly convergent sum termwise
(`hasDerivAt_tsum`-shape, each summand via the geometric expansion
`(вҲ’log(1вҲ’w))' В· w' = ОЈ_m w^mВ·log Nрқ”ӯ`, tails dominated by
`ОЈ_рқ”ӯ Nрқ”ӯ^{вҲ’9/8}` вҖ” summable by
`summable_natCard_absNorm_mul_rpow_neg`) gives the double series.
Termwise, the same Fourier inversion as `poitouConstEdge_tendsto` at
the shifted point `x = mВ·log Nрқ”ӯ > 0`:
`ПҖвҒ»В№ вҲ«_в„қ Re[ОҰ(5/4+it)В·Nрқ”ӯ^{вҲ’m(5/4+it)}] dt
= 2В·e^{вҲ’5x/4}В·G(x) = 2В·F(mВ·log Nрқ”ӯ)/Nрқ”ӯ^{m/2}`, so each pair `(рқ”ӯ, m)`
contributes `вҲ’2В·(log Nрқ”ӯ/Nрқ”ӯ^{m/2})В·F(mВ·log Nрқ”ӯ)`.  Summation and the
`T вҶ’ вҲһ` limit exchange by dominated convergence against the
absolutely convergent majorant `ОЈ_{рқ”ӯ,m} log Nрқ”ӯ В· Nрқ”ӯ^{вҲ’5m/4}`
(uniform in `T`; only the finitely many pairs with
`mВ·log Nрқ”ӯ вүӨ 6` survive in the limit since `F` is supported in
`[вҲ’6, 6]`), yielding the stated sum in its `m : в„•` (`m+1`)
indexing over the subtype of nonzero primes. -/
theorem poitouPrimeEdge_tendsto (K : Type*) [Field K] [NumberField K] :
    Filter.Tendsto (poitouPrimeEdge K) Filter.atTop
      (nhds (-(2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1))))) := by
  sorry

/-- **Poitou's Propositions 2вҖ“3: the vertical edge minus its pole
part converges to the arithmetic terms** (ASSEMBLED 2026-07-24 from
the integrand-split leaf
`DedekindContinuation.poitouEdge_sub_poleEdge_eq` and the three limit
leaves `poitouConstEdge_tendsto`, `poitouGammaEdge_tendsto`,
`poitouPrimeEdge_tendsto` by limit arithmetic (`Filter.Tendsto.add`
+ `Filter.Tendsto.congr`); Poitou pp. 6-02вҖ“6-06, Propositions 2вҖ“3
with Lemmes 1вҖ“2).  The whole edge lies in the absolute-convergence
half-plane `re s = 5/4 > 1`, where subtracting `poitouPoleEdge`
removes exactly the log-derivative `1/s + 1/(sвҲ’1)` of the
normalizing factor `s(sвҲ’1)` and leaves the folded edge of
`ОҰВ·Z_K'/Z_K` with `(Z_K'/Z_K)(s) = (log|d|)/2 + rвӮӮВ·(ПҲ(s) вҲ’ log 2ПҖ)
+ (О¶_K'/О¶_K)(s)` (`rвӮҒ = 0` via `htc`) вҖ” the split leaf; the three
limit leaves then evaluate the pieces to `log|d_K|`,
`вҲ’n(Оі + log 8ПҖ) + nВ·вҲ«вӮҖ^вҲһ (1вҲ’F)/(2 sinh(x/2))`, and
`вҲ’2В·ОЈ_{рқ”ӯ,m} (log Nрқ”ӯ/Nрқ”ӯ^{m/2})В·F(mВ·log Nрқ”ӯ)` respectively. -/
theorem DedekindContinuation.poitouEdge_sub_poleEdge_tendsto {K : Type*}
    [Field K] [NumberField K] (pkg : DedekindContinuation K)
    (htc : NumberField.IsTotallyComplex K) :
    Filter.Tendsto (fun T : в„қ => pkg.poitouEdge T - poitouPoleEdge T)
      Filter.atTop
      (nhds (Real.log |(NumberField.discr K : в„қ)| -
        (Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi)) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2))) -
        2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1)))) := by
  have hlim := ((poitouConstEdge_tendsto K).add
    (poitouGammaEdge_tendsto K htc)).add (poitouPrimeEdge_tendsto K)
  have hkey : Real.log |(NumberField.discr K : в„қ)| -
        (Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi)) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2))) -
        2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1)) =
      Real.log |(NumberField.discr K : в„қ)| +
        (-((Module.finrank в„ҡ K : в„қ) *
            (Real.eulerMascheroniConstant + Real.log (8 * Real.pi))) +
          (Module.finrank в„ҡ K : в„қ) *
            (вҲ« x in Set.Ioi (0 : в„қ),
              (1 - poitouF x) / (2 * Real.sinh (x / 2)))) +
        -(2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1))) := by
    ring
  rw [hkey]
  exact hlim.congr fun T => (pkg.poitouEdge_sub_poleEdge_eq htc T).symm

/-- **Poitou's Propositions 2вҖ“3: evaluation of the folded vertical
edge** (ASSEMBLED 2026-07-24 from the pole-part leaf
`poitouPoleEdge_tendsto` and the arithmetic-part leaf
`DedekindContinuation.poitouEdge_sub_poleEdge_tendsto` by the
telescoping identity `E(T) = (E(T) вҲ’ P(T)) + P(T)`; Poitou
pp. 6-02вҖ“6-06).  The `T вҶ’ вҲһ` limit of the folded vertical edge
`DedekindContinuation.poitouEdge` is the full arithmetic right-hand
side of formula (6) except the zero sum: `log|d_K|`, the
archimedean `вҲ’n(Оі + log 8ПҖ) + nвҲ«вӮҖ^вҲһ (1вҲ’F)/(2 sinh(x/2))`, the pole
term `ОҰ(0) + ОҰ(1)`, and the prime sum. -/
theorem DedekindContinuation.poitouEdge_tendsto {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K)
    (htc : NumberField.IsTotallyComplex K) :
    Filter.Tendsto pkg.poitouEdge Filter.atTop
      (nhds (Real.log |(NumberField.discr K : в„қ)| -
        (Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi)) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2))) +
        ((poitouPhi 0).re + (poitouPhi 1).re) -
        2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1)))) := by
  have hB := pkg.poitouEdge_sub_poleEdge_tendsto htc
  have hsum := hB.add poitouPoleEdge_tendsto
  have hkey : Real.log |(NumberField.discr K : в„қ)| -
        (Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi)) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2))) +
        ((poitouPhi 0).re + (poitouPhi 1).re) -
        2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1)) =
      (Real.log |(NumberField.discr K : в„қ)| -
        (Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi)) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2))) -
        2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1))) +
      ((poitouPhi 0).re + (poitouPhi 1).re) := by ring
  rw [hkey]
  exact hsum.congr fun T => by ring

/-- **Poitou's contour argument in raw `F`-form: the zero sum
converges to formula (6)** (ASSEMBLED 2026-07-24 from the three
contour-stage leaves; originally the contour-integral core of the
decomposition of `DedekindContinuation.fejer_zero_sum_tendsto`; the
window-count input is dependency-injected as `hcount` so that the
counting leaf `DedekindContinuation.zero_count_window` stays in the
used-constant cone while the stage leaves are open).  For totally
complex `K` the symmetric truncations of the zero sum converge to
the third form of Poitou's formula (6) (p. 6-07) at `F = poitouF`,
`rвӮҒ = 0`, `F(0) = 1`, BEFORE the FejГ©r specialization arithmetic:

`ОЈ_{|im ПҒ|вүӨT} mult(ПҒ)В·Re ОҰ(ПҒ) вҶ’ log|d_K| вҲ’ n(Оі + log 8ПҖ)
   + nвҲ«вӮҖ^вҲһ (1вҲ’F)/(2 sinh(x/2)) + (ОҰ(0) + ОҰ(1))
   вҲ’ 2 ОЈ_{рқ”ӯ,mвүҘ1} (log Nрқ”ӯ/Nрқ”ӯ^{m/2})В·F(mВ·log Nрқ”ӯ)`.

Proof structure (G. Poitou, *Sur les petits discriminants*, SГ©m.
DelangeвҖ“PisotвҖ“Poitou 18 (1976/77), exp. 6, pp. 6-01вҖ“6-07): writing
`S(T)` for the truncated zero sum and
`E(T) = DedekindContinuation.poitouEdge pkg T` for the folded
vertical-edge functional, the identity `S(T) = (S(T) вҲ’ E(T)) + E(T)`
splits the limit between

* `DedekindContinuation.zero_sum_sub_poitouEdge_tendsto_zero`
  (formula (1) + Proposition 1: residue theorem on the rectangle,
  functional-equation folding, horizontal edges vanish via `hcount`
  and BorelвҖ“CarathГ©odory) вҖ” consuming the boundary nonvanishing leaf
  `DedekindContinuation.xi_ne_zero_of_re_eq_one` through `hbnd`; and
* `DedekindContinuation.poitouEdge_tendsto` (Propositions 2вҖ“3 with
  Lemmes 1вҖ“2: pole part, Fourier inversion, Euler product, digamma).

Realness (Poitou's step 5, `conj_symm` pairing `ПҒ вҶ” ПҒМ„`) is built
into the `Re`-form of the statement and of `poitouEdge`. -/
theorem DedekindContinuation.weil_explicit_formula_F {K : Type*} [Field K]
    [NumberField K] (pkg : DedekindContinuation K)
    (htc : NumberField.IsTotallyComplex K)
    (hcount : вҲғ C : в„қ, 0 < C вҲ§ вҲҖ T : в„қ, 2 вүӨ T вҶ’ вҲҖ s : Finset в„Ӯ,
      (вҲҖ ПҒ вҲҲ s, |(|ПҒ.im| - T)| вүӨ 1) вҶ’
      вҲ‘ ПҒ вҲҲ s, (pkg.mult ПҒ : в„қ) вүӨ C * Real.log T) :
    Filter.Tendsto (fun T : в„қ =>
        вҲ‘' ПҒ : {ПҒ : в„Ӯ // pkg.mult ПҒ вү  0 вҲ§ |ПҒ.im| вүӨ T},
          (pkg.mult ПҒ.1 : в„қ) * (poitouPhi ПҒ.1).re)
      Filter.atTop
      (nhds (Real.log |(NumberField.discr K : в„қ)| -
        (Module.finrank в„ҡ K : в„қ) *
          (Real.eulerMascheroniConstant + Real.log (8 * Real.pi)) +
        (Module.finrank в„ҡ K : в„қ) *
          (вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2))) +
        ((poitouPhi 0).re + (poitouPhi 1).re) -
        2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
              P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
          Real.log (Ideal.absNorm P.1) /
              (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
            poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1)))) := by
  have hdiff := pkg.zero_sum_sub_poitouEdge_tendsto_zero hcount
    pkg.xi_ne_zero_of_re_eq_one
  have hedge := pkg.poitouEdge_tendsto htc
  have hsum := hdiff.add hedge
  rw [zero_add] at hsum
  exact hsum.congr fun T => by ring

/-- **FejГ©r specialization, archimedean part: `ОҰ(0) + ОҰ(1) = 4вҲ«вӮҖ^вҲһ f`**
(PROVEN 2026-07-24 вҖ” leaf (cвӮҒ) of the decomposition of
`DedekindContinuation.fejer_zero_sum_tendsto`; the Remarque of Poitou
p. 6-07: the `cosh(x/2)` factors cancel).  For real `r` the integrand
of `ОҰ(r)` is the real function `F(x)В·e^{(rвҲ’1/2)x}`
(`integral_complex_ofReal`), so `ОҰ(0).re + ОҰ(1).re
= вҲ« F(x)В·(e^{вҲ’x/2} + e^{x/2}) = вҲ« F(x)В·2cosh(x/2) = 2вҲ«_в„қ f = 4вҲ«вӮҖ^вҲһ f`
(integrability from continuity + compact support in `[-6, 6]`,
evenness of `f` via `integral_comp_abs`). -/
theorem poitouPhi_zero_add_one_re :
    (poitouPhi 0).re + (poitouPhi 1).re =
      4 * вҲ« x in Set.Ioi (0 : в„қ), odlyzkoTestFn x := by
  have hfcont : Continuous odlyzkoTestFn := by
    rw [show odlyzkoTestFn = fun x : в„қ => max (1 - |x| / 6) 0 from rfl]
    exact (continuous_const.sub (continuous_abs.div_const 6)).max continuous_const
  have hf0 : вҲҖ x : в„қ, 6 < |x| вҶ’ odlyzkoTestFn x = 0 := by
    intro x hx
    rw [odlyzkoTestFn]
    exact max_eq_right (by linarith)
  have hFcont : Continuous poitouF :=
    hfcont.div (Real.continuous_cosh.comp (continuous_id.div_const 2))
      fun x => (Real.cosh_pos _).ne'
  have hFsupp : HasCompactSupport poitouF := by
    refine HasCompactSupport.intro (isCompact_Icc (a := (-6 : в„қ)) (b := 6)) ?_
    intro x hx
    simp only [Set.mem_Icc, not_and_or, not_le] at hx
    have h6 : 6 < |x| := by
      rcases hx with h | h
      В· have := neg_abs_le x; linarith
      В· have := le_abs_self x; linarith
    rw [poitouF, hf0 x h6, zero_div]
  have hre : вҲҖ r : в„қ, (poitouPhi (r : в„Ӯ)).re =
      вҲ« x : в„қ, poitouF x * Real.exp ((r - 1 / 2) * x) := by
    intro r
    rw [poitouPhi]
    have hcongr : (fun x : в„қ =>
        ((odlyzkoTestFn x / Real.cosh (x / 2) : в„қ) : в„Ӯ) *
          Complex.exp (((r : в„Ӯ) - 1 / 2) * (x : в„Ӯ))) =
        fun x : в„қ => ((poitouF x * Real.exp ((r - 1 / 2) * x) : в„қ) : в„Ӯ) := by
      funext x
      rw [Complex.ofReal_mul, Complex.ofReal_exp, poitouF]
      congr 2
      push_cast
      ring
    rw [hcongr, integral_complex_ofReal, Complex.ofReal_re]
  have hint : вҲҖ r : в„қ, MeasureTheory.Integrable
      (fun x : в„қ => poitouF x * Real.exp ((r - 1 / 2) * x)) := by
    intro r
    refine Continuous.integrable_of_hasCompactSupport
      (hFcont.mul (Real.continuous_exp.comp (continuous_const.mul continuous_id))) ?_
    exact hFsupp.mul_right
  have h0 := hre 0
  have h1 := hre 1
  rw [Complex.ofReal_zero] at h0
  rw [Complex.ofReal_one] at h1
  rw [h0, h1, вҶҗ MeasureTheory.integral_add (hint 0) (hint 1)]
  have hsum : (fun x : в„қ => poitouF x * Real.exp ((0 - 1 / 2) * x) +
      poitouF x * Real.exp ((1 - 1 / 2) * x)) =
      fun x : в„қ => 2 * odlyzkoTestFn x := by
    funext x
    rw [poitouF, Real.cosh_eq,
      show ((0 : в„қ) - 1 / 2) * x = -(x / 2) by ring,
      show ((1 : в„қ) - 1 / 2) * x = x / 2 by ring]
    have hne : Real.exp (x / 2) + Real.exp (-(x / 2)) вү  0 := by positivity
    field_simp
    ring
  rw [hsum, MeasureTheory.integral_const_mul]
  have habs : (вҲ« x : в„қ, odlyzkoTestFn x) =
      2 * вҲ« x in Set.Ioi (0 : в„қ), odlyzkoTestFn x := by
    rw [show (вҲ« x : в„қ, odlyzkoTestFn x) = вҲ« x : в„қ, odlyzkoTestFn |x| from
      MeasureTheory.integral_congr_ae (Filter.Eventually.of_forall fun x => by
        simp only [odlyzkoTestFn, abs_abs])]
    exact integral_comp_abs
  rw [habs]
  ring

/-- **FejГ©r specialization, ultrametric part: the `F`-form prime sum
is `poitouPrimeTerm`** (PROVEN 2026-07-24 вҖ” leaf (cвӮӮ) of the
decomposition of `DedekindContinuation.fejer_zero_sum_tendsto`).
Per summand (`N = Nрқ”ӯ > 0`, `y = mВ·log Nрқ”ӯ`, `m вүҘ 1`):
`cosh(y/2) = (N^{m/2} + N^{вҲ’m/2})/2`, so
`2В·(log N/N^{m/2})В·f(y)/cosh(y/2) = 4В·log NВ·f(y)/(1 + N^m)` вҖ” the
summand of `poitouPrimeTerm`; `tsum_congr` twice after
`tsum_mul_left`, the per-summand identity by `rpow` manipulation
(`Real.rpow_def_of_pos`, `Real.rpow_add`, `Real.rpow_natCast`) and
`field_simp`, with `Nрқ”ӯ > 0` from `Ideal.absNorm_eq_zero_iff` and
`P вү  вҠҘ`. -/
theorem poitouF_prime_sum (K : Type*) [Field K] [NumberField K] :
    2 * вҲ‘' (P : {P : Ideal (NumberField.RingOfIntegers K) //
          P.IsPrime вҲ§ P вү  вҠҘ}) (m : в„•),
      Real.log (Ideal.absNorm P.1) /
          (Ideal.absNorm P.1 : в„қ) ^ (((m : в„қ) + 1) / 2) *
        poitouF (((m : в„қ) + 1) * Real.log (Ideal.absNorm P.1)) =
      poitouPrimeTerm K := by
  rw [poitouPrimeTerm, show (4 : в„қ) = 2 * 2 by norm_num, mul_assoc]
  congr 1
  rw [вҶҗ tsum_mul_left]
  refine tsum_congr fun P => ?_
  rw [вҶҗ tsum_mul_left]
  refine tsum_congr fun m => ?_
  have hNpos : (0 : в„қ) < (Ideal.absNorm P.1 : в„қ) := by
    have h0 : Ideal.absNorm P.1 вү  0 := by
      rw [Ne, Ideal.absNorm_eq_zero_iff]
      exact P.2.2
    exact_mod_cast Nat.pos_of_ne_zero h0
  set N : в„қ := (Ideal.absNorm P.1 : в„қ) with hN
  have hA : (0 : в„қ) < N ^ (((m : в„қ) + 1) / 2) := Real.rpow_pos_of_pos hNpos _
  set A : в„қ := N ^ (((m : в„қ) + 1) / 2) with hAdef
  have hexp1 : Real.exp (((m : в„қ) + 1) * Real.log N / 2) = A := by
    rw [hAdef, Real.rpow_def_of_pos hNpos]
    congr 1
    ring
  have hexp2 : Real.exp (-(((m : в„қ) + 1) * Real.log N / 2)) = AвҒ»В№ := by
    rw [Real.exp_neg, hexp1]
  have hAA : A * A = N ^ (m + 1) := by
    rw [hAdef, вҶҗ Real.rpow_add hNpos]
    rw [show ((m : в„қ) + 1) / 2 + ((m : в„қ) + 1) / 2 = ((m + 1 : в„•) : в„қ) by
      push_cast; ring]
    rw [Real.rpow_natCast]
  rw [poitouF, Real.cosh_eq, hexp1, hexp2, вҶҗ hAA]
  have h1 : A вү  0 := hA.ne'
  have h2 : A + AвҒ»В№ вү  0 := by positivity
  have h3 : 1 + A * A вү  0 := by positivity
  field_simp
  ring

/-- **FejГ©r specialization, integral part:
`вҲ«вӮҖ^вҲһ (1вҲ’F)/(2 sinh(x/2)) = вҲ«вӮҖ^вҲһ (1вҲ’f)/sinh x + log 2`** (PROVEN
2026-07-24 вҖ” leaf (cвӮғ) of the decomposition of
`DedekindContinuation.fejer_zero_sum_tendsto`; this is what turns
Poitou's `Оі + log 8ПҖ` into the target's `Оі + log 4ПҖ`).  Pointwise on
`x > 0`, using `sinh x = 2В·sinh(x/2)В·cosh(x/2)` (`Real.sinh_two_mul`),
`(1 вҲ’ F)/(2 sinh(x/2)) = (1 вҲ’ f)/sinh x + (cosh(x/2) вҲ’ 1)/sinh x`;
both summands are continuous on `(0, вҲһ)` and dominated by the
integrable majorant `6В·e^{вҲ’x/2}` (for `(1вҲ’f)/sinh`: on `(0, 6]` it is
`(x/6)/sinh x вүӨ 1/6 вүӨ 6e^{вҲ’x/2}` since `e^{x/2} вүӨ eВі вүӨ 36`, and past
`6` it is `1/sinh x вүӨ 4e^{вҲ’x}`; for the second summand:
`cosh(x/2) вҲ’ 1 вүӨ sinh(x/2)` since `cosh вҲ’ sinh = e^{вҲ’x/2} вүӨ 1`, so it
is at most `1/(2cosh(x/2)) вүӨ e^{вҲ’x/2}`), so `integral_add` splits the
integral.  The second piece has the explicit antiderivative
`G(x) = log(cosh(x/2)/(1 + cosh(x/2)))` вҖ” check
`G' = sinh(x/2)/(2В·cosh(x/2)(1+cosh(x/2))) = (cosh(x/2)вҲ’1)/sinh x`
via `sinhВІ = coshВІ вҲ’ 1` вҖ” with `G(0) = log(1/2)` and `G вҶ’ log 1 = 0`
at `вҲһ` (the quotient is `1 вҲ’ (1+cosh)вҒ»В№ вҶ’ 1`), so
`MeasureTheory.integral_Ioi_of_hasDerivAt_of_tendsto` evaluates
`вҲ«вӮҖ^вҲһ (cosh(x/2) вҲ’ 1)/sinh x = 0 вҲ’ log(1/2) = log 2`. -/
theorem integral_one_sub_poitouF_div_two_sinh :
    вҲ« x in Set.Ioi (0 : в„қ), (1 - poitouF x) / (2 * Real.sinh (x / 2)) =
      (вҲ« x in Set.Ioi (0 : в„қ), (1 - odlyzkoTestFn x) / Real.sinh x) +
        Real.log 2 := by
  have hmaj : MeasureTheory.IntegrableOn (fun x : в„қ => 6 * Real.exp (-(1/2) * x))
      (Set.Ioi (0:в„қ)) :=
    (exp_neg_integrableOn_Ioi 0 (by norm_num : (0:в„қ) < 1/2)).const_mul 6
  have hfcont : Continuous odlyzkoTestFn := by
    rw [show odlyzkoTestFn = fun x : в„қ => max (1 - |x| / 6) 0 from rfl]
    exact (continuous_const.sub (continuous_abs.div_const 6)).max continuous_const
  have hsinh_ne : вҲҖ x вҲҲ Set.Ioi (0:в„қ), Real.sinh x вү  0 :=
    fun x hx => (Real.sinh_pos_iff.mpr hx).ne'
  have hcont1 : ContinuousOn (fun x : в„қ => (1 - odlyzkoTestFn x) / Real.sinh x)
      (Set.Ioi (0:в„қ)) :=
    ((continuous_const.sub hfcont).continuousOn).div
      Real.continuous_sinh.continuousOn hsinh_ne
