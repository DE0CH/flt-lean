        ((Field.absoluteGaloisGroup.map (algebraMap ‚Ąö ‚Ąö_[2])
          ŌÉ).toRingEquiv) : ‚Ą§_[3]ň£) : ‚Ą§_[3]) = 1 := by
  haveI h3 : Fact (Nat.Prime 3) := ‚ü®Nat.prime_three‚ü©
