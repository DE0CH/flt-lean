/-- **No common root over an algebraically closed field**: the heart
of the coprimality. -/
theorem no_common_root [IsAlgClosed K] (h╬Ф : W.╬Ф тЙа 0) {n : тДХ}
    (hn : 2 тЙд n) (xтВА : K) (h╬ж : (W.╬ж (n : тДд)).eval xтВА = 0)
    (h╬и : (W.╬иSq (n : тДд)).eval xтВА = 0) : False := by
  classical
  -- the point above `xтВА`
  obtain тЯиyтВА, hyтВАтЯй := IsAlgClosed.exists_root
    (p := Polynomial.X ^ 2 + Polynomial.C (W.aтВБ * xтВА + W.aтВГ) *
      Polynomial.X - Polynomial.C
        (xтВА ^ 3 + W.aтВВ * xтВА ^ 2 + W.aтВД * xтВА + W.aтВЖ))
    (by
      have hd2 : (Polynomial.X ^ 2 +
          Polynomial.C (W.aтВБ * xтВА + W.aтВГ) * Polynomial.X -
          Polynomial.C (xтВА ^ 3 + W.aтВВ * xтВА ^ 2 + W.aтВД * xтВА + W.aтВЖ) :
          Polynomial K).natDegree = 2 := by
        compute_degree!
      intro hdeg
      have hne : (Polynomial.X ^ 2 +
          Polynomial.C (W.aтВБ * xтВА + W.aтВГ) * Polynomial.X -
          Polynomial.C (xтВА ^ 3 + W.aтВВ * xтВА ^ 2 + W.aтВД * xтВА + W.aтВЖ) :
          Polynomial K) тЙа 0 := by
        intro h0
        rw [h0, Polynomial.natDegree_zero] at hd2
        exact two_ne_zero hd2.symm
      rw [Polynomial.degree_eq_natDegree hne, hd2] at hdeg
      norm_num at hdeg)
  have heq : W.toAffine.Equation xтВА yтВА := by
    rw [Affine.equation_iff]
    have := hyтВА
    rw [Polynomial.IsRoot, Polynomial.eval_sub, Polynomial.eval_add,
      Polynomial.eval_mul, Polynomial.eval_pow, Polynomial.eval_C,
      Polynomial.eval_C, Polynomial.eval_X] at this
    linear_combination this
  -- the seed values and the value sequence
  set b := (W.╧ИтВВ).evalEval xтВА yтВА with hbdef
  set c := (W.╬итВГ).eval xтВА with hcdef
  set d := (W.pre╬итВД).eval xтВА with hddef
  have hw : тИА m : тДд, (W.╧И m).evalEval xтВА yтВА = normEDS b c d m :=
    fun m => evalEval_╧И_normEDS xтВА yтВА m
  -- the on-curve square identity `b┬▓ = ╬итВВSq(xтВА)`
  have hb2 : b ^ 2 = (W.╬итВВSq).eval xтВА := by
    have h := congrArg (Polynomial.evalEvalRingHom xтВА yтВА) W.╧ИтВВ_sq
    simp only [map_add, map_mul, map_pow, map_ofNat,
      Polynomial.coe_evalEvalRingHom, Polynomial.evalEval_C] at h
    rw [show W.toAffine.polynomial.evalEval xтВА yтВА = 0 from heq] at h
    rw [hbdef]
    rw [h]
    ring
  -- `wтВЩ = 0`
  have hwn : normEDS b c d (n : тДд) = 0 := by
    have hsq : ((W.╧И (n : тДд)).evalEval xтВА yтВА) ^ 2 =
        ((W.╬иSq (n : тДд))).eval xтВА := by
      rw [тЖР WeierstrassCurve.evalEval_╬и_sq _ heq,
        WeierstrassCurve.evalEval_╧И _ heq]
    rw [тЖР hw]
    exact pow_eq_zero_iff two_ne_zero |>.mp (by rw [hsq, h╬и])
  -- `wтВЩтВКтВБ тмЭ wтВЩтВЛтВБ = 0` from the `╬ж`-definition
  have hprod : normEDS b c d ((n : тДд) + 1) *
      normEDS b c d ((n : тДд) - 1) = 0 := by
    have h╬жeq : W.╬ж (n : тДд) = Polynomial.X * W.╬иSq (n : тДд) -
        W.pre╬и ((n : тДд) + 1) * W.pre╬и ((n : тДд) - 1) *
          (if Even (n : тДд) then 1 else W.╬итВВSq) := rfl
    have hbridge : тИА m : тДд, (W.╧И m).evalEval xтВА yтВА =
        (W.pre╬и m).eval xтВА * (if Even m then b else 1) := by
      intro m
      rw [WeierstrassCurve.evalEval_╧И _ heq]
      rw [show W.╬и m = Polynomial.C (W.pre╬и m) *
        (if Even m then W.╧ИтВВ else 1) from by
          rw [WeierstrassCurve.╬и]]
      rcases Int.even_or_odd m with hm | hm
      ┬╖ rw [if_pos hm, if_pos hm]
        simp [Polynomial.evalEval_C, hbdef]
      ┬╖ rw [if_neg (Int.not_even_iff_odd.mpr hm),
          if_neg (Int.not_even_iff_odd.mpr hm)]
        simp [Polynomial.evalEval_C]
    have h1 := hbridge ((n : тДд) + 1)
    have h2 := hbridge ((n : тДд) - 1)
    rw [hw] at h1 h2
    rcases Nat.even_or_odd n with hpar | hpar
    ┬╖ -- even `n`: neighbours odd, parity factor `1`
      have hev : Even ((n : тДд)) := by exact_mod_cast hpar
      have hne1 : ┬м Even ((n : тДд) + 1) := by
        rw [Int.even_add_one, not_not]
        exact hev
      have hne2 : ┬м Even ((n : тДд) - 1) := by
        intro hcon
        exact hne1 (by
          rcases hcon with тЯиt, htтЯй
          exact тЯиt + 1, by omegaтЯй)
      rw [if_pos hev, mul_one] at h╬жeq
      have h╬жv := congrArg (Polynomial.eval xтВА) h╬жeq
      rw [h╬ж] at h╬жv
      simp only [Polynomial.eval_mul, Polynomial.eval_sub,
        Polynomial.eval_X] at h╬жv
      rw [h╬и, mul_zero, zero_sub, eq_comm, neg_eq_zero] at h╬жv
      rw [if_neg hne1, mul_one] at h1
      rw [if_neg hne2, mul_one] at h2
      rw [h1, h2]
      exact h╬жv
    ┬╖ -- odd `n`: neighbours even, parity factor `╬итВВSq(xтВА) = b┬▓`
      have hodd' : ┬м Even ((n : тДд)) := by
        exact_mod_cast Nat.not_even_iff_odd.mpr hpar
      have he1 : Even ((n : тДд) + 1) := by
        rw [Int.even_add_one]
        exact hodd'
      have he2 : Even ((n : тДд) - 1) := by
        rcases he1 with тЯиt, htтЯй
        exact тЯиt - 1, by omegaтЯй
      rw [if_neg hodd'] at h╬жeq
      have h╬жv := congrArg (Polynomial.eval xтВА) h╬жeq
      rw [h╬ж] at h╬жv
      simp only [Polynomial.eval_mul, Polynomial.eval_sub,
        Polynomial.eval_X] at h╬жv
      rw [h╬и, mul_zero, zero_sub, eq_comm, neg_eq_zero] at h╬жv
      rw [if_pos he1] at h1
      rw [if_pos he2] at h2
      rw [h1, h2]
      calc (W.pre╬и ((n : тДд) + 1)).eval xтВА * b *
            ((W.pre╬и ((n : тДд) - 1)).eval xтВА * b) =
          (W.pre╬и ((n : тДд) + 1)).eval xтВА *
            (W.pre╬и ((n : тДд) - 1)).eval xтВА * b ^ 2 := by ring
        _ = 0 := by rw [hb2, h╬жv]
  -- the rank of apparition
  have hex : тИГ r : тДХ, 2 тЙд r тИз normEDS b c d r = 0 := тЯиn, hn, hwnтЯй
  classical
  set r := Nat.find hex with hrdef
  obtain тЯиhr2, hr0тЯй := Nat.find_spec hex
  have hrank : EDSRank.IsRank b c d r := by
    refine тЯиhr2, hr0, ?_тЯй
    intro k hk1 hkr
    rcases eq_or_lt_of_le hk1 with h1 | h2
    ┬╖ rw [тЖР h1]
      simp [normEDS_one]
    ┬╖ intro h0
      exact Nat.find_min hex hkr тЯиh2, h0тЯй
  by_cases hadj : normEDS b c d ((r : тДд) + 1) = 0
  ┬╖ -- adjacent zeros: degenerate seeds, excluded by the certificates
    rcases hrank.degenerate_of_adjacent hadj with тЯиhb, hcтЯй | тЯиhc, hd, -тЯй
    ┬╖ exact psi23_not_both_zero W h╬Ф xтВА
        (by rw [тЖР hb2, hb, zero_pow two_ne_zero]) (hcdef тЦ╕ hc)
    ┬╖ exact psi34_not_both_zero W h╬Ф xтВА (hcdef тЦ╕ hc) (hddef тЦ╕ hd)
  ┬╖ -- the rank divides two consecutive integers
    have hdvdn := hrank.dvd_of_eq_zero hadj n (by omega) hwn
    rcases mul_eq_zero.mp hprod with h1 | h1
    ┬╖ have hdvd1 := hrank.dvd_of_eq_zero hadj (n + 1) (by omega)
        (by rwa [show (((n + 1 : тДХ)) : тДд) = (n : тДд) + 1 by omega])
      have hone : (r : тДд) тИг 1 := by
        have ha : (r : тДд) тИг ((n : тДд) + 1) := by
          exact_mod_cast Int.natCast_dvd_natCast.mpr hdvd1
        have hb' : (r : тДд) тИг (n : тДд) :=
          Int.natCast_dvd_natCast.mpr hdvdn
        have := dvd_sub ha hb'
        rwa [show ((n : тДд) + 1) - (n : тДд) = 1 by ring] at this
      have hone' : r тИг 1 := by exact_mod_cast hone
      have := Nat.le_of_dvd one_pos hone'
      omega
    ┬╖ have hdvd1 := hrank.dvd_of_eq_zero hadj (n - 1) (by omega)
        (by rwa [show (((n - 1 : тДХ)) : тДд) = (n : тДд) - 1 by omega])
      have hone : (r : тДд) тИг 1 := by
        have ha : (r : тДд) тИг ((n : тДд) - 1) := by
          have := Int.natCast_dvd_natCast.mpr hdvd1
          rwa [show (((n - 1 : тДХ)) : тДд) = (n : тДд) - 1 by omega] at this
        have hb' : (r : тДд) тИг (n : тДд) :=
          Int.natCast_dvd_natCast.mpr hdvdn
        have := dvd_sub hb' ha
        rwa [show ((n : тДд)) - ((n : тДд) - 1) = 1 by ring] at this
      have hone' : r тИг 1 := by exact_mod_cast hone
      have := Nat.le_of_dvd one_pos hone'
      omega

set_option backward.isDefEq.respectTransparency false in
set_option maxHeartbeats 1000000 in
/-- **Coprimality of `╬жтВЩ` and `╬иSqтВЩ` over any field with `╬Ф тЙа 0`**:
the direct replacement for the resultant-formula route. -/
theorem isCoprime_╬ж_╬иSq_field {k : Type*} [Field k]
    (W : WeierstrassCurve k) (h╬Ф : W.╬Ф тЙа 0) {n : тДд} (hn : n тЙа 0) :
    IsCoprime (W.╬ж n) (W.╬иSq n) := by
  classical
  -- reduce to `n = |n|` by the parity of the division polynomials
  have h╬жabs : W.╬ж n = W.╬ж ((n.natAbs : тДХ) : тДд) := by
    rcases Int.natAbs_eq n with h | h
    ┬╖ conv_lhs => rw [h]
    ┬╖ conv_lhs => rw [h, WeierstrassCurve.╬ж_neg]
  have h╬иabs : W.╬иSq n = W.╬иSq ((n.natAbs : тДХ) : тДд) := by
    rcases Int.natAbs_eq n with h | h
    ┬╖ conv_lhs => rw [h]
    ┬╖ conv_lhs => rw [h, WeierstrassCurve.╬иSq_neg]
  rw [h╬жabs, h╬иabs]
  set m : тДХ := n.natAbs with hmdef
  have hm1 : 1 тЙд m := by
    have := Int.natAbs_pos.mpr hn
    omega
  set nn : тДд := ((m : тДХ) : тДд) with hnndef
  have hpos : 0 < nn := by omega
  rcases eq_or_lt_of_le (by omega : (1 : тДд) тЙд nn) with h1 | h2
  ┬╖ -- `n = 1`: `╬иSq 1 = 1`
    rw [тЖР h1, show W.╬иSq 1 = 1 from by
      rw [show (1 : тДд) = ((1 : тДХ) : тДд) from rfl,
        WeierstrassCurve.╬иSq_ofNat]
      simp]
    exact isCoprime_one_right
  -- `n тЙе 2`: no common root over the algebraic closure
  by_contra hcop
  set g := EuclideanDomain.gcd (W.╬ж nn) (W.╬иSq nn) with hgdef
  have h╬жne : W.╬ж nn тЙа 0 := by
    intro h0
    have hc := congrArg (fun q => Polynomial.coeff q (nn.natAbs ^ 2)) h0
    simp only [Polynomial.coeff_zero] at hc
    rw [WeierstrassCurve.coeff_╬ж] at hc
    exact one_ne_zero hc
  have hgne : g тЙа 0 := fun h0 =>
    h╬жne ((EuclideanDomain.gcd_eq_zero_iff.mp h0).1)
  have hgunit : ┬мIsUnit g := fun h =>
    hcop (EuclideanDomain.gcd_isUnit_iff.mp h)
  -- a root of `g` in the algebraic closure
  set Kb := AlgebraicClosure k
  set ╧Ж : k тЖТ+* Kb := algebraMap k Kb
  have hgmapne : g.map ╧Ж тЙа 0 := Polynomial.map_ne_zero hgne
  have hdeg : (g.map ╧Ж).degree тЙа 0 := by
    rw [Polynomial.degree_map]
    intro h0
    exact hgunit (Polynomial.isUnit_iff_degree_eq_zero.mpr h0)
  obtain тЯиxтВА, hxтВАтЯй := IsAlgClosed.exists_root (p := g.map ╧Ж) hdeg
  -- transfer the common vanishing
  have h╬ж0 : ((W.map ╧Ж).╬ж nn).eval xтВА = 0 := by
    rw [WeierstrassCurve.map_╬ж]
    obtain тЯиq, hqтЯй := EuclideanDomain.gcd_dvd_left (W.╬ж nn) (W.╬иSq nn)
    rw [hq, Polynomial.map_mul, Polynomial.eval_mul,
