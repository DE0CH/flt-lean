/-- The `╧И`-values at a point are the normalised EDS of the seed
values. -/
lemma evalEval_╧И_normEDS (x y : K) (n : тДд) :
    (W.╧И n).evalEval x y =
      normEDS ((W.╧ИтВВ).evalEval x y) ((W.╬итВГ).eval x)
        ((W.pre╬итВД).eval x) n := by
  have h := map_normEDS (Polynomial.evalEvalRingHom x y) W.╧ИтВВ
    (Polynomial.C W.╬итВГ) (Polynomial.C W.pre╬итВД) n
  calc (W.╧И n).evalEval x y
      = (Polynomial.evalEvalRingHom x y)
          (normEDS W.╧ИтВВ (Polynomial.C W.╬итВГ)
            (Polynomial.C W.pre╬итВД) n) := rfl
    _ = normEDS ((Polynomial.evalEvalRingHom x y) W.╧ИтВВ)
          ((Polynomial.evalEvalRingHom x y) (Polynomial.C W.╬итВГ))
          ((Polynomial.evalEvalRingHom x y) (Polynomial.C W.pre╬итВД))
          n := h
    _ = _ := by
        simp only [Polynomial.coe_evalEvalRingHom,
          Polynomial.evalEval_C]

