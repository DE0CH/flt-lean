  have h╬и0 : ((W.map ╧Ж).╬иSq nn).eval xтВА = 0 := by
    rw [WeierstrassCurve.map_╬иSq]
    obtain тЯиq, hqтЯй := EuclideanDomain.gcd_dvd_right (W.╬ж nn) (W.╬иSq nn)
    rw [hq, Polynomial.map_mul, Polynomial.eval_mul,
      show (g.map ╧Ж).eval xтВА = 0 from hxтВА, zero_mul]
  have h╬ФK : (W.map ╧Ж).╬Ф тЙа 0 := by
    rw [WeierstrassCurve.map_╬Ф]
    intro h0
    exact h╬Ф ((map_eq_zero ╧Ж).mp h0)
