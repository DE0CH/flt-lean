/-
WeilPairingTwoLine.lean — the polynomial core of the p = 2 alternation
leg of the Weil pairing (`WeilPairing.weilValue_two_torsion_config_eq_one`):

* `two_line_reciprocity`: the reciprocity identity between the two
  chord/tangent lines of a 2-torsion Miller setup — the single
  CAS-verified identity `hkey` of HLEG-NOTES.md §3(c-i), reduced to its
  8-line-value core.  The `linear_combination` certificate was computed
  by Groebner lift (Singular `lift`, over the substituted configuration
  ring) and lifted back to the eleven hypothesis generators by exact
  sequential polynomial division; the final identity was re-verified
  symbolically (sympy `expand`) before generation.

* `line_norm_cubic`: the norm factorization of a chord/tangent line
  against the fiber cubic — `ℓ(T)·ℓ(⊖T) = −(x_T−x_B)(x_T−x_U)(x_T−x_P)`
  — with per-branch certificates (chord: localized at `x_U − x_B`;
  tangent: via the tangent-slope relation).

Both are pure scalar identities over an arbitrary field, consumed by
`WeilPairing.lean`.
-/
module

public import Mathlib.Algebra.Field.Defs
public import Mathlib.Tactic.LinearCombination
public import Mathlib.Tactic.Ring

@[expose] public section

namespace WeilPairing

/-- **Norm factorization of a chord/tangent line against the fiber
cubic** (scalar form): `(xB,yB)` is the line's base point, `⊖(xU,yU)`
its second point (`h5`), `(xP,yP)` the third intersection, 2-torsion
(`hT` is not needed); `(t,yt)` is any curve point.  `hbr` selects the
genuine-chord or the tangent-slope branch. -/
theorem line_norm_cubic {F : Type*} [Field F]
    (a1 a2 a3 a4 a6 xU yU xB yB xP L t yt : F)
    (h1 : L ^ 2 + a1 * L - a2 - xB - xU = xP)
    (h5 : L * (xU - xB) + yB = -yU - a1 * xU - a3)
    (hEU : yU ^ 2 + a1 * xU * yU + a3 * yU =
      xU ^ 3 + a2 * xU ^ 2 + a4 * xU + a6)
    (hEB : yB ^ 2 + a1 * xB * yB + a3 * yB =
      xB ^ 3 + a2 * xB ^ 2 + a4 * xB + a6)
    (hEt : yt ^ 2 + a1 * t * yt + a3 * yt =
      t ^ 3 + a2 * t ^ 2 + a4 * t + a6)
    (hbr : xB ≠ xU ∨ (xB = xU ∧
      L * (2 * yB + a1 * xB + a3) =
        3 * xB ^ 2 + 2 * a2 * xB + a4 - a1 * yB)) :
    (yt - (L * (t - xB) + yB)) * ((-yt - a1 * t - a3) - (L * (t - xB) + yB)) =
      -((t - xB) * (t - xU) * (t - xP)) := by
  rcases hbr with hx | ⟨hx, htan⟩
  · have hne : xU - xB ≠ 0 := sub_ne_zero.mpr (Ne.symm hx)
    refine mul_left_cancel₀ hne ?_
    linear_combination
      (-t^2*xB + t^2*xU + t*xB^2 - t*xU^2 - xB^2*xU + xB*xU^2) * h1 +
      (-L*t*xB + L*t*xU + L*xB^2 - L*xB*xU + t*yB - t*yU - xB*yB + xB*yU) * h5 +
      (t - xB) * hEU +
      (-t + xU) * hEB +
      (xB - xU) * hEt
  · subst hx
    rw [sub_self, mul_zero, zero_add] at h5
    subst h5
    linear_combination
      (t^2 - 2*t*xB + xB^2) * h1 +
      (t - xB) * htan +
      (1 : F) * hEU +
      (-1 : F) * hEt

/-- **Assembly of the `p = 2` cross-ratio identity from the norm
factorizations and the two-line reciprocity** (the line values enter
as opaque atoms `v••`, so this is cheap linear algebra over the
x-coordinates): dividing out the four ⊖-line values — nonzero since
their norms are products of the twelve abscissa separations — the
squared-value identity reduces to the reciprocity `hrec` and a pure
abscissa identity. -/
theorem norm_reciprocity_assembly {F : Type*} [Field F]
    (xP xS xR xPS xQR : F)
    (v1R v1nR v1QR v1nQR v2S v2nS v2PS v2nPS : F)
    (hn1R : v1R * v1nR = -((xR - xPS) * (xR - xS) * (xR - xP)))
    (hn1QR : v1QR * v1nQR = -((xQR - xPS) * (xQR - xS) * (xQR - xP)))
    (hn2S : v2S * v2nS = -((xS - xQR) * (xS - xR) * (xS - xP)))
    (hn2PS : v2PS * v2nPS = -((xPS - xQR) * (xPS - xR) * (xPS - xP)))
    (hrec : v1R * v2PS * v1nQR * v2nS = v1QR * v2S * v1nR * v2nPS)
    (d1 : xR - xPS ≠ 0) (d2 : xR - xS ≠ 0) (d3 : xR - xP ≠ 0)
    (d4 : xQR - xPS ≠ 0) (d5 : xQR - xS ≠ 0) (d6 : xQR - xP ≠ 0)
    (d7 : xS - xQR ≠ 0) (d8 : xS - xR ≠ 0) (d9 : xS - xP ≠ 0)
    (d10 : xPS - xQR ≠ 0) (d11 : xPS - xR ≠ 0) (d12 : xPS - xP ≠ 0) :
    (xQR - xS) ^ 2 * v1R ^ 2 * (xS - xR) ^ 2 * v2PS ^ 2 *
      ((xQR - xP) * (xS - xP)) =
    v1QR ^ 2 * (xR - xS) ^ 2 * v2S ^ 2 * (xPS - xR) ^ 2 *
      ((xR - xP) * (xPS - xP)) := by
  have hM1 : v1nR ≠ 0 := by
    intro h0
    rw [h0, mul_zero] at hn1R
    exact (mul_ne_zero (mul_ne_zero d1 d2) d3)
      (neg_eq_zero.mp hn1R.symm)
  have hM2 : v1nQR ≠ 0 := by
    intro h0
    rw [h0, mul_zero] at hn1QR
    exact (mul_ne_zero (mul_ne_zero d4 d5) d6)
      (neg_eq_zero.mp hn1QR.symm)
  have hM3 : v2nS ≠ 0 := by
    intro h0
    rw [h0, mul_zero] at hn2S
    exact (mul_ne_zero (mul_ne_zero d7 d8) d9)
      (neg_eq_zero.mp hn2S.symm)
  have hM4 : v2nPS ≠ 0 := by
    intro h0
    rw [h0, mul_zero] at hn2PS
    exact (mul_ne_zero (mul_ne_zero d10 d11) d12)
      (neg_eq_zero.mp hn2PS.symm)
  have hM : v1nR * v1nQR * v2nS * v2nPS ≠ 0 :=
    mul_ne_zero (mul_ne_zero (mul_ne_zero hM1 hM2) hM3) hM4
  refine mul_right_cancel₀ hM ?_
  calc (xQR - xS) ^ 2 * v1R ^ 2 * (xS - xR) ^ 2 * v2PS ^ 2 *
        ((xQR - xP) * (xS - xP)) * (v1nR * v1nQR * v2nS * v2nPS)
      = ((xQR - xS) ^ 2 * (xS - xR) ^ 2 * (xQR - xP) * (xS - xP)) *
          (v1R * v1nR) * (v2PS * v2nPS) *
          (v1R * v2PS * v1nQR * v2nS) := by ring
    _ = ((xQR - xS) ^ 2 * (xS - xR) ^ 2 * (xQR - xP) * (xS - xP)) *
          (-((xR - xPS) * (xR - xS) * (xR - xP))) *
          (-((xPS - xQR) * (xPS - xR) * (xPS - xP))) *
          (v1QR * v2S * v1nR * v2nPS) := by rw [hn1R, hn2PS, hrec]
    _ = ((xR - xS) ^ 2 * (xPS - xR) ^ 2 * (xR - xP) * (xPS - xP)) *
          (-((xQR - xPS) * (xQR - xS) * (xQR - xP))) *
          (-((xS - xQR) * (xS - xR) * (xS - xP))) *
          (v1QR * v2S * v1nR * v2nPS) := by ring
    _ = ((xR - xS) ^ 2 * (xPS - xR) ^ 2 * (xR - xP) * (xPS - xP)) *
          (v1QR * v1nQR) * (v2S * v2nS) *
          (v1QR * v2S * v1nR * v2nPS) := by rw [hn1QR, hn2S]
    _ = v1QR ^ 2 * (xR - xS) ^ 2 * v2S ^ 2 * (xPS - xR) ^ 2 *
          ((xR - xP) * (xPS - xP)) * (v1nR * v1nQR * v2nS * v2nPS) := by
        ring

set_option maxHeartbeats 16000000 in
set_option maxRecDepth 4000 in
/-- **Two-line reciprocity for a 2-torsion Miller configuration**
(machine-generated certificate; see the module docstring): the product
of each line's values on the *other* line's off-`P` divisor points,
oriented, is symmetric. -/
theorem two_line_reciprocity {F : Type*} [CommRing F]
    (a1 a2 a3 a4 a6 xS yS xR yR xPS yPS xQR yQR xP yP L1 L2 : F)
    (h1 : L1 ^ 2 + a1 * L1 - a2 - xPS - xS = xP)
    (h2 : L2 ^ 2 + a1 * L2 - a2 - xQR - xR = xP)
    (h3 : L1 * (xP - xPS) + yPS = yP)
    (h4 : L2 * (xP - xQR) + yQR = yP)
    (h5 : L1 * (xS - xPS) + yPS = -yS - a1 * xS - a3)
    (h6 : L2 * (xR - xQR) + yQR = -yR - a1 * xR - a3)
    (hT : 2 * yP + a1 * xP + a3 = 0)
    (hES : yS ^ 2 + a1 * xS * yS + a3 * yS =
      xS ^ 3 + a2 * xS ^ 2 + a4 * xS + a6)
    (hER : yR ^ 2 + a1 * xR * yR + a3 * yR =
      xR ^ 3 + a2 * xR ^ 2 + a4 * xR + a6)
    (hEPS : yPS ^ 2 + a1 * xPS * yPS + a3 * yPS =
      xPS ^ 3 + a2 * xPS ^ 2 + a4 * xPS + a6)
    (hEQR : yQR ^ 2 + a1 * xQR * yQR + a3 * yQR =
      xQR ^ 3 + a2 * xQR ^ 2 + a4 * xQR + a6) :
    (yR - (L1 * (xR - xPS) + yPS)) * (yPS - (L2 * (xPS - xQR) + yQR)) *
      ((-yQR - a1 * xQR - a3) - (L1 * (xQR - xPS) + yPS)) *
      ((-yS - a1 * xS - a3) - (L2 * (xS - xQR) + yQR)) =
    (yQR - (L1 * (xQR - xPS) + yPS)) * (yS - (L2 * (xS - xQR) + yQR)) *
      ((-yR - a1 * xR - a3) - (L1 * (xR - xPS) + yPS)) *
      ((-yPS - a1 * xPS - a3) - (L2 * (xPS - xQR) + yQR)) := by
  linear_combination
