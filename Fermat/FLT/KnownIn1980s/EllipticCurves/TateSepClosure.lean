open ValuativeRel -- `ùí™[k]` notation for the ring of integers of `k`, and `valuation`

-- Can be deleted when mathlib#41391 lands
set_option linter.overlappingInstances false

-- let k be a nonarchimedean local field
variable {k : Type*} [Field k] [ValuativeRel k] [TopologicalSpace k]
  [IsNonarchimedeanLocalField k]

-- let E/k be elliptic with split multiplicative reduction, minimal
variable (E : WeierstrassCurve k) [E.IsElliptic] [E.HasSplitMultiplicativeReduction ùí™[k]]
  [E.IsMinimal ùí™[k]]

/-! ### Tate's uniformisation over a separable closure

Passing to the limit over the finite subextensions of a separable closure `Œ©` of `k`, the
finite-level uniformisations `E(l) ‚âÖ lÀ£/q·∂ª` glue to a Galois-equivariant uniformisation
`E(Œ©) ‚âÖ Œ©À£/q·∂ª`. The `N`-torsion of `Œ©À£/q·∂ª` is generated by the `N`-th roots of unity and
(the classes of) the `N`-th roots of `q`, so the uniformisation identifies the `N`-torsion
of `E` explicitly: this is how one computes the Galois representations attached to `E`.

The statement below is an existential Prop (see the vendoring note in the module
docstring): the isomorphism is pinned down mathematically only up to a sign (the choice
of one of the two isomorphisms `E_{q(E)} ‚âÖ E`), and no consumer needs a canonical
choice ‚Äî only existence of an equivariant one.
-/

-- Now let `Œ©` be a separable closure of `k`. It is not itself a nonarchimedean local field
-- (it is not complete), so it does not fit the framework above; but `E(Œ©)` is the union of
-- the `E(l)` over the finite subextensions `l/k` of `Œ©`, and Tate's theory applies to each.
-- (`Œ©` is placed in a NAMED universe so that the finite-level hypothesis of the gluing
-- implication below can quantify over fields in the same universe ‚Äî the intermediate
-- fields of `Œ©/k` ‚Äî keeping the universe inferable at the application site.)
universe uŒ©
variable (Œ© : Type uŒ©) [Field Œ©] [Algebra k Œ©] [IsSepClosed Œ©] [Algebra.IsSeparable k Œ©]

-- the base change of E to Œ© is elliptic (same remark as for `l` above)
instance : (E.baseChange Œ©).IsElliptic :=
  inferInstanceAs (E.map (algebraMap k Œ©)).IsElliptic

/-- The image of the Tate parameter in a separable closure `Œ©` of `k`, as a unit. (`Œ©` is
not a nonarchimedean local field, so this is not literally `(E.baseChange Œ©).qUnit`.) -/
noncomputable def WeierstrassCurve.qUnitSepClosure : Œ©À£ :=
  Units.map (algebraMap k Œ©).toMonoidHom E.qUnit

-- `DecidableEq Œ©` is needed for the group law on `(E‚ÅÑŒ©).Point`
variable [DecidableEq Œ©]

set_option warn.sorry false in
/-- **The gluing implication for Tate's uniformisation** (sorry node ‚Äî
Œ©-level from finite level): GIVEN the finite-level canonical
uniformisation ‚Äî for every nonarchimedean local field `l` an additive
equivalence `lÀ£/q^‚Ñ§ ‚âÉ+ E_q(l)` whose underlying function is the
canonical (choice-free) `TateCurve.pointMapQuot` ‚Äî the uniformising
homomorphism over the separable closure `Œ©` exists: `Œ©À£ ‚Üí+ E_q(Œ©)`,
surjective, with kernel exactly `q^‚Ñ§`, commuting with every
`k`-automorphism of `Œ©`. Content of the (sorried) gluing: every
`u ‚àà Œ©À£` and every point of `E_q(Œ©)` lives in a finite subextension
`l/k` of `Œ©/k`; a finite extension of a nonarchimedean local field is a
nonarchimedean local field with a unique valuative extension structure,
so the hypothesis applies at each level; the resulting maps are
compatible with the inclusions `l ‚äÜ l'` and with the `œÉ`-twists because
the underlying function `pointMapQuot` is defined by universal series
independent of the field (naturality of the annulus-representative
point map under valuative embeddings), so they glue to `Œ©À£` and the
kernel/surjectivity/equivariance properties pass to the colimit. -/
theorem WeierstrassCurve.exists_tateCurveHomSepClosure_of_finiteLevel
    [CharZero k] (q : kÀ£) (hq : valuation k (q : k) < 1)
    (hfin : ‚àÄ (l : Type uŒ©) [Field l] [ValuativeRel l] [TopologicalSpace l]
      [IsNonarchimedeanLocalField l] [CharZero l] [DecidableEq l] (ql : lÀ£)
      (hql : valuation l (ql : l) < 1),
      ‚àÉ e : Additive (lÀ£ ‚ß∏ Subgroup.zpowers ql) ‚âÉ+
          (WeierstrassCurve.tateCurve ((ql : l) : l)).toAffine.Point,
        ‚àÄ x, e x = TateCurve.pointMapQuot ql hql x.toMul) :
    ‚àÉ œÜ : Additive Œ©À£ ‚Üí+ (((tateCurve ((q : k) : k))‚ÅÑŒ©)).Point,
      Function.Surjective œÜ ‚àß
      (‚àÄ u : Œ©À£, œÜ (Additive.ofMul u) = 0 ‚Üî
        u ‚àà Subgroup.zpowers (Units.map (algebraMap k Œ©).toMonoidHom q)) ‚àß
      (‚àÄ (œÉ : Œ© ‚âÉ‚Çê[k] Œ©) (u : Œ©À£),
        WeierstrassCurve.Affine.Point.map (W' := tateCurve ((q : k) : k))
            œÉ.toAlgHom (œÜ (Additive.ofMul u)) =
          œÜ (Additive.ofMul (Units.map œÉ.toAlgHom.toRingHom.toMonoidHom u))) := by
  -- The naturality of the fundamental-annulus bilateral coordinates under a
  -- valuative extension of nonarchimedean local fields (PROVEN in
  -- `TateUniformization.lean`: `coeffRingEval_map`, `evalA_XA_map`,
  -- `evalA_YA_map`, `bilateralX_map`, `bilateralY_map`), packaged as the
  -- coordinate-pair fact the gluing needs to check well-definedness of the
  -- glued point map independently of the chosen finite subextension.
  have hnat : ‚àÄ {l : Type uŒ©} [Field l] [ValuativeRel l] [TopologicalSpace l]
      [IsNonarchimedeanLocalField l] [CharZero l] [Algebra k l]
      [ValuativeExtension k l] (u‚ÇÄ q‚ÇÄ : k) (h0 : u‚ÇÄ ‚âÝ 0) (h1 : u‚ÇÄ ‚âÝ 1)
      (hu : valuation k u‚ÇÄ ‚â§ 1) (hq1 : valuation k q‚ÇÄ < 1)
      (hqu : valuation k q‚ÇÄ < valuation k u‚ÇÄ)
      (h0' : algebraMap k l u‚ÇÄ ‚âÝ 0) (h1' : algebraMap k l u‚ÇÄ ‚âÝ 1)
      (hu' : valuation l (algebraMap k l u‚ÇÄ) ‚â§ 1)
      (hq1' : valuation l (algebraMap k l q‚ÇÄ) < 1)
      (hqu' : valuation l (algebraMap k l q‚ÇÄ) < valuation l (algebraMap k l u‚ÇÄ)),
      algebraMap k l (TateCurve.bilateralX u‚ÇÄ q‚ÇÄ) =
        TateCurve.bilateralX (algebraMap k l u‚ÇÄ) (algebraMap k l q‚ÇÄ) ‚àß
      algebraMap k l (TateCurve.bilateralY u‚ÇÄ q‚ÇÄ) =
        TateCurve.bilateralY (algebraMap k l u‚ÇÄ) (algebraMap k l q‚ÇÄ) :=
    fun {l} _ _ _ _ _ _ _ u‚ÇÄ q‚ÇÄ h0 h1 hu hq1 hqu h0' h1' hu' hq1' hqu' =>
      ‚ü®TateCurve.bilateralX_map u‚ÇÄ q‚ÇÄ h0 h1 hu hq1 hqu h0' h1' hu' hq1' hqu',
       TateCurve.bilateralY_map u‚ÇÄ q‚ÇÄ h0 h1 hu hq1 hqu h0' h1' hu' hq1' hqu'‚ü©
  sorry

/-- **The Tate-curve uniformising homomorphism over a separable closure**
(derived 2026-07-18 by feeding the finite-level uniformisation
`TateCurve.tateCurveEquiv` ‚Äî canonical, with underlying function
`pointMapQuot`, from `TateUniformization.lean` ‚Äî into the gluing
implication above): for a unit `q` of `k` with `|q| < 1` there is a
surjective group homomorphism `Œ©À£ ‚Üí E_q(Œ©)` with kernel exactly `q^‚Ñ§`,
commuting with every `k`-algebra automorphism of `Œ©` ON THE NOSE. -/
theorem WeierstrassCurve.exists_tateCurveHomSepClosure [CharZero k] (q : kÀ£)
    (hq : valuation k (q : k) < 1) :
    ‚àÉ œÜ : Additive Œ©À£ ‚Üí+ (((tateCurve ((q : k) : k))‚ÅÑŒ©)).Point,
      Function.Surjective œÜ ‚àß
      (‚àÄ u : Œ©À£, œÜ (Additive.ofMul u) = 0 ‚Üî
        u ‚àà Subgroup.zpowers (Units.map (algebraMap k Œ©).toMonoidHom q)) ‚àß
      (‚àÄ (œÉ : Œ© ‚âÉ‚Çê[k] Œ©) (u : Œ©À£),
        WeierstrassCurve.Affine.Point.map (W' := tateCurve ((q : k) : k))
            œÉ.toAlgHom (œÜ (Additive.ofMul u)) =
          œÜ (Additive.ofMul (Units.map œÉ.toAlgHom.toRingHom.toMonoidHom u))) :=
  WeierstrassCurve.exists_tateCurveHomSepClosure_of_finiteLevel Œ© q hq
    (fun _l _ _ _ _ _ _ ql hql =>
      ‚ü®TateCurve.tateCurveEquiv ql hql,
        fun x => TateCurve.tateCurveEquiv_apply ql hql x‚ü©)

/-- **Tate's uniformisation of the TATE CURVE over a separable closure**
(derived 2026-07-18 from the pre-quotient homomorphism
`exists_tateCurveHomSepClosure` by the first isomorphism theorem): for a
unit `q` of `k` with `|q| < 1`, the points of the Tate curve `E_q` over
a separable closure `Œ©` are `Œ©À£/q^‚Ñ§`, Galois-equivariantly ON THE NOSE.
The uniformising homomorphism `Œ©À£ ‚Üí E_q(Œ©)` is surjective with kernel
`q^‚Ñ§`, so it descends to an isomorphism on the quotient; equivariance
descends along the quotient map. -/
theorem WeierstrassCurve.exists_tateCurveEquivSepClosure [CharZero k] (q : kÀ£)
    (hq : valuation k (q : k) < 1) :
    ‚àÉ e : Additive (Œ©À£ ‚ß∏ Subgroup.zpowers
        (Units.map (algebraMap k Œ©).toMonoidHom q)) ‚âÉ+
      (((tateCurve ((q : k) : k))‚ÅÑŒ©)).Point,
      ‚àÄ (œÉ : Œ© ‚âÉ‚Çê[k] Œ©) (u : Œ©À£),
        WeierstrassCurve.Affine.Point.map (W' := tateCurve ((q : k) : k))
            œÉ.toAlgHom (e (Additive.ofMul ‚Üëu)) =
          e (Additive.ofMul ‚Üë(Units.map œÉ.toAlgHom.toRingHom.toMonoidHom u)) := by
  obtain ‚ü®œÜ, hœÜsurj, hœÜker, hœÜequiv‚ü© :=
    WeierstrassCurve.exists_tateCurveHomSepClosure (k := k) Œ© q hq
  -- the multiplicative form of `œÜ`, as a `MonoidHom` out of `Œ©À£`
  let œà : Œ©À£ ‚Üí* Multiplicative ((((tateCurve ((q : k) : k))‚ÅÑŒ©)).Point) :=
    { toFun := fun u => Multiplicative.ofAdd (œÜ (Additive.ofMul u))
      map_one' := by simp
      map_mul' := fun u v => by simp }
  -- `q^‚Ñ§` is contained in the kernel, so `œà` descends to the quotient
  have hZle : Subgroup.zpowers (Units.map (algebraMap k Œ©).toMonoidHom q) ‚â§
      œà.ker := by
    intro z hz
    exact (hœÜker z).mpr hz
  let œàbar : (Œ©À£ ‚ß∏ Subgroup.zpowers
      (Units.map (algebraMap k Œ©).toMonoidHom q)) ‚Üí*
      Multiplicative ((((tateCurve ((q : k) : k))‚ÅÑŒ©)).Point) :=
    QuotientGroup.lift _ œà hZle
  -- the descended map is injective (kernel of `œÜ` is exactly `q^‚Ñ§`) ‚Ä¶
  have hinj : Function.Injective œàbar := by
    rw [injective_iff_map_eq_one]
    intro x hx
    induction x using QuotientGroup.induction_on with
    | H u =>
      rw [QuotientGroup.eq_one_iff]
      exact (hœÜker u).mp hx
  -- ‚Ä¶ and surjective (because `œÜ` is)
  have hsurj : Function.Surjective œàbar := by
    intro p
    obtain ‚ü®a, ha‚ü© := hœÜsurj (Multiplicative.toAdd p)
    refine ‚ü®((Additive.toMul a : Œ©À£) : Œ©À£ ‚ß∏ Subgroup.zpowers
      (Units.map (algebraMap k Œ©).toMonoidHom q)), ?_‚ü©
    show Multiplicative.ofAdd (œÜ (Additive.ofMul (Additive.toMul a))) = p
    simp [ha]
  -- assemble the additive equivalence out of the multiplicative bijection
  refine ‚ü®MulEquiv.toAdditiveLeft
    (MulEquiv.ofBijective œàbar ‚ü®hinj, hsurj‚ü©), fun œÉ u => ?_‚ü©
  -- on the class of `u` the equivalence evaluates to `œÜ (ofMul u)`,
  -- so equivariance is exactly the equivariance of `œÜ`
  exact hœÜequiv œÉ u

omit [E.IsMinimal ùí™[k]] in
set_option backward.isDefEq.respectTransparency false in
set_option synthInstance.maxHeartbeats 400000 in
set_option maxHeartbeats 1000000 in
/-- **Tate's uniformisation theorem over a separable closure** (derived
2026-07-17 from the choice-free Tate-curve uniformisation above and
Tate's theorem `exists_variableChange_tateCurve`): for `E/k`
an elliptic curve, in minimal Weierstrass form, with split multiplicative reduction
over a nonarchimedean local field `k`, and `Œ©` a separable closure of `k`, there is a
group isomorphism `Œ©À£/q(E)·∂ª ‚âÖ E(Œ©)` that is equivariant for the natural actions of
`Gal(Œ©/k)` on both sides (Silverman, ATAEC V.3.1 + V.5.3: glue the finite-level
uniformisations `E(l) ‚âÖ lÀ£/q·∂ª` over the finite subextensions `l/k` of `Œ©`; the
`k`-linearity of every `œÉ ‚àà Gal(Œ©/k)` makes the sign choice `œÉ`-stable, cf.
`tateEquiv_galois` in the upstream FLT file). Stated as an existential Prop because
the isomorphism is canonical only up to negation. -/
theorem WeierstrassCurve.exists_tateEquivSepClosure [CharZero k] :
    ‚àÉ e : Additive (Œ©À£ ‚ß∏ Subgroup.zpowers (E.qUnitSepClosure Œ©)) ‚âÉ+ ((E‚ÅÑŒ©)).Point,
      ‚àÄ (œÉ : Œ© ‚âÉ‚Çê[k] Œ©) (u : Œ©À£),
        WeierstrassCurve.Affine.Point.map (W' := E) œÉ.toAlgHom (e (Additive.ofMul ‚Üëu)) =
          e (Additive.ofMul ‚Üë(Units.map œÉ.toAlgHom.toRingHom.toMonoidHom u)) := by
  classical
  obtain ‚ü®C, hC‚ü© := E.exists_variableChange_tateCurve
  obtain ‚ü®e‚ÇÄ, he‚ÇÄ‚ü© := WeierstrassCurve.exists_tateCurveEquivSepClosure (k := k) Œ©
    E.qUnit E.valuation_q_lt_one
  -- the `Œ©`-stage curve equality behind the variable change
  have hEq : (E‚ÅÑŒ©) = (C.baseChange Œ©) ‚Ä¢
      ((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©) := by
    conv_lhs => rw [‚Üê hC]
    exact (baseChange_smul_baseChange _ _ _).symm
  haveI hTell : (((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©)).IsElliptic := by
    haveI h1 : ((C.baseChange Œ©) ‚Ä¢
        ((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©)).IsElliptic := by
      rw [‚Üê hEq]
      infer_instance
    have h2 : ((C.baseChange Œ©)‚Åª¬π ‚Ä¢ ((C.baseChange Œ©) ‚Ä¢
        ((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©))).IsElliptic := inferInstance
    rw [inv_smul_smul] at h2
    exact h2
  let Œ® : ((E‚ÅÑŒ©)).Point ‚âÉ+ (((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©)).Point :=
    (Affine.Point.equivOfEq hEq).trans
      (Affine.Point.equivVariableChange
        ((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©) (C.baseChange Œ©))
  have hŒ®app : ‚àÄ R : ((E‚ÅÑŒ©)).Point, Œ® R =
      (Affine.Point.equivVariableChange
        ((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©) (C.baseChange Œ©))
      ((Affine.Point.equivOfEq hEq) R) := fun R => rfl
  refine ‚ü®e‚ÇÄ.trans Œ®.symm, ?_‚ü©
  intro œÉ u
  -- œÉ fixes the base-changed variable-change data (it is `k`-rational)
  have hœÉu : œÉ.toAlgHom (((C.baseChange Œ©).u : Œ©)) = ((C.baseChange Œ©).u : Œ©) := by
    simp only [VariableChange.baseChange, VariableChange.map, Units.coe_map,
      MonoidHom.coe_coe]
    exact œÉ.toAlgHom.commutes _
  have hœÉr : œÉ.toAlgHom (C.baseChange Œ©).r = (C.baseChange Œ©).r := by
    simp only [VariableChange.baseChange, VariableChange.map]
    exact œÉ.toAlgHom.commutes _
  have hœÉs : œÉ.toAlgHom (C.baseChange Œ©).s = (C.baseChange Œ©).s := by
    simp only [VariableChange.baseChange, VariableChange.map]
    exact œÉ.toAlgHom.commutes _
  have hœÉt : œÉ.toAlgHom (C.baseChange Œ©).t = (C.baseChange Œ©).t := by
    simp only [VariableChange.baseChange, VariableChange.map]
    exact œÉ.toAlgHom.commutes _
  -- equivariance of `Œ®` under `œÉ`
  have h12 : ‚àÄ Q : ((E‚ÅÑŒ©)).Point,
      Œ® (WeierstrassCurve.Affine.Point.map (W' := E) œÉ.toAlgHom Q) =
      WeierstrassCurve.Affine.Point.map (W' := tateCurve ((E.qUnit : k) : k))
        œÉ.toAlgHom (Œ® Q) := by
    intro Q
    rw [hŒ®app, hŒ®app]
    cases Q with
    | zero => simp [‚Üê WeierstrassCurve.Affine.Point.zero_def]
    | some x y hxy =>
      rw [WeierstrassCurve.Affine.Point.map_some,
        WeierstrassCurve.Affine.Point.equivOfEq_some,
        WeierstrassCurve.Affine.Point.equivOfEq_some,
        WeierstrassCurve.Affine.Point.equivVariableChange_some,
        WeierstrassCurve.Affine.Point.equivVariableChange_some,
        WeierstrassCurve.Affine.Point.map_some]
      refine WeierstrassCurve.Affine.Point.some_eq_some _ ?_ ?_
      ¬∑ simp only [map_add, map_mul, map_pow, hœÉu, hœÉr]
      ¬∑ simp only [map_add, map_mul, map_pow, hœÉu, hœÉs, hœÉt]
  have h12' : ‚àÄ R : (((tateCurve ((E.qUnit : k) : k))‚ÅÑŒ©)).Point,
      Œ®.symm (WeierstrassCurve.Affine.Point.map
        (W' := tateCurve ((E.qUnit : k) : k)) œÉ.toAlgHom R) =
      WeierstrassCurve.Affine.Point.map (W' := E) œÉ.toAlgHom (Œ®.symm R) := by
    intro R
    apply Œ®.injective
    rw [Œ®.apply_symm_apply, h12, Œ®.apply_symm_apply]
  show WeierstrassCurve.Affine.Point.map (W' := E) œÉ.toAlgHom
      (Œ®.symm (e‚ÇÄ (Additive.ofMul ‚Üëu))) =
      Œ®.symm (e‚ÇÄ (Additive.ofMul
        ‚Üë(Units.map œÉ.toAlgHom.toRingHom.toMonoidHom u)))
  rw [‚Üê h12', he‚ÇÄ]

/-- **Representatives of torsion in the Tate quotient** (PROVEN ‚Äî pure
group theory): every `N`-torsion class of `GÀ£/q^‚Ñ§` is represented by an
element whose `N`-th power is an integer power of `q`. This is step (a)
of the derivation of the multiplicative-reduction inertia statements
from `exists_tateEquivSepClosure`. -/
theorem exists_rep_pow_eq_zpow_of_torsion {G : Type*} [CommGroup G]
    (q : G) {N : ‚Ñï} (t : Additive (G ‚ß∏ Subgroup.zpowers q))
    (ht : ((N : ‚Ñ§)) ‚Ä¢ t = 0) :
    ‚àÉ (u : G) (a : ‚Ñ§),
      Additive.ofMul ((u : G ‚ß∏ Subgroup.zpowers q)) = t ‚àß u ^ N = q ^ a := by
  obtain ‚ü®u, hu‚ü© := QuotientGroup.mk_surjective (Additive.toMul t)
  have h1 : ((u : G ‚ß∏ Subgroup.zpowers q)) ^ N = 1 := by
    have h2 := congrArg Additive.toMul ht
    rw [toMul_zsmul, toMul_zero, zpow_natCast] at h2
    rw [hu]
    exact h2
  have h3 : (u ^ N : G) ‚àà Subgroup.zpowers q := by
    rw [‚Üê QuotientGroup.eq_one_iff, QuotientGroup.mk_pow]
    exact h1
  obtain ‚ü®a, ha‚ü© := Subgroup.mem_zpowers_iff.mp h3
  exact ‚ü®u, a, by rw [hu, ofMul_toMul], ha.symm‚ü©

/-- **The inertia-difference of a Tate-parameter root is a root of
unity** (PROVEN): if `œÉ` fixes `u^N`, then `œÉ(u)¬∑u‚Åª¬π` is an `N`-th root
of unity. Step (c) of the multiplicative-reduction derivation: for a
torsion representative `u` with `u^N = q_E^a`, every `œÉ ‚àà Gal(Œ©/k)`
fixes `u^N` (the Tate parameter comes from the base field), so `œÉ`
moves `u` by at most an `N`-th root of unity. -/
theorem map_mul_inv_mem_rootsOfUnity_of_pow_fixed
    {k Œ© : Type*} [Field k] [Field Œ©] [Algebra k Œ©]
    (œÉ : Œ© ‚âÉ‚Çê[k] Œ©) (u : Œ©À£) {N : ‚Ñï}
    (hfix : Units.map œÉ.toAlgHom.toRingHom.toMonoidHom (u ^ N) = u ^ N) :
