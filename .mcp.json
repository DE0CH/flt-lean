{
  "mcpServers": {
    "lean-lsp": {
      "command": "uvx",
      "args": [
        "lean-lsp-mcp",
        "--lean-project-path",
        "."
      ],
      "env": {
        "LEAN_LSP_MAX_OPEN_FILES": "64"
      }
    },
    "annas-mcp": {
      "command": ".venv/bin/python",
      "args": [
        "annas-mcp.py",
        "mcp"
      ],
      "env": {
        "ANNAS_KEY": "${ANNAS_KEY}"
      }
    },
    "report-flt-lean": {
      "command": ".venv/bin/python",
      "args": [
        "report-mcp.py",
        "--socket-dir",
        "/home/chend/flt-lean/.report-server"
      ],
      "timeout": 7200000
    },
    "report-flt-lean-1": {
