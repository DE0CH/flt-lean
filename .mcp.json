{
  "mcpServers": {
    "lean-lsp": {
      "command": "uvx",
      "args": [
        "lean-lsp-mcp",
        "--lean-project-path",
        "."
      ]
    },
    "annas-mcp": {
      "command": ".venv/bin/python",
      "args": [
        "annas-mcp.py",
        "mcp"
      ],
      "env": {
        "ANNAS_KEY": "${ANNAS_KEY}"
      }
    },
    "report-flt-lean": {
